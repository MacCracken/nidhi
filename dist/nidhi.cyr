}

# n_zone_new(sample_id) -> Zone with all Rust defaults.
#must_use
fn n_zone_new(sample_id) {
    var z = alloc(sizeof(NZone));
    NZone_set_sample_id(z, sample_id);
    NZone_set_key_lo(z, 0);
    NZone_set_key_hi(z, 127);
    NZone_set_vel_lo(z, 1);
    NZone_set_vel_hi(z, 127);
    NZone_set_root_note(z, 60);
    NZone_set_tune_cents(z, 0);
    NZone_set_volume_db(z, 0);
    NZone_set_pan(z, 0);
    NZone_set_loop_mode(z, LOOP_ONESHOT);
    NZone_set_loop_start(z, 0);
    NZone_set_loop_end(z, 0);
    NZone_set_crossfade_length(z, 0);
    NZone_set_sample_offset(z, 0);
    NZone_set_sample_end(z, 0);
    NZone_set_filter_cutoff(z, 0);
    NZone_set_filter_resonance(z, f64_div(f64_from(707), f64_from(1000)));
