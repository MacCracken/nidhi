# --- Behavioral methods ---

# matches(note, vel) -> 1 if note/vel fall within this zone's inclusive ranges.
#inline
#must_use
fn n_zone_matches(z, note, vel) {
    if (note < NZone_key_lo(z)) { return 0; }
    if (note > NZone_key_hi(z)) { return 0; }
    if (vel < NZone_vel_lo(z)) { return 0; }
    if (vel > NZone_vel_hi(z)) { return 0; }
    return 1;
}

# playback_ratio(note) -> resampling ratio (f64 bits). 1.0 at root, x2 per octave.
#   semitones = (note - root_note) + tune_cents / 100
#   ratio     = 2^(semitones / 12)
#inline
#must_use
fn n_zone_playback_ratio(z, note) {
    var semitones = f64_add(
        f64_sub(f64_from(note), f64_from(NZone_root_note(z))),
        f64_div(NZone_tune_cents(z), f64_from(100)));
    return f64_pow(f64_from(2), f64_div(semitones, f64_from(12)));
}

# --- sample.cyr ---

# sample.cyr -- Sample data, interpolation, onset detection, SampleBank
# Requires: alloc, vec (vec_new/push/get/set/len/truncate), math (f64_*), f64_util
#
# Ports rust-old/src/sample.rs. Sample buffers are stdlib vecs of f64 bit patterns
# (interleaved for stereo), matching how naad/shravan carry audio. SampleId is a bare
# i64 bank index (the Rust newtype wrapper is dropped). The SIMD cubic-hermite path is
# not ported (it was a bit-exact optimization of the scalar path). detect_onsets is
# nidhi's own energy-based REX slicer -- naad's detect_onsets is a different
# (spectral-flux) algorithm, so this is ported directly for feature parity.

# --- Sample ---
# Fields: data (vec of f64 bits, interleaved), channels (1 or 2), sample_rate (Hz),
# frames (samples per channel), name (Str ptr or 0), slices (vec of frame indices).
#derive(accessors)
struct NSample {
    data;
    channels;
    sample_rate;
    frames;
    name;
    slices;
}

#must_use
fn n_sample_from_mono(data, sample_rate) {
    var s = alloc(sizeof(NSample));
    NSample_set_data(s, data);
    NSample_set_channels(s, 1);
    NSample_set_sample_rate(s, sample_rate);
    NSample_set_frames(s, vec_len(data));
    NSample_set_name(s, 0);
    NSample_set_slices(s, vec_new());
    return s;
}

#must_use
fn n_sample_from_stereo(data, sample_rate) {
    var s = alloc(sizeof(NSample));
    NSample_set_data(s, data);
    NSample_set_channels(s, 2);
    NSample_set_sample_rate(s, sample_rate);
    NSample_set_frames(s, vec_len(data) / 2);
    NSample_set_name(s, 0);
    NSample_set_slices(s, vec_new());
    return s;
}

fn n_sample_with_name(s, name) {
    NSample_set_name(s, name);
    return s;
}

fn n_sample_with_slices(s, slices) {
    NSample_set_slices(s, slices);
    return s;
}

# --- Private frame readers (zero-pad out-of-range for the interpolator edges) ---

# read_mono_frame(idx) -> f64. Stereo folds to mono via (L+R)*0.5.
#inline
#must_use
fn n_sample_read_mono_frame(s, idx) {
    if (idx < 0) { return 0; }
    if (idx >= NSample_frames(s)) { return 0; }
    var data = NSample_data(s);
    var ch = NSample_channels(s);
    if (ch == 1) { return vec_get(data, idx); }
    var l = vec_get(data, idx * ch);
    var r = vec_get(data, idx * ch + 1);
    return f64_mul(f64_add(l, r), F64_HALF);
}

# read_stereo left/right lanes (mono duplicated to both). Zero-pad OOB.
#inline
#must_use
fn n_sample_read_stereo_l(s, idx) {
    if (idx < 0) { return 0; }
    if (idx >= NSample_frames(s)) { return 0; }
    var data = NSample_data(s);
    var ch = NSample_channels(s);
    if (ch == 1) { return vec_get(data, idx); }
    return vec_get(data, idx * ch);
}

#inline
#must_use
fn n_sample_read_stereo_r(s, idx) {
    if (idx < 0) { return 0; }
    if (idx >= NSample_frames(s)) { return 0; }
    var data = NSample_data(s);
    var ch = NSample_channels(s);
    if (ch == 1) { return vec_get(data, idx); }
    return vec_get(data, idx * ch + 1);
}

# --- Cubic Hermite (Catmull-Rom) interpolation -- the engine's correctness anchor ---
# a = -0.5*y0 + 1.5*y1 - 1.5*y2 + 0.5*y3
# b =  y0     - 2.5*y1 + 2.0*y2 - 0.5*y3
# c = -0.5*y0            + 0.5*y2
# return ((a*t + b)*t + c)*t + y1     (Horner)
#inline
#must_use
fn n_cubic_hermite(y0, y1, y2, y3, t) {
    var neg_half = f64_neg(F64_HALF);
    var c15 = f64_div(f64_from(3), f64_from(2));
    var neg15 = f64_neg(c15);
    var c25 = f64_div(f64_from(5), f64_from(2));
    var neg25 = f64_neg(c25);
    var a = f64_add(f64_add(f64_add(f64_mul(neg_half, y0), f64_mul(c15, y1)),
        f64_mul(neg15, y2)), f64_mul(F64_HALF, y3));
    var b = f64_add(f64_add(f64_add(y0, f64_mul(neg25, y1)),
        f64_mul(F64_TWO, y2)), f64_mul(neg_half, y3));
    var c = f64_add(f64_mul(neg_half, y0), f64_mul(F64_HALF, y2));
    return f64_add(f64_mul(f64_add(f64_mul(f64_add(f64_mul(a, t), b), t), c), t), y1);
}

# read_cubic(position) -> f64. floor(position) (not trunc) for negative-edge padding.
#inline
#must_use
fn n_sample_read_cubic(s, position) {
    if (NSample_frames(s) == 0) { return 0; }
    var idx = f64_to(f64_floor(position));
    var frac = f64_sub(position, f64_from(idx));
    var y0 = n_sample_read_mono_frame(s, idx - 1);
    var y1 = n_sample_read_mono_frame(s, idx);
    var y2 = n_sample_read_mono_frame(s, idx + 1);
    var y3 = n_sample_read_mono_frame(s, idx + 2);
    return n_cubic_hermite(y0, y1, y2, y3, frac);
}

#inline
#must_use
fn n_sample_read_interpolated(s, position) {
    return n_sample_read_cubic(s, position);
}

# read_stereo_interpolated(position, out) -> writes out[0]=L, out[1]=R (f64 bits).
#inline
fn n_sample_read_stereo_interpolated(s, position, out) {
    if (NSample_frames(s) == 0) {
        store64(out, 0);
        store64(out + 8, 0);
        return 0;
    }
    var idx = f64_to(f64_floor(position));
    var frac = f64_sub(position, f64_from(idx));
    var left = n_cubic_hermite(
        n_sample_read_stereo_l(s, idx - 1), n_sample_read_stereo_l(s, idx),
        n_sample_read_stereo_l(s, idx + 1), n_sample_read_stereo_l(s, idx + 2), frac);
    var right = n_cubic_hermite(
        n_sample_read_stereo_r(s, idx - 1), n_sample_read_stereo_r(s, idx),
        n_sample_read_stereo_r(s, idx + 1), n_sample_read_stereo_r(s, idx + 2), frac);
    store64(out, left);
    store64(out + 8, right);
    return 0;
}

# --- detect_onsets: energy-based transient detection, rebuilds s.slices ---
# window = max(min(512, frames/2), 1); hop = max(window/2, 1) (guards vs infinite loop).
# Per-window MEAN energy (sum of squares / window), stereo mixed to mono via (L+R)*0.5.
# Onset when normalized positive energy jump (diff/max_energy) strictly exceeds the
# clamped [0.01,1.0] threshold AND >= min_slice_frames since the last slice.
fn n_sample_detect_onsets(s, threshold, min_slice_frames) {
    var slices = NSample_slices(s);
    vec_truncate(slices, 0);
    var frames = NSample_frames(s);
    if (frames < 2) { return 0; }
    var data = NSample_data(s);
    var ch = NSample_channels(s);

    var window = 512;
    var half_frames = frames / 2;
    if (half_frames < window) { window = half_frames; }
    if (window < 1) { window = 1; }
    var hop = window / 2;
    if (hop < 1) { hop = 1; }
    var thr = f64_min(f64_max(threshold, f64_div(F64_ONE, f64_from(100))), F64_ONE);

    var e_frames = vec_new();
    var e_vals = vec_new();
    var pos = 0;
    while (pos + window <= frames) {
        var energy = 0;
        var i = pos;
        var lim = pos + window;
        while (i < lim) {
            var sm = 0;
            if (ch == 1) {
                sm = vec_get(data, i);
            } else {
                sm = f64_mul(f64_add(vec_get(data, i * 2), vec_get(data, i * 2 + 1)), F64_HALF);
            }
            energy = f64_add(energy, f64_mul(sm, sm));
            i = i + 1;
        }
        vec_push(e_frames, pos);
        vec_push(e_vals, f64_div(energy, f64_from(window)));
        pos = pos + hop;
    }

    var n = vec_len(e_vals);
    if (n < 2) { return 0; }

    var max_e = 0;
    var k = 0;
    while (k < n) {
        var e = vec_get(e_vals, k);
        if (f64_gt(e, max_e) == 1) { max_e = e; }
        k = k + 1;
    }
    var eps = f64_div(F64_ONE, f64_from(10000000000));
    if (f64_lt(max_e, eps) == 1) { return 0; }

    var last_slice = 0;
    var idx = 1;
    while (idx < n) {
        var frame = vec_get(e_frames, idx);
        var energy2 = vec_get(e_vals, idx);
        var prev_energy = vec_get(e_vals, idx - 1);
        var diff = f64_div(f64_sub(energy2, prev_energy), max_e);
        if (f64_gt(diff, thr) == 1) {
            if (frame - last_slice >= min_slice_frames) {
                vec_push(slices, frame);
                last_slice = frame;
            }
        }
        idx = idx + 1;
    }
    return 0;
}

# --- SampleBank ---
#derive(accessors)
struct NSampleBank {
    samples;
}

#must_use
fn n_sample_bank_new() {
    var b = alloc(sizeof(NSampleBank));
    NSampleBank_set_samples(b, vec_new());
    return b;
}

# add(sample) -> id (= length BEFORE push). sample is a NSample pointer.
#must_use
fn n_sample_bank_add(bank, sample) {
    var samples = NSampleBank_samples(bank);
    var id = vec_len(samples);
    vec_push(samples, sample);
    return id;
}

# get(id) -> NSample pointer, or 0 if out of range.
#must_use
fn n_sample_bank_get(bank, id) {
    var samples = NSampleBank_samples(bank);
    if (id < 0) { return 0; }
    if (id >= vec_len(samples)) { return 0; }
    return vec_get(samples, id);
}

#must_use
fn n_sample_bank_len(bank) {
    return vec_len(NSampleBank_samples(bank));
}

#must_use
fn n_sample_bank_is_empty(bank) {
    if (vec_len(NSampleBank_samples(bank)) == 0) { return 1; }
    return 0;
}

# --- instrument.cyr ---

# instrument.cyr -- Instrument: zone collection + round-robin voice selection
# Requires: alloc, vec, zone (n_zone_matches, NZone_group, NZone_sample_id)
#
# Ports rust-old/src/instrument.rs. zones and rr_counters are stdlib vecs. rr_counters is
# indexed BY GROUP NUMBER (length >= max_group+1); group 0 is ungrouped and uses no counter.
# The RR counter is a post-incremented u32 with 2^32 wrap. find_zone_rr returns a 0-based
# zone index, or -1 for None (Rust's Option<(usize,&Zone)>).

#derive(accessors)
struct NInstrument {
    name;
    zones;
    rr_counters;
}

#must_use
fn n_instrument_new(name) {
    var inst = alloc(sizeof(NInstrument));
    NInstrument_set_name(inst, name);
    NInstrument_set_zones(inst, vec_new());
    NInstrument_set_rr_counters(inst, vec_new());
    return inst;
}

# Grow rr_counters to at least `needed` length, zero-filled (Rust Vec::resize(n, 0)).
fn n_instrument_ensure_counters(inst, needed) {
    var rr = NInstrument_rr_counters(inst);
    while (vec_len(rr) < needed) { vec_push(rr, 0); }
    return 0;
}

fn n_instrument_add_zone(inst, zone) {
    var zones = NInstrument_zones(inst);
    vec_push(zones, zone);
    var group = NZone_group(zone);
    if (group > 0) {
        n_instrument_ensure_counters(inst, group + 1);
    }
    return 0;
}

# find_zones(note, vel) -> vec of matching NZone pointers (in zone order).
#must_use
fn n_instrument_find_zones(inst, note, vel) {
    var zones = NInstrument_zones(inst);
    var out = vec_new();
    var n = vec_len(zones);
    var i = 0;
    while (i < n) {
        var z = vec_get(zones, i);
        if (n_zone_matches(z, note, vel) == 1) { vec_push(out, z); }
        i = i + 1;
    }
    return out;
}

# find_zone_rr(note, vel) -> 0-based zone index, or -1 if no zone matches.
# The RR group is the group of the FIRST matching zone; only same-group matches
# participate. Ungrouped (group 0) always returns the first match.
fn n_instrument_find_zone_rr(inst, note, vel) {
    var zones = NInstrument_zones(inst);
    var n = vec_len(zones);
    var matching = vec_new();
    var i = 0;
    while (i < n) {
        var z = vec_get(zones, i);
        if (n_zone_matches(z, note, vel) == 1) { vec_push(matching, i); }
        i = i + 1;
    }
    if (vec_len(matching) == 0) { return (0 - 1); }

    var first_match = vec_get(matching, 0);
    var group = NZone_group(vec_get(zones, first_match));
    if (group == 0) { return first_match; }

    var group_matches = vec_new();
    var j = 0;
    var m = vec_len(matching);
    while (j < m) {
        var idx = vec_get(matching, j);
        if (NZone_group(vec_get(zones, idx)) == group) { vec_push(group_matches, idx); }
        j = j + 1;
    }
    if (vec_len(group_matches) == 0) { return (0 - 1); }

    n_instrument_ensure_counters(inst, group + 1);
    var rr = NInstrument_rr_counters(inst);
    var counter = vec_get(rr, group);
    var pick = counter % vec_len(group_matches);
    vec_set(rr, group, (counter + 1) & 0xFFFFFFFF);
    return vec_get(group_matches, pick);
}

#must_use
fn n_instrument_zone_count(inst) {
    return vec_len(NInstrument_zones(inst));
}

# --- capture.cyr ---

# capture.cyr -- sample recording, silence trim, normalization, loop detection
# Requires: alloc, vec, math, sample (NSample_*), naad (normalize, rms)
#
# Ports rust-old/src/capture.rs. "Use naad fully": normalize_peak -> naad normalize(buffer)
# (scale peak to 1.0 in place), normalize_rms -> naad rms(buffer) + scale. trim_silence and
# detect_loop_points are nidhi-specific and ported directly.

# --- SampleRecorder ---
#derive(accessors)
struct NSampleRecorder {
    buffer;
    sample_rate;
    channels;
}

#must_use
fn n_recorder_new(sample_rate, channels) {
    var ch = channels;
    if (ch < 1) { ch = 1; }
    if (ch > 2) { ch = 2; }
    var r = alloc(sizeof(NSampleRecorder));
    NSampleRecorder_set_buffer(r, vec_new());
    NSampleRecorder_set_sample_rate(r, sample_rate);
    NSampleRecorder_set_channels(r, ch);
    return r;
}

# write(data) -- append all f64 elements of the vec `data` (interleaved) to the buffer.
fn n_recorder_write(r, data) {
    var buffer = NSampleRecorder_buffer(r);
    var n = vec_len(data);
    var i = 0;
    while (i < n) {
        vec_push(buffer, vec_get(data, i));
        i = i + 1;
    }
    return 0;
}

#must_use
fn n_recorder_frames(r) {
    return vec_len(NSampleRecorder_buffer(r)) / NSampleRecorder_channels(r);
}

fn n_recorder_clear(r) {
    vec_truncate(NSampleRecorder_buffer(r), 0);
    return 0;
}

# finish() -> NSample owning the recorded buffer.
#must_use
fn n_recorder_finish(r) {
    var buffer = NSampleRecorder_buffer(r);
    var sr = NSampleRecorder_sample_rate(r);
    if (NSampleRecorder_channels(r) == 2) {
        return n_sample_from_stereo(buffer, sr);
    }
    return n_sample_from_mono(buffer, sr);
}

#must_use
fn n_recorder_finish_processed(r, silence_threshold) {
    var sample = n_recorder_finish(r);
    n_trim_silence(sample, silence_threshold);
    n_normalize_peak(sample);
    return sample;
}

# --- trim_silence: remove leading + trailing silence (strict > threshold) ---
fn n_trim_silence(sample, threshold) {
    var thr = f64_max(threshold, 0);
    var ch = NSample_channels(sample);
    var frames = NSample_frames(sample);
    if (frames == 0) { return 0; }
    var data = NSample_data(sample);

    var start = frames;
    var found_start = 0;
    var f = 0;
    while (f < frames) {
        if (found_start == 0) {
            var c = 0;
            var nonsilent = 0;
            while (c < ch) {
                if (f64_gt(f64_abs(vec_get(data, f * ch + c)), thr) == 1) { nonsilent = 1; }
                c = c + 1;
            }
            if (nonsilent == 1) {
                start = f;
                found_start = 1;
            }
        }
        f = f + 1;
    }

    var end = 0;
    var found_end = 0;
    var g = frames;
    while (g > 0) {
        g = g - 1;
        if (found_end == 0) {
            var c2 = 0;
            var ns2 = 0;
            while (c2 < ch) {
                if (f64_gt(f64_abs(vec_get(data, g * ch + c2)), thr) == 1) { ns2 = 1; }
                c2 = c2 + 1;
            }
            if (ns2 == 1) {
                end = g + 1;
                found_end = 1;
            }
        }
    }

    if (start >= end) {
        vec_truncate(data, 0);
        NSample_set_frames(sample, 0);
        return 0;
    }

    var sample_start = start * ch;
    var sample_end = end * ch;
    var nd = vec_new();
    var k = sample_start;
    while (k < sample_end) {
        vec_push(nd, vec_get(data, k));
        k = k + 1;
    }
    NSample_set_data(sample, nd);
    NSample_set_frames(sample, end - start);
    return 0;
}

# --- normalize_peak: scale so loudest |sample| -> 1.0 (via naad) ---
fn n_normalize_peak(sample) {
    normalize(NSample_data(sample));
    return 0;
}

# --- normalize_rms: scale to target RMS (naad rms + manual gain) ---
fn n_normalize_rms(sample, target_rms) {
    var data = NSample_data(sample);
    if (vec_len(data) == 0) { return 0; }
    var r = rms(data);
    var eps = f64_div(F64_ONE, f64_from(10000000000));
    if (f64_gt(r, eps) == 1) {
        var gain = f64_div(target_rms, r);
        var n = vec_len(data);
        var i = 0;
        while (i < n) {
            vec_set(data, i, f64_mul(vec_get(data, i), gain));
            i = i + 1;
        }
    }
    return 0;
}

# --- detect_loop_points: zero-crossing + normalized cross-correlation ---
# Returns a vec of pair pointers (each alloc(16): start at +0, end at +8), best score first,
# at most 10. Empty if frames < min_loop_frames*2 or < 2 positive zero crossings.
#must_use
fn n_detect_loop_points(sample, min_loop_frames) {
    var out = vec_new();
    var frames = NSample_frames(sample);
    if (frames < min_loop_frames * 2) { return out; }
    var data = NSample_data(sample);
    var ch = NSample_channels(sample);
    var eps = f64_div(F64_ONE, f64_from(10000000000));

    # 1. downmix to mono (mean over channels)
    var mono = vec_new();
    var f = 0;
    while (f < frames) {
        var s = 0;
        var c = 0;
        while (c < ch) {
            s = f64_add(s, vec_get(data, f * ch + c));
            c = c + 1;
        }
        vec_push(mono, f64_div(s, f64_from(ch)));
        f = f + 1;
    }

    # 2. positive-going zero crossings: mono[i-1] <= 0 && mono[i] > 0
    var crossings = vec_new();
    var i = 1;
    var mlen = vec_len(mono);
    while (i < mlen) {
        if (f64_le(vec_get(mono, i - 1), 0) == 1) {
            if (f64_gt(vec_get(mono, i), 0) == 1) { vec_push(crossings, i); }
        }
        i = i + 1;
    }
    if (vec_len(crossings) < 2) { return out; }

    # 3. score candidate pairs
    var compare_len = 64;
    if (frames / 4 < compare_len) { compare_len = frames / 4; }
    var c_starts = vec_new();
    var c_ends = vec_new();
    var c_scores = vec_new();
    var ncross = vec_len(crossings);
    var ci = 0;
    while (ci < ncross) {
        var start = vec_get(crossings, ci);
        var cj = ci + 1;
        while (cj < ncross) {
            var end = vec_get(crossings, cj);
            if (end - start >= min_loop_frames) {
                if (start + compare_len <= frames) {
                    if (end + compare_len <= frames) {
                        var dot = 0;
                        var na = 0;
                        var nb = 0;
                        var k = 0;
                        while (k < compare_len) {
                            var a = vec_get(mono, start + k);
                            var b = vec_get(mono, end + k);
                            dot = f64_add(dot, f64_mul(a, b));
                            na = f64_add(na, f64_mul(a, a));
                            nb = f64_add(nb, f64_mul(b, b));
                            k = k + 1;
                        }
                        var denom = f64_sqrt(f64_mul(na, nb));
                        var score = 0;
                        if (f64_gt(denom, eps) == 1) { score = f64_div(dot, denom); }
                        vec_push(c_starts, start);
                        vec_push(c_ends, end);
                        vec_push(c_scores, score);
                    }
                }
            }
            cj = cj + 1;
        }
        # 100-candidate cap: checked once per OUTER iteration
        if (vec_len(c_starts) > 100) { ci = ncross; } else { ci = ci + 1; }
    }

    # 4. STABLE insertion sort by score DESCENDING (ties keep insertion order, matching
    #    Rust's stable sort_by). Element a2 shifts left past strictly-smaller scores only.
    var ncand = vec_len(c_starts);
    var a2 = 1;
    while (a2 < ncand) {
        var ks = vec_get(c_starts, a2);
        var ke = vec_get(c_ends, a2);
        var ksc = vec_get(c_scores, a2);
        var b2 = a2 - 1;
        var shifting = 1;
        while (shifting == 1) {
            if (b2 < 0) {
                shifting = 0;
            } else {
                if (f64_lt(vec_get(c_scores, b2), ksc) == 1) {
                    vec_set(c_starts, b2 + 1, vec_get(c_starts, b2));
                    vec_set(c_ends, b2 + 1, vec_get(c_ends, b2));
                    vec_set(c_scores, b2 + 1, vec_get(c_scores, b2));
                    b2 = b2 - 1;
                } else {
                    shifting = 0;
                }
            }
        }
        vec_set(c_starts, b2 + 1, ks);
        vec_set(c_ends, b2 + 1, ke);
        vec_set(c_scores, b2 + 1, ksc);
        a2 = a2 + 1;
    }

    # 5. top 10 (start,end) pairs
    var take = ncand;
    if (take > 10) { take = 10; }
    var t = 0;
    while (t < take) {
        var pair = alloc(16);
        store64(pair, vec_get(c_starts, t));
        store64(pair + 8, vec_get(c_ends, t));
        vec_push(out, pair);
        t = t + 1;
    }
    return out;
}

# --- stretch.cyr ---

# stretch.cyr -- time-stretching (WSOLA / OLA), pitch-preserving
# Requires: alloc, vec, math (f64_*, f64_cos/ceil/round/floor), f64_util (n_is_finite)
#
# Ports rust-old/src/stretch.rs. Pure f64 array math, no naad dependency. Buffers are stdlib
# vecs of f64 bit patterns. StretchMode PhaseVocoder falls back to WSOLA (unimplemented in Rust too).

var SM_OLA           = 0;
var SM_WSOLA         = 1;
var SM_PHASE_VOCODER = 2;

# --- helpers ---

# n_dot(a, a_off, b, b_off, n) -- sum_{i<n} a[a_off+i]*b[b_off+i]  (f64).
#inline
fn n_dot(a, a_off, b, b_off, n) {
    var sum = 0;
    var i = 0;
    while (i < n) {
        sum = f64_add(sum, f64_mul(vec_get(a, a_off + i), vec_get(b, b_off + i)));
        i = i + 1;
    }
    return sum;
}

# cross_correlate(a, b, max_lag) -- signed lag maximizing the dot product of a vs b shifted by
# that lag. Negative lag shifts a forward; non-negative lag shifts b forward (lag 0 included).
#must_use
fn n_cross_correlate(a, b, max_lag) {
    var alen = vec_len(a);
    var blen = vec_len(b);
    if (alen == 0) { return 0; }
    if (blen == 0) { return 0; }
    var best_lag = 0;
    var have_best = 0;
    var best_corr = 0;

    var max_neg = max_lag;
    if (alen - 1 < max_neg) { max_neg = alen - 1; }
    var lag = 1;
    while (lag <= max_neg) {
        var ol = alen - lag;
        if (blen < ol) { ol = blen; }
        if (ol > 0) {
            var sum = n_dot(a, lag, b, 0, ol);
            if (have_best == 0) {
                best_corr = sum;
                best_lag = 0 - lag;
                have_best = 1;
            } else {
                if (f64_gt(sum, best_corr) == 1) {
                    best_corr = sum;
                    best_lag = 0 - lag;
                }
            }
        }
        lag = lag + 1;
    }

    var max_pos = max_lag;
    if (blen - 1 < max_pos) { max_pos = blen - 1; }
    var lag2 = 0;
    while (lag2 <= max_pos) {
        var ol2 = alen;
        if (blen - lag2 < ol2) { ol2 = blen - lag2; }
        if (ol2 > 0) {
            var sum2 = n_dot(a, 0, b, lag2, ol2);
            if (have_best == 0) {
                best_corr = sum2;
                best_lag = lag2;
                have_best = 1;
            } else {
                if (f64_gt(sum2, best_corr) == 1) {
                    best_corr = sum2;
                    best_lag = lag2;
                }
            }
        }
        lag2 = lag2 + 1;
    }
    return best_lag;
}

# hann_window(size) -> vec of f64: 0.5*(1 - cos(2*PI*i/(size-1))).
#must_use
fn n_hann_window(size) {
    var w = vec_new();
    if (size == 0) { return w; }
    var denom = size - 1;
    if (denom < 1) { denom = 1; }
    var denom_f = f64_from(denom);
    var i = 0;
    while (i < size) {
        var ang = f64_div(f64_mul(F64_TAU, f64_from(i)), denom_f);
        vec_push(w, f64_mul(F64_HALF, f64_sub(F64_ONE, f64_cos(ang))));
        i = i + 1;
    }
    return w;
}

# normalize_by_window_sum(output, window_sum) -- output[i] /= window_sum[i] where ws > 1e-6.
fn n_normalize_by_window_sum(output, window_sum) {
    var n = vec_len(output);
    if (vec_len(window_sum) < n) { n = vec_len(window_sum); }
    var thr = f64_div(F64_ONE, f64_from(1000000));
    var i = 0;
    while (i < n) {
        var ws = vec_get(window_sum, i);
        if (f64_gt(ws, thr) == 1) {
            vec_set(output, i, f64_div(vec_get(output, i), ws));
        }
        i = i + 1;
    }
    return 0;
}

# --- TimeStretcher ---
#derive(accessors)
struct NTimeStretcher {
    input;
    sample_rate;
    frame_size;
    overlap;
}

#must_use
fn n_stretcher_new(input, sample_rate) {
    var s = alloc(sizeof(NTimeStretcher));
    NTimeStretcher_set_input(s, input);
    NTimeStretcher_set_sample_rate(s, sample_rate);
    NTimeStretcher_set_frame_size(s, 1024);
    NTimeStretcher_set_overlap(s, F64_HALF);
    return s;
}

fn n_stretcher_with_frame_size(s, size) {
    NTimeStretcher_set_frame_size(s, size);
    return s;
}

# stretch_short(ratio) -- linear-interpolation resample for input_len < frame_size.
#must_use
fn n_stretch_short(s, ratio) {
    var input = NTimeStretcher_input(s);
    var input_len = vec_len(input);
    var out = vec_new();
    var target_len = f64_to(f64_round(f64_mul(f64_from(input_len), ratio)));
    if (target_len == 0) { return out; }
    var i = 0;
    while (i < target_len) {
        var src = f64_div(f64_from(i), ratio);
        var idx = f64_to(f64_floor(src));
        var frac = f64_sub(src, f64_from(idx));
        var a = 0;
        if (idx >= 0) { if (idx < input_len) { a = vec_get(input, idx); } }
        var b = a;
        if (idx + 1 >= 0) { if (idx + 1 < input_len) { b = vec_get(input, idx + 1); } }
        vec_push(out, f64_add(a, f64_mul(f64_sub(b, a), frac)));
        i = i + 1;
    }
    return out;
}

# stretch(ratio) -- WSOLA. ratio>1 = longer/slower; <1 = shorter/faster.
#must_use
fn n_stretch(s, ratio) {
    var input = NTimeStretcher_input(s);
    var input_len = vec_len(input);
    var frame_size = NTimeStretcher_frame_size(s);
    var out = vec_new();
    if (input_len == 0) { return out; }
    if (frame_size == 0) { return out; }
    if (f64_le(ratio, 0) == 1) { return out; }
    if (n_is_finite(ratio) == 0) { return out; }
    if (input_len < frame_size) { return n_stretch_short(s, ratio); }

    var overlap = NTimeStretcher_overlap(s);
    var syn_hop = f64_to(f64_mul(f64_from(frame_size), f64_sub(F64_ONE, overlap)));
    if (syn_hop == 0) {
        var c = 0;
        while (c < input_len) { vec_push(out, vec_get(input, c)); c = c + 1; }
        return out;
    }
    var ana_hop = f64_div(f64_from(syn_hop), ratio);
    var tolerance = frame_size / 4;
    var window = n_hann_window(frame_size);
    var out_len = f64_to(f64_ceil(f64_mul(f64_from(input_len), ratio))) + frame_size;

    var output = vec_new();
    var window_sum = vec_new();
    var z = 0;
    while (z < out_len) { vec_push(output, 0); vec_push(window_sum, 0); z = z + 1; }

    var have_prev = 0;
    var prev = 0;
    var frame_idx = 0;
    var looping = 1;
    while (looping == 1) {
        var out_pos = frame_idx * syn_hop;
        if (out_pos + frame_size > out_len) {
            looping = 0;
        } else {
            var expected_input = f64_to(f64_mul(f64_from(frame_idx), ana_hop));
            var optimal_input = expected_input;
            if (optimal_input < 0) { optimal_input = 0; }
            if (have_prev == 1) {
                var ss = expected_input - tolerance;
                if (ss < 0) { ss = 0; }
                var se = expected_input + tolerance;
                var cap = input_len - frame_size;
                if (se > cap) { se = cap; }
                if (ss > se) {
                    optimal_input = expected_input;
                    if (optimal_input < 0) { optimal_input = 0; }
                } else {
                    var best_pos = ss;
                    var have_bc = 0;
                    var best_corr = 0;
                    var pos = ss;
                    while (pos <= se) {
                        var rem = input_len - pos;
                        var nn = frame_size;
                        if (rem < nn) { nn = rem; }
                        var corr = n_dot(prev, 0, input, pos, nn);
                        if (have_bc == 0) {
                            best_corr = corr;
                            best_pos = pos;
                            have_bc = 1;
                        } else {
                            if (f64_gt(corr, best_corr) == 1) {
                                best_corr = corr;
                                best_pos = pos;
                            }
                        }
                        pos = pos + 1;
                    }
                    optimal_input = best_pos;
                }
            }
            if (optimal_input + frame_size > input_len) {
                looping = 0;
            } else {
                var newprev = vec_new();
                var i = 0;
                while (i < frame_size) {
                    var sv = vec_get(input, optimal_input + i);
                    vec_push(newprev, sv);
                    var oi = out_pos + i;
                    if (oi < out_len) {
                        var wv = vec_get(window, i);
                        vec_set(output, oi, f64_add(vec_get(output, oi), f64_mul(sv, wv)));
                        vec_set(window_sum, oi, f64_add(vec_get(window_sum, oi), f64_mul(wv, wv)));
                    }
                    i = i + 1;
                }
                prev = newprev;
                have_prev = 1;
                frame_idx = frame_idx + 1;
            }
        }
    }

    n_normalize_by_window_sum(output, window_sum);
    var target_len = f64_to(f64_round(f64_mul(f64_from(input_len), ratio)));
    var final_len = target_len;
    if (vec_len(output) < final_len) { final_len = vec_len(output); }
    vec_truncate(output, final_len);
    return output;
}

# stretch_ola(ratio) -- plain overlap-add (no correlation search; direct input position).
#must_use
fn n_stretch_ola(s, ratio) {
    var input = NTimeStretcher_input(s);
    var input_len = vec_len(input);
    var frame_size = NTimeStretcher_frame_size(s);
    var out = vec_new();
    if (input_len == 0) { return out; }
    if (frame_size == 0) { return out; }
    if (f64_le(ratio, 0) == 1) { return out; }
    if (n_is_finite(ratio) == 0) { return out; }
    if (input_len < frame_size) { return n_stretch_short(s, ratio); }

    var overlap = NTimeStretcher_overlap(s);
    var syn_hop = f64_to(f64_mul(f64_from(frame_size), f64_sub(F64_ONE, overlap)));
    if (syn_hop == 0) {
        var c = 0;
        while (c < input_len) { vec_push(out, vec_get(input, c)); c = c + 1; }
        return out;
    }
    var ana_hop = f64_div(f64_from(syn_hop), ratio);
    var window = n_hann_window(frame_size);
    var out_len = f64_to(f64_ceil(f64_mul(f64_from(input_len), ratio))) + frame_size;

    var output = vec_new();
    var window_sum = vec_new();
    var z = 0;
    while (z < out_len) { vec_push(output, 0); vec_push(window_sum, 0); z = z + 1; }

    var frame_idx = 0;
    var looping = 1;
    while (looping == 1) {
        var out_pos = frame_idx * syn_hop;
        if (out_pos + frame_size > out_len) {
            looping = 0;
        } else {
            var input_pos = f64_to(f64_mul(f64_from(frame_idx), ana_hop));
            if (input_pos + frame_size > input_len) {
                looping = 0;
            } else {
                var i = 0;
                while (i < frame_size) {
                    var oi = out_pos + i;
                    if (oi < out_len) {
                        var wv = vec_get(window, i);
                        var sv = vec_get(input, input_pos + i);
                        vec_set(output, oi, f64_add(vec_get(output, oi), f64_mul(sv, wv)));
                        vec_set(window_sum, oi, f64_add(vec_get(window_sum, oi), f64_mul(wv, wv)));
                    }
                    i = i + 1;
                }
                frame_idx = frame_idx + 1;
            }
        }
    }

    n_normalize_by_window_sum(output, window_sum);
    var target_len = f64_to(f64_round(f64_mul(f64_from(input_len), ratio)));
    var final_len = target_len;
    if (vec_len(output) < final_len) { final_len = vec_len(output); }
    vec_truncate(output, final_len);
    return output;
}

# stretch_with_mode(ratio, mode) -- Ola -> OLA; Wsola/PhaseVocoder -> WSOLA.
#must_use
fn n_stretch_with_mode(s, ratio, mode) {
    if (mode == SM_OLA) { return n_stretch_ola(s, ratio); }
    return n_stretch(s, ratio);
}

# --- effect_chain.cyr ---

# effect_chain.cyr -- per-instrument serial effect chain (up to 5 naad effects)
# Requires: alloc, vec, math, naad (reverb_new/reverb_process_sample, comb_filter_new/
#           comb_filter_process_sample, effects_chorus_new/effects_chorus_process_sample,
#           dynamics_compressor_new/_process_sample, dynamics_limiter_new/_process_sample,
#           naad_is_err)
#
# Ports rust-old/src/effect_chain.rs. "Use naad fully": slots hold real naad effect objects
# (the Rust no_std passthrough is dropped). Effects run SERIALLY with per-slot bypass + wet/dry
# mix. process_stereo runs L then R through the SAME stateful chain (source behavior, preserved).
#
# NOTE (bug-for-bug parity): the Rust source builds the Reverb with positional args
# (sr, 1.5, 0.3, 0.5, 0.6) against naad's reverb_new(decay, damping, pre_delay_ms, mix,
# sample_rate) -- i.e. the sample_rate arrives in `decay` and 0.6 in `sample_rate`. Replicated
# verbatim; if reverb_new rejects it, the slot falls back to None (Rust `.unwrap_or(None)`).

var FX_NONE       = 0;
var FX_REVERB     = 1;
var FX_DELAY      = 2;
var FX_CHORUS     = 3;
var FX_COMPRESSOR = 4;
var FX_LIMITER    = 5;
var N_FX_MAX_SLOTS = 5;

# --- EffectSlot ---
# Fields: effect_type (FX_* tag), bypass (0/1), mix (f64 bits, 0=dry 1=wet),
# state (naad effect pointer, or 0 for None/failed-construction).
#derive(accessors)
struct NEffectSlot {
    effect_type;
    bypass;
    mix;
    state;
}

#must_use
fn n_effect_slot_new() {
    var s = alloc(sizeof(NEffectSlot));
    NEffectSlot_set_effect_type(s, FX_NONE);
    NEffectSlot_set_bypass(s, 0);
    NEffectSlot_set_mix(s, F64_ONE);
    NEffectSlot_set_state(s, 0);
    return s;
}

# --- EffectChain ---
#derive(accessors)
struct NEffectChain {
    slots;
    sample_rate;
}

#must_use
fn n_effect_chain_new(sample_rate) {
    var c = alloc(sizeof(NEffectChain));
    NEffectChain_set_slots(c, vec_new());
    NEffectChain_set_sample_rate(c, sample_rate);
    return c;
}

# create_state(effect_type) -> naad effect pointer, or 0 (None/failed). sample_rate f64 bits.
fn n_effect_chain_create_state(chain, effect_type) {
    var sr = NEffectChain_sample_rate(chain);
    if (effect_type == FX_REVERB) {
        # (sr, 1.5, 0.3, 0.5, 0.6) -> reverb_new(decay, damping, pre_delay_ms, mix, sample_rate)
        var st = reverb_new(sr, f64_div(f64_from(3), f64_from(2)),
            f64_div(f64_from(3), f64_from(10)), F64_HALF, f64_div(f64_from(6), f64_from(10)));
        if (naad_is_err(st) == 1) { return 0; }
        return st;
    }
    if (effect_type == FX_DELAY) {
        var samples = f64_to(f64_mul(sr, f64_div(f64_from(3), f64_from(10))));   # (sr * 0.3) as usize
        return comb_filter_new(samples, f64_div(f64_from(4), f64_from(10)));      # feedback 0.4
    }
    if (effect_type == FX_CHORUS) {
        # (3, 0.02, 0.002, 1.5, 0.5, sr)
        var st2 = effects_chorus_new(3, f64_div(f64_from(2), f64_from(100)),
            f64_div(f64_from(2), f64_from(1000)), f64_div(f64_from(3), f64_from(2)), F64_HALF, sr);
        if (naad_is_err(st2) == 1) { return 0; }
        return st2;
    }
    if (effect_type == FX_COMPRESSOR) {
        # (-20, 4, 0.01, 0.1, sr)
        return dynamics_compressor_new(f64_neg(f64_from(20)), f64_from(4),
            f64_div(F64_ONE, f64_from(100)), f64_div(F64_ONE, f64_from(10)), sr);
    }
    if (effect_type == FX_LIMITER) {
        # (-1.0, 0.05, sr)
        return dynamics_limiter_new(f64_neg(F64_ONE), f64_div(f64_from(5), f64_from(100)), sr);
    }
    return 0;
}

# add(effect_type) -> 1 on success, 0 if the chain is already full (MAX_SLOTS).
fn n_effect_chain_add(chain, effect_type) {
    var slots = NEffectChain_slots(chain);
    if (vec_len(slots) >= N_FX_MAX_SLOTS) { return 0; }
    var slot = n_effect_slot_new();
    NEffectSlot_set_effect_type(slot, effect_type);
    NEffectSlot_set_state(slot, n_effect_chain_create_state(chain, effect_type));
    vec_push(slots, slot);
    return 1;
}

fn n_effect_chain_remove(chain, index) {
    var slots = NEffectChain_slots(chain);
    if (index >= 0) {
        if (index < vec_len(slots)) { vec_remove(slots, index); }
    }
    return 0;
}

fn n_effect_chain_clear(chain) {
    vec_truncate(NEffectChain_slots(chain), 0);
    return 0;
}

#must_use
fn n_effect_chain_len(chain) {
    return vec_len(NEffectChain_slots(chain));
}

#must_use
fn n_effect_chain_is_empty(chain) {
    if (vec_len(NEffectChain_slots(chain)) == 0) { return 1; }
    return 0;
}

# slot(index) -> EffectSlot pointer, or 0 if out of range.
#must_use
fn n_effect_chain_slot(chain, index) {
    var slots = NEffectChain_slots(chain);
    if (index < 0) { return 0; }
    if (index >= vec_len(slots)) { return 0; }
    return vec_get(slots, index);
}

# apply one effect to a sample -> wet value. Reverb returns a stereo pair; take the left (.0).
#inline
fn n_effect_apply(effect_type, state, input) {
    if (state == 0) { return input; }
    if (effect_type == FX_REVERB) { return load64(reverb_process_sample(state, input)); }
    if (effect_type == FX_DELAY) { return comb_filter_process_sample(state, input); }
    if (effect_type == FX_CHORUS) { return effects_chorus_process_sample(state, input); }
    if (effect_type == FX_COMPRESSOR) { return dynamics_compressor_process_sample(state, input); }
    if (effect_type == FX_LIMITER) { return dynamics_limiter_process_sample(state, input); }
    return input;
}

# process_sample(input) -> output. Serial; skip bypassed/None slots; wet/dry blend per slot.
#inline
fn n_effect_chain_process_sample(chain, input) {
    var slots = NEffectChain_slots(chain);
    var n = vec_len(slots);
    var out = input;
    var i = 0;
    while (i < n) {
        var slot = vec_get(slots, i);
        var etype = NEffectSlot_effect_type(slot);
        if (NEffectSlot_bypass(slot) == 0) {
            if (etype != FX_NONE) {
                var wet = n_effect_apply(etype, NEffectSlot_state(slot), out);
                var mix = NEffectSlot_mix(slot);
                out = f64_add(f64_mul(out, f64_sub(F64_ONE, mix)), f64_mul(wet, mix));
            }
        }
        i = i + 1;
    }
    return out;
}

# process_stereo(left, right, out2) -> out2[0]=L, out2[1]=R. L then R share the stateful chain.
#inline
fn n_effect_chain_process_stereo(chain, left, right, out2) {
    store64(out2, n_effect_chain_process_sample(chain, left));
    store64(out2 + 8, n_effect_chain_process_sample(chain, right));
    return 0;
}

# --- io.cyr ---

# io.cyr -- WAV loading + streaming (behind the Rust `io` feature; uses shravan)
# Requires: alloc, vec, string (strlen), str (str_new), syscalls/fs (file_open/read/write/close,
#           memcpy, load8/store8), sample (n_sample_from_mono/stereo/with_name), error (ERR_IMPORT),
#           shravan (wav_decode, decode_file, decode_result_info/samples, fmtinfo_channels/
#           sample_rate/total_samples, wav_stream_new/feed/flush, stream_evt_type/data,
#           STREAM_EVT_HEADER/SAMPLES/END)
#
# Ports rust-old/src/io.rs. Samples are f64 bit patterns end-to-end (shravan decodes to f64), so
# the Rust Vec<f32> boundary conversions are no-ops here. All failures collapse to ERR_IMPORT.
# Success returns a positive Sample pointer; failure returns the negative ERR_IMPORT code.

# n_read_file(path, out_len) -> heap byte buffer (or 0 on error); writes byte count to out_len.
# Mirrors shravan's decode_file read loop (grow-and-read).
fn n_read_file(path, out_len) {
    var fd = file_open(path, 0, 0);
    if (fd < 0) { return 0; }
    var buf_cap = 1048576;
    var buf = alloc(buf_cap);
    var total = 0;
    var reading = 1;
    while (reading == 1) {
        var avail = buf_cap - total;
        if (avail <= 0) {
            var new_cap = buf_cap * 2;
            var new_buf = alloc(new_cap);
            memcpy(new_buf, buf, total);
            buf = new_buf;
            buf_cap = new_cap;
            avail = buf_cap - total;
        }
        var n = file_read(fd, buf + total, avail);
        if (n <= 0) { reading = 0; } else { total = total + n; }
    }
    file_close(fd);
    store64(out_len, total);
    return buf;
}

# n_file_stem(path cstr) -> a new Str of the basename without extension (Rust Path::file_stem).
# A leading '.' is NOT treated as an extension separator (".bashrc" -> ".bashrc").
#must_use
fn n_file_stem(path) {
    var len = strlen(path);
    var slash = 0 - 1;
    var i = 0;
    while (i < len) {
        if (load8(path + i) == 47) { slash = i; }
        i = i + 1;
    }
    var start = slash + 1;
    var dot = 0 - 1;
    var j = start;
    while (j < len) {
        if (load8(path + j) == 46) { dot = j; }
        j = j + 1;
    }
    var end = len;
    if (dot > start) { end = dot; }
    return str_new(path + start, end - start);
}

# Build a Sample from a decode_result (mono if channels==1 else stereo).
#must_use
fn n_sample_from_decode(dr) {
    var info = decode_result_info(dr);
    var samples = decode_result_samples(dr);
    var channels = fmtinfo_channels(info);
    var sample_rate = fmtinfo_sample_rate(info);
    if (channels == 1) { return n_sample_from_mono(samples, sample_rate); }
    return n_sample_from_stereo(samples, sample_rate);
}

# load_wav_from_memory(data, len) -> Sample pointer, or ERR_IMPORT.
#must_use
fn n_load_wav_from_memory(data, len) {
    var dr = wav_decode(data, len);
    if (dr < 0) { return ERR_IMPORT; }
    return n_sample_from_decode(dr);
}

# load_wav(path) -> Sample pointer (named from the file stem), or ERR_IMPORT.
#must_use
fn n_load_wav(path) {
    var dr = decode_file(path);
    if (dr < 0) { return ERR_IMPORT; }
    var sample = n_sample_from_decode(dr);
    return n_sample_with_name(sample, n_file_stem(path));
}

# --- StreamingWavReader ---
#derive(accessors)
struct NStreamReader {
    decoder;
    info;
    pending;
    channels;
    sample_rate;
    total_frames;
    frames_read;
    finished;
    file_data;
    file_len;
    file_offset;
}

# open(path) -> NStreamReader pointer, or ERR_IMPORT. Does a full decode up front for metadata.
#must_use
fn n_stream_reader_open(path) {
    var lenslot = alloc(8);
    var file_data = n_read_file(path, lenslot);
    if (file_data == 0) { return ERR_IMPORT; }
    var file_len = load64(lenslot);
    var dr = wav_decode(file_data, file_len);
    if (dr < 0) { return ERR_IMPORT; }
    var info = decode_result_info(dr);
    var r = alloc(sizeof(NStreamReader));
    NStreamReader_set_decoder(r, wav_stream_new(0));
    NStreamReader_set_info(r, info);
    NStreamReader_set_pending(r, vec_new());
    NStreamReader_set_channels(r, fmtinfo_channels(info));
    NStreamReader_set_sample_rate(r, fmtinfo_sample_rate(info));
    NStreamReader_set_total_frames(r, fmtinfo_total_samples(info));
    NStreamReader_set_frames_read(r, 0);
    NStreamReader_set_finished(r, 0);
    NStreamReader_set_file_data(r, file_data);
    NStreamReader_set_file_len(r, file_len);
    NStreamReader_set_file_offset(r, 0);
    return r;
}

# Append every SAMPLES event's data vec into pending; set finished on END; stash HEADER info.
fn n_stream_drain_events(reader, events) {
    var pending = NStreamReader_pending(reader);
    var ne = vec_len(events);
    var ei = 0;
    while (ei < ne) {
        var evt = vec_get(events, ei);
        var etype = stream_evt_type(evt);
        if (etype == STREAM_EVT_HEADER) {
            NStreamReader_set_info(reader, stream_evt_data(evt));
        } else {
            if (etype == STREAM_EVT_SAMPLES) {
                var s = stream_evt_data(evt);
                var ns = vec_len(s);
                var si = 0;
                while (si < ns) { vec_push(pending, vec_get(s, si)); si = si + 1; }
            } else {
                if (etype == STREAM_EVT_END) { NStreamReader_set_finished(reader, 1); }
            }
        }
        ei = ei + 1;
    }
    return 0;
}

# read_chunk(chunk_frames) -> vec of interleaved f64 samples (empty when done).
fn n_stream_reader_read_chunk(reader, chunk_frames) {
    var channels = NStreamReader_channels(reader);
    var remaining = NStreamReader_total_frames(reader) - NStreamReader_frames_read(reader);
    var frames_to_read = chunk_frames;
    if (remaining < frames_to_read) { frames_to_read = remaining; }
    if (frames_to_read == 0) { return vec_new(); }
    var samples_needed = frames_to_read * channels;
    var pending = NStreamReader_pending(reader);
    var decoder = NStreamReader_decoder(reader);

    var looping = 1;
    while (looping == 1) {
        if (vec_len(pending) >= samples_needed) {
            looping = 0;
        } else {
            if (NStreamReader_finished(reader) == 1) {
                looping = 0;
            } else {
                var file_offset = NStreamReader_file_offset(reader);
                var file_len = NStreamReader_file_len(reader);
                if (file_offset < file_len) {
                    var end = file_offset + 4096;
                    if (end > file_len) { end = file_len; }
                    var chunk_ptr = NStreamReader_file_data(reader) + file_offset;
                    NStreamReader_set_file_offset(reader, end);
                    var events = wav_stream_feed(decoder, chunk_ptr, end - file_offset);
                    n_stream_drain_events(reader, events);
                } else {
                    var fevents = wav_stream_flush(decoder);
                    n_stream_drain_events(reader, fevents);
                    NStreamReader_set_finished(reader, 1);
                }
            }
        }
    }

    var take = samples_needed;
    if (vec_len(pending) < take) { take = vec_len(pending); }
    var result = vec_new();
    var ti = 0;
    while (ti < take) { vec_push(result, vec_get(pending, ti)); ti = ti + 1; }
    # drain the first `take` samples from pending
    var newpending = vec_new();
    var plen = vec_len(pending);
    var pi = take;
    while (pi < plen) { vec_push(newpending, vec_get(pending, pi)); pi = pi + 1; }
    NStreamReader_set_pending(reader, newpending);
    NStreamReader_set_frames_read(reader, NStreamReader_frames_read(reader) + take / channels);
    return result;
}

# read_all() -> Sample built from the whole stream.
#must_use
fn n_stream_reader_read_all(reader) {
    var data = n_stream_reader_read_chunk(reader, NStreamReader_total_frames(reader));
    if (NStreamReader_channels(reader) == 1) {
        return n_sample_from_mono(data, NStreamReader_sample_rate(reader));
    }
    return n_sample_from_stereo(data, NStreamReader_sample_rate(reader));
}

# --- sf2.cyr ---

# sf2.cyr -- SF2 / SoundFont-2 RIFF binary parser
# Requires: alloc, vec, str (str_new), math (f64_*), byte ops (load8), sample (n_sample_*),
#           zone (n_zone_*), instrument (n_instrument_*), loop_mode (LOOP_*)
#
# Ports rust-old/src/sf2.rs. ALL multi-byte integers are little-endian. Parses an in-memory byte
# buffer (data ptr + len) into (presets, instruments, SampleBank). Success -> Sf2Result pointer;
# failure -> a negative error code. Lenient on bad content (skips), strict on structural errors.
# Every read is bounds-checked (returns 0 past end) so hostile input never reads OOB.

# --- FourCC constants (bytes packed little-endian, byte0 in the low 8 bits) ---
var CC_RIFF = 0x46464952;
var CC_SFBK = 0x6B626673;
var CC_LIST = 0x5453494C;
var CC_SDTA = 0x61746473;
var CC_SMPL = 0x6C706D73;
var CC_PDTA = 0x61746470;
var CC_PHDR = 0x72646870;
var CC_PBAG = 0x67616270;
var CC_PGEN = 0x6E656770;
var CC_INST = 0x74736E69;
var CC_IBAG = 0x67616269;
var CC_IGEN = 0x6E656769;
var CC_SHDR = 0x72646873;

# --- bounds-checked little-endian byte readers (0 past end) ---
#inline
fn sf2_u8(data, len, off) {
    if (off < 0) { return 0; }
    if (off >= len) { return 0; }
    return load8(data + off);
}

#inline
fn sf2_u16(data, len, off) {
    if (off < 0) { return 0; }
    if (off + 2 > len) { return 0; }
    return load8(data + off) | (load8(data + off + 1) << 8);
}

#inline
fn sf2_i16(data, len, off) {
    var v = sf2_u16(data, len, off);
    if (v >= 0x8000) { return v - 0x10000; }
    return v;
}

#inline
fn sf2_u32(data, len, off) {
    if (off < 0) { return 0; }
    if (off + 4 > len) { return 0; }
    return load8(data + off) | (load8(data + off + 1) << 8) | (load8(data + off + 2) << 16) | (load8(data + off + 3) << 24);
}

# fourcc packed LE (same as u32); compares against CC_* constants.
#inline
fn sf2_fourcc(data, len, off) {
    return sf2_u32(data, len, off);
}

# read a fixed-width field as a Str, cut at the first NUL (or the field width, or end of data).
#must_use
fn sf2_cstr(data, dlen, off, flen) {
    var slen = 0;
    var scanning = 1;
    while (scanning == 1) {
        if (slen >= flen) {
            scanning = 0;
        } else {
            var idx = off + slen;
            if (idx >= dlen) {
                scanning = 0;
            } else {
                if (load8(data + idx) == 0) { scanning = 0; } else { slen = slen + 1; }
            }
        }
    }
    return str_new(data + off, slen);
}

# range-generator amount: lo = low byte, hi = high byte of the 16-bit amount.
#inline
fn sf2_amt_lo(amount) { return amount & 0xFF; }
#inline
fn sf2_amt_hi(amount) { return ((amount & 0xFFFF) >> 8) & 0xFF; }

# --- record structs ---
#derive(accessors)
struct Sf2Phdr { name; preset; bank; bag_index; }
#derive(accessors)
struct Sf2Bag { gen_index; }
#derive(accessors)
struct Sf2Gen { oper; amount; }
#derive(accessors)
struct Sf2Inst { name; bag_index; }
#derive(accessors)
struct Sf2Shdr { name; start; end; loop_start; loop_end; sample_rate; original_pitch; sample_type; }

# public preset descriptor + the 3-list parse result
#derive(accessors)
struct Sf2Preset { name; bank; preset_number; }
#derive(accessors)
struct Sf2Result { presets; instruments; bank; }

# preset key/vel range passed down to the instrument-bag resolver
#derive(accessors)
struct Sf2PRange { pk_lo; pk_hi; have_pk; pv_lo; pv_hi; have_pv; }

# --- record-array parsers (count = chunklen / SIZE, floor) ---
#must_use
fn sf2_parse_phdr(data, len) {
    var out = vec_new();
    var count = len / 38;
    var i = 0;
    while (i < count) {
        var off = i * 38;
        var r = alloc(sizeof(Sf2Phdr));
        Sf2Phdr_set_name(r, sf2_cstr(data, len, off, 20));
        Sf2Phdr_set_preset(r, sf2_u16(data, len, off + 20));
        Sf2Phdr_set_bank(r, sf2_u16(data, len, off + 22));
        Sf2Phdr_set_bag_index(r, sf2_u16(data, len, off + 24));
        vec_push(out, r);
        i = i + 1;
    }
    return out;
}

#must_use
fn sf2_parse_bag(data, len) {
    var out = vec_new();
    var count = len / 4;
    var i = 0;
    while (i < count) {
        var r = alloc(sizeof(Sf2Bag));
        Sf2Bag_set_gen_index(r, sf2_u16(data, len, i * 4));
        vec_push(out, r);
        i = i + 1;
    }
    return out;
}

#must_use
fn sf2_parse_gen(data, len) {
    var out = vec_new();
    var count = len / 4;
    var i = 0;
    while (i < count) {
        var off = i * 4;
        var r = alloc(sizeof(Sf2Gen));
        Sf2Gen_set_oper(r, sf2_u16(data, len, off));
        Sf2Gen_set_amount(r, sf2_i16(data, len, off + 2));
        vec_push(out, r);
        i = i + 1;
    }
    return out;
}

#must_use
fn sf2_parse_inst(data, len) {
    var out = vec_new();
    var count = len / 22;
    var i = 0;
    while (i < count) {
        var off = i * 22;
        var r = alloc(sizeof(Sf2Inst));
        Sf2Inst_set_name(r, sf2_cstr(data, len, off, 20));
        Sf2Inst_set_bag_index(r, sf2_u16(data, len, off + 20));
        vec_push(out, r);
        i = i + 1;
    }
    return out;
}

#must_use
fn sf2_parse_shdr(data, len) {
    var out = vec_new();
    var count = len / 46;
    var i = 0;
    while (i < count) {
        var off = i * 46;
        var r = alloc(sizeof(Sf2Shdr));
        Sf2Shdr_set_name(r, sf2_cstr(data, len, off, 20));
        Sf2Shdr_set_start(r, sf2_u32(data, len, off + 20));
        Sf2Shdr_set_end(r, sf2_u32(data, len, off + 24));
        Sf2Shdr_set_loop_start(r, sf2_u32(data, len, off + 28));
        Sf2Shdr_set_loop_end(r, sf2_u32(data, len, off + 32));
        Sf2Shdr_set_sample_rate(r, sf2_u32(data, len, off + 36));
        Sf2Shdr_set_original_pitch(r, sf2_u8(data, len, off + 40));
        Sf2Shdr_set_sample_type(r, sf2_u16(data, len, off + 44));
        vec_push(out, r);
        i = i + 1;
    }
    return out;
}

# pcm16_to_f32: 16-bit LE PCM -> vec of f64 in [-1,1). Divisor 32768. Empty on bad range.
#must_use
fn sf2_pcm16_to_f32(data, dlen, start_sample, end_sample) {
    var out = vec_new();
    var byte_start = start_sample * 2;
    var byte_end = end_sample * 2;
    if (byte_end > dlen) { return out; }
    if (byte_start > byte_end) { return out; }
    var num = (byte_end - byte_start) / 2;
    var i = 0;
    while (i < num) {
        var s = sf2_i16(data, dlen, byte_start + i * 2);
        vec_push(out, f64_div(f64_from(s), f64_from(32768)));
        i = i + 1;
    }
    return out;
}

# resolve one instrument bag: read igens, apply preset-range clamp, build a zone, add to inst_obj.
fn sf2_do_ibag(ibags, igens, shdrs, smpl_ptr, smpl_len, bank, inst_obj, ib, prange) {
    var igen_start = Sf2Bag_gen_index(vec_get(ibags, ib));
    var igen_end = vec_len(igens);
    if (ib + 1 < vec_len(ibags)) { igen_end = Sf2Bag_gen_index(vec_get(ibags, ib + 1)); }

    var sample_id = 0 - 1;
    var kr_lo = 0;
    var kr_hi = 127;
    var vr_lo = 0;
    var vr_hi = 127;
    var root_override = 0 - 1;
    var sample_modes = 0;

    var iglim = igen_end;
    if (vec_len(igens) < iglim) { iglim = vec_len(igens); }
    var ig = igen_start;
    while (ig < iglim) {
        var igr = vec_get(igens, ig);
        var ioper = Sf2Gen_oper(igr);
        var iamt = Sf2Gen_amount(igr);
        if (ioper == 53) { sample_id = iamt & 0xFFFF; }
        if (ioper == 43) { kr_lo = sf2_amt_lo(iamt); kr_hi = sf2_amt_hi(iamt); }
        if (ioper == 44) { vr_lo = sf2_amt_lo(iamt); vr_hi = sf2_amt_hi(iamt); }
        if (ioper == 58) { var k = iamt & 0xFF; if (k <= 127) { root_override = k; } }
        if (ioper == 54) { sample_modes = iamt & 0xFFFF; }
        ig = ig + 1;
    }

    if (sample_id < 0) { return 0; }
    var shdr_lim = vec_len(shdrs) - 1;
    if (shdr_lim < 0) { shdr_lim = 0; }
    if (sample_id >= shdr_lim) { return 0; }
    var shdr = vec_get(shdrs, sample_id);
    if ((Sf2Shdr_sample_type(shdr) & 0x8000) != 0) { return 0; }

    var root_key = Sf2Shdr_original_pitch(shdr);
    if (root_override >= 0) { root_key = root_override; }

    var lm = sample_modes & 3;
    var loop_mode = LOOP_ONESHOT;
    if (lm == 1) { loop_mode = LOOP_FORWARD; }
    if (lm == 2) { loop_mode = LOOP_FORWARD; }
    if (lm == 3) { loop_mode = LOOP_SUSTAIN; }

    var fk_lo = kr_lo;
    var fk_hi = kr_hi;
    if (Sf2PRange_have_pk(prange) == 1) {
        if (Sf2PRange_pk_lo(prange) > fk_lo) { fk_lo = Sf2PRange_pk_lo(prange); }
        if (Sf2PRange_pk_hi(prange) < fk_hi) { fk_hi = Sf2PRange_pk_hi(prange); }
    }
    var fv_lo = vr_lo;
    var fv_hi = vr_hi;
    if (Sf2PRange_have_pv(prange) == 1) {
        if (Sf2PRange_pv_lo(prange) > fv_lo) { fv_lo = Sf2PRange_pv_lo(prange); }
        if (Sf2PRange_pv_hi(prange) < fv_hi) { fv_hi = Sf2PRange_pv_hi(prange); }
    }

    var pcm = sf2_pcm16_to_f32(smpl_ptr, smpl_len, Sf2Shdr_start(shdr), Sf2Shdr_end(shdr));
    var sample = n_sample_from_mono(pcm, Sf2Shdr_sample_rate(shdr));
    sample = n_sample_with_name(sample, Sf2Shdr_name(shdr));
    var sid = n_sample_bank_add(bank, sample);

    var zone = n_zone_new(sid);
    zone = n_zone_with_key_range(zone, fk_lo, fk_hi);
    zone = n_zone_with_vel_range(zone, fv_lo, fv_hi);
    zone = n_zone_with_root_note(zone, root_key);
    if (loop_mode != LOOP_ONESHOT) {
        var ls = Sf2Shdr_loop_start(shdr) - Sf2Shdr_start(shdr);
        if (ls < 0) { ls = 0; }
        var le = Sf2Shdr_loop_end(shdr) - Sf2Shdr_start(shdr);
        if (le < 0) { le = 0; }
        zone = n_zone_with_loop(zone, loop_mode, ls, le);
    }
    n_instrument_add_zone(inst_obj, zone);
    return 0;
}

# resolve one preset bag: find the referenced instrument + preset ranges, walk its ibags.
fn sf2_do_pbag(pbags, pgens, insts, ibags, igens, shdrs, smpl_ptr, smpl_len, bank, inst_obj, bi) {
    var gen_start = Sf2Bag_gen_index(vec_get(pbags, bi));
    var gen_end = vec_len(pgens);
    if (bi + 1 < vec_len(pbags)) { gen_end = Sf2Bag_gen_index(vec_get(pbags, bi + 1)); }

    var inst_index = 0 - 1;
    var prange = alloc(sizeof(Sf2PRange));
    Sf2PRange_set_have_pk(prange, 0);
    Sf2PRange_set_have_pv(prange, 0);

    var glim = gen_end;
    if (vec_len(pgens) < glim) { glim = vec_len(pgens); }
    var g = gen_start;
    while (g < glim) {
        var pg = vec_get(pgens, g);
        var oper = Sf2Gen_oper(pg);
        var amt = Sf2Gen_amount(pg);
        if (oper == 41) { inst_index = amt & 0xFFFF; }
        if (oper == 43) {
            Sf2PRange_set_pk_lo(prange, sf2_amt_lo(amt));
            Sf2PRange_set_pk_hi(prange, sf2_amt_hi(amt));
            Sf2PRange_set_have_pk(prange, 1);
        }
        if (oper == 44) {
            Sf2PRange_set_pv_lo(prange, sf2_amt_lo(amt));
            Sf2PRange_set_pv_hi(prange, sf2_amt_hi(amt));
            Sf2PRange_set_have_pv(prange, 1);
        }
        g = g + 1;
    }

    if (inst_index < 0) { return 0; }
    var inst_lim = vec_len(insts) - 1;
    if (inst_lim < 0) { inst_lim = 0; }
    if (inst_index >= inst_lim) { return 0; }

    var inst_rec = vec_get(insts, inst_index);
    var ibag_start = Sf2Inst_bag_index(inst_rec);
    var ibag_end = Sf2Inst_bag_index(vec_get(insts, inst_index + 1));
    var ib = ibag_start;
    while (ib < ibag_end) {
        if (ib >= vec_len(ibags)) { return 0; }
        sf2_do_ibag(ibags, igens, shdrs, smpl_ptr, smpl_len, bank, inst_obj, ib, prange);
        ib = ib + 1;
    }
    return 0;
}

# resolve all presets -> instruments -> zones. Fills the presets/instruments vecs + bank.
fn sf2_resolve(phdrs, pbags, pgens, insts, ibags, igens, shdrs, smpl_ptr, smpl_len, presets, instruments, bank) {
    var ph_lim = vec_len(phdrs) - 1;
    if (ph_lim < 0) { ph_lim = 0; }
    var pi = 0;
    while (pi < ph_lim) {
        var phdr = vec_get(phdrs, pi);
        var bag_start = Sf2Phdr_bag_index(phdr);
        var bag_end = Sf2Phdr_bag_index(vec_get(phdrs, pi + 1));
        var inst_obj = n_instrument_new(Sf2Phdr_name(phdr));

        var bi = bag_start;
        var looping = 1;
        while (looping == 1) {
            if (bi >= bag_end) {
                looping = 0;
            } else {
                if (bi >= vec_len(pbags)) {
                    looping = 0;
                } else {
                    sf2_do_pbag(pbags, pgens, insts, ibags, igens, shdrs, smpl_ptr, smpl_len, bank, inst_obj, bi);
                    bi = bi + 1;
                }
            }
        }

        if (n_instrument_zone_count(inst_obj) > 0) {
            var preset = alloc(sizeof(Sf2Preset));
            Sf2Preset_set_name(preset, Sf2Phdr_name(phdr));
            Sf2Preset_set_bank(preset, Sf2Phdr_bank(phdr));
            Sf2Preset_set_preset_number(preset, Sf2Phdr_preset(phdr));
            vec_push(presets, preset);
            vec_push(instruments, inst_obj);
        }
        pi = pi + 1;
    }
    return 0;
}

# parse(data, len) -> Sf2Result pointer, or a negative error code.
#must_use
fn sf2_parse(data, len) {
    if (len < 12) { return 0 - 1; }
    if (sf2_fourcc(data, len, 0) != CC_RIFF) { return 0 - 2; }
    if (sf2_fourcc(data, len, 8) != CC_SFBK) { return 0 - 3; }

    var smpl_ptr = 0;
    var smpl_len = 0;
    var smpl_found = 0;
    var pdta_ptr = 0;
    var pdta_len = 0;
    var pdta_found = 0;

    # top-level chunk scan over data[12..]
    var off = 12;
    while (off + 8 <= len) {
        var cid = sf2_fourcc(data, len, off);
        var csize = sf2_u32(data, len, off + 4);
        var cdata_start = off + 8;
        var cdata_end = cdata_start + csize;
        if (cdata_end > len) { return 0 - 6; }
        if (cid == CC_LIST) {
            if (csize >= 4) {
                var list_type = sf2_fourcc(data, len, cdata_start);
                if (list_type == CC_SDTA) {
                    var soff = cdata_start + 4;
                    var subscan = 1;
                    while (subscan == 1) {
                        if (soff + 8 > cdata_end) {
                            subscan = 0;
                        } else {
                            var sid = sf2_fourcc(data, len, soff);
                            var ssize = sf2_u32(data, len, soff + 4);
                            var sdstart = soff + 8;
                            var sdend = sdstart + ssize;
                            if (sdend > cdata_end) {
                                return 0 - 6;
                            } else {
                                if (sid == CC_SMPL) {
                                    smpl_ptr = data + sdstart;
                                    smpl_len = ssize;
                                    smpl_found = 1;
                                }
                                soff = sdend + (ssize & 1);
                            }
                        }
                    }
                }
                if (list_type == CC_PDTA) {
                    pdta_ptr = data + cdata_start + 4;
                    pdta_len = csize - 4;
                    pdta_found = 1;
                }
            }
        }
        off = cdata_end + (csize & 1);
    }

    if (smpl_found == 0) { return 0 - 7; }
    if (pdta_found == 0) { return 0 - 8; }

    # pdta sub-chunk scan
    var phdr_ptr = 0; var phdr_len = 0; var phdr_found = 0;
    var pbag_ptr = 0; var pbag_len = 0; var pbag_found = 0;
    var pgen_ptr = 0; var pgen_len = 0; var pgen_found = 0;
    var inst_ptr = 0; var inst_len = 0; var inst_found = 0;
    var ibag_ptr = 0; var ibag_len = 0; var ibag_found = 0;
    var igen_ptr = 0; var igen_len = 0; var igen_found = 0;
    var shdr_ptr = 0; var shdr_len = 0; var shdr_found = 0;

    var poff = 0;
    while (poff + 8 <= pdta_len) {
        var pid = sf2_fourcc(pdta_ptr, pdta_len, poff);
        var psize = sf2_u32(pdta_ptr, pdta_len, poff + 4);
        var pdstart = poff + 8;
        var pdend = pdstart + psize;
        if (pdend > pdta_len) {
            return 0 - 6;
        } else {
            if (pid == CC_PHDR) { phdr_ptr = pdta_ptr + pdstart; phdr_len = psize; phdr_found = 1; }
            if (pid == CC_PBAG) { pbag_ptr = pdta_ptr + pdstart; pbag_len = psize; pbag_found = 1; }
            if (pid == CC_PGEN) { pgen_ptr = pdta_ptr + pdstart; pgen_len = psize; pgen_found = 1; }
            if (pid == CC_INST) { inst_ptr = pdta_ptr + pdstart; inst_len = psize; inst_found = 1; }
            if (pid == CC_IBAG) { ibag_ptr = pdta_ptr + pdstart; ibag_len = psize; ibag_found = 1; }
            if (pid == CC_IGEN) { igen_ptr = pdta_ptr + pdstart; igen_len = psize; igen_found = 1; }
            if (pid == CC_SHDR) { shdr_ptr = pdta_ptr + pdstart; shdr_len = psize; shdr_found = 1; }
            poff = pdend + (psize & 1);
        }
    }

    if (phdr_found == 0) { return 0 - 9; }
    if (pbag_found == 0) { return 0 - 10; }
    if (pgen_found == 0) { return 0 - 11; }
    if (inst_found == 0) { return 0 - 12; }
    if (ibag_found == 0) { return 0 - 13; }
    if (igen_found == 0) { return 0 - 14; }
    if (shdr_found == 0) { return 0 - 15; }

    var phdrs = sf2_parse_phdr(phdr_ptr, phdr_len);
    var pbags = sf2_parse_bag(pbag_ptr, pbag_len);
    var pgens = sf2_parse_gen(pgen_ptr, pgen_len);
    var insts = sf2_parse_inst(inst_ptr, inst_len);
    var ibags = sf2_parse_bag(ibag_ptr, ibag_len);
    var igens = sf2_parse_gen(igen_ptr, igen_len);
    var shdrs = sf2_parse_shdr(shdr_ptr, shdr_len);

    var presets = vec_new();
    var instruments = vec_new();
    var bank = n_sample_bank_new();
    sf2_resolve(phdrs, pbags, pgens, insts, ibags, igens, shdrs, smpl_ptr, smpl_len, presets, instruments, bank);

    var result = alloc(sizeof(Sf2Result));
    Sf2Result_set_presets(result, presets);
    Sf2Result_set_instruments(result, instruments);
    Sf2Result_set_bank(result, bank);
    return result;
}

# --- sfz.cyr ---

# sfz.cyr -- SFZ text parser (v1 + v2 subset)
# Requires: alloc, vec, str (str_*), string, math (f64_*, f64_parse_ok), byte ops (load8),
#           sample, zone (n_zone_*), instrument (n_instrument_*), envelope (n_adsr_config_from_seconds),
#           loop_mode (LOOP_*)
#
# Ports rust-old/src/sfz.rs. Line-based, whitespace-tokenized, key=value opcodes. Unknown opcodes
# and malformed tokens are silently ignored. Strings are stdlib Str objects. Option<String> ->
# null pointer (0 = None); Option<u8> -> -1 sentinel. parse is infallible (always returns a file).

var SFZ_HDR_NONE    = 0 - 1;
var SFZ_HDR_CONTROL = 0;
var SFZ_HDR_GLOBAL  = 1;
var SFZ_HDR_GROUP   = 2;
var SFZ_HDR_REGION  = 3;
var SFZ_HDR_CURVE   = 4;

# --- small helpers ---
#inline
fn sfz_is_ws(c) {
    if (c == 32) { return 1; }
    if (c == 9) { return 1; }
    if (c == 13) { return 1; }
    if (c == 10) { return 1; }
    return 0;
}

fn sfz_starts(s, cstr) {
    return str_starts_with(s, str_from(cstr));
}

# parse a signed decimal integer from a Str (Rust i32/i64 FromStr: optional leading +/-).
# Returns 1 + writes to out, or 0 (unparseable).
fn sfz_int(s, out) {
    var data = str_data(s);
    var len = str_len(s);
    if (len == 0) { return 0; }
    var i = 0;
    var neg = 0;
    var c0 = load8(data);
    if (c0 == 45) { neg = 1; i = 1; }
    if (c0 == 43) { i = 1; }
    var val = 0;
    var any = 0;
    while (i < len) {
        var c = load8(data + i);
        if (c < 48) { return 0; }
        if (c > 57) { return 0; }
        val = val * 10 + (c - 48);
        any = 1;
        i = i + 1;
    }
    if (any == 0) { return 0; }
    if (neg == 1) { val = 0 - val; }
    store64(out, val);
    return 1;
}

# parse an unsigned decimal integer (Rust u32/usize FromStr: optional leading +, rejects -).
fn sfz_uint(s, out) {
    var data = str_data(s);
    var len = str_len(s);
    if (len == 0) { return 0; }
    var i = 0;
    if (load8(data) == 43) { i = 1; }
    var val = 0;
    var any = 0;
    while (i < len) {
        var c = load8(data + i);
        if (c < 48) { return 0; }
        if (c > 57) { return 0; }
        val = val * 10 + (c - 48);
        any = 1;
        i = i + 1;
    }
    if (any == 0) { return 0; }
    store64(out, val);
    return 1;
}

# parse a u8 (Rust parse::<u8>: unsigned, 0..=255). Returns 0 (unparseable) if out of range.
fn sfz_u8(s, out) {
    if (sfz_uint(s, out) == 0) { return 0; }
    if (load64(out) > 255) { return 0; }
    return 1;
}

# parse a Str as f64. Returns 1 + writes bits to out, or 0.
fn sfz_f64(s, out) {
    return f64_parse_ok(str_cstr(s), out);
}

# strip a single leading/trailing double-quote from a Str (trim_matches('"')).
fn sfz_trim_quotes(s) {
    var len = str_len(s);
    var data = str_data(s);
    var start = 0;
    var end = len;
    if (end > start) { if (load8(data + start) == 34) { start = start + 1; } }
    if (end > start) { if (load8(data + end - 1) == 34) { end = end - 1; } }
    return str_substr(s, start, end);
}

# split a Str into a vec of line Strs (on '\n'; no trailing empty after a final newline).
fn sfz_lines(s) {
    var out = vec_new();
    var data = str_data(s);
    var len = str_len(s);
    var start = 0;
    var i = 0;
    while (i < len) {
        if (load8(data + i) == 10) {
            vec_push(out, str_new(data + start, i - start));
            start = i + 1;
        }
        i = i + 1;
    }
    if (start < len) { vec_push(out, str_new(data + start, len - start)); }
    return out;
}

# split a Str into a vec of token Strs on whitespace runs (no empties).
fn sfz_tokenize(s) {
    var out = vec_new();
    var data = str_data(s);
    var len = str_len(s);
    var i = 0;
    while (i < len) {
        if (sfz_is_ws(load8(data + i)) == 1) {
            i = i + 1;
        } else {
            var start = i;
            var scanning = 1;
            while (scanning == 1) {
                if (i >= len) { scanning = 0; }
                else { if (sfz_is_ws(load8(data + i)) == 1) { scanning = 0; } else { i = i + 1; } }
            }
            vec_push(out, str_new(data + start, i - start));
        }
    }
    return out;
}

# --- parse_note_or_number(s) -> MIDI 0..127, or -1 (None) ---
#must_use
fn n_sfz_note_or_num(value) {
    var out = alloc(8);
    if (sfz_int(value, out) == 1) {
        var v = load64(out);
        if (v >= 0) { if (v <= 255) { return v; } }
    }
    var data = str_data(value);
    var len = str_len(value);
    if (len == 0) { return 0 - 1; }
    var c0 = load8(data);
    if (c0 >= 65) { if (c0 <= 90) { c0 = c0 + 32; } }
    var base = 0 - 1;
    if (c0 == 99) { base = 0; }
    if (c0 == 100) { base = 2; }
    if (c0 == 101) { base = 4; }
    if (c0 == 102) { base = 5; }
    if (c0 == 103) { base = 7; }
    if (c0 == 97) { base = 9; }
    if (c0 == 98) { base = 11; }
    if (base < 0) { return 0 - 1; }
    var idx = 1;
    var accidental = 0;
    if (idx < len) {
        var c1 = load8(data + idx);
        if (c1 == 35) { accidental = 1; idx = idx + 1; }
        else {
            if (c1 == 115) { accidental = 1; idx = idx + 1; }
            else {
                if (c1 == 98) {
                    if (idx + 1 < len) {
                        var c2 = load8(data + idx + 1);
                        if (c2 >= 48) { if (c2 <= 57) { accidental = 0 - 1; idx = idx + 1; } }
                    }
                }
            }
        }
    }
    var octave_str = str_substr(value, idx, len);
    if (sfz_int(octave_str, out) == 0) { return 0 - 1; }
    var octave = load64(out);
    var midi = (octave + 1) * 12 + base + accidental;
    if (midi < 0) { return 0 - 1; }
    if (midi > 127) { return 0 - 1; }
    return midi;
}

# --- SfzRegion (37 fields) ---
#derive(accessors)
struct NSfzRegion {
    sample;
    lokey;
    hikey;
    lovel;
    hivel;
    pitch_keycenter;
    tune;
    volume;
    pan;
    loop_mode;
    loop_start;
    loop_end;
    group;
    ampeg_attack;
    ampeg_decay;
    ampeg_sustain;
    ampeg_release;
    cutoff;
    fil_veltrack;
    fileg_attack;
    fileg_decay;
    fileg_sustain;
    fileg_release;
    fileg_depth;
    transpose;
    offset;
    end;
    resonance;
    fil_type;
    key;
    pitchlfo_freq;
    pitchlfo_depth;
    fillfo_freq;
    fillfo_depth;
    fil_keytrack;
    output;
    cc_modulations;
}

# a cc modulation entry: (param Str, cc int, depth f64)
#derive(accessors)
struct NSfzCC { param; cc; depth; }

#must_use
fn n_sfz_region_new() {
    var r = alloc(sizeof(NSfzRegion));
    var f100 = f64_from(100);
    NSfzRegion_set_sample(r, 0);
    NSfzRegion_set_lokey(r, 0);
    NSfzRegion_set_hikey(r, 127);
    NSfzRegion_set_lovel(r, 1);
    NSfzRegion_set_hivel(r, 127);
    NSfzRegion_set_pitch_keycenter(r, 60);
    NSfzRegion_set_tune(r, 0);
    NSfzRegion_set_volume(r, 0);
    NSfzRegion_set_pan(r, 0);
    NSfzRegion_set_loop_mode(r, 0);
    NSfzRegion_set_loop_start(r, 0);
    NSfzRegion_set_loop_end(r, 0);
    NSfzRegion_set_group(r, 0);
    NSfzRegion_set_ampeg_attack(r, 0);
    NSfzRegion_set_ampeg_decay(r, 0);
    NSfzRegion_set_ampeg_sustain(r, f100);
    NSfzRegion_set_ampeg_release(r, 0);
    NSfzRegion_set_cutoff(r, 0);
    NSfzRegion_set_fil_veltrack(r, 0);
    NSfzRegion_set_fileg_attack(r, 0);
    NSfzRegion_set_fileg_decay(r, 0);
    NSfzRegion_set_fileg_sustain(r, f100);
    NSfzRegion_set_fileg_release(r, 0);
    NSfzRegion_set_fileg_depth(r, 0);
    NSfzRegion_set_transpose(r, 0);
    NSfzRegion_set_offset(r, 0);
    NSfzRegion_set_end(r, 0);
    NSfzRegion_set_resonance(r, 0);
    NSfzRegion_set_fil_type(r, 0);
    NSfzRegion_set_key(r, 0 - 1);
    NSfzRegion_set_pitchlfo_freq(r, 0);
    NSfzRegion_set_pitchlfo_depth(r, 0);
    NSfzRegion_set_fillfo_freq(r, 0);
    NSfzRegion_set_fillfo_depth(r, 0);
    NSfzRegion_set_fil_keytrack(r, 0);
    NSfzRegion_set_output(r, 0);
    NSfzRegion_set_cc_modulations(r, vec_new());
    return r;
}

# apply one opcode (key, value are Str). Numeric parse failure leaves the field unchanged.
fn n_sfz_apply_opcode(r, key, value) {
    var o = alloc(8);
    if (str_eq_cstr(key, "sample") == 1) { NSfzRegion_set_sample(r, value); return 0; }
    if (str_eq_cstr(key, "lokey") == 1) { var n = n_sfz_note_or_num(value); if (n >= 0) { NSfzRegion_set_lokey(r, n); } return 0; }
    if (str_eq_cstr(key, "hikey") == 1) { var n = n_sfz_note_or_num(value); if (n >= 0) { NSfzRegion_set_hikey(r, n); } return 0; }
    if (str_eq_cstr(key, "key") == 1) { var n = n_sfz_note_or_num(value); if (n >= 0) { NSfzRegion_set_key(r, n); } return 0; }
    if (str_eq_cstr(key, "lovel") == 1) { if (sfz_u8(value, o) == 1) { NSfzRegion_set_lovel(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "hivel") == 1) { if (sfz_u8(value, o) == 1) { NSfzRegion_set_hivel(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "pitch_keycenter") == 1) { var n = n_sfz_note_or_num(value); if (n >= 0) { NSfzRegion_set_pitch_keycenter(r, n); } return 0; }
    if (str_eq_cstr(key, "tune") == 1) { if (sfz_int(value, o) == 1) { NSfzRegion_set_tune(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "volume") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_volume(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "pan") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_pan(r, f64_min(f64_max(load64(o), f64_neg(f64_from(100))), f64_from(100))); } return 0; }
    if (str_eq_cstr(key, "loop_mode") == 1) { NSfzRegion_set_loop_mode(r, value); return 0; }
    if (str_eq_cstr(key, "loopmode") == 1) { NSfzRegion_set_loop_mode(r, value); return 0; }
    if (str_eq_cstr(key, "loop_start") == 1) { if (sfz_uint(value, o) == 1) { NSfzRegion_set_loop_start(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "loopstart") == 1) { if (sfz_uint(value, o) == 1) { NSfzRegion_set_loop_start(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "loop_end") == 1) { if (sfz_uint(value, o) == 1) { NSfzRegion_set_loop_end(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "loopend") == 1) { if (sfz_uint(value, o) == 1) { NSfzRegion_set_loop_end(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "seq_position") == 1) { if (sfz_uint(value, o) == 1) { NSfzRegion_set_group(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "group") == 1) { if (sfz_uint(value, o) == 1) { NSfzRegion_set_group(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "ampeg_attack") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_ampeg_attack(r, f64_max(load64(o), 0)); } return 0; }
    if (str_eq_cstr(key, "ampeg_decay") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_ampeg_decay(r, f64_max(load64(o), 0)); } return 0; }
    if (str_eq_cstr(key, "ampeg_sustain") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_ampeg_sustain(r, f64_min(f64_max(load64(o), 0), f64_from(100))); } return 0; }
    if (str_eq_cstr(key, "ampeg_release") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_ampeg_release(r, f64_max(load64(o), 0)); } return 0; }
    if (str_eq_cstr(key, "cutoff") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_cutoff(r, f64_max(load64(o), 0)); } return 0; }
    if (str_eq_cstr(key, "fil_veltrack") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_fil_veltrack(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "fileg_attack") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_fileg_attack(r, f64_max(load64(o), 0)); } return 0; }
    if (str_eq_cstr(key, "fileg_decay") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_fileg_decay(r, f64_max(load64(o), 0)); } return 0; }
    if (str_eq_cstr(key, "fileg_sustain") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_fileg_sustain(r, f64_min(f64_max(load64(o), 0), f64_from(100))); } return 0; }
    if (str_eq_cstr(key, "fileg_release") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_fileg_release(r, f64_max(load64(o), 0)); } return 0; }
    if (str_eq_cstr(key, "fileg_depth") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_fileg_depth(r, f64_min(f64_max(load64(o), f64_neg(f64_from(9600))), f64_from(9600))); } return 0; }
    if (str_eq_cstr(key, "transpose") == 1) { if (sfz_int(value, o) == 1) { NSfzRegion_set_transpose(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "offset") == 1) { if (sfz_uint(value, o) == 1) { NSfzRegion_set_offset(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "end") == 1) { if (sfz_uint(value, o) == 1) { NSfzRegion_set_end(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "resonance") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_resonance(r, f64_max(load64(o), 0)); } return 0; }
    if (str_eq_cstr(key, "fil_resonance") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_resonance(r, f64_max(load64(o), 0)); } return 0; }
    if (str_eq_cstr(key, "fil_type") == 1) { NSfzRegion_set_fil_type(r, value); return 0; }
    if (str_eq_cstr(key, "filtype") == 1) { NSfzRegion_set_fil_type(r, value); return 0; }
    if (str_eq_cstr(key, "pitchlfo_freq") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_pitchlfo_freq(r, f64_max(load64(o), 0)); } return 0; }
    if (str_eq_cstr(key, "pitchlfo_depth") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_pitchlfo_depth(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "fillfo_freq") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_fillfo_freq(r, f64_max(load64(o), 0)); } return 0; }
    if (str_eq_cstr(key, "fillfo_depth") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_fillfo_depth(r, load64(o)); } return 0; }
    if (str_eq_cstr(key, "fil_keytrack") == 1) { if (sfz_f64(value, o) == 1) { NSfzRegion_set_fil_keytrack(r, f64_min(f64_max(load64(o), 0), f64_from(1200))); } return 0; }
    if (str_eq_cstr(key, "output") == 1) { if (sfz_u8(value, o) == 1) { NSfzRegion_set_output(r, load64(o)); } return 0; }

    # CC modulation fallback: key contains "_oncc"
    var pos = str_index_of_cstr(key, "_oncc");
    if (pos >= 0) {
        var param = str_substr(key, 0, pos);
        var cc_str = str_substr(key, pos + 5, str_len(key));
        var cc_out = alloc(8);
        if (sfz_u8(cc_str, cc_out) == 1) {
            if (sfz_f64(value, o) == 1) {
                var m = alloc(sizeof(NSfzCC));
                NSfzCC_set_param(m, param);
                NSfzCC_set_cc(m, load64(cc_out));
                NSfzCC_set_depth(m, load64(o));
                vec_push(NSfzRegion_cc_modulations(r), m);
            }
        }
        return 0;
    }
    return 0;
}

# inherit a numeric field from parent when self is at `def` and parent differs.
#inline
fn sfz_inh(self_v, parent_v, def) {
    if (self_v == def) { if (parent_v != def) { return parent_v; } }
    return self_v;
}

# inherit_from(parent): global->group->region. Self keeps any non-default it already has.
fn n_sfz_inherit_from(self, parent) {
    var f100 = f64_from(100);
    # Option/pointer fields
    if (NSfzRegion_sample(self) == 0) { NSfzRegion_set_sample(self, NSfzRegion_sample(parent)); }
    if (NSfzRegion_loop_mode(self) == 0) { NSfzRegion_set_loop_mode(self, NSfzRegion_loop_mode(parent)); }
    if (NSfzRegion_fil_type(self) == 0) { NSfzRegion_set_fil_type(self, NSfzRegion_fil_type(parent)); }
    if (NSfzRegion_key(self) < 0) { NSfzRegion_set_key(self, NSfzRegion_key(parent)); }
    if (vec_len(NSfzRegion_cc_modulations(self)) == 0) {
        if (vec_len(NSfzRegion_cc_modulations(parent)) > 0) {
            NSfzRegion_set_cc_modulations(self, NSfzRegion_cc_modulations(parent));
        }
    }
    # numeric fields
    NSfzRegion_set_lokey(self, sfz_inh(NSfzRegion_lokey(self), NSfzRegion_lokey(parent), 0));
    NSfzRegion_set_hikey(self, sfz_inh(NSfzRegion_hikey(self), NSfzRegion_hikey(parent), 127));
    NSfzRegion_set_lovel(self, sfz_inh(NSfzRegion_lovel(self), NSfzRegion_lovel(parent), 1));
    NSfzRegion_set_hivel(self, sfz_inh(NSfzRegion_hivel(self), NSfzRegion_hivel(parent), 127));
    NSfzRegion_set_pitch_keycenter(self, sfz_inh(NSfzRegion_pitch_keycenter(self), NSfzRegion_pitch_keycenter(parent), 60));
    NSfzRegion_set_tune(self, sfz_inh(NSfzRegion_tune(self), NSfzRegion_tune(parent), 0));
    NSfzRegion_set_volume(self, sfz_inh(NSfzRegion_volume(self), NSfzRegion_volume(parent), 0));
    NSfzRegion_set_pan(self, sfz_inh(NSfzRegion_pan(self), NSfzRegion_pan(parent), 0));
    NSfzRegion_set_loop_start(self, sfz_inh(NSfzRegion_loop_start(self), NSfzRegion_loop_start(parent), 0));
    NSfzRegion_set_loop_end(self, sfz_inh(NSfzRegion_loop_end(self), NSfzRegion_loop_end(parent), 0));
    NSfzRegion_set_group(self, sfz_inh(NSfzRegion_group(self), NSfzRegion_group(parent), 0));
    NSfzRegion_set_ampeg_attack(self, sfz_inh(NSfzRegion_ampeg_attack(self), NSfzRegion_ampeg_attack(parent), 0));
    NSfzRegion_set_ampeg_decay(self, sfz_inh(NSfzRegion_ampeg_decay(self), NSfzRegion_ampeg_decay(parent), 0));
    NSfzRegion_set_ampeg_sustain(self, sfz_inh(NSfzRegion_ampeg_sustain(self), NSfzRegion_ampeg_sustain(parent), f100));
    NSfzRegion_set_ampeg_release(self, sfz_inh(NSfzRegion_ampeg_release(self), NSfzRegion_ampeg_release(parent), 0));
    NSfzRegion_set_cutoff(self, sfz_inh(NSfzRegion_cutoff(self), NSfzRegion_cutoff(parent), 0));
    NSfzRegion_set_fil_veltrack(self, sfz_inh(NSfzRegion_fil_veltrack(self), NSfzRegion_fil_veltrack(parent), 0));
    NSfzRegion_set_fileg_attack(self, sfz_inh(NSfzRegion_fileg_attack(self), NSfzRegion_fileg_attack(parent), 0));
    NSfzRegion_set_fileg_decay(self, sfz_inh(NSfzRegion_fileg_decay(self), NSfzRegion_fileg_decay(parent), 0));
    NSfzRegion_set_fileg_sustain(self, sfz_inh(NSfzRegion_fileg_sustain(self), NSfzRegion_fileg_sustain(parent), f100));
    NSfzRegion_set_fileg_release(self, sfz_inh(NSfzRegion_fileg_release(self), NSfzRegion_fileg_release(parent), 0));
    NSfzRegion_set_fileg_depth(self, sfz_inh(NSfzRegion_fileg_depth(self), NSfzRegion_fileg_depth(parent), 0));
    NSfzRegion_set_transpose(self, sfz_inh(NSfzRegion_transpose(self), NSfzRegion_transpose(parent), 0));
    NSfzRegion_set_offset(self, sfz_inh(NSfzRegion_offset(self), NSfzRegion_offset(parent), 0));
    NSfzRegion_set_end(self, sfz_inh(NSfzRegion_end(self), NSfzRegion_end(parent), 0));
    NSfzRegion_set_resonance(self, sfz_inh(NSfzRegion_resonance(self), NSfzRegion_resonance(parent), 0));
    NSfzRegion_set_pitchlfo_freq(self, sfz_inh(NSfzRegion_pitchlfo_freq(self), NSfzRegion_pitchlfo_freq(parent), 0));
    NSfzRegion_set_pitchlfo_depth(self, sfz_inh(NSfzRegion_pitchlfo_depth(self), NSfzRegion_pitchlfo_depth(parent), 0));
    NSfzRegion_set_fillfo_freq(self, sfz_inh(NSfzRegion_fillfo_freq(self), NSfzRegion_fillfo_freq(parent), 0));
    NSfzRegion_set_fillfo_depth(self, sfz_inh(NSfzRegion_fillfo_depth(self), NSfzRegion_fillfo_depth(parent), 0));
    NSfzRegion_set_fil_keytrack(self, sfz_inh(NSfzRegion_fil_keytrack(self), NSfzRegion_fil_keytrack(parent), 0));
    NSfzRegion_set_output(self, sfz_inh(NSfzRegion_output(self), NSfzRegion_output(parent), 0));
    return 0;
}

# --- SfzFile ---
#derive(accessors)
struct NSfzFile { global; groups; regions; group_indices; default_path; includes; }

fn n_sfz_parse_header(token) {
    var len = str_len(token);
    if (len < 2) { return SFZ_HDR_NONE; }
    var data = str_data(token);
    if (load8(data) != 60) { return SFZ_HDR_NONE; }
    if (load8(data + len - 1) != 62) { return SFZ_HDR_NONE; }
    var inner = str_substr(token, 1, len - 1);
    if (str_eq_cstr(inner, "control") == 1) { return SFZ_HDR_CONTROL; }
    if (str_eq_cstr(inner, "global") == 1) { return SFZ_HDR_GLOBAL; }
    if (str_eq_cstr(inner, "group") == 1) { return SFZ_HDR_GROUP; }
    if (str_eq_cstr(inner, "region") == 1) { return SFZ_HDR_REGION; }
    if (str_eq_cstr(inner, "curve") == 1) { return SFZ_HDR_CURVE; }
    return SFZ_HDR_NONE;
}

# parse(input_cstr) -> NSfzFile pointer (never fails).
#must_use
fn n_sfz_parse(input_cstr) {
    var input = str_from(input_cstr);
    var global = n_sfz_region_new();
    var groups = vec_new();
    var regions = vec_new();
    var group_indices = vec_new();
    var default_path = 0;
    var includes = vec_new();
    var current_header = SFZ_HDR_NONE;
    var current_group_idx = 0 - 1;

    var lines = sfz_lines(input);
    var nl = vec_len(lines);
    var li = 0;
    while (li < nl) {
        var line = str_trim(vec_get(lines, li));
        li = li + 1;
        if (str_len(line) == 0) {
            # skip
        } else {
            if (sfz_starts(line, "//") == 1) {
                # comment, skip
            } else {
                if (sfz_starts(line, "#include") == 1) {
                    var rest = sfz_trim_quotes(str_trim(str_substr(line, 8, str_len(line))));
                    if (str_len(rest) > 0) { vec_push(includes, rest); }
                } else {
                    var tokens = sfz_tokenize(line);
                    var nt = vec_len(tokens);
                    var ti = 0;
                    while (ti < nt) {
                        var token = vec_get(tokens, ti);
                        ti = ti + 1;
                        var hk = n_sfz_parse_header(token);
                        if (hk != SFZ_HDR_NONE) {
                            current_header = hk;
                            if (hk == SFZ_HDR_GROUP) {
                                vec_push(groups, n_sfz_region_new());
                                current_group_idx = vec_len(groups) - 1;
                            }
                            if (hk == SFZ_HDR_REGION) {
                                vec_push(regions, n_sfz_region_new());
                                vec_push(group_indices, current_group_idx);
                            }
                        } else {
                            var eq = str_index_of(token, 61);
                            if (eq > 0) {
                                var k = str_substr(token, 0, eq);
                                var v = str_substr(token, eq + 1, str_len(token));
                                if (str_len(k) > 0) {
                                    if (str_len(v) > 0) {
                                        if (current_header == SFZ_HDR_CONTROL) {
                                            if (str_eq_cstr(k, "default_path") == 1) { default_path = v; }
                                        } else {
                                            if (current_header == SFZ_HDR_GLOBAL) { n_sfz_apply_opcode(global, k, v); }
                                            else {
                                                if (current_header == SFZ_HDR_GROUP) { n_sfz_apply_opcode(vec_get(groups, vec_len(groups) - 1), k, v); }
                                                else {
                                                    if (current_header == SFZ_HDR_REGION) { n_sfz_apply_opcode(vec_get(regions, vec_len(regions) - 1), k, v); }
                                                    else {
                                                        if (current_header == SFZ_HDR_NONE) { n_sfz_apply_opcode(global, k, v); }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    var f = alloc(sizeof(NSfzFile));
    NSfzFile_set_global(f, global);
    NSfzFile_set_groups(f, groups);
    NSfzFile_set_regions(f, regions);
    NSfzFile_set_group_indices(f, group_indices);
    NSfzFile_set_default_path(f, default_path);
    NSfzFile_set_includes(f, includes);
    return f;
}

# --- mapping helpers ---
#must_use
fn n_sfz_map_loop_mode(s) {
    if (s == 0) { return LOOP_ONESHOT; }
    if (str_eq_cstr(s, "loop_continuous") == 1) { return LOOP_FORWARD; }
    if (str_eq_cstr(s, "loop_sustain") == 1) { return LOOP_SUSTAIN; }
    return LOOP_ONESHOT;
}

#must_use
fn n_sfz_map_fil_type(s) {
    if (s == 0) { return FILTER_LOWPASS; }
    if (str_eq_cstr(s, "hpf_1p") == 1) { return FILTER_HIGHPASS; }
    if (str_eq_cstr(s, "hpf_2p") == 1) { return FILTER_HIGHPASS; }
    if (str_eq_cstr(s, "bpf_2p") == 1) { return FILTER_BANDPASS; }
    if (str_eq_cstr(s, "brf_2p") == 1) { return FILTER_NOTCH; }
    return FILTER_LOWPASS;
}

# map_fil_veltrack(cents) = clamp(cents / 9600, 0, 1)
#must_use
fn n_sfz_map_fil_veltrack(cents) {
    return f64_min(f64_max(f64_div(cents, f64_from(9600)), 0), F64_ONE);
}

# a (zone, filename) pair produced by to_zones
#derive(accessors)
struct NSfzZoneFile { zone; filename; }

# to_zones(sfzfile, sample_rate f64 bits) -> vec of NSfzZoneFile.
#must_use
fn n_sfz_to_zones(f, sample_rate) {
    var out = vec_new();
    var regions = NSfzFile_regions(f);
    var groups = NSfzFile_groups(f);
    var group_indices = NSfzFile_group_indices(f);
    var global = NSfzFile_global(f);
    var default_path = NSfzFile_default_path(f);
    var nreg = vec_len(regions);
    var i = 0;
    while (i < nreg) {
        # merged = clone of region (shallow copy of the struct fields is enough here)
        var merged = n_sfz_clone_region(vec_get(regions, i));
        var gi = vec_get(group_indices, i);
        if (gi >= 0) {
            if (gi < vec_len(groups)) { n_sfz_inherit_from(merged, vec_get(groups, gi)); }
        }
        n_sfz_inherit_from(merged, global);

        # key shorthand
        var kk = NSfzRegion_key(merged);
        if (kk >= 0) {
            if (NSfzRegion_lokey(merged) == 0) { if (NSfzRegion_hikey(merged) == 127) { NSfzRegion_set_lokey(merged, kk); NSfzRegion_set_hikey(merged, kk); } }
            if (NSfzRegion_pitch_keycenter(merged) == 60) { NSfzRegion_set_pitch_keycenter(merged, kk); }
        }

        var samp = NSfzRegion_sample(merged);
        if (samp == 0) {
            # no sample -> skip region
        } else {
            var filename = samp;
            if (default_path != 0) {
                if (str_starts_with(filename, default_path) == 0) {
                    filename = str_cat(default_path, filename);
                }
            }
            # tune_cents = tune + transpose * 100
            var tune_cents = f64_add(f64_from(NSfzRegion_tune(merged)), f64_mul(f64_from(NSfzRegion_transpose(merged)), f64_from(100)));
            var filter_type = n_sfz_map_fil_type(NSfzRegion_fil_type(merged));

            var zone = n_zone_new(i);
            zone = n_zone_with_key_range(zone, NSfzRegion_lokey(merged), NSfzRegion_hikey(merged));
            zone = n_zone_with_vel_range(zone, NSfzRegion_lovel(merged), NSfzRegion_hivel(merged));
            zone = n_zone_with_root_note(zone, NSfzRegion_pitch_keycenter(merged));
            zone = n_zone_with_tune(zone, tune_cents);
            zone = n_zone_with_volume(zone, NSfzRegion_volume(merged));
            zone = n_zone_with_pan(zone, f64_div(NSfzRegion_pan(merged), f64_from(100)));
            zone = n_zone_with_loop(zone, n_sfz_map_loop_mode(NSfzRegion_loop_mode(merged)), NSfzRegion_loop_start(merged), NSfzRegion_loop_end(merged));
            zone = n_zone_with_filter(zone, NSfzRegion_cutoff(merged), n_sfz_map_fil_veltrack(NSfzRegion_fil_veltrack(merged)));
            zone = n_zone_with_filter_type(zone, filter_type);
            zone = n_zone_with_group(zone, NSfzRegion_group(merged));

            if (f64_gt(NSfzRegion_resonance(merged), 0) == 1) { zone = n_zone_with_filter_resonance(zone, NSfzRegion_resonance(merged)); }
            if (NSfzRegion_offset(merged) > 0) { zone = n_zone_with_sample_offset(zone, NSfzRegion_offset(merged)); }
            if (NSfzRegion_end(merged) > 0) { zone = n_zone_with_sample_end(zone, NSfzRegion_end(merged)); }

            # ampeg
            var f100 = f64_from(100);
            var has_ampeg = 0;
            if (NSfzRegion_ampeg_attack(merged) != 0) { has_ampeg = 1; }
            if (NSfzRegion_ampeg_decay(merged) != 0) { has_ampeg = 1; }
            if (NSfzRegion_ampeg_sustain(merged) != f100) { has_ampeg = 1; }
            if (NSfzRegion_ampeg_release(merged) != 0) { has_ampeg = 1; }
            if (has_ampeg == 1) {
                var adsr = n_adsr_config_from_seconds(NSfzRegion_ampeg_attack(merged), NSfzRegion_ampeg_decay(merged), f64_div(NSfzRegion_ampeg_sustain(merged), f100), NSfzRegion_ampeg_release(merged), sample_rate);
                zone = n_zone_with_adsr(zone, adsr);
            }
            # fileg
            var has_fileg = 0;
            if (NSfzRegion_fileg_depth(merged) != 0) { has_fileg = 1; }
            if (NSfzRegion_fileg_attack(merged) != 0) { has_fileg = 1; }
            if (NSfzRegion_fileg_decay(merged) != 0) { has_fileg = 1; }
            if (NSfzRegion_fileg_sustain(merged) != f100) { has_fileg = 1; }
            if (NSfzRegion_fileg_release(merged) != 0) { has_fileg = 1; }
            if (has_fileg == 1) {
                var fileg = n_adsr_config_from_seconds(NSfzRegion_fileg_attack(merged), NSfzRegion_fileg_decay(merged), f64_div(NSfzRegion_fileg_sustain(merged), f100), NSfzRegion_fileg_release(merged), sample_rate);
                zone = n_zone_with_filter_envelope(zone, fileg, NSfzRegion_fileg_depth(merged));
            }
            # LFOs
            if (f64_gt(NSfzRegion_pitchlfo_freq(merged), 0) == 1) { if (NSfzRegion_pitchlfo_depth(merged) != 0) { zone = n_zone_with_pitch_lfo(zone, NSfzRegion_pitchlfo_freq(merged), NSfzRegion_pitchlfo_depth(merged)); } }
            if (f64_gt(NSfzRegion_fillfo_freq(merged), 0) == 1) { if (NSfzRegion_fillfo_depth(merged) != 0) { zone = n_zone_with_filter_lfo(zone, NSfzRegion_fillfo_freq(merged), NSfzRegion_fillfo_depth(merged)); } }
            if (f64_gt(NSfzRegion_fil_keytrack(merged), 0) == 1) { zone = n_zone_with_key_tracking(zone, f64_div(NSfzRegion_fil_keytrack(merged), f64_from(1200))); }
            if (NSfzRegion_output(merged) > 0) { zone = n_zone_with_output_bus(zone, NSfzRegion_output(merged)); }

            var pair = alloc(sizeof(NSfzZoneFile));
            NSfzZoneFile_set_zone(pair, zone);
            NSfzZoneFile_set_filename(pair, filename);
            vec_push(out, pair);
        }
        i = i + 1;
    }
    return out;
}

# shallow clone of a region (copy every slot; the cc_modulations vec is shared by reference,
# matching how to_zones only reads it).
#must_use
fn n_sfz_clone_region(src) {
    var r = alloc(sizeof(NSfzRegion));
    var n = sizeof(NSfzRegion) / 8;
    var i = 0;
    while (i < n) {
        store64(r + i * 8, load64(src + i * 8));
        i = i + 1;
    }
    return r;
}

# a (instrument, sample_files) result
#derive(accessors)
struct NSfzInstResult { instrument; sample_files; }

# to_instrument(name, sample_rate) -> NSfzInstResult. Dedups filenames -> sequential SampleIds.
#must_use
fn n_sfz_to_instrument(f, name, sample_rate) {
    var pairs = n_sfz_to_zones(f, sample_rate);
    var inst = n_instrument_new(name);
    var sample_files = vec_new();
    var np = vec_len(pairs);
    var i = 0;
    while (i < np) {
        var pair = vec_get(pairs, i);
        var zone = NSfzZoneFile_zone(pair);
        var filename = NSfzZoneFile_filename(pair);
        # find filename in sample_files (string equality)
        var idx = 0 - 1;
        var nf = vec_len(sample_files);
        var j = 0;
        while (j < nf) {
            if (str_eq(vec_get(sample_files, j), filename) == 1) { idx = j; j = nf; }
            else { j = j + 1; }
        }
        if (idx < 0) {
            vec_push(sample_files, filename);
            idx = vec_len(sample_files) - 1;
        }
        NZone_set_sample_id(zone, idx);
        n_instrument_add_zone(inst, zone);
        i = i + 1;
    }
    var res = alloc(sizeof(NSfzInstResult));
    NSfzInstResult_set_instrument(res, inst);
    NSfzInstResult_set_sample_files(res, sample_files);
    return res;
}

# --- engine.cyr ---

# engine.cyr -- SamplerEngine: voice management + per-sample render loop
# Requires: alloc, vec, math (f64_*, f64_pow, f64_floor), sample, zone, instrument, envelope,
#           loop_mode, naad (filter_svf_*, SvfOutput_*, modulation_lfo_*, smoothing_*,
#           voice_manager_*, POLY_MODE_*, STEAL_MODE_*, MODULATION_LFO_SINE, naad_is_err)
#
# Ports rust-old/src/engine.rs (std path). "Use naad fully": the SVF filter, LFOs, cutoff
# smoother, and VoiceManager are naad's own. The engine never ticks the VoiceManager, so naad
# ages stay 0 -> Oldest steals the highest active index -- exactly the Rust parity behavior.
# Options -> null pointer (0) / -1 sentinel. All f32 -> f64. fill_buffer_stereo is rendered
# per-frame (output-identical to the Rust per-voice block render).

# PolyMode / StealMode: reuse naad's constants (POLY_MODE_POLY=0/MONO=1/LEGATO=2,
# STEAL_MODE_OLDEST=0/QUIETEST=1/LOWEST=2/NONE=3).

# --- VoiceFilter: stereo pair of naad SVFs ---
#derive(accessors)
struct NVoiceFilter { active; last_cutoff; filter_l; filter_r; mode; }

#must_use
fn nvf_bypass() {
    var vf = alloc(sizeof(NVoiceFilter));
    NVoiceFilter_set_active(vf, 0);
    NVoiceFilter_set_last_cutoff(vf, 0);
    NVoiceFilter_set_filter_l(vf, 0);
    NVoiceFilter_set_filter_r(vf, 0);
    NVoiceFilter_set_mode(vf, FILTER_LOWPASS);
    return vf;
}

#must_use
fn nvf_new(cutoff, resonance, mode, vel_track, velocity, sample_rate) {
    if (f64_le(cutoff, 0) == 1) { return nvf_bypass(); }
    var vel_norm = f64_div(f64_from(velocity), f64_from(127));
    var ec = f64_mul(cutoff, f64_sub(F64_ONE, f64_mul(vel_track, f64_sub(F64_ONE, vel_norm))));
    var hi = f64_mul(sample_rate, f64_div(f64_from(49), f64_from(100)));
    ec = f64_min(f64_max(ec, f64_from(20)), hi);
    var q = f64_max(resonance, f64_div(F64_ONE, f64_from(10)));
    var fl = filter_svf_new(ec, q, sample_rate);
    if (naad_is_err(fl) == 1) { fl = 0; }
    var fr = filter_svf_new(ec, q, sample_rate);
    if (naad_is_err(fr) == 1) { fr = 0; }
    var vf = alloc(sizeof(NVoiceFilter));
    var active = 0;
    if (fl != 0) { active = 1; }
    NVoiceFilter_set_active(vf, active);
    NVoiceFilter_set_last_cutoff(vf, ec);
    NVoiceFilter_set_filter_l(vf, fl);
    NVoiceFilter_set_filter_r(vf, fr);
    NVoiceFilter_set_mode(vf, mode);
    return vf;
}

#inline
fn nvf_pick(svfout, mode) {
    if (mode == FILTER_HIGHPASS) { return SvfOutput_high_pass(svfout); }
    if (mode == FILTER_BANDPASS) { return SvfOutput_band_pass(svfout); }
    if (mode == FILTER_NOTCH) { return SvfOutput_notch(svfout); }
    return SvfOutput_low_pass(svfout);
}

fn nvf_set_cutoff(vf, cutoff, sample_rate) {
    if (NVoiceFilter_active(vf) == 0) { return 0; }
    var hi = f64_mul(sample_rate, f64_div(f64_from(49), f64_from(100)));
    var c = f64_min(f64_max(cutoff, f64_from(20)), hi);
    if (f64_lt(f64_abs(f64_sub(c, NVoiceFilter_last_cutoff(vf))), f64_div(F64_ONE, f64_from(2))) == 1) { return 0; }
    NVoiceFilter_set_last_cutoff(vf, c);
    var fl = NVoiceFilter_filter_l(vf);
    if (fl != 0) { filter_svf_set_params(fl, c, filter_svf_q(fl)); }
    var fr = NVoiceFilter_filter_r(vf);
    if (fr != 0) { filter_svf_set_params(fr, c, filter_svf_q(fr)); }
    return 0;
}

fn nvf_process_stereo(vf, left, right, out2) {
    if (NVoiceFilter_active(vf) == 0) { store64(out2, left); store64(out2 + 8, right); return 0; }
    var mode = NVoiceFilter_mode(vf);
    var l = left;
    var fl = NVoiceFilter_filter_l(vf);
    if (fl != 0) { l = nvf_pick(filter_svf_process_sample(fl, left), mode); }
    var r = right;
    var fr = NVoiceFilter_filter_r(vf);
    if (fr != 0) { r = nvf_pick(filter_svf_process_sample(fr, right), mode); }
    store64(out2, l);
    store64(out2 + 8, r);
    return 0;
}

# --- SamplerVoice ---
#derive(accessors)
struct NSamplerVoice {
    active;
    zone_index;
    position;
    speed;
    amplitude;
    note;
    age;
    forward;
    amp_env;
    filter_env;
    filter_env_depth;
    base_cutoff;
    filter;
    pitch_bend;
    pressure;
    brightness;
    choke_group;
    pitch_lfo;
    pitch_lfo_depth;
    filter_lfo;
    filter_lfo_depth;
    fil_keytrack;
    cutoff_smoother;
}

#must_use
fn n_voice_new(sample_rate) {
    var v = alloc(sizeof(NSamplerVoice));
    NSamplerVoice_set_active(v, 0);
    NSamplerVoice_set_zone_index(v, 0);
    NSamplerVoice_set_position(v, 0);
    NSamplerVoice_set_speed(v, F64_ONE);
    NSamplerVoice_set_amplitude(v, F64_ONE);
    NSamplerVoice_set_note(v, 0);
    NSamplerVoice_set_age(v, 0);
    NSamplerVoice_set_forward(v, 1);
    NSamplerVoice_set_amp_env(v, n_amp_envelope_new(n_adsr_config_default(), sample_rate));
    NSamplerVoice_set_filter_env(v, 0);
    NSamplerVoice_set_filter_env_depth(v, 0);
    NSamplerVoice_set_base_cutoff(v, 0);
    NSamplerVoice_set_filter(v, nvf_bypass());
    NSamplerVoice_set_pitch_bend(v, 0);
    NSamplerVoice_set_pressure(v, 0);
    NSamplerVoice_set_brightness(v, F64_HALF);
    NSamplerVoice_set_choke_group(v, 0);
    NSamplerVoice_set_pitch_lfo(v, 0);
    NSamplerVoice_set_pitch_lfo_depth(v, 0);
    NSamplerVoice_set_filter_lfo(v, 0);
    NSamplerVoice_set_filter_lfo_depth(v, 0);
    NSamplerVoice_set_fil_keytrack(v, 0);
    NSamplerVoice_set_cutoff_smoother(v, smoothing_new(f64_div(f64_from(5), f64_from(1000)), sample_rate, 0));
    return v;
}

#inline
#must_use
fn n_voice_is_active(v) { return NSamplerVoice_active(v); }
#inline
#must_use
fn n_voice_note(v) { return NSamplerVoice_note(v); }

# --- SamplerEngine ---
#derive(accessors)
struct NSamplerEngine {
    voices;
    instrument;
    bank;
    sample_rate;
    default_adsr;
    pitch_bend_range;
    scratch_buf;
    voice_mgr;
}

#must_use
fn n_engine_new(max_voices, sample_rate) {
    var e = alloc(sizeof(NSamplerEngine));
    var voices = vec_new();
    var i = 0;
    while (i < max_voices) { vec_push(voices, n_voice_new(sample_rate)); i = i + 1; }
    NSamplerEngine_set_voices(e, voices);
    NSamplerEngine_set_instrument(e, 0);
    NSamplerEngine_set_bank(e, n_sample_bank_new());
    NSamplerEngine_set_sample_rate(e, sample_rate);
    var rel = f64_to(f64_max(f64_mul(sample_rate, f64_div(F64_ONE, f64_from(100))), F64_ONE));
    NSamplerEngine_set_default_adsr(e, n_adsr_config_new(0, 0, F64_ONE, rel));
    NSamplerEngine_set_pitch_bend_range(e, f64_from(2));
    var scratch = vec_new();
    var z = 0;
    while (z < 2048) { vec_push(scratch, 0); z = z + 1; }
    NSamplerEngine_set_scratch_buf(e, scratch);
    NSamplerEngine_set_voice_mgr(e, voice_manager_new(max_voices, POLY_MODE_POLY, STEAL_MODE_OLDEST));
    return e;
}

fn n_engine_set_instrument(e, inst) { NSamplerEngine_set_instrument(e, inst); return 0; }
fn n_engine_set_bank(e, bank) { NSamplerEngine_set_bank(e, bank); return 0; }
#must_use
fn n_engine_bank(e) { return NSamplerEngine_bank(e); }
fn n_engine_set_adsr(e, cfg) { NSamplerEngine_set_default_adsr(e, cfg); return 0; }
fn n_engine_set_release_ms(e, ms) {
    var cfg = NSamplerEngine_default_adsr(e);
    var rel = f64_to(f64_max(f64_div(f64_mul(NSamplerEngine_sample_rate(e), ms), f64_from(1000)), F64_ONE));
    NAdsrConfig_set_release_samples(cfg, rel);
    return 0;
}
fn n_engine_set_pitch_bend_range(e, semitones) { NSamplerEngine_set_pitch_bend_range(e, f64_max(semitones, 0)); return 0; }
fn n_engine_set_steal_mode(e, mode) { VoiceManager_set_steal_mode(NSamplerEngine_voice_mgr(e), mode); return 0; }
fn n_engine_set_poly_mode(e, mode) { VoiceManager_set_poly_mode(NSamplerEngine_voice_mgr(e), mode); return 0; }

fn n_engine_apply_pitch_bend(e, note, bend) {
    var bs = f64_mul(bend, NSamplerEngine_pitch_bend_range(e));
    var voices = NSamplerEngine_voices(e);
    var nv = vec_len(voices);
    var i = 0;
    while (i < nv) {
        var v = vec_get(voices, i);
        if (NSamplerVoice_active(v) == 1) { if (NSamplerVoice_note(v) == note) { NSamplerVoice_set_pitch_bend(v, bs); } }
        i = i + 1;
    }
    return 0;
}

fn n_engine_apply_pressure(e, note, pressure) {
    var p = f64_min(f64_max(pressure, 0), F64_ONE);
    var voices = NSamplerEngine_voices(e);
    var nv = vec_len(voices);
    var i = 0;
    while (i < nv) {
        var v = vec_get(voices, i);
        if (NSamplerVoice_active(v) == 1) { if (NSamplerVoice_note(v) == note) { NSamplerVoice_set_pressure(v, p); } }
        i = i + 1;
    }
    return 0;
}

fn n_engine_apply_brightness(e, note, brightness) {
    var b = f64_min(f64_max(brightness, 0), F64_ONE);
    var voices = NSamplerEngine_voices(e);
    var nv = vec_len(voices);
    var i = 0;
    while (i < nv) {
        var v = vec_get(voices, i);
        if (NSamplerVoice_active(v) == 1) { if (NSamplerVoice_note(v) == note) { NSamplerVoice_set_brightness(v, b); } }
        i = i + 1;
    }
    return 0;
}

#must_use
fn n_engine_active_voice_count(e) {
    var voices = NSamplerEngine_voices(e);
    var nv = vec_len(voices);
    var c = 0;
    var i = 0;
    while (i < nv) { if (NSamplerVoice_active(vec_get(voices, i)) == 1) { c = c + 1; } i = i + 1; }
    return c;
}

# test helper: 1 if some active voice currently plays `note`, else 0.
#must_use
fn n_engine_has_active_note(e, note) {
    var voices = NSamplerEngine_voices(e);
    var nv = vec_len(voices);
    var i = 0;
    while (i < nv) {
        var v = vec_get(voices, i);
        if (NSamplerVoice_active(v) == 1) { if (NSamplerVoice_note(v) == note) { return 1; } }
        i = i + 1;
    }
    return 0;
}

# note_on(note, velocity) -> voice index, or -1.
fn n_engine_note_on(e, note, velocity) {
    var inst = NSamplerEngine_instrument(e);
    if (inst == 0) { return 0 - 1; }
    var matching = n_instrument_find_zones(inst, note, velocity);
    if (vec_len(matching) == 0) { return 0 - 1; }
    var zones = NInstrument_zones(inst);
    var zone = vec_get(matching, 0);
    var zone_idx = 0;
    var nz = vec_len(zones);
    var zi = 0;
    while (zi < nz) {
        if (vec_get(zones, zi) == zone) { zone_idx = zi; zi = nz; } else { zi = zi + 1; }
    }

    var sr = NSamplerEngine_sample_rate(e);
    var speed = n_zone_playback_ratio(zone, note);
    var amp = n_velocity_curve_apply(NZone_vel_curve(zone), velocity);
    var f_cutoff = NZone_filter_cutoff(zone);
    var f_res = NZone_filter_resonance(zone);
    var f_type = NZone_filter_type(zone);
    var f_vel = NZone_filter_vel_track(zone);
    var adsr_config = NZone_adsr(zone);
    if (adsr_config == 0) { adsr_config = NSamplerEngine_default_adsr(e); }
    var choke = NZone_choke_group(zone);
    var sample_offset = NZone_sample_offset(zone);
    var fileg_config = NZone_fileg(zone);
    var fileg_depth = NZone_fileg_depth(zone);
    var plfo_rate = NZone_pitchlfo_rate(zone);
    var plfo_depth = NZone_pitchlfo_depth(zone);
    var flfo_rate = NZone_fillfo_rate(zone);
    var flfo_depth = NZone_fillfo_depth(zone);
    var keytrack = NZone_fil_keytrack(zone);

    var voice_filter = nvf_new(f_cutoff, f_res, f_type, f_vel, velocity, sr);

    # choke: hard-cut active voices in the same choke group (before allocation)
    if (choke > 0) {
        var voices0 = NSamplerEngine_voices(e);
        var nv0 = vec_len(voices0);
        var ci = 0;
        while (ci < nv0) {
            var cv = vec_get(voices0, ci);
            if (NSamplerVoice_active(cv) == 1) { if (NSamplerVoice_choke_group(cv) == choke) { NSamplerVoice_set_active(cv, 0); } }
            ci = ci + 1;
        }
    }

    var vidx = voice_manager_note_on(NSamplerEngine_voice_mgr(e), note, f64_div(f64_from(velocity), f64_from(127)));
    if (vidx < 0) { return 0 - 1; }

    var voice = vec_get(NSamplerEngine_voices(e), vidx);
    NSamplerVoice_set_active(voice, 1);
    NSamplerVoice_set_zone_index(voice, zone_idx);
    NSamplerVoice_set_position(voice, f64_from(sample_offset));
    NSamplerVoice_set_speed(voice, speed);
    NSamplerVoice_set_amplitude(voice, amp);
    NSamplerVoice_set_note(voice, note);
    NSamplerVoice_set_age(voice, 0);
    NSamplerVoice_set_forward(voice, 1);
    NSamplerVoice_set_filter(voice, voice_filter);
    NSamplerVoice_set_base_cutoff(voice, f_cutoff);
    NSamplerVoice_set_pitch_bend(voice, 0);
    NSamplerVoice_set_pressure(voice, 0);
    NSamplerVoice_set_brightness(voice, F64_HALF);
    NSamplerVoice_set_choke_group(voice, choke);

    if (fileg_config != 0) {
        var fenv = n_amp_envelope_new(fileg_config, sr);
        n_amp_envelope_trigger(fenv);
        NSamplerVoice_set_filter_env(voice, fenv);
        NSamplerVoice_set_filter_env_depth(voice, fileg_depth);
    } else {
        NSamplerVoice_set_filter_env(voice, 0);
        NSamplerVoice_set_filter_env_depth(voice, 0);
    }

    var plfo = 0;
    if (f64_gt(plfo_rate, 0) == 1) {
        if (plfo_depth != 0) {
            plfo = modulation_lfo_new(MODULATION_LFO_SINE, plfo_rate, sr);
            if (naad_is_err(plfo) == 1) { plfo = 0; }
        }
    }
    NSamplerVoice_set_pitch_lfo(voice, plfo);
    var flfo = 0;
    if (f64_gt(flfo_rate, 0) == 1) {
        if (flfo_depth != 0) {
            flfo = modulation_lfo_new(MODULATION_LFO_SINE, flfo_rate, sr);
            if (naad_is_err(flfo) == 1) { flfo = 0; }
        }
    }
    NSamplerVoice_set_filter_lfo(voice, flfo);
    NSamplerVoice_set_pitch_lfo_depth(voice, plfo_depth);
    NSamplerVoice_set_filter_lfo_depth(voice, flfo_depth);
    NSamplerVoice_set_fil_keytrack(voice, keytrack);

    var aenv = n_amp_envelope_new(adsr_config, sr);
    n_amp_envelope_trigger(aenv);
    NSamplerVoice_set_amp_env(voice, aenv);

    return vidx;
}

fn n_engine_note_off(e, note) {
    voice_manager_note_off(NSamplerEngine_voice_mgr(e), note);
    var voices = NSamplerEngine_voices(e);
    var nv = vec_len(voices);
    var i = 0;
    while (i < nv) {
        var v = vec_get(voices, i);
        if (NSamplerVoice_active(v) == 1) {
            if (NSamplerVoice_note(v) == note) {
                if (n_amp_envelope_is_active(NSamplerVoice_amp_env(v)) == 1) {
                    n_amp_envelope_release(NSamplerVoice_amp_env(v));
                    if (NSamplerVoice_filter_env(v) != 0) { n_amp_envelope_release(NSamplerVoice_filter_env(v)); }
                }
            }
        }
        i = i + 1;
    }
    return 0;
}

fn n_engine_all_notes_off(e) {
    voice_manager_all_notes_off(NSamplerEngine_voice_mgr(e));
    var voices = NSamplerEngine_voices(e);
    var nv = vec_len(voices);
    var i = 0;
    while (i < nv) {
        var v = vec_get(voices, i);
        if (NSamplerVoice_active(v) == 1) {
            if (n_amp_envelope_is_active(NSamplerVoice_amp_env(v)) == 1) {
                n_amp_envelope_release(NSamplerVoice_amp_env(v));
                if (NSamplerVoice_filter_env(v) != 0) { n_amp_envelope_release(NSamplerVoice_filter_env(v)); }
            }
        }
        i = i + 1;
    }
    return 0;
}

# advance_position -> 1 to keep the voice, 0 to deactivate. speed here is the effective (bent) speed.
fn n_advance_position(voice, loop_mode, loop_start, loop_end, frames, released) {
    var eff_end = f64_from(frames);
    if (loop_end > 0) { eff_end = f64_from(loop_end); }
    var speed = NSamplerVoice_speed(voice);
    var pos = NSamplerVoice_position(voice);
    if (loop_mode == LOOP_ONESHOT) {
        pos = f64_add(pos, speed);
        NSamplerVoice_set_position(voice, pos);
        if (f64_ge(pos, f64_from(frames)) == 1) { return 0; }
        return 1;
    }
    if (loop_mode == LOOP_FORWARD) {
        pos = f64_add(pos, speed);
        if (f64_ge(pos, eff_end) == 1) { pos = f64_from(loop_start); }
        NSamplerVoice_set_position(voice, pos);
        return 1;
    }
    if (loop_mode == LOOP_PINGPONG) {
        if (NSamplerVoice_forward(voice) == 1) {
            pos = f64_add(pos, speed);
            if (f64_ge(pos, eff_end) == 1) { NSamplerVoice_set_forward(voice, 0); }
        } else {
            pos = f64_sub(pos, speed);
            if (f64_le(pos, f64_from(loop_start)) == 1) { NSamplerVoice_set_forward(voice, 1); }
        }
        NSamplerVoice_set_position(voice, pos);
        return 1;
    }
    if (loop_mode == LOOP_REVERSE) {
        pos = f64_sub(pos, speed);
        NSamplerVoice_set_position(voice, pos);
        if (f64_lt(pos, 0) == 1) { return 0; }
        return 1;
    }
    # LOOP_SUSTAIN
    pos = f64_add(pos, speed);
    NSamplerVoice_set_position(voice, pos);
    if (released == 1) {
        if (f64_ge(pos, f64_from(frames)) == 1) { return 0; }
    } else {
        if (f64_ge(pos, eff_end) == 1) { NSamplerVoice_set_position(voice, f64_from(loop_start)); }
    }
    return 1;
}

# render one active voice, adding its stereo contribution to accum2 (2 f64 slots).
fn n_engine_render_voice(voice, zones, bank, sr, accum2, scratch, xscratch, fscratch) {
    NSamplerVoice_set_age(voice, NSamplerVoice_age(voice) + 1);
    var zone = vec_get(zones, NSamplerVoice_zone_index(voice));
    var sample = n_sample_bank_get(bank, NZone_sample_id(zone));
    if (sample == 0) { NSamplerVoice_set_active(voice, 0); return 0; }
    var frames = NSample_frames(sample);
    var eff_frames = frames;
    if (NZone_sample_end(zone) > 0) { if (NZone_sample_end(zone) < eff_frames) { eff_frames = NZone_sample_end(zone); } }

    # pitch modulation
    var pitch_mod_cents = f64_mul(NSamplerVoice_pitch_bend(voice), f64_from(100));
    var plfo = NSamplerVoice_pitch_lfo(voice);
    if (plfo != 0) {
        pitch_mod_cents = f64_add(pitch_mod_cents, f64_mul(modulation_lfo_next_value(plfo), NSamplerVoice_pitch_lfo_depth(voice)));
    }
    var eff_speed = NSamplerVoice_speed(voice);
    if (pitch_mod_cents != 0) {
        eff_speed = f64_mul(NSamplerVoice_speed(voice), f64_pow(f64_from(2), f64_div(pitch_mod_cents, f64_from(1200))));
    }

    # read interpolated source
    n_sample_read_stereo_interpolated(sample, NSamplerVoice_position(voice), scratch);
    var sl = load64(scratch);
    var srr = load64(scratch + 8);

    # loop crossfade (Forward / LoopSustain, crossfade_length > 0)
    var xfade = NZone_crossfade_length(zone);
    if (xfade > 0) {
        var lm0 = NZone_loop_mode(zone);
        var do_xf = 0;
        if (lm0 == LOOP_FORWARD) { do_xf = 1; }
        if (lm0 == LOOP_SUSTAIN) { do_xf = 1; }
        if (do_xf == 1) {
            var loop_end_f = f64_from(eff_frames);
            if (NZone_loop_end(zone) > 0) { loop_end_f = f64_from(NZone_loop_end(zone)); }
            var xfade_f = f64_from(xfade);
            var dist = f64_sub(loop_end_f, NSamplerVoice_position(voice));
            if (f64_ge(dist, 0) == 1) {
                if (f64_lt(dist, xfade_f) == 1) {
                    var t = f64_div(dist, xfade_f);
                    var xfade_pos = f64_add(f64_from(NZone_loop_start(zone)), f64_sub(xfade_f, dist));
                    n_sample_read_stereo_interpolated(sample, xfade_pos, xscratch);
                    sl = f64_add(f64_mul(sl, t), f64_mul(load64(xscratch), f64_sub(F64_ONE, t)));
                    srr = f64_add(f64_mul(srr, t), f64_mul(load64(xscratch + 8), f64_sub(F64_ONE, t)));
                }
            }
        }
    }

    # filter cutoff modulation (only when base_cutoff > 0)
    if (f64_gt(NSamplerVoice_base_cutoff(voice), 0) == 1) {
        var cutoff = NSamplerVoice_base_cutoff(voice);
        if (f64_gt(NSamplerVoice_fil_keytrack(voice), 0) == 1) {
            var semis = f64_from(NSamplerVoice_note(voice) - 60);
            var kt_cents = f64_mul(f64_mul(semis, f64_from(100)), NSamplerVoice_fil_keytrack(voice));
            cutoff = f64_mul(cutoff, f64_pow(f64_from(2), f64_div(kt_cents, f64_from(1200))));
        }
        var fenv = NSamplerVoice_filter_env(voice);
        if (fenv != 0) {
            var mod_cents = f64_mul(NSamplerVoice_filter_env_depth(voice), n_amp_envelope_tick(fenv));
            cutoff = f64_mul(cutoff, f64_pow(f64_from(2), f64_div(mod_cents, f64_from(1200))));
        }
        var flfo = NSamplerVoice_filter_lfo(voice);
        if (flfo != 0) {
            var lfo_cents = f64_mul(modulation_lfo_next_value(flfo), NSamplerVoice_filter_lfo_depth(voice));
            cutoff = f64_mul(cutoff, f64_pow(f64_from(2), f64_div(lfo_cents, f64_from(1200))));
        }
        cutoff = f64_mul(cutoff, f64_add(F64_HALF, f64_mul(NSamplerVoice_brightness(voice), F64_HALF)));
        var smoother = NSamplerVoice_cutoff_smoother(voice);
        smoothing_set_target(smoother, cutoff);
        cutoff = smoothing_next_value(smoother);
        nvf_set_cutoff(NSamplerVoice_filter(voice), cutoff, sr);
    }

    # stereo filter
    nvf_process_stereo(NSamplerVoice_filter(voice), sl, srr, fscratch);
    sl = load64(fscratch);
    srr = load64(fscratch + 8);

    # amplitude envelope
    var env = n_amp_envelope_tick(NSamplerVoice_amp_env(voice));
    if (n_amp_envelope_is_active(NSamplerVoice_amp_env(voice)) == 0) {
        NSamplerVoice_set_active(voice, 0);
        return 0;
    }

    # pressure, gain, pan
    var pressure_mod = f64_add(F64_ONE, f64_mul(f64_sub(NSamplerVoice_pressure(voice), F64_HALF), f64_div(f64_from(4), f64_from(10))));
    var amp = f64_mul(f64_mul(NSamplerVoice_amplitude(voice), env), pressure_mod);
    var pan = NZone_pan(zone);
    var pan_l = f64_mul(f64_sub(F64_ONE, pan), F64_HALF);
    var pan_r = f64_mul(f64_add(F64_ONE, pan), F64_HALF);
    store64(accum2, f64_add(load64(accum2), f64_mul(f64_mul(sl, amp), pan_l)));
    store64(accum2 + 8, f64_add(load64(accum2 + 8), f64_mul(f64_mul(srr, amp), pan_r)));

    # advance read cursor with the pitch-bent speed
    var saved_speed = NSamplerVoice_speed(voice);
    NSamplerVoice_set_speed(voice, eff_speed);
    var released = n_amp_envelope_is_releasing(NSamplerVoice_amp_env(voice));
    if (n_advance_position(voice, NZone_loop_mode(zone), NZone_loop_start(zone), NZone_loop_end(zone), eff_frames, released) == 0) {
        NSamplerVoice_set_active(voice, 0);
    }
    NSamplerVoice_set_speed(voice, saved_speed);
    return 0;
}

# next_sample_stereo -> writes out2[0]=L, out2[1]=R.
fn n_engine_next_sample_stereo(e, out2) {
    store64(out2, 0);
    store64(out2 + 8, 0);
    var inst = NSamplerEngine_instrument(e);
    if (inst == 0) { return 0; }
    var zones = NInstrument_zones(inst);
    var bank = NSamplerEngine_bank(e);
    var sr = NSamplerEngine_sample_rate(e);
    var scratch = alloc(16);
    var xscratch = alloc(16);
    var fscratch = alloc(16);
    var voices = NSamplerEngine_voices(e);
    var nv = vec_len(voices);
    var vi = 0;
    while (vi < nv) {
        var voice = vec_get(voices, vi);
        if (NSamplerVoice_active(voice) == 1) {
            n_engine_render_voice(voice, zones, bank, sr, out2, scratch, xscratch, fscratch);
        }
        vi = vi + 1;
    }
    return 0;
}

#must_use
fn n_engine_next_sample(e) {
    var o = alloc(16);
    n_engine_next_sample_stereo(e, o);
    return f64_mul(f64_add(load64(o), load64(o + 8)), F64_HALF);
}

# fill_buffer(buf vec, n): mono, each element = next_sample.
fn n_engine_fill_buffer(e, buf, n) {
    var i = 0;
    while (i < n) { vec_set(buf, i, n_engine_next_sample(e)); i = i + 1; }
    return 0;
}

# fill_buffer_stereo(buf vec, len): interleaved stereo, rendered per-frame (output-identical
# to the Rust per-voice block render).
fn n_engine_fill_buffer_stereo(e, buf, len) {
    var frames = len / 2;
    var o = alloc(16);
    var f = 0;
    while (f < frames) {
        n_engine_next_sample_stereo(e, o);
        vec_set(buf, f * 2, load64(o));
        vec_set(buf, f * 2 + 1, load64(o + 8));
        f = f + 1;
    }
    return 0;
}
