# --- error.cyr ---

# error.cyr -- nidhi error codes
# Requires: (nothing -- pure integer constants + a predicate)
#
# Ports the Rust `NidhiError` enum to negative integer error codes, matching the
# naad/hisab/shravan ecosystem convention (functions return 0/ERR_NONE or a valid
# pointer on success, a negative ERR_* on failure). The Rust variants' String
# payloads are dropped -- the code IS the error. Config/data types that need a
# faithful serde round-trip use `#derive(Serialize)` instead (see zone.cyr etc.).
#
# Rust variant           -> code
#   (ok)                 ->  ERR_NONE            = 0
#   SampleNotFound(id)   ->  ERR_SAMPLE_NOT_FOUND = -1
#   InvalidZone(msg)     ->  ERR_INVALID_ZONE     = -2
#   InvalidParameter{..} ->  ERR_INVALID_PARAMETER = -3
#   Playback(msg)        ->  ERR_PLAYBACK         = -4
#   ImportError(msg)     ->  ERR_IMPORT           = -5

var ERR_NONE              = 0;
var ERR_SAMPLE_NOT_FOUND  = (0 - 1);
var ERR_INVALID_ZONE      = (0 - 2);
var ERR_INVALID_PARAMETER = (0 - 3);
var ERR_PLAYBACK          = (0 - 4);
var ERR_IMPORT            = (0 - 5);

# n_is_err -- 1 if `code` is a nidhi error (negative), else 0.
#must_use
fn n_is_err(code) {
    if (code < 0) { return 1; }
    return 0;
}

# --- f64_util.cyr ---

# f64_util.cyr -- nidhi f64 helpers (self-contained, no naad dependency)
# Requires: math (f64_abs, f64_lt)
#
# f64 values are IEEE-754 bit patterns in i64 slots. nidhi's Rust is written in
# f32 but Cyrius has only f64 (ADR-002: everything is i64) -- every f32 becomes an
# f64 bit-pattern here, matching how naad/shravan store audio samples (vecs of f64).
# Symbols are `n_`-prefixed so they never collide with naad's `flush_denormal` in
# the flat concatenated bundle namespace.

# f32::MIN_POSITIVE (smallest positive normal f32 = 2^-126) as an f64 bit pattern.
# Used as the denormal-flush threshold to match the Rust crate-root helper exactly.
var N_F32_MIN_POS = 0x3810000000000000;

# f32::EPSILON (2^-23 ~= 1.1920929e-7) as an f64 bit pattern. Shared tolerance for
# "approximately equal" checks that the Rust code did against f32::EPSILON.
var N_F32_EPSILON = 0x3E80000000000000;

# n_is_finite(x) -- 1 if the f64 bit pattern x is finite (not +/-Inf, not NaN), else 0.
# Non-finite <=> the 11 exponent bits are all set (0x7FF).
#inline
#must_use
fn n_is_finite(x) {
    if ((x & 0x7FF0000000000000) == 0x7FF0000000000000) { return 0; }
    return 1;
}

# n_flush_denormal -- flush subnormal-magnitude values to +0.0 to avoid the 10-100x
# x86 slowdown on denormals. Mirrors Rust `flush_denormal`:
#   if x.abs() < f32::MIN_POSITIVE { 0.0 } else { x }
# (+0.0 has bit pattern 0, so `return 0` is the correct f64 zero.)
#inline
#must_use
fn n_flush_denormal(x) {
    if (f64_lt(f64_abs(x), N_F32_MIN_POS) == 1) { return 0; }
    return x;
}

# --- loop_mode.cyr ---

# loop_mode.cyr -- LoopMode tags
# Requires: (nothing)
#
# Ports the Rust fieldless `LoopMode` enum. Tag order == Rust declaration order;
# the #[default] variant is OneShot(0), so the zero value is a valid default.
#
#   0 LOOP_ONESHOT   -- play once, stop (default)
#   1 LOOP_FORWARD   -- start->end, jump to loop_start, repeat
#   2 LOOP_PINGPONG  -- forward then backward within the loop region
#   3 LOOP_REVERSE   -- play backwards
#   4 LOOP_SUSTAIN   -- loop while held, play through to end on release

var LOOP_ONESHOT  = 0;
var LOOP_FORWARD  = 1;
var LOOP_PINGPONG = 2;
var LOOP_REVERSE  = 3;
var LOOP_SUSTAIN  = 4;

# n_loop_mode_default -- the #[default] variant (OneShot).
#must_use
fn n_loop_mode_default() {
    return LOOP_ONESHOT;
}

# n_loop_mode_valid -- 1 if `m` is a defined LoopMode tag (0..=4), else 0.
#must_use
fn n_loop_mode_valid(m) {
    if (m < 0) { return 0; }
    if (m > 4) { return 0; }
    return 1;
}

# --- envelope.cyr ---

# envelope.cyr -- ADSR config + naad-backed amplitude envelope
# Requires: math (f64_*), f64_util (N_F32_EPSILON), naad (envelope_adsr_*,
#           naad_is_err, ENV_STATE_RELEASE)
#
# "Use naad fully": nidhi's Rust std AmpEnvelope simply wrapped naad::envelope::Adsr;
# the no_std linear ADSR was only a fallback for when naad was absent. In Cyrius naad
# is always present, so AmpEnvelope IS a naad Adsr and the entire fallback (tick_no_std,
# EnvState, level/pos fields) collapses. What survives is NAdsrConfig -- the sample-based,
# SFZ-mappable per-zone envelope config -- plus a builder that converts it to a naad Adsr.
# Envelope stages map to naad's ENV_STATE_IDLE/ATTACK/DECAY/SUSTAIN/RELEASE.

# --- NAdsrConfig: all durations in samples (mirrors Rust AdsrConfig) ---
# Fields: attack_samples (i64), decay_samples (i64), sustain_level (f64 bits, 0..1),
# release_samples (i64).
#derive(accessors)
struct NAdsrConfig {
    attack_samples;
    decay_samples;
    sustain_level;
    release_samples;
}

# Default: attack=0, decay=0, sustain=1.0, release=441 (~10ms @ 44.1k).
#must_use
fn n_adsr_config_default() {
    var c = alloc(sizeof(NAdsrConfig));
    NAdsrConfig_set_attack_samples(c, 0);
    NAdsrConfig_set_decay_samples(c, 0);
    NAdsrConfig_set_sustain_level(c, F64_ONE);
    NAdsrConfig_set_release_samples(c, 441);
    return c;
}

#must_use
fn n_adsr_config_new(attack_samples, decay_samples, sustain_level, release_samples) {
    var c = alloc(sizeof(NAdsrConfig));
    NAdsrConfig_set_attack_samples(c, attack_samples);
    NAdsrConfig_set_decay_samples(c, decay_samples);
    NAdsrConfig_set_sustain_level(c, sustain_level);
    NAdsrConfig_set_release_samples(c, release_samples);
    return c;
}

# from_seconds: samples = (secs * sample_rate), truncated toward zero, with
# max(0) on attack/decay and max(1) on release. sustain clamped to [0,1].
# All args are f64 bit patterns.
#must_use
fn n_adsr_config_from_seconds(attack, decay, sustain, release, sample_rate) {
    var a = f64_to(f64_max(f64_mul(attack, sample_rate), 0));
    var d = f64_to(f64_max(f64_mul(decay, sample_rate), 0));
    var s = f64_min(f64_max(sustain, 0), F64_ONE);
    var r = f64_to(f64_max(f64_mul(release, sample_rate), F64_ONE));
    return n_adsr_config_new(a, d, s, r);
}

# is_default_sfz: true when the config is the SFZ "no explicit envelope" default
# (attack==0, decay==0, sustain~=1.0, release <= ~1ms). sample_rate is f64 bits.
#must_use
fn n_adsr_config_is_default_sfz(config, sample_rate) {
    if (NAdsrConfig_attack_samples(config) != 0) { return 0; }
    if (NAdsrConfig_decay_samples(config) != 0) { return 0; }
    if (f64_lt(f64_abs(f64_sub(NAdsrConfig_sustain_level(config), F64_ONE)), N_F32_EPSILON) == 0) {
        return 0;
    }
    var thresh = f64_to(f64_mul(sample_rate, f64_div(F64_ONE, f64_from(1000))));
    if (NAdsrConfig_release_samples(config) > thresh) { return 0; }
    return 1;
}

# --- AmpEnvelope: a naad Adsr built from an NAdsrConfig ---
# n_amp_envelope_new(config, sample_rate) -> naad Adsr pointer. Mirrors the Rust std
# path: to_seconds -> Adsr::with_sample_rate(a.max0, d.max0, s.clamp01, r.max0, sr.max1)
# with a hardcoded-valid fallback (0,0,1.0,0.01,44100) if validation fails.
# sample_rate is an f64 bit pattern (Hz).
#must_use
fn n_amp_envelope_new(config, sample_rate) {
    # to_seconds divides by the RAW sample_rate (matches Rust); ONLY the 5th arg is clamped max(.,1).
    var a = f64_max(f64_div(f64_from(NAdsrConfig_attack_samples(config)), sample_rate), 0);
    var d = f64_max(f64_div(f64_from(NAdsrConfig_decay_samples(config)), sample_rate), 0);
    var s = f64_min(f64_max(NAdsrConfig_sustain_level(config), 0), F64_ONE);
    var rel = f64_max(f64_div(f64_from(NAdsrConfig_release_samples(config)), sample_rate), 0);
    var env = envelope_adsr_with_sample_rate(a, d, s, rel, f64_max(sample_rate, F64_ONE));
    if (naad_is_err(env) == 1) {
        # fallback: 0.0 attack, 0.0 decay, 1.0 sustain, 0.01s release, 44100 Hz -- always valid
        env = envelope_adsr_with_sample_rate(0, 0, F64_ONE, f64_div(F64_ONE, f64_from(100)), f64_from(44100));
    }
    return env;
}

# Lifecycle wrappers over naad (thin -- keep nidhi's envelope vocabulary).
#inline
fn n_amp_envelope_trigger(env) { return envelope_adsr_gate_on(env); }

#inline
fn n_amp_envelope_release(env) { return envelope_adsr_gate_off(env); }

#inline
fn n_amp_envelope_tick(env) { return envelope_adsr_next_value(env); }

#inline
#must_use
fn n_amp_envelope_is_active(env) { return envelope_adsr_is_active(env); }

#inline
#must_use
fn n_amp_envelope_is_releasing(env) {
    if (envelope_adsr_state(env) == ENV_STATE_RELEASE) { return 1; }
    return 0;
}

# --- zone.cyr ---

# zone.cyr -- Zone config: key/velocity mapping, tuning, filter, envelope, LFO, bus
# Requires: math (f64_*), loop_mode (LOOP_*), envelope (NAdsrConfig ptrs stored in adsr/fileg)
#
# Ports rust-old/src/zone.rs. Every f32 -> f64 bit pattern. Option<AdsrConfig> (adsr, fileg)
# -> nullable NAdsrConfig pointer (0 == None). The builder setters mutate in place and return
# the zone pointer so calls chain (z = n_zone_with_x(z, ...)). Clamps are load-bearing.

# --- VelocityCurve (fieldless enum -> tag constants) ---
var VEL_CURVE_LINEAR  = 0;
var VEL_CURVE_CONVEX  = 1;
var VEL_CURVE_CONCAVE = 2;
var VEL_CURVE_SWITCH  = 3;

# n_velocity_curve_apply(curve, vel) -> gain in 0..1 (f64 bits). vel is raw MIDI 0..127.
# Linear: v; Convex: sqrt(v); Concave: v*v; Switch: 1.0 if vel>64 else 0.0 (raw vel, not v).
#inline
#must_use
fn n_velocity_curve_apply(curve, vel) {
    if (curve == VEL_CURVE_SWITCH) {
        if (vel > 64) { return F64_ONE; }
        return 0;
    }
    var v = f64_div(f64_from(vel), f64_from(127));
    if (curve == VEL_CURVE_CONVEX) { return f64_sqrt(v); }
    if (curve == VEL_CURVE_CONCAVE) { return f64_mul(v, v); }
    return v;
}

# --- FilterMode (fieldless enum -> tag constants) ---
var FILTER_LOWPASS  = 0;
var FILTER_HIGHPASS = 1;
var FILTER_BANDPASS = 2;
var FILTER_NOTCH    = 3;

