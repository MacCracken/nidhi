# Version: 2.5.12
# Generated by: cyrius distlib
# Do not edit -- rebuild with: cyrius distlib

# --- shravan.cyr ---

# shravan — audio codecs for AGNOS (Cyrius port)
# Ported from ~10K lines of Rust to Cyrius.
#
# Phase 1: error, format, pcm, codec, wav
#
# Design decisions:
#   - All audio samples are f64 internally (Cyrius native, more precision than f32)
#   - Packed Result: Ok returns value >= 0, Err sets bit 63 (value < 0)
#   - Buffers are raw byte pointers + length
#   - Vec used for dynamic sample arrays (stores f64 bit patterns as i64)
#   - Error codes are integer enums, error messages via helper functions

# Stdlib modules resolved via cyrius.toml [deps] stdlib.

# ================================================================
# Constants — f64 bit patterns for common values
# ================================================================

# f64 constants — initialized at startup via shravan_init_constants()
var F64_ZERO       = 0;
var F64_NEG_HALF   = 0;
var F64_NEG_ONE    = 0;
# F64_ONE, F64_TWO, and F64_HALF are provided by math.cyr (stdlib)

# PCM normalization constants (divisors and reciprocals)
var F64_128        = 0;
var F64_255        = 0;
var F64_32768      = 0;
var F64_32767      = 0;
var F64_8388608    = 0;
var F64_8388607    = 0;
var F64_2147483648 = 0;
var F64_2147483647 = 0;

# Pre-computed reciprocals for PCM conversion (mul instead of div)
var F64_RCP_128        = 0;
var F64_RCP_32768      = 0;
var F64_RCP_8388608    = 0;
var F64_RCP_2147483648 = 0;

# Pre-computed power for f32 denormal conversion
var F64_2_NEG_149  = 0;
var F64_2_NEG_150  = 0;

fn shravan_init_constants() {
    F64_ZERO       = f64_from(0);
    F64_NEG_HALF   = f64_neg(F64_HALF);  # F64_HALF from math.cyr
    F64_NEG_ONE    = f64_neg(F64_ONE);
    F64_128        = f64_from(128);
    F64_255        = f64_from(255);
    F64_32768      = f64_from(32768);
    F64_32767      = f64_from(32767);
    F64_8388608    = f64_from(8388608);
    F64_8388607    = f64_from(8388607);
    F64_2147483648 = f64_mul(f64_from(32768), f64_from(65536));
    F64_2147483647 = f64_sub(F64_2147483648, F64_ONE);

    # Reciprocals for PCM hot paths (mul is ~3x faster than div)
    F64_RCP_128        = f64_div(F64_ONE, F64_128);
    F64_RCP_32768      = f64_div(F64_ONE, F64_32768);
    F64_RCP_8388608    = f64_div(F64_ONE, F64_8388608);
    F64_RCP_2147483648 = f64_div(F64_ONE, F64_2147483648);

    # f32 denormal: 2^-149 and 2^-150
    F64_2_NEG_149 = f64_pow(F64_TWO, f64_from(0 - 149));
    F64_2_NEG_150 = f64_pow(F64_TWO, f64_from(0 - 150));
    return 0;
}

# ================================================================
# Error module
# ================================================================

enum ShravanErr {
    ERR_NONE              = 0;
    ERR_UNSUPPORTED_FMT   = 1;
    ERR_INVALID_HEADER    = 2;
    ERR_DECODE            = 3;
    ERR_ENCODE            = 4;
    ERR_END_OF_STREAM     = 5;
    ERR_INVALID_RATE      = 6;
    ERR_INVALID_CHANNELS  = 7;
}

# Pack an error code into a negative result (bit 63 set)
fn err(code) {
    return 0 - code;
}

# is_err(r) and err_code(r) come from the stdlib (syscalls, pulled via io):
# they are byte-identical to shravan's packed-Result convention
# (is_err = r < 0, err_code = 0 - r). Only res_ok is shravan's own — the
# stdlib's res_ok (result.cyr) operates on tagged Result structs, not the
# packed >=0/<0 integer results the codecs use.
fn res_ok(r) {
    if (r >= 0) { return 1; }
    return 0;
}

# Print error message to stderr
fn err_print(code) {
    if (code == ERR_UNSUPPORTED_FMT)  { syscall(1, 2, "unsupported format\n", 19); }
    if (code == ERR_INVALID_HEADER)   { syscall(1, 2, "invalid header\n", 15); }
    if (code == ERR_DECODE)           { syscall(1, 2, "decode error\n", 13); }
    if (code == ERR_ENCODE)           { syscall(1, 2, "encode error\n", 13); }
    if (code == ERR_END_OF_STREAM)    { syscall(1, 2, "end of stream\n", 14); }
    if (code == ERR_INVALID_RATE)     { syscall(1, 2, "invalid sample rate\n", 20); }
    if (code == ERR_INVALID_CHANNELS) { syscall(1, 2, "invalid channel count\n", 22); }
    return 0;
}

# ================================================================
# Format module
# ================================================================

enum AudioFormat {
    FMT_WAV    = 0;
    FMT_FLAC   = 1;
    FMT_RAW    = 2;
    FMT_OGG    = 3;
    FMT_AIFF   = 4;
    FMT_MP3    = 5;
    FMT_OPUS   = 6;
    FMT_AAC    = 7;
    FMT_ALAC   = 8;
    FMT_MP4    = 9;
}

fn format_name(fmt) {
    if (fmt == FMT_WAV)  { return "WAV"; }
    if (fmt == FMT_FLAC) { return "FLAC"; }
    if (fmt == FMT_RAW)  { return "Raw PCM"; }
    if (fmt == FMT_OGG)  { return "Ogg"; }
    if (fmt == FMT_AIFF) { return "AIFF"; }
    if (fmt == FMT_MP3)  { return "MP3"; }
    if (fmt == FMT_OPUS) { return "Opus"; }
    if (fmt == FMT_AAC)  { return "AAC"; }
    if (fmt == FMT_ALAC) { return "ALAC"; }
    if (fmt == FMT_MP4)  { return "MP4/M4A"; }
    return "Unknown";
}

# Struct size constants
var FMTINFO_SIZE       = 48;
var DECODE_RESULT_SIZE = 16;
var BITREADER_SIZE     = 32;

# FormatInfo — heap-allocated struct
# Layout (48 bytes):
#   +0:  format        (i64, AudioFormat enum)
#   +8:  sample_rate   (i64, Hz)
#   +16: channels      (i64)
#   +24: bit_depth     (i64)
#   +32: duration_secs (f64 bit pattern)
#   +40: total_samples (i64)

fn fmtinfo_new(format, sample_rate, channels, bit_depth, duration_secs, total_samples) {
    var fi = alloc(48);
    store64(fi,      format);
    store64(fi + 8,  sample_rate);
    store64(fi + 16, channels);
    store64(fi + 24, bit_depth);
    store64(fi + 32, duration_secs);
    store64(fi + 40, total_samples);
    return fi;
}

fn fmtinfo_format(fi)       { return load64(fi); }
fn fmtinfo_sample_rate(fi)  { return load64(fi + 8); }
fn fmtinfo_channels(fi)     { return load64(fi + 16); }
fn fmtinfo_bit_depth(fi)    { return load64(fi + 24); }
fn fmtinfo_duration(fi)     { return load64(fi + 32); }
fn fmtinfo_total_samples(fi){ return load64(fi + 40); }

# Detect audio format from header bytes.
# data: pointer to byte buffer, len: buffer length
# Returns AudioFormat enum value on success, negative error on failure.
fn detect_format(data, len) {
    if (len < 4) { return err(ERR_INVALID_HEADER); }

    # WAV: "RIFF"
    if (load8(data) == 0x52) {
        if (load8(data+1) == 0x49) {
            if (load8(data+2) == 0x46) {
                if (load8(data+3) == 0x46) {
                    return FMT_WAV;
                }
            }
        }
    }

    # FLAC: "fLaC"
    if (load8(data) == 0x66) {
        if (load8(data+1) == 0x4C) {
            if (load8(data+2) == 0x61) {
                if (load8(data+3) == 0x43) {
                    return FMT_FLAC;
                }
            }
        }
    }

    # Ogg: "OggS"
    if (load8(data) == 0x4F) {
        if (load8(data+1) == 0x67) {
            if (load8(data+2) == 0x67) {
                if (load8(data+3) == 0x53) {
                    return FMT_OGG;
                }
            }
        }
    }

    # AIFF/AIFC: "FORM" + offset 8 = "AIFF" or "AIFC"
    if (load8(data) == 0x46) {
        if (load8(data+1) == 0x4F) {
            if (load8(data+2) == 0x52) {
                if (load8(data+3) == 0x4D) {
                    if (len >= 12) {
                        # Check for "AIFF" at offset 8
                        if (load8(data+8) == 0x41) {
                            if (load8(data+9) == 0x49) {
                                if (load8(data+10) == 0x46) {
                                    if (load8(data+11) == 0x46) { return FMT_AIFF; }
                                    if (load8(data+11) == 0x43) { return FMT_AIFF; }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    # MP3: ID3v2 tag "ID3"
    if (load8(data) == 0x49) {
        if (load8(data+1) == 0x44) {
            if (load8(data+2) == 0x33) {
                return FMT_MP3;
            }
        }
    }

    # MPEG sync: 0xFF 0xE0 mask
    if (load8(data) == 0xFF) {
        var b1 = load8(data + 1);
        if ((b1 & 0xE0) == 0xE0) {
            # Distinguish ADTS (AAC) from MP3
            # ADTS: 0xFFF sync + layer=0 → (b1 & 0xF6) == 0xF0
            if ((b1 & 0xF6) == 0xF0) {
                return FMT_AAC;
            }
            return FMT_MP3;
        }
    }

    # MP4/M4A: "ftyp" box at offset 4 (ISO base media file format)
    if (len >= 8) {
        if (load8(data+4) == 0x66) {
            if (load8(data+5) == 0x74) {
                if (load8(data+6) == 0x79) {
                    if (load8(data+7) == 0x70) {
                        return FMT_MP4;
                    }
                }
            }
        }
    }

    return err(ERR_UNSUPPORTED_FMT);
}

# ================================================================
# PCM module — sample format conversions
# ================================================================

enum PcmFormat {
    PCM_I8  = 0;
    PCM_I16 = 1;
    PCM_I24 = 2;
    PCM_I32 = 3;
    PCM_F32 = 4;
    PCM_F64 = 5;
}

fn pcm_bytes_per_sample(fmt) {
    if (fmt == PCM_I8)  { return 1; }
    if (fmt == PCM_I16) { return 2; }
    if (fmt == PCM_I24) { return 3; }
    if (fmt == PCM_I32) { return 4; }
    if (fmt == PCM_F32) { return 4; }
    if (fmt == PCM_F64) { return 8; }
    return 0;
}

fn pcm_bit_depth(fmt) {
    if (fmt == PCM_I8)  { return 8; }
    if (fmt == PCM_I16) { return 16; }
    if (fmt == PCM_I24) { return 24; }
    if (fmt == PCM_I32) { return 32; }
    if (fmt == PCM_F32) { return 32; }
    if (fmt == PCM_F64) { return 64; }
    return 0;
}

# Read a little-endian u16 from buffer at offset
fn read_u16_le(data, off) {
    return load8(data + off) | (load8(data + off + 1) << 8);
}

# Read a little-endian u32 from buffer at offset
fn read_u32_le(data, off) {
    return load8(data + off) | (load8(data + off + 1) << 8) | (load8(data + off + 2) << 16) | (load8(data + off + 3) << 24);
}

# Write a little-endian u16 to buffer at offset
fn write_u16_le(buf, off, val) {
    store8(buf + off, val & 0xFF);
    store8(buf + off + 1, (val >> 8) & 0xFF);
    return 0;
}

# Write a little-endian u32 to buffer at offset
fn write_u32_le(buf, off, val) {
    store8(buf + off, val & 0xFF);
    store8(buf + off + 1, (val >> 8) & 0xFF);
    store8(buf + off + 2, (val >> 16) & 0xFF);
    store8(buf + off + 3, (val >> 24) & 0xFF);
    return 0;
}

# Sign-extend a value from N bits to 64 bits
# Uses conditional subtraction since >> is logical (unsigned) in Cyrius
fn sign_extend(val, bits) {
    var half = 1 << (bits - 1);
    if (val >= half) {
        return val - (1 << bits);
    }
    return val;
}

# Clamp an f64 to [-1.0, 1.0]
fn f64_clamp_sample(x) {
    return f64_clamp(x, F64_NEG_ONE, F64_ONE);
}

# SEC-017: Overflow-checked allocation for a*b bytes.
# Returns pointer on success, or negative error if a*b would overflow
# or exceed 256MB safety cap.
var _ALLOC_MAX = 268435456;  # 256MB

fn _safe_alloc_mul(a, b) {
    if (a <= 0) { return err(ERR_DECODE); }
    if (b <= 0) { return err(ERR_DECODE); }
    if (a > _ALLOC_MAX / b) { return err(ERR_DECODE); }
    return alloc(a * b);
}

# Allocate a vec with pre-set capacity (avoids growth in hot loops)
fn _vec_new_cap(n) {
    var v = alloc(24);
    var data = alloc(n * 8);
    store64(v, data);
    store64(v + 8, 0);
    store64(v + 16, n);
    return v;
}

# Convert signed 16-bit samples to f64 vec.
# src: pointer to i16 LE samples, count: number of samples
# Returns: vec of f64 bit patterns
fn i16_to_f64(src, count) {
    var v = _vec_new_cap(count);
    var scale = F64_RCP_32768;
    for (var i = 0; i < count; i = i + 1) {
        var raw = read_u16_le(src, i * 2);
        var signed = sign_extend(raw, 16);
        vec_push(v, f64_mul(f64_from(signed), scale));
    }
    return v;
}

# Convert f64 vec to signed 16-bit samples.
# samples: vec of f64, out: buffer to write i16 LE
# Returns: number of bytes written
fn f64_to_i16(samples, out) {
    var len = vec_len(samples);
    for (var i = 0; i < len; i = i + 1) {
        var s = f64_clamp_sample(vec_get(samples, i));
        var val = f64_to(f64_mul(s, F64_32767));
        write_u16_le(out, i * 2, val & 0xFFFF);
    }
    return len * 2;
}

# Convert signed 32-bit samples to f64 vec.
fn i32_to_f64(src, count) {
    var v = _vec_new_cap(count);
    var scale = F64_RCP_2147483648;
    for (var i = 0; i < count; i = i + 1) {
        var raw = read_u32_le(src, i * 4);
        var signed = sign_extend(raw, 32);
        vec_push(v, f64_mul(f64_from(signed), scale));
    }
    return v;
}

# Convert f64 vec to signed 32-bit samples.
fn f64_to_i32(samples, out) {
    var len = vec_len(samples);
    for (var i = 0; i < len; i = i + 1) {
        var s = f64_clamp_sample(vec_get(samples, i));
        var val = f64_to(f64_mul(s, F64_2147483647));
        write_u32_le(out, i * 4, val);
    }
    return len * 4;
}

# Convert 24-bit packed LE samples (3 bytes each) to f64 vec.
fn i24_packed_to_f64(src, count) {
    var v = _vec_new_cap(count);
    var scale = F64_RCP_8388608;
    for (var i = 0; i < count; i = i + 1) {
        var off = i * 3;
        var raw = load8(src + off) | (load8(src + off + 1) << 8) | (load8(src + off + 2) << 16);
        var signed = sign_extend(raw, 24);
        vec_push(v, f64_mul(f64_from(signed), scale));
    }
    return v;
}

# Convert f64 vec to 24-bit packed LE samples.
fn f64_to_i24_packed(samples, out) {
    var len = vec_len(samples);
    for (var i = 0; i < len; i = i + 1) {
        var s = f64_clamp_sample(vec_get(samples, i));
        var val = f64_to(f64_mul(s, F64_8388607));
        var off = i * 3;
        store8(out + off, val & 0xFF);
        store8(out + off + 1, (val >> 8) & 0xFF);
        store8(out + off + 2, (val >> 16) & 0xFF);
    }
    return len * 3;
}

# Convert signed 24-bit integers (stored as i64, lower 24 bits) to f64 vec.
# src: pointer to i64 values, count: number of samples
# Returns: vec of f64 bit patterns
fn i24_to_f64(src, count) {
    var v = _vec_new_cap(count);
    var scale = F64_RCP_8388608;
    for (var i = 0; i < count; i = i + 1) {
        var raw = load64(src + i * 8) & 0xFFFFFF;
        var signed = sign_extend(raw, 24);
        vec_push(v, f64_mul(f64_from(signed), scale));
    }
    return v;
}

# Convert f64 vec to signed 24-bit integers (stored as i64).
# samples: vec of f64, out: pointer to i64 buffer
# Returns: number of samples written
fn f64_to_i24(samples, out) {
    var len = vec_len(samples);
    for (var i = 0; i < len; i = i + 1) {
        var s = f64_clamp_sample(vec_get(samples, i));
        var val = f64_to(f64_mul(s, F64_8388607));
        store64(out + i * 8, val & 0xFFFFFF);
    }
    return len;
}

# Convert unsigned 8-bit PCM (center=128) to f64 vec.
fn u8_to_f64(src, count) {
    var v = _vec_new_cap(count);
    var scale = F64_RCP_128;
    for (var i = 0; i < count; i = i + 1) {
        var raw = load8(src + i);
        vec_push(v, f64_mul(f64_sub(f64_from(raw), F64_128), scale));
    }
    return v;
}

# Convert f64 vec to unsigned 8-bit PCM.
fn f64_to_u8(samples, out) {
    var len = vec_len(samples);
    for (var i = 0; i < len; i = i + 1) {
        var s = f64_clamp_sample(vec_get(samples, i));
        var val = f64_to(f64_add(f64_mul(s, F64_128), F64_128));
        if (val < 0)   { val = 0; }
        if (val > 255) { val = 255; }
        store8(out + i, val);
    }
    return len;
}

# Convert IEEE 754 float32 (4 bytes LE) to f64 vec.
fn f32_to_f64_vec(src, count) {
    var v = _vec_new_cap(count);
    for (var i = 0; i < count; i = i + 1) {
        var bits = read_u32_le(src, i * 4);
        # Decompose f32: sign(1) | exp(8) | mantissa(23)
        var sign = (bits >> 31) & 1;
        var exp = (bits >> 23) & 0xFF;
        var mant = bits & 0x7FFFFF;

        var f = F64_ZERO;
        if (exp == 0) {
            if (mant == 0) {
                # +-0.0
                f = F64_ZERO;
            } else {
                # Denormalized: mant * 2^(-149) — use pre-computed constant
                f = f64_mul(f64_from(mant), F64_2_NEG_149);
            }
        } else {
            if (exp == 0xFF) {
                # Inf/NaN — just produce 0 for safety
                f = F64_ZERO;
            } else {
                # Normalized: (2^23 + mant) * 2^(exp - 150)
                var int_mant = 8388608 + mant;
                var power = exp - 150;
                f = f64_mul(f64_from(int_mant), f64_pow(F64_TWO, f64_from(power)));
            }
        }
        if (sign == 1) { f = f64_neg(f); }
        vec_push(v, f);
    }
    return v;
}

# Interleave channel buffers into a single vec.
# channels: vec of vecs (each is a channel), ch_count: number of channels
# Returns: interleaved vec
fn interleave(channels, ch_count) {
    if (ch_count == 0) { return vec_new(); }
    var ch0 = vec_get(channels, 0);
    var frames = vec_len(ch0);
    var out = vec_new();
    for (var fr = 0; fr < frames; fr = fr + 1) {
        for (var c = 0; c < ch_count; c = c + 1) {
            var ch = vec_get(channels, c);
            if (fr < vec_len(ch)) {
                vec_push(out, vec_get(ch, fr));
            }
        }
    }
    return out;
}

# Deinterleave into separate channel vecs.
# samples: interleaved vec, ch_count: number of channels
# Returns: vec of vecs
fn deinterleave(samples, ch_count) {
    if (ch_count == 0) { return vec_new(); }
    var total = vec_len(samples);
    var frames = total / ch_count;
    var out = vec_new();
    for (var c = 0; c < ch_count; c = c + 1) {
        var ch = vec_new();
        for (var fr = 0; fr < frames; fr = fr + 1) {
            vec_push(ch, vec_get(samples, fr * ch_count + c));
        }
        vec_push(out, ch);
    }
    return out;
}

# ================================================================
# WAV module — RIFF WAVE encode/decode
# ================================================================

# WAV format codes
enum WavFmt {
    WAV_FMT_PCM        = 1;
    WAV_FMT_IEEE_FLOAT = 3;
    WAV_FMT_EXTENSIBLE = 65534;
}

# Decode result — returned as a tagged pair: {fmtinfo_ptr, samples_vec}
# Layout (16 bytes):
#   +0: fmtinfo pointer
#   +8: samples vec pointer
fn decode_result_new(fi, samples) {
    var dr = alloc(16);
    store64(dr, fi);
    store64(dr + 8, samples);
    return dr;
}
fn decode_result_info(dr)    { return load64(dr); }
fn decode_result_samples(dr) { return load64(dr + 8); }

# Decode WAV data from a byte buffer.
# data: pointer to WAV bytes, len: total byte length
# Returns: decode_result pointer on success, negative error on failure
fn wav_decode(data, len) {
    if (len < 44) { return err(ERR_INVALID_HEADER); }

    # Validate RIFF magic ("RIFF" = 0x46464952 LE)
    if (read_u32_le(data, 0) != 0x46464952) { return err(ERR_INVALID_HEADER); }

    # Validate WAVE identifier ("WAVE" = 0x45564157 LE)
    if (read_u32_le(data, 8) != 0x45564157) { return err(ERR_INVALID_HEADER); }

    # Scan for fmt and data chunks
    var pos = 12;
    var fmt_code = 0;
    var fmt_ch = 0;
    var fmt_rate = 0;
    var fmt_bps = 0;
    var fmt_found = 0;
    var dat_start = 0;
    var dat_size = 0;
    var dat_found = 0;

    while (pos + 8 <= len) {
        var chunk_id = read_u32_le(data, pos);
        var ck_size = read_u32_le(data, pos + 4);

        # "fmt " = 0x20746D66 LE
        if (chunk_id == 0x20746D66) {
            if (ck_size < 16) { return err(ERR_INVALID_HEADER); }
            fmt_code = read_u16_le(data, pos + 8);
            fmt_ch   = read_u16_le(data, pos + 10);
            fmt_rate = read_u32_le(data, pos + 12);
            # skip byte_rate(4) + block_align(2)
            fmt_bps  = read_u16_le(data, pos + 22);

            # WAVE_FORMAT_EXTENSIBLE
            if (fmt_code == WAV_FMT_EXTENSIBLE) {
                if (ck_size >= 40) {
                    if (pos + 34 <= len) {
                        var valid_bits = read_u16_le(data, pos + 26);
                        if (valid_bits > 0) { fmt_bps = valid_bits; }
                        fmt_code = read_u16_le(data, pos + 32);
                    }
                }
            }
            fmt_found = 1;
        }

        # "data" = 0x61746164 LE
        if (chunk_id == 0x61746164) {
            dat_start = pos + 8;
            dat_size = ck_size;
            dat_found = 1;
        }

        # Advance to next chunk (pad to even), with overflow guard
        if (ck_size > len - pos - 8) { pos = len + 1; }
        else {
            var padded = ck_size + (ck_size & 1);
            pos = pos + padded + 8;
        }

        if (fmt_found == 1) {
            if (dat_found == 1) {
                # Break: we use a high pos to exit
                pos = len + 1;
            }
        }
    }

    if (fmt_found == 0) { return err(ERR_INVALID_HEADER); }
    if (dat_found == 0) { return err(ERR_INVALID_HEADER); }
    if (fmt_ch == 0)    { return err(ERR_INVALID_CHANNELS); }
    if (fmt_rate == 0)  { return err(ERR_INVALID_RATE); }

    # Clamp data_size to available bytes
    var avail = len - dat_start;
    if (dat_size > avail) { dat_size = avail; }
    var audio = data + dat_start;

    # Decode samples to f64 based on format
    var samples = vec_new();

    if (fmt_code == WAV_FMT_PCM) {
        if (fmt_bps == 8) {
            # Unsigned 8-bit PCM
            samples = u8_to_f64(audio, dat_size);
        }
        if (fmt_bps == 16) {
            var count = dat_size / 2;
            samples = i16_to_f64(audio, count);
        }
        if (fmt_bps == 24) {
            var count = dat_size / 3;
            samples = i24_packed_to_f64(audio, count);
        }
        if (fmt_bps == 32) {
            var count = dat_size / 4;
            samples = i32_to_f64(audio, count);
        }
    }
    if (fmt_code == WAV_FMT_IEEE_FLOAT) {
        if (fmt_bps == 32) {
            var count = dat_size / 4;
            samples = f32_to_f64_vec(audio, count);
        }
    }

    var sample_count = vec_len(samples);
    if (sample_count == 0) {
        if (dat_size > 0) {
            return err(ERR_DECODE);
        }
    }

    var total_frames = sample_count / fmt_ch;
    var dur = f64_div(f64_from(total_frames), f64_from(fmt_rate));

    var fi = fmtinfo_new(FMT_WAV, fmt_rate, fmt_ch, fmt_bps, dur, total_frames);
    return decode_result_new(fi, samples);
}

# Encode interleaved f64 samples as WAV byte stream.
# samples: vec of f64 bit patterns
# sample_rate, channels: integers
# pcm_fmt: PcmFormat enum
# out: buffer to write WAV data into (must be large enough)
# Returns: total bytes written, or negative error
fn wav_encode(samples, sample_rate, channels, pcm_fmt, out) {
    if (channels == 0)    { return err(ERR_INVALID_CHANNELS); }
    if (sample_rate == 0) { return err(ERR_INVALID_RATE); }
    if (pcm_fmt == PCM_F64) { return err(ERR_ENCODE); }

    var fmt_code = WAV_FMT_PCM;
    if (pcm_fmt == PCM_F32) { fmt_code = WAV_FMT_IEEE_FLOAT; }

    var bps = pcm_bit_depth(pcm_fmt);
    var bytes_ps = pcm_bytes_per_sample(pcm_fmt);
    var block_align = channels * bytes_ps;
    var byte_rate = block_align * sample_rate;

    var sample_count = vec_len(samples);

    # Encode raw sample data into a temp buffer after the header
    var header_size = 44;
    var raw_data = out + header_size;
    var raw_size = 0;

    if (pcm_fmt == PCM_I8) {
        raw_size = f64_to_u8(samples, raw_data);
    }
    if (pcm_fmt == PCM_I16) {
        raw_size = f64_to_i16(samples, raw_data);
    }
    if (pcm_fmt == PCM_I24) {
        raw_size = f64_to_i24_packed(samples, raw_data);
    }
    if (pcm_fmt == PCM_I32) {
        raw_size = f64_to_i32(samples, raw_data);
    }
    if (pcm_fmt == PCM_F32) {
        # Convert f64 back to f32 IEEE 754 LE
        raw_size = f64_to_f32_bytes(samples, raw_data);
    }

    var data_size = raw_size;
    var file_size = 4 + 24 + 8 + data_size;

    # RIFF header
    store8(out, 0x52); store8(out+1, 0x49); store8(out+2, 0x46); store8(out+3, 0x46);
    write_u32_le(out, 4, file_size);
    store8(out+8, 0x57); store8(out+9, 0x41); store8(out+10, 0x56); store8(out+11, 0x45);

    # fmt chunk
    store8(out+12, 0x66); store8(out+13, 0x6D); store8(out+14, 0x74); store8(out+15, 0x20);
    write_u32_le(out, 16, 16);
    write_u16_le(out, 20, fmt_code);
    write_u16_le(out, 22, channels);
    write_u32_le(out, 24, sample_rate);
    write_u32_le(out, 28, byte_rate);
    write_u16_le(out, 32, block_align);
    write_u16_le(out, 34, bps);

    # data chunk header
    store8(out+36, 0x64); store8(out+37, 0x61); store8(out+38, 0x74); store8(out+39, 0x61);
    write_u32_le(out, 40, data_size);

    # raw_data is already written at out + 44
    return header_size + data_size;
}

# Convert f64 vec to IEEE 754 float32 LE bytes
fn f64_to_f32_bytes(samples, out) {
    var len = vec_len(samples);
    for (var i = 0; i < len; i = i + 1) {
        var f = vec_get(samples, i);
        # Convert f64 bit pattern to f32 bit pattern
        var bits = f64_to_f32_bits(f);
        write_u32_le(out, i * 4, bits);
    }
    return len * 4;
}

# Convert an f64 bit pattern to f32 bit pattern
# Handles normalized, denormalized, zero, inf, nan
fn f64_to_f32_bits(f) {
    # f64: sign(1) | exp(11) | mantissa(52)
    # f32: sign(1) | exp(8)  | mantissa(23)
    var sign = (f >> 63) & 1;
    var exp = (f >> 52) & 0x7FF;
    var mant = f & 0xFFFFFFFFFFFFF;

    var f32_sign = sign << 31;

    if (exp == 0) {
        # Zero or denorm → f32 zero (denorms too small for f32)
        return f32_sign;
    }
    if (exp == 0x7FF) {
        # Inf or NaN
        if (mant == 0) {
            return f32_sign | 0x7F800000;
        }
        return f32_sign | 0x7FC00000;
    }

    # Normalized: f64 bias=1023, f32 bias=127
    var unbiased = exp - 1023;
    if (unbiased > 127) {
        # Overflow → inf
        return f32_sign | 0x7F800000;
    }
    if (unbiased < (0 - 126)) {
        # Underflow → zero
        return f32_sign;
    }

    var f32_exp = (unbiased + 127) & 0xFF;
    var f32_mant = (mant >> 29) & 0x7FFFFF;

    return f32_sign | (f32_exp << 23) | f32_mant;
}

# ================================================================
# AIFF module — Audio Interchange File Format encode/decode
# ================================================================

# Big-endian read helpers
fn read_u16_be(data, off) {
    return (load8(data + off) << 8) | load8(data + off + 1);
}

fn read_u32_be(data, off) {
    return (load8(data+off) << 24) | (load8(data+off+1) << 16) | (load8(data+off+2) << 8) | load8(data+off+3);
}

fn write_u16_be(buf, off, val) {
    store8(buf + off, (val >> 8) & 0xFF);
    store8(buf + off + 1, val & 0xFF);
    return 0;
}

fn write_u32_be(buf, off, val) {
    store8(buf+off, (val >> 24) & 0xFF);
    store8(buf+off+1, (val >> 16) & 0xFF);
    store8(buf+off+2, (val >> 8) & 0xFF);
    store8(buf+off+3, val & 0xFF);
    return 0;
}

# Convert 80-bit IEEE 754 extended float to integer (for sample rate)
# ext: pointer to 10 bytes
# Returns the integer value (sufficient for sample rates)
fn extended_to_f64(ext) {
    var b0 = load8(ext);
    var exponent = ((b0 & 0x7F) << 8) | load8(ext + 1);

    # Read 64-bit mantissa (big-endian) — but we only need top bits for integer rates
    # mantissa has explicit integer bit at position 63
    # value = mantissa >> (63 - (exponent - 16383))
    var unbiased = exponent - 16383;

    # Read mantissa as integer, handling potential overflow by reading in parts
    # For sample rates up to ~192000, we only need the top ~18 bits of mantissa
    # Read top 4 bytes (32 bits) — sufficient for all practical sample rates
    var mant_hi = (load8(ext+2) << 24) | (load8(ext+3) << 16) | (load8(ext+4) << 8) | load8(ext+5);

    # mantissa_hi represents bits 63..32 of the mantissa
    # value = mant_hi >> (31 - unbiased) when unbiased <= 31
    # value = mant_hi << (unbiased - 31) when unbiased > 31
    var result = 0;
    if (unbiased <= 31) {
        result = mant_hi >> (31 - unbiased);
    } else {
        # Need lower mantissa bits too
        var mant_lo = (load8(ext+6) << 24) | (load8(ext+7) << 16) | (load8(ext+8) << 8) | load8(ext+9);
        var shift = unbiased - 31;
        result = (mant_hi << shift) | (mant_lo >> (32 - shift));
    }

    # Return as f64 for consistency with FormatInfo duration calculations
    return f64_from(result);
}

# Convert a positive integer to 80-bit IEEE 754 extended float
# For sample rates (always positive integers like 44100, 48000)
# val: integer value, ext: pointer to 10-byte output buffer
fn f64_to_extended(val, ext) {
    if (val == 0) {
        for (var i = 0; i < 10; i = i + 1) { store8(ext + i, 0); }
        return 0;
    }

    # Find highest set bit position (0-based from LSB)
    var n = val;
    var p = 0;
    while (n > 1) { n = n >> 1; p = p + 1; }

    var biased = p + 16383;
    # mantissa = val << (63 - p), with explicit integer bit
    var mantissa = val << (63 - p);

    store8(ext, (biased >> 8) & 0x7F);
    store8(ext + 1, biased & 0xFF);
    for (var i = 0; i < 8; i = i + 1) {
        store8(ext + 2 + i, (mantissa >> (56 - i * 8)) & 0xFF);
    }
    return 0;
}

# Endianness constants
enum Endian { ENDIAN_BIG = 0; ENDIAN_LITTLE = 1; }

# Decode signed big-endian 16-bit samples to f64 vec
fn i16be_to_f64(src, count) {
    var v = vec_new();
    for (var i = 0; i < count; i = i + 1) {
        var raw = read_u16_be(src, i * 2);
        var signed = sign_extend(raw, 16);
        vec_push(v, f64_div(f64_from(signed), F64_32768));
    }
    return v;
}

# Decode signed big-endian 24-bit samples to f64 vec
fn i24be_to_f64(src, count) {
    var v = vec_new();
    for (var i = 0; i < count; i = i + 1) {
        var off = i * 3;
        var raw = (load8(src+off) << 16) | (load8(src+off+1) << 8) | load8(src+off+2);
        var signed = sign_extend(raw, 24);
        vec_push(v, f64_div(f64_from(signed), F64_8388608));
    }
    return v;
}

# Decode signed big-endian 32-bit samples to f64 vec
fn i32be_to_f64(src, count) {
    var v = vec_new();
    for (var i = 0; i < count; i = i + 1) {
        var raw = read_u32_be(src, i * 4);
        var signed = sign_extend(raw, 32);
        vec_push(v, f64_div(f64_from(signed), F64_2147483648));
    }
    return v;
}

# Decode signed 8-bit AIFF samples (signed, not unsigned like WAV)
fn i8_to_f64(src, count) {
    var v = vec_new();
    for (var i = 0; i < count; i = i + 1) {
        var raw = load8(src + i);
        var signed = sign_extend(raw, 8);
        vec_push(v, f64_div(f64_from(signed), F64_128));
    }
    return v;
}

# Decode PCM bytes based on bit depth and endianness
fn aiff_decode_pcm(audio, audio_len, bits, endian) {
    if (bits == 8) {
        return i8_to_f64(audio, audio_len);
    }
    if (bits == 16) {
        var count = audio_len / 2;
        if (endian == ENDIAN_BIG) { return i16be_to_f64(audio, count); }
        return i16_to_f64(audio, count);
    }
    if (bits == 24) {
        var count = audio_len / 3;
        if (endian == ENDIAN_BIG) { return i24be_to_f64(audio, count); }
        return i24_packed_to_f64(audio, count);
    }
    if (bits == 32) {
        var count = audio_len / 4;
        if (endian == ENDIAN_BIG) { return i32be_to_f64(audio, count); }
        return i32_to_f64(audio, count);
    }
    return vec_new();
}

# Decode AIFF/AIFF-C data
# data: pointer to AIFF bytes, len: total byte length
# Returns: decode_result pointer, or negative error
fn aiff_decode(data, len) {
    if (len < 12) { return err(ERR_INVALID_HEADER); }

    # Check "FORM" magic
    if (load8(data) != 0x46)   { return err(ERR_INVALID_HEADER); }
    if (load8(data+1) != 0x4F) { return err(ERR_INVALID_HEADER); }
    if (load8(data+2) != 0x52) { return err(ERR_INVALID_HEADER); }
    if (load8(data+3) != 0x4D) { return err(ERR_INVALID_HEADER); }

    # Check AIFF or AIFC at offset 8
    var is_aifc = 0;
    if (load8(data+8)==0x41) {
        if (load8(data+9)==0x49) {
            if (load8(data+10)==0x46) {
                if (load8(data+11)==0x46) { is_aifc = 0; }
                if (load8(data+11)==0x43) { is_aifc = 1; }
            }
        }
    }

    var pos = 12;
    var channels = 0;
    var sample_size = 0;
    var sample_rate_f = F64_ZERO;
    var comm_found = 0;
    var ssnd_start = 0;
    var ssnd_len = 0;
    var ssnd_found = 0;
    var endian = ENDIAN_BIG;

    while (pos + 8 <= len) {
        var ck0 = load8(data+pos);
        var ck1 = load8(data+pos+1);
        var ck2 = load8(data+pos+2);
        var ck3 = load8(data+pos+3);
        var ck_size = read_u32_be(data, pos + 4);

        # "COMM" = 0x43 0x4F 0x4D 0x4D
        if (ck0==0x43) { if (ck1==0x4F) { if (ck2==0x4D) { if (ck3==0x4D) {
            var base = pos + 8;
            channels = read_u16_be(data, base);
            # num_sample_frames at base+2 (4 bytes), skip
            sample_size = read_u16_be(data, base + 6);

            # 10-byte extended float sample rate at base+8
            sample_rate_f = extended_to_f64(data + base + 8);

            if (is_aifc == 1) {
                # Compression type at base+18 (4 bytes)
                if (base + 22 <= len) {
                    var c0 = load8(data+base+18);
                    var c1 = load8(data+base+19);
                    var c2 = load8(data+base+20);
                    var c3 = load8(data+base+21);
                    # "NONE" = 0x4E 0x4F 0x4E 0x45
                    if (c0==0x4E) { if (c1==0x4F) { if (c2==0x4E) { if (c3==0x45) {
                        endian = ENDIAN_BIG;
                    }}}}
                    # "sowt" = 0x73 0x6F 0x77 0x74
                    if (c0==0x73) { if (c1==0x6F) { if (c2==0x77) { if (c3==0x74) {
                        endian = ENDIAN_LITTLE;
                    }}}}
                }
            }
            comm_found = 1;
        }}}}

        # "SSND" = 0x53 0x53 0x4E 0x44
        if (ck0==0x53) { if (ck1==0x53) { if (ck2==0x4E) { if (ck3==0x44) {
            if (ck_size >= 8) {
                var ssnd_offset = read_u32_be(data, pos + 8);
                # Guard against underflow: ssnd_offset must fit within chunk
                if (ssnd_offset <= ck_size - 8) {
                    var pcm_start = pos + 8 + 8 + ssnd_offset;
                    if (pcm_start <= len) {
                        ssnd_len = ck_size - 8 - ssnd_offset;
                        ssnd_start = pcm_start;
                        ssnd_found = 1;
                    }
                }
            }
        }}}}

        # Advance to next chunk with overflow guard
        if (ck_size > len - pos - 8) { pos = len + 1; }
        else { pos = pos + 8 + ck_size + (ck_size & 1); }
        if (comm_found == 1) { if (ssnd_found == 1) { pos = len + 1; } }
    }

    if (comm_found == 0) { return err(ERR_INVALID_HEADER); }
    if (ssnd_found == 0) { return err(ERR_INVALID_HEADER); }
    if (channels == 0)   { return err(ERR_INVALID_CHANNELS); }

    var sample_rate = f64_to(sample_rate_f);
    if (sample_rate == 0) { return err(ERR_INVALID_RATE); }

    var avail = len - ssnd_start;
    if (ssnd_len > avail) { ssnd_len = avail; }

    var samples = aiff_decode_pcm(data + ssnd_start, ssnd_len, sample_size, endian);
    var sc = vec_len(samples);
    var tf = sc / channels;
    var dur = f64_div(f64_from(tf), f64_from(sample_rate));

    return decode_result_new(
        fmtinfo_new(FMT_AIFF, sample_rate, channels, sample_size, dur, tf),
        samples
    );
}

# Encode f64 samples to big-endian PCM bytes
fn f64_to_i16_be(samples, out) {
    var len = vec_len(samples);
    for (var i = 0; i < len; i = i + 1) {
        var s = f64_clamp_sample(vec_get(samples, i));
        var val = f64_to(f64_mul(s, F64_32767));
        write_u16_be(out, i * 2, val & 0xFFFF);
    }
    return len * 2;
}

fn f64_to_i24_be(samples, out) {
    var len = vec_len(samples);
    for (var i = 0; i < len; i = i + 1) {
        var s = f64_clamp_sample(vec_get(samples, i));
        var val = f64_to(f64_mul(s, F64_8388607));
        var off = i * 3;
        store8(out+off, (val >> 16) & 0xFF);
        store8(out+off+1, (val >> 8) & 0xFF);
        store8(out+off+2, val & 0xFF);
    }
    return len * 3;
}

fn f64_to_i32_be(samples, out) {
    var len = vec_len(samples);
    for (var i = 0; i < len; i = i + 1) {
        var s = f64_clamp_sample(vec_get(samples, i));
        var val = f64_to(f64_mul(s, F64_2147483647));
        write_u32_be(out, i * 4, val);
    }
    return len * 4;
}

fn f64_to_i8_signed(samples, out) {
    var len = vec_len(samples);
    var F64_127 = f64_from(127);
    for (var i = 0; i < len; i = i + 1) {
        var s = f64_clamp_sample(vec_get(samples, i));
        var val = f64_to(f64_mul(s, F64_127));
        store8(out + i, val & 0xFF);
    }
    return len;
}

# Encode interleaved f64 samples as AIFF byte stream (big-endian PCM)
# samples: vec, sample_rate: Hz, channels: count, bits: 8/16/24/32
# out: buffer to write AIFF data into
# Returns: total bytes written, or negative error
fn aiff_encode(samples, sample_rate, channels, bits, out) {
    if (channels == 0)    { return err(ERR_INVALID_CHANNELS); }
    if (sample_rate == 0) { return err(ERR_INVALID_RATE); }
    if (bits != 8) { if (bits != 16) { if (bits != 24) { if (bits != 32) {
        return err(ERR_ENCODE);
    }}}}

    var num_frames = vec_len(samples) / channels;

    # Encode raw PCM to temp area after header space
    # Header: FORM(12) + COMM(8+18) + SSND(8+8) = 54 bytes
    var header_size = 54;
    var raw_data = out + header_size;
    var raw_size = 0;

    if (bits == 8)  { raw_size = f64_to_i8_signed(samples, raw_data); }
    if (bits == 16) { raw_size = f64_to_i16_be(samples, raw_data); }
    if (bits == 24) { raw_size = f64_to_i24_be(samples, raw_data); }
    if (bits == 32) { raw_size = f64_to_i32_be(samples, raw_data); }

    var ssnd_data_size = 8 + raw_size;
    var comm_size = 18;
    var form_payload = 4 + 8 + comm_size + 8 + ssnd_data_size;

    # FORM header
    store8(out, 0x46); store8(out+1, 0x4F); store8(out+2, 0x52); store8(out+3, 0x4D);
    write_u32_be(out, 4, form_payload);
    store8(out+8, 0x41); store8(out+9, 0x49); store8(out+10, 0x46); store8(out+11, 0x46);

    # COMM chunk
    store8(out+12, 0x43); store8(out+13, 0x4F); store8(out+14, 0x4D); store8(out+15, 0x4D);
    write_u32_be(out, 16, comm_size);
    write_u16_be(out, 20, channels);
    write_u32_be(out, 22, num_frames);
    write_u16_be(out, 26, bits);
    # 10-byte extended float sample rate at offset 28
    f64_to_extended(sample_rate, out + 28);

    # SSND chunk
    store8(out+38, 0x53); store8(out+39, 0x53); store8(out+40, 0x4E); store8(out+41, 0x44);
    write_u32_be(out, 42, ssnd_data_size);
    write_u32_be(out, 46, 0);  # offset
    write_u32_be(out, 50, 0);  # blockSize

    return header_size + raw_size;
}

# ================================================================
# ALAC module — Apple Lossless Audio Codec decoder
# ================================================================

# ALAC constants
var ALAC_MB0 = 10;
var ALAC_MAX_PREFIX = 9;
var ALAC_QBSHIFT = 9;
var ALAC_MAX_COEFS = 32;

# ALAC element tags
enum AlacTag { ID_SCE = 0; ID_CPE = 1; ID_LFE = 3; ID_END = 7; }

# ALACSpecificConfig — parsed from 24 bytes
# Layout (80 bytes):
#   +0:  frame_length (i64)
#   +8:  bit_depth (i64)
#   +16: pb (i64)
#   +24: mb (i64)
#   +32: kb (i64)
#   +40: num_channels (i64)
#   +48: max_run (i64)
#   +56: max_frame_bytes (i64)
#   +64: avg_bit_rate (i64)
#   +72: sample_rate (i64)
fn alac_config_new() {
    return alloc(80);
}
fn alac_config_set(cfg, idx, val) { store64(cfg + idx * 8, val); return 0; }
fn alac_config_get(cfg, idx) { return load64(cfg + idx * 8); }

fn alac_parse_config(data, len) {
    if (len < 24) { return err(ERR_INVALID_HEADER); }

    var frame_length = read_u32_be(data, 0);
    var version = load8(data + 4);
    if (version != 0) { return err(ERR_INVALID_HEADER); }

    var bit_depth = load8(data + 5);
    if (bit_depth != 16) { if (bit_depth != 20) { if (bit_depth != 24) { if (bit_depth != 32) {
        return err(ERR_INVALID_HEADER);
    }}}}

    var pb = load8(data + 6);
    var mb = load8(data + 7);
    var kb = load8(data + 8);
    var num_ch = load8(data + 9);
    if (num_ch == 0) { return err(ERR_INVALID_CHANNELS); }
    if (num_ch > 8)  { return err(ERR_INVALID_CHANNELS); }

    var max_run = read_u16_be(data, 10);
    var max_frame_bytes = read_u32_be(data, 12);
    var avg_bit_rate = read_u32_be(data, 16);
    var sample_rate = read_u32_be(data, 20);
    if (sample_rate == 0) { return err(ERR_INVALID_RATE); }

    var cfg = alac_config_new();
    alac_config_set(cfg, 0, frame_length);
    alac_config_set(cfg, 1, bit_depth);
    alac_config_set(cfg, 2, pb);
    alac_config_set(cfg, 3, mb);
    alac_config_set(cfg, 4, kb);
    alac_config_set(cfg, 5, num_ch);
    alac_config_set(cfg, 6, max_run);
    alac_config_set(cfg, 7, max_frame_bytes);
    alac_config_set(cfg, 8, avg_bit_rate);
    alac_config_set(cfg, 9, sample_rate);
    return cfg;
}

# MSB-first bit reader for ALAC
# Layout (24 bytes): +0: data_ptr, +8: byte_pos, +16: bit_pos
fn bitreader_new(data, len) {
    var br = alloc(32);
    store64(br, data);
    store64(br + 8, 0);
    store64(br + 16, 0);
    store64(br + 24, len);
    return br;
}

fn bitreader_read(br, bits) {
    if (bits == 0) { return 0; }
    # SEC-016: reject negative or oversized bit requests
    if (bits < 0) { return err(ERR_DECODE); }
    if (bits > 64) { return err(ERR_DECODE); }
    var data = load64(br);
    var bpos = load64(br + 8);
    var bbit = load64(br + 16);
    var dlen = load64(br + 24);
    var result = 0;
    var remaining = bits;

    while (remaining > 0) {
        if (bpos >= dlen) { return err(ERR_END_OF_STREAM); }
        var avail = 8 - bbit;
        var take = remaining;
        if (take > avail) { take = avail; }
        var shift = avail - take;
        # take is at most 8 (capped by avail), so 1 << take is safe
        var mask = ((1 << take) - 1) << shift;
        var val = (load8(data + bpos) & mask) >> shift;
        result = (result << take) | val;
        remaining = remaining - take;
        bbit = bbit + take;
        if (bbit >= 8) { bbit = 0; bpos = bpos + 1; }
    }

    store64(br + 8, bpos);
    store64(br + 16, bbit);
    return result;
}

fn bitreader_read_bit(br) {
    return bitreader_read(br, 1);
}

# Floor of log2(x + 3)
fn alac_lg3(x) {
    var v = x + 3;
    var r = 0;
    while (v > 1) { v = v >> 1; r = r + 1; }
    return r;
}

# Decode a single Rice-coded value
fn alac_rice_decode(br, m, k, max_bits) {
    var prefix = 0;
    while (prefix < ALAC_MAX_PREFIX) {
        var b = bitreader_read_bit(br);
        if (is_err(b) == 1) { return b; }
        if (b == 0) { prefix = ALAC_MAX_PREFIX + 1; }
        else { prefix = prefix + 1; }
    }
    # Adjust: if we broke out with b==0, prefix was not incremented for that bit
    if (prefix > ALAC_MAX_PREFIX) { prefix = prefix - ALAC_MAX_PREFIX - 1; }

    if (prefix >= ALAC_MAX_PREFIX) {
        return bitreader_read(br, max_bits);
    }

    var suffix = 0;
    if (k > 0) { suffix = bitreader_read(br, k); }
    if (is_err(suffix) == 1) { return suffix; }
    return prefix * m + suffix;
}

# Decode Rice-coded residual block
# output: pre-allocated buffer (pointer), num_samples: count
fn alac_rice_decode_block(br, output, num_samples, max_bits, pb, kb) {
    var history = ALAC_MB0;
    var sign_mod = 0;
    var i = 0;

    while (i < num_samples) {
        var k = alac_lg3(history);
        if (k > kb) { k = kb; }
        var m = (1 << k) - 1;

        var raw = alac_rice_decode(br, m, k, max_bits);
        if (is_err(raw) == 1) { return raw; }
        raw = raw + sign_mod;

        # Unsigned to signed: 0,1,2,3,4 -> 0,-1,1,-2,2
        var signed = 0;
        if ((raw & 1) != 0) {
            signed = 0 - ((raw + 1) >> 1);
        } else {
            signed = raw >> 1;
        }

        store64(output + i * 8, signed);
        sign_mod = 0;

        # Update history
        if (raw > 0xFFFF) { history = 0xFFFF; }
        else {
            history = history + (raw * pb) - ((history * pb) >> ALAC_QBSHIFT);
        }

        # Zero-run detection
        if (history < 128) {
            if ((i + 1) < num_samples) {
                var k_run = alac_lg3(history);
                if (k_run > kb) { k_run = kb; }
                var m_run = (1 << k_run) - 1;
                var run_len = alac_rice_decode(br, m_run, k_run, 16);
                if (is_err(run_len) == 1) { return run_len; }
                var run = run_len;
                if (run > (num_samples - i - 1)) { run = num_samples - i - 1; }
                var j = 0;
                while (j < run) {
                    i = i + 1;
                    if (i < num_samples) { store64(output + i * 8, 0); }
                    j = j + 1;
                }
                history = 0;
                sign_mod = 1;
            }
        }
        i = i + 1;
    }
    return 0;
}

# Apply inverse LPC prediction (unfilter)
# buf: pointer to i64 array, num_samples: count
# coefs: pointer to i64 array of coefficients, num_coefs: count
# den_shift: shift amount
fn alac_unfilter(buf, num_samples, coefs, num_coefs, den_shift) {
    if (num_coefs == 0) { return 0; }
    if (num_samples == 0) { return 0; }

    # Warmup: cumulative sum for first num_coefs samples
    var limit = num_coefs;
    if (limit > num_samples - 1) { limit = num_samples - 1; }
    for (var j = 1; j <= limit; j = j + 1) {
        var prev = load64(buf + (j-1) * 8);
        var cur = load64(buf + j * 8);
        store64(buf + j * 8, cur + prev);
    }

    if (num_coefs + 1 >= num_samples) { return 0; }

    # Main prediction loop
    for (var j = num_coefs + 1; j < num_samples; j = j + 1) {
        var prediction = 0;
        var base = load64(buf + (j - num_coefs - 1) * 8);
        for (var c = 0; c < num_coefs; c = c + 1) {
            var diff = load64(buf + (j - 1 - c) * 8) - base;
            var coef = load64(coefs + c * 8);
            prediction = prediction + diff * coef;
        }
        # Arithmetic right shift for signed values
        # SEC-009: guard INT64_MIN (negation overflows in two's complement)
        var pred_shifted = prediction;
        if (den_shift > 0) {
            # Manual arithmetic right shift since >> is logical
            if (prediction == (1 << 63)) {
                # Guard: 0 - INT64_MIN == INT64_MIN (overflow), treat as 0
                pred_shifted = 0;
            } else {
                if (prediction < 0) {
                    pred_shifted = 0 - ((0 - prediction) >> den_shift);
                } else {
                    pred_shifted = prediction >> den_shift;
                }
            }
        }
        var prev_sample = load64(buf + (j-1) * 8);
        var residual = load64(buf + j * 8);
        store64(buf + j * 8, residual + pred_shifted + prev_sample);
    }
    return 0;
}

# Stereo de-matrixing (unmix)
fn alac_unmix_stereo(u_buf, v_buf, out_l, out_r, num_samples, mix_bits, mix_res) {
    for (var i = 0; i < num_samples; i = i + 1) {
        var u = load64(u_buf + i * 8);
        var v = load64(v_buf + i * 8);
        if (mix_res != 0) {
            var left = u + v - ((mix_res * v) >> mix_bits);
            var right = left - v;
            store64(out_l + i * 8, left);
            store64(out_r + i * 8, right);
        } else {
            store64(out_l + i * 8, u);
            store64(out_r + i * 8, v);
        }
    }
    return 0;
}

# Decode a single ALAC element (mono or stereo)
fn alac_decode_element(br, cfg, channels, max_bits) {
    var _unused = bitreader_read(br, 12);
    var partial = bitreader_read_bit(br);
    var bytes_shifted = bitreader_read(br, 2);
    var escape_flag = bitreader_read_bit(br);

    var num_samples = 0;
    if (partial == 1) {
        var hi = bitreader_read(br, 16);
        var lo = bitreader_read(br, 16);
        num_samples = (hi << 16) | lo;
    } else {
        num_samples = alac_config_get(cfg, 0);
    }

    if (num_samples == 0) { return vec_new(); }
    if (num_samples > 16384) { return err(ERR_DECODE); }

    var shifted_bits = bytes_shifted * 8;
    if (shifted_bits >= max_bits) { return err(ERR_DECODE); }
    var effective_bits = max_bits - shifted_bits;

    if (escape_flag == 1) {
        # Uncompressed: read raw samples
        var total = num_samples * channels;
        var out = vec_new();
        for (var i = 0; i < total; i = i + 1) {
            var raw = bitreader_read(br, max_bits);
            if (is_err(raw) == 1) { return raw; }
            vec_push(out, sign_extend(raw, max_bits));
        }
        return out;
    }

    # Compressed frame
    var mix_bits = bitreader_read(br, 8);
    var mix_res = bitreader_read(br, 8);
    # Sign-extend mix_res from 8 bits
    mix_res = sign_extend(mix_res, 8);

    # Read prediction params per channel
    var pred_modes = alloc(channels * 8);
    var den_shifts = alloc(channels * 8);
    var pb_factors = alloc(channels * 8);
    var num_coefs_arr = alloc(channels * 8);
    var coefs_arr = alloc(channels * 8);  # pointers to coef arrays

    for (var ch = 0; ch < channels; ch = ch + 1) {
        store64(pred_modes + ch*8, bitreader_read(br, 4));
        store64(den_shifts + ch*8, bitreader_read(br, 4));
        store64(pb_factors + ch*8, bitreader_read(br, 3));
        var nc = bitreader_read(br, 5);
        if (nc > ALAC_MAX_COEFS) { nc = ALAC_MAX_COEFS; }
        store64(num_coefs_arr + ch*8, nc);

        var coefs = alloc(nc * 8);
        for (var c = 0; c < nc; c = c + 1) {
            var raw = bitreader_read(br, 16);
            store64(coefs + c * 8, sign_extend(raw, 16));
        }
        store64(coefs_arr + ch*8, coefs);
    }

    # Decode residuals per channel
    var pb = alac_config_get(cfg, 2);
    var kb = alac_config_get(cfg, 4);
    var channel_bufs = alloc(channels * 8);

    for (var ch = 0; ch < channels; ch = ch + 1) {
        var pbf = load64(pb_factors + ch*8);
        var adj_pb = (pb * pbf) >> 2;
        var residuals = alloc(num_samples * 8);
        for (var z = 0; z < num_samples; z = z + 1) { store64(residuals + z*8, 0); }
        var rc = alac_rice_decode_block(br, residuals, num_samples, effective_bits, adj_pb, kb);
        if (is_err(rc) == 1) { return rc; }
        store64(channel_bufs + ch*8, residuals);
    }

    # Apply inverse LPC per channel
    for (var ch = 0; ch < channels; ch = ch + 1) {
        if (load64(pred_modes + ch*8) == 0) {
            var buf = load64(channel_bufs + ch*8);
            var nc = load64(num_coefs_arr + ch*8);
            var coefs = load64(coefs_arr + ch*8);
            var ds = load64(den_shifts + ch*8);
            alac_unfilter(buf, num_samples, coefs, nc, ds);
        }
    }

    # Stereo de-matrixing
    if (channels == 2) {
        if (mix_res != 0) {
            var u_buf = load64(channel_bufs);
            var v_buf = load64(channel_bufs + 8);
            var out_l = alloc(num_samples * 8);
            var out_r = alloc(num_samples * 8);
            alac_unmix_stereo(u_buf, v_buf, out_l, out_r, num_samples, mix_bits, mix_res);
            store64(channel_bufs, out_l);
            store64(channel_bufs + 8, out_r);
        }
    }

    # Interleave into output vec
    var out = vec_new();
    for (var i = 0; i < num_samples; i = i + 1) {
        for (var ch = 0; ch < channels; ch = ch + 1) {
            var buf = load64(channel_bufs + ch*8);
            vec_push(out, load64(buf + i*8));
        }
    }
    return out;
}

# Decode raw ALAC data: 24-byte config + frame bytes
fn alac_decode(data, len) {
    if (len < 24) { return err(ERR_INVALID_HEADER); }

    var cfg = alac_parse_config(data, 24);
    if (is_err(cfg) == 1) { return cfg; }

    var bit_depth = alac_config_get(cfg, 1);
    var num_ch = alac_config_get(cfg, 5);
    var sample_rate = alac_config_get(cfg, 9);
    var max_bits = bit_depth;

    var br = bitreader_new(data + 24, len - 24);

    # Collect all channel samples
    var all_channels = vec_new();
    var done = 0;

    while (done == 0) {
        var tag = bitreader_read(br, 3);
        if (is_err(tag) == 1) { done = 1; }
        else {
            if (tag == ID_END) { done = 1; }
            else {
                var _inst = bitreader_read(br, 4);
                if (tag == ID_SCE) {
                    var samples = alac_decode_element(br, cfg, 1, max_bits);
                    if (is_err(samples) == 1) { return samples; }
                    vec_push(all_channels, samples);
                }
                if (tag == ID_LFE) {
                    var samples = alac_decode_element(br, cfg, 1, max_bits);
                    if (is_err(samples) == 1) { return samples; }
                    vec_push(all_channels, samples);
                }
                if (tag == ID_CPE) {
                    var samples = alac_decode_element(br, cfg, 2, max_bits);
                    if (is_err(samples) == 1) { return samples; }
                    # Deinterleave into two channels
                    var nf = vec_len(samples) / 2;
                    var left = vec_new();
                    var right = vec_new();
                    for (var i = 0; i < nf; i = i + 1) {
                        vec_push(left, vec_get(samples, i * 2));
                        vec_push(right, vec_get(samples, i * 2 + 1));
                    }
                    vec_push(all_channels, left);
                    vec_push(all_channels, right);
                }
            }
        }
    }

    if (vec_len(all_channels) == 0) {
        return decode_result_new(
            fmtinfo_new(FMT_ALAC, sample_rate, num_ch, bit_depth, F64_ZERO, 0),
            vec_new()
        );
    }

    # Convert to interleaved f64 samples
    var nch = vec_len(all_channels);
    var ch0 = vec_get(all_channels, 0);
    var nframes = vec_len(ch0);
    var scale = f64_pow(F64_TWO, f64_from(bit_depth - 1));
    var output = vec_new();

    for (var fr = 0; fr < nframes; fr = fr + 1) {
        for (var c = 0; c < nch; c = c + 1) {
            var ch = vec_get(all_channels, c);
            if (fr < vec_len(ch)) {
                vec_push(output, f64_div(f64_from(vec_get(ch, fr)), scale));
            } else {
                vec_push(output, F64_ZERO);
            }
        }
    }

    var total_frames = nframes;
    var dur = f64_div(f64_from(total_frames), f64_from(sample_rate));

    return decode_result_new(
        fmtinfo_new(FMT_ALAC, sample_rate, nch, bit_depth, dur, total_frames),
        output
    );
}

# ================================================================
# Codec module — auto-detect and dispatch
# ================================================================

# Auto-detect format and decode.
# data: pointer to audio bytes, len: total length
# Returns: decode_result pointer, or negative error
fn codec_open(data, len) {
    var fmt = detect_format(data, len);
    if (is_err(fmt) == 1) { return fmt; }

    if (fmt == FMT_WAV)  { return wav_decode(data, len); }
    if (fmt == FMT_AIFF) { return aiff_decode(data, len); }
    if (fmt == FMT_FLAC) { return flac_decode(data, len); }
    if (fmt == FMT_OGG)  { return ogg_decode(data, len); }
    if (fmt == FMT_MP3)  { return mp3_decode(data, len); }
    if (fmt == FMT_AAC)  { return aac_decode(data, len); }
    if (fmt == FMT_ALAC) { return alac_decode(data, len); }
    if (fmt == FMT_OPUS) { return ogg_decode(data, len); }
    if (fmt == FMT_MP4)  { return mp4_decode(data, len); }

    return err(ERR_UNSUPPORTED_FMT);
}

# ================================================================
# Convenience helpers: decode_file / decode_reader
# ================================================================

# Decode an audio file from a filesystem path.
# path: null-terminated C string path
# Returns: decode_result pointer, or negative error
fn decode_file(path) {
    var fd = file_open(path, 0, 0);  # O_RDONLY = 0, mode unused (6.x file_open(path, flags, mode))
    if (fd < 0) { return err(ERR_DECODE); }

    # Read entire file into buffer
    var buf_cap = 1048576;  # 1MB initial
    var buf = alloc(buf_cap);
    var total = 0;

    var reading = 1;
    while (reading == 1) {
        var avail = buf_cap - total;
        if (avail <= 0) {
            # Grow buffer (double, cap at 256MB)
            if (buf_cap >= 268435456) {
                file_close(fd);
                return err(ERR_DECODE);
            }
            var new_cap = buf_cap * 2;
            var new_buf = alloc(new_cap);
            memcpy(new_buf, buf, total);
            buf = new_buf;
            buf_cap = new_cap;
            avail = buf_cap - total;
        }
        var n = file_read(fd, buf + total, avail);
        if (n <= 0) { reading = 0; }
        else { total = total + n; }
    }

    file_close(fd);

    if (total == 0) { return err(ERR_DECODE); }

    return codec_open(buf, total);
}

# Streaming decode: feed chunks of data, receive events.
# Returns a stream decoder (wav/flac/aiff auto-detected on first feed).
# chunk_frames: number of frames per SAMPLES event (0 = single-shot)
fn decode_reader(chunk_frames) {
    # Auto-detect stream type from first feed via wrapper struct.
    # Layout (32 bytes):
    #   +0:  state (0=detecting, 1=wav, 2=flac, 3=aiff)
    #   +8:  inner stream handle
    #   +16: chunk_frames
    #   +24: header buffer pointer
    var dr = alloc(32);
    store64(dr, 0);
    store64(dr + 8, 0);
    store64(dr + 16, chunk_frames);
    store64(dr + 24, alloc(4096));
    return dr;
}

fn decode_reader_feed(dr, data, len) {
    var state = load64(dr);
    var chunk_frames = load64(dr + 16);
    if (chunk_frames == 0) { chunk_frames = 4096; }

    if (state == 0) {
        # Detecting: need at least 12 bytes for format magic
        if (len < 12) { return vec_new(); }
        var fmt = detect_format(data, len);
        if (is_err(fmt) == 1) { return vec_new(); }

        if (fmt == FMT_WAV) {
            var s = wav_stream_new(chunk_frames);
            store64(dr, 1);
            store64(dr + 8, s);
            return wav_stream_feed(s, data, len);
        }
        if (fmt == FMT_FLAC) {
            var s = flac_stream_new();  # full-buffer decoder; ignores chunk_frames by design
            store64(dr, 2);
            store64(dr + 8, s);
            return flac_stream_feed(s, data, len);
        }
        if (fmt == FMT_AIFF) {
            var s = aiff_stream_new(chunk_frames);
            store64(dr, 3);
            store64(dr + 8, s);
            return aiff_stream_feed(s, data, len);
        }
        return vec_new();  # unsupported format for streaming
    }

    var inner = load64(dr + 8);
    if (state == 1) { return wav_stream_feed(inner, data, len); }
    if (state == 2) { return flac_stream_feed(inner, data, len); }
    if (state == 3) { return aiff_stream_feed(inner, data, len); }
    return vec_new();
}

fn decode_reader_flush(dr) {
    var state = load64(dr);
    var inner = load64(dr + 8);
    if (state == 1) { return wav_stream_flush(inner); }
    if (state == 2) { return flac_stream_flush(inner); }
    if (state == 3) { return aiff_stream_flush(inner); }
    return vec_new();
}

# --- flac.cyr ---

# ================================================================
# FLAC — Free Lossless Audio Codec (decoder + encoder)
# ================================================================
#
# Decoder: STREAMINFO, frame sync, CRC-8/16, subframes (CONSTANT,
#          VERBATIM, FIXED 0-4, LPC 1-32), Rice/Rice2, channel
#          decorrelation (independent, left-side, right-side, mid-side).
#
# Encoder: Fixed prediction (order 0-4), Rice coding, mid-side stereo,
#          CRC-8/16, MD5 signature.
#
# All samples stored as f64 bit patterns in vec (matches the rest of shravan).

# Channel assignment codes
var FLAC_CH_LEFT_SIDE  = 8;
var FLAC_CH_RIGHT_SIDE = 9;
var FLAC_CH_MID_SIDE   = 10;

# Decorrelation modes
var FLAC_DECOR_INDEPENDENT = 0;
var FLAC_DECOR_LEFT_SIDE   = 1;
var FLAC_DECOR_RIGHT_SIDE  = 2;
var FLAC_DECOR_MID_SIDE    = 3;

# ================================================================
# CRC-8 (polynomial 0x07, init 0)
# ================================================================

var flac_crc8_table = 0;

fn flac_crc8_init() {
    flac_crc8_table = alloc(256);
    var i = 0;
    while (i < 256) {
        var crc = i;
        var bit = 0;
        while (bit < 8) {
            if ((crc & 0x80) != 0) {
                crc = ((crc << 1) ^ 0x07) & 0xFF;
            } else {
                crc = (crc << 1) & 0xFF;
            }
            bit = bit + 1;
        }
        store8(flac_crc8_table + i, crc);
        i = i + 1;
    }
    return 0;
}

fn flac_crc8(data, len) {
    var crc = 0;
    var i = 0;
    while (i < len) {
        crc = load8(flac_crc8_table + ((crc ^ load8(data + i)) & 0xFF));
        i = i + 1;
    }
    return crc;
}

# ================================================================
# CRC-16 (polynomial 0x8005, init 0)
# ================================================================

var flac_crc16_table = 0;

fn flac_crc16_init() {
    flac_crc16_table = alloc(256 * 8);
    var i = 0;
    while (i < 256) {
        var crc = i << 8;
        var bit = 0;
        while (bit < 8) {
            if ((crc & 0x8000) != 0) {
                crc = ((crc << 1) ^ 0x8005) & 0xFFFF;
            } else {
                crc = (crc << 1) & 0xFFFF;
            }
            bit = bit + 1;
        }
        store64(flac_crc16_table + i * 8, crc);
        i = i + 1;
    }
    return 0;
}

fn flac_crc16(data, len) {
    var crc = 0;
    var i = 0;
    while (i < len) {
        var idx = ((crc >> 8) ^ load8(data + i)) & 0xFF;
        crc = ((crc << 8) ^ load64(flac_crc16_table + idx * 8)) & 0xFFFF;
        i = i + 1;
    }
    return crc;
}

# ================================================================
# FLAC bitreader extensions (reuses bitreader_new / bitreader_read)
# ================================================================

# Read unary: count zero-bits before first 1-bit
# SEC-008: bound reduced from 1M to 32768 (max realistic: 65535 * 32bps Rice residual)
fn flac_br_read_unary(br) {
    var count = 0;
    while (1) {
        var b = bitreader_read_bit(br);
        if (is_err(b) == 1) { return b; }
        if (b == 1) { return count; }
        count = count + 1;
        if (count > 32768) { return err(ERR_DECODE); }
    }
    return count;
}

# Read UTF-8-like coded number (FLAC frame/sample number)
fn flac_br_read_utf8_u64(br) {
    var first = bitreader_read(br, 8);
    if (is_err(first) == 1) { return first; }
    if (first < 0x80) { return first; }

    # Count leading ones
    var leading = 0;
    var tmp = first;
    while ((tmp & 0x80) != 0) {
        leading = leading + 1;
        tmp = (tmp << 1) & 0xFF;
    }
    if (leading > 7) { return err(ERR_DECODE); }

    var mask = (1 << (7 - leading)) - 1;
    var value = first & mask;
    var j = 1;
    while (j < leading) {
        var b = bitreader_read(br, 8);
        if (is_err(b) == 1) { return b; }
        if ((b & 0xC0) != 0x80) { return err(ERR_DECODE); }
        value = (value << 6) | (b & 0x3F);
        j = j + 1;
    }
    return value;
}

# Align to byte boundary
fn flac_br_align(br) {
    var bbit = load64(br + 16);
    if (bbit != 0) {
        store64(br + 16, 0);
        store64(br + 8, load64(br + 8) + 1);
    }
    return 0;
}

# Get current byte position
fn flac_br_byte_pos(br) {
    return load64(br + 8);
}

# Set byte position (and reset bit pos to 0)
fn flac_br_set_pos(br, pos) {
    store64(br + 8, pos);
    store64(br + 16, 0);
    return 0;
}

# ================================================================
# STREAMINFO parsing
# ================================================================

# STREAMINFO struct layout (64 bytes):
#   +0:  min_block_size  (i64)
#   +8:  max_block_size  (i64)
#   +16: sample_rate     (i64)
#   +24: channels        (i64)
#   +32: bits_per_sample (i64)
#   +40: total_samples   (i64)
#   +48: audio_start     (i64) — byte offset where frames begin
#   +56: seek_table      (vec pointer) — vec of SeekPoint structs (24 bytes each)

fn flac_parse_streaminfo(data, offset) {
    var d = data + offset;
    var min_bs = (load8(d) << 8) | load8(d + 1);
    var max_bs = (load8(d + 2) << 8) | load8(d + 3);
    # bytes 4..9: min/max frame size (skipped)
    # bytes 10..13: sr(20) | ch-1(3) | bps-1(5) | total_hi(4)
    var sr = (load8(d + 10) << 12) | (load8(d + 11) << 4) | (load8(d + 12) >> 4);
    var ch = ((load8(d + 12) >> 1) & 0x07) + 1;
    var bps_hi = load8(d + 12) & 0x01;
    var bps = (bps_hi << 4) | (load8(d + 13) >> 4);
    bps = bps + 1;
    var ts_hi = (load8(d + 13) & 0x0F) << 32;
    var ts_lo = (load8(d + 14) << 24) | (load8(d + 15) << 16) | (load8(d + 16) << 8) | load8(d + 17);
    var total_samples = ts_hi | ts_lo;

    var si = alloc(64);
    store64(si,      min_bs);
    store64(si + 8,  max_bs);
    store64(si + 16, sr);
    store64(si + 24, ch);
    store64(si + 32, bps);
    store64(si + 40, total_samples);
    store64(si + 48, 0);
    store64(si + 56, 0);
    return si;
}

fn _flac_read_u64_be(data, off) {
    var v = load8(data + off) << 56;
    v = v | (load8(data + off + 1) << 48);
    v = v | (load8(data + off + 2) << 40);
    v = v | (load8(data + off + 3) << 32);
    v = v | (load8(data + off + 4) << 24);
    v = v | (load8(data + off + 5) << 16);
    v = v | (load8(data + off + 6) << 8);
    v = v | load8(data + off + 7);
    return v;
}

# Parse metadata blocks, return STREAMINFO struct with audio_start and seek_table
fn flac_parse_metadata(data, len) {
    if (len < 8) { return err(ERR_INVALID_HEADER); }
    if (load8(data) != 0x66) { return err(ERR_INVALID_HEADER); }
    if (load8(data + 1) != 0x4C) { return err(ERR_INVALID_HEADER); }
    if (load8(data + 2) != 0x61) { return err(ERR_INVALID_HEADER); }
    if (load8(data + 3) != 0x43) { return err(ERR_INVALID_HEADER); }

    var pos = 4;
    var si = 0;
    var seek_table = vec_new();
    var done = 0;

    while (done == 0) {
        if (pos + 4 > len) { return err(ERR_END_OF_STREAM); }
        var hdr_byte = load8(data + pos);
        var is_last = (hdr_byte & 0x80) != 0;
        var block_type = hdr_byte & 0x7F;
        var block_size = (load8(data + pos + 1) << 16) | (load8(data + pos + 2) << 8) | load8(data + pos + 3);
        pos = pos + 4;

        if (block_type == 0) {
            if (pos + 34 > len) { return err(ERR_INVALID_HEADER); }
            si = flac_parse_streaminfo(data, pos);
        }
        if (block_type == 3) {
            var num_points = block_size / 18;
            # SEC-012: cap seek points to prevent DoS from crafted SEEKTABLE
            if (num_points > 1024) { num_points = 1024; }
            var sp_pos = pos;
            for (var i = 0; i < num_points; i = i + 1) {
                if (sp_pos + 18 > len) { break; }
                var sample_number = _flac_read_u64_be(data, sp_pos);
                if (sample_number != (0 - 1)) {
                    var byte_offset = _flac_read_u64_be(data, sp_pos + 8);
                    var num_samples = (load8(data + sp_pos + 16) << 8) | load8(data + sp_pos + 17);
                    var sp = alloc(24);
                    store64(sp, sample_number);
                    store64(sp + 8, byte_offset);
                    store64(sp + 16, num_samples);
                    vec_push(seek_table, sp);
                }
                sp_pos = sp_pos + 18;
            }
        }

        if (pos + block_size > len) { return err(ERR_INVALID_HEADER); }
        pos = pos + block_size;
        if (is_last) { done = 1; }
    }

    if (si == 0) { return err(ERR_INVALID_HEADER); }
    store64(si + 48, pos);
    store64(si + 56, seek_table);
    return si;
}

# ================================================================
# Frame sync and header decoding
# ================================================================

# Find next frame sync (0xFFF8 or 0xFFF9). Returns sync byte position or error.
# Also advances br past the sync code.
fn flac_find_sync(br, data, data_len) {
    flac_br_align(br);
    var bpos = flac_br_byte_pos(br);
    while (bpos + 1 < data_len) {
        if (load8(data + bpos) == 0xFF) {
            var next = load8(data + bpos + 1);
            if (next == 0xF8) {
                flac_br_set_pos(br, bpos + 2);
                return bpos;
            }
            if (next == 0xF9) {
                flac_br_set_pos(br, bpos + 2);
                return bpos;
            }
        }
        bpos = bpos + 1;
    }
    return err(ERR_END_OF_STREAM);
}

# Decode block size from 4-bit code
fn flac_decode_block_size(code, br) {
    if (code == 0) { return err(ERR_DECODE); }
    if (code == 1) { return 192; }
    if (code >= 2) { if (code <= 5) { return 576 << (code - 2); } }
    if (code == 6) {
        var v = bitreader_read(br, 8);
        if (is_err(v) == 1) { return v; }
        return v + 1;
    }
    if (code == 7) {
        var v = bitreader_read(br, 16);
        if (is_err(v) == 1) { return v; }
        if (v + 1 > 65535) { return err(ERR_DECODE); }
        return v + 1;
    }
    if (code >= 8) { if (code <= 15) { return 256 << (code - 8); } }
    return err(ERR_DECODE);
}

# Decode sample rate from 4-bit code
fn flac_decode_sample_rate(code, br, si_rate) {
    if (code == 0)  { return si_rate; }
    if (code == 1)  { return 88200; }
    if (code == 2)  { return 176400; }
    if (code == 3)  { return 192000; }
    if (code == 4)  { return 8000; }
    if (code == 5)  { return 16000; }
    if (code == 6)  { return 22050; }
    if (code == 7)  { return 24000; }
    if (code == 8)  { return 32000; }
    if (code == 9)  { return 44100; }
    if (code == 10) { return 48000; }
    if (code == 11) { return 96000; }
    if (code == 12) {
        var v = bitreader_read(br, 8);
        if (is_err(v) == 1) { return v; }
        return v * 1000;
    }
    if (code == 13) {
        var v = bitreader_read(br, 16);
        if (is_err(v) == 1) { return v; }
        return v;
    }
    if (code == 14) {
        var v = bitreader_read(br, 16);
        if (is_err(v) == 1) { return v; }
        return v * 10;
    }
    return err(ERR_DECODE);
}

# Decode bits per sample from 3-bit code
fn flac_decode_bps(code, si_bps) {
    if (code == 0) { return si_bps; }
    if (code == 1) { return 8; }
    if (code == 2) { return 12; }
    if (code == 3) { return err(ERR_DECODE); }
    if (code == 4) { return 16; }
    if (code == 5) { return 20; }
    if (code == 6) { return 24; }
    return err(ERR_DECODE);
}

# ================================================================
# Rice residual decoding
# ================================================================

# Decode Rice-coded residuals into a pre-allocated buffer.
# Returns number of residuals or error.
fn flac_decode_residual(br, buf, block_size, pred_order) {
    var coding = bitreader_read(br, 2);
    if (is_err(coding) == 1) { return coding; }
    var rice_bits = 0;
    if (coding == 0) { rice_bits = 4; }
    else { if (coding == 1) { rice_bits = 5; }
    else { return err(ERR_DECODE); } }

    var part_order = bitreader_read(br, 4);
    if (is_err(part_order) == 1) { return part_order; }
    var num_parts = 1 << part_order;
    var total = block_size - pred_order;
    var idx = 0;
    var part = 0;

    while (part < num_parts) {
        var count = 0;
        if (part_order == 0) {
            count = block_size - pred_order;
        } else {
            if (part == 0) {
                count = (block_size >> part_order) - pred_order;
            } else {
                count = block_size >> part_order;
            }
        }

        var rparam = bitreader_read(br, rice_bits);
        if (is_err(rparam) == 1) { return rparam; }
        var escape_val = 15;
        if (rice_bits == 5) { escape_val = 31; }

        if (rparam == escape_val) {
            # Escape: raw bits per sample
            var raw_bits = bitreader_read(br, 5);
            if (is_err(raw_bits) == 1) { return raw_bits; }
            var k = 0;
            while (k < count) {
                var raw = bitreader_read(br, raw_bits);
                if (is_err(raw) == 1) { return raw; }
                store64(buf + idx * 8, sign_extend(raw, raw_bits));
                idx = idx + 1;
                k = k + 1;
            }
        } else {
            # Rice-coded
            var k = 0;
            while (k < count) {
                var q = flac_br_read_unary(br);
                if (is_err(q) == 1) { return q; }
                var rem = 0;
                if (rparam > 0) {
                    rem = bitreader_read(br, rparam);
                    if (is_err(rem) == 1) { return rem; }
                }
                var uval = (q << rparam) | rem;
                # Zigzag decode
                var sval = 0;
                if ((uval & 1) == 0) {
                    sval = uval >> 1;
                } else {
                    sval = 0 - (uval >> 1) - 1;
                }
                store64(buf + idx * 8, sval);
                idx = idx + 1;
                k = k + 1;
            }
        }
        part = part + 1;
    }
    return total;
}

# ================================================================
# Subframe decoding
# ================================================================

# Decode CONSTANT subframe -> alloc buffer of block_size samples
fn flac_decode_constant(br, block_size, bps) {
    var raw = bitreader_read(br, bps);
    if (is_err(raw) == 1) { return raw; }
    var val = sign_extend(raw, bps);
    var buf = alloc(block_size * 8);
    var i = 0;
    while (i < block_size) {
        store64(buf + i * 8, val);
        i = i + 1;
    }
    return buf;
}

# Decode VERBATIM subframe
fn flac_decode_verbatim(br, block_size, bps) {
    var buf = alloc(block_size * 8);
    var i = 0;
    while (i < block_size) {
        var raw = bitreader_read(br, bps);
        if (is_err(raw) == 1) { return raw; }
        store64(buf + i * 8, sign_extend(raw, bps));
        i = i + 1;
    }
    return buf;
}

# Decode FIXED subframe (order 0-4)
fn flac_decode_fixed(br, block_size, bps, order) {
    var buf = alloc(block_size * 8);
    # Read warm-up samples
    var i = 0;
    while (i < order) {
        var raw = bitreader_read(br, bps);
        if (is_err(raw) == 1) { return raw; }
        store64(buf + i * 8, sign_extend(raw, bps));
        i = i + 1;
    }

    # Read residuals into temp buffer
    var num_res = block_size - order;
    var res = alloc(num_res * 8);
    var rc = flac_decode_residual(br, res, block_size, order);
    if (is_err(rc) == 1) { return rc; }

    # Apply fixed prediction
    var ri = 0;
    while (ri < num_res) {
        var n = order + ri;
        var residual = load64(res + ri * 8);
        var predicted = 0;
        if (order == 0) {
            predicted = residual;
        }
        if (order == 1) {
            predicted = load64(buf + (n - 1) * 8) + residual;
        }
        if (order == 2) {
            predicted = 2 * load64(buf + (n - 1) * 8) - load64(buf + (n - 2) * 8) + residual;
        }
        if (order == 3) {
            predicted = 3 * load64(buf + (n - 1) * 8) - 3 * load64(buf + (n - 2) * 8) + load64(buf + (n - 3) * 8) + residual;
        }
        if (order == 4) {
            predicted = 4 * load64(buf + (n - 1) * 8) - 6 * load64(buf + (n - 2) * 8) + 4 * load64(buf + (n - 3) * 8) - load64(buf + (n - 4) * 8) + residual;
        }
        store64(buf + n * 8, predicted);
        ri = ri + 1;
    }
    return buf;
}

# Decode LPC subframe (order 1-32)
fn flac_decode_lpc(br, block_size, bps, order) {
    var buf = alloc(block_size * 8);
    # Read warm-up samples
    var i = 0;
    while (i < order) {
        var raw = bitreader_read(br, bps);
        if (is_err(raw) == 1) { return raw; }
        store64(buf + i * 8, sign_extend(raw, bps));
        i = i + 1;
    }

    # QLP coefficient precision (4 bits)
    var prec_raw = bitreader_read(br, 4);
    if (is_err(prec_raw) == 1) { return prec_raw; }
    if (prec_raw == 15) { return err(ERR_DECODE); }
    var qlp_prec = prec_raw + 1;

    # QLP shift (5 bits, signed)
    var shift_raw = bitreader_read(br, 5);
    if (is_err(shift_raw) == 1) { return shift_raw; }
    var qlp_shift = sign_extend(shift_raw, 5);

    # Read coefficients
    var coeffs = alloc(order * 8);
    var ci = 0;
    while (ci < order) {
        var raw = bitreader_read(br, qlp_prec);
        if (is_err(raw) == 1) { return raw; }
        store64(coeffs + ci * 8, sign_extend(raw, qlp_prec));
        ci = ci + 1;
    }

    # Read residuals
    var num_res = block_size - order;
    var res = alloc(num_res * 8);
    var rc = flac_decode_residual(br, res, block_size, order);
    if (is_err(rc) == 1) { return rc; }

    # Apply LPC prediction
    var ri = 0;
    while (ri < num_res) {
        var n = order + ri;
        var acc = 0;
        var j = 0;
        while (j < order) {
            acc = acc + load64(coeffs + j * 8) * load64(buf + (n - 1 - j) * 8);
            j = j + 1;
        }
        # Arithmetic right shift for acc >> qlp_shift
        var predicted = 0;
        if (qlp_shift >= 0) {
            if (acc < 0) {
                predicted = 0 - ((0 - acc) >> qlp_shift);
            } else {
                predicted = acc >> qlp_shift;
            }
        } else {
            predicted = acc << (0 - qlp_shift);
        }
        store64(buf + n * 8, predicted + load64(res + ri * 8));
        ri = ri + 1;
    }
    return buf;
}

# Decode a single subframe, returns pointer to sample buffer or error
fn flac_decode_subframe(br, block_size, bps) {
    # Subframe header: 1 zero bit + 6-bit type + wasted-bits flag
    var zero = bitreader_read(br, 1);
    if (is_err(zero) == 1) { return zero; }
    if (zero != 0) { return err(ERR_DECODE); }

    var sf_type = bitreader_read(br, 6);
    if (is_err(sf_type) == 1) { return sf_type; }

    var has_wasted = bitreader_read(br, 1);
    if (is_err(has_wasted) == 1) { return has_wasted; }

    var wasted = 0;
    if (has_wasted == 1) {
        wasted = flac_br_read_unary(br);
        if (is_err(wasted) == 1) { return wasted; }
        wasted = wasted + 1;
    }

    var eff_bps = bps - wasted;
    var buf = 0;

    if (sf_type == 0) {
        buf = flac_decode_constant(br, block_size, eff_bps);
    } else { if (sf_type == 1) {
        buf = flac_decode_verbatim(br, block_size, eff_bps);
    } else { if (sf_type >= 8) { if (sf_type <= 12) {
        var order = sf_type - 8;
        if (order > 4) { return err(ERR_DECODE); }
        buf = flac_decode_fixed(br, block_size, eff_bps, order);
    } else { if (sf_type >= 32) { if (sf_type <= 63) {
        var order = sf_type - 31;
        buf = flac_decode_lpc(br, block_size, eff_bps, order);
    } else {
        return err(ERR_DECODE);
    } } else {
        return err(ERR_DECODE);
    } } } else {
        return err(ERR_DECODE);
    } } }

    if (is_err(buf) == 1) { return buf; }

    # Apply wasted bits shift
    if (wasted > 0) {
        var wi = 0;
        while (wi < block_size) {
            store64(buf + wi * 8, load64(buf + wi * 8) << wasted);
            wi = wi + 1;
        }
    }
    return buf;
}

# ================================================================
# Channel decorrelation
# ================================================================

fn flac_apply_decorrelation(ch0, ch1, block_size, mode) {
    if (mode == FLAC_DECOR_INDEPENDENT) { return 0; }
    var i = 0;
    if (mode == FLAC_DECOR_LEFT_SIDE) {
        # ch0=left, ch1=side -> right = left - side
        while (i < block_size) {
            var l = load64(ch0 + i * 8);
            var s = load64(ch1 + i * 8);
            store64(ch1 + i * 8, l - s);
            i = i + 1;
        }
    }
    if (mode == FLAC_DECOR_RIGHT_SIDE) {
        # ch0=side, ch1=right -> left = side + right
        while (i < block_size) {
            var s = load64(ch0 + i * 8);
            var r = load64(ch1 + i * 8);
            store64(ch0 + i * 8, s + r);
            i = i + 1;
        }
    }
    if (mode == FLAC_DECOR_MID_SIDE) {
        while (i < block_size) {
            var m = load64(ch0 + i * 8);
            var s = load64(ch1 + i * 8);
            var mid = (m << 1) | (s & 1);
            # Arithmetic right shift for (mid + side) >> 1 and (mid - side) >> 1
            var lv = mid + s;
            var rv = mid - s;
            # These are guaranteed even so >> 1 is safe
            if (lv < 0) { lv = 0 - ((0 - lv) >> 1); } else { lv = lv >> 1; }
            if (rv < 0) { rv = 0 - ((0 - rv) >> 1); } else { rv = rv >> 1; }
            store64(ch0 + i * 8, lv);
            store64(ch1 + i * 8, rv);
            i = i + 1;
        }
    }
    return 0;
}

# ================================================================
# Main FLAC decoder
# ================================================================

fn flac_decode(data, len) {
    var si = flac_parse_metadata(data, len);
    if (is_err(si) == 1) { return si; }

    var si_rate = load64(si + 16);
    var si_ch   = load64(si + 24);
    var si_bps  = load64(si + 32);
    var audio_start = load64(si + 48);

    if (si_rate == 0) { return err(ERR_INVALID_RATE); }

    var all_samples = vec_new();
    var br = bitreader_new(data, len);
    flac_br_set_pos(br, audio_start);

    var done = 0;
    while (done == 0) {
        var sync_pos = flac_find_sync(br, data, len);
        if (is_err(sync_pos) == 1) { done = 1; }

        if (done == 0) {
            var frame_start = sync_pos;
            # Read sync code second byte to get blocking strategy
            var sync_byte2 = load8(data + sync_pos + 1);
            var _blocking = sync_byte2 & 1;

            var bs_code = bitreader_read(br, 4);
            if (is_err(bs_code) == 1) { return bs_code; }
            var sr_code = bitreader_read(br, 4);
            if (is_err(sr_code) == 1) { return sr_code; }
            var ch_assign = bitreader_read(br, 4);
            if (is_err(ch_assign) == 1) { return ch_assign; }
            var ss_code = bitreader_read(br, 3);
            if (is_err(ss_code) == 1) { return ss_code; }
            var _reserved = bitreader_read(br, 1);
            if (is_err(_reserved) == 1) { return _reserved; }

            var _frame_num = flac_br_read_utf8_u64(br);
            if (is_err(_frame_num) == 1) { return _frame_num; }

            var block_size = flac_decode_block_size(bs_code, br);
            if (is_err(block_size) == 1) { return block_size; }
            var _frame_sr = flac_decode_sample_rate(sr_code, br, si_rate);
            if (is_err(_frame_sr) == 1) { return _frame_sr; }
            var frame_bps = flac_decode_bps(ss_code, si_bps);
            if (is_err(frame_bps) == 1) { return frame_bps; }

            # CRC-8 verification
            flac_br_align(br);
            var crc8_pos = flac_br_byte_pos(br);
            var expected_crc8 = bitreader_read(br, 8);
            if (is_err(expected_crc8) == 1) { return expected_crc8; }
            var computed_crc8 = flac_crc8(data + frame_start, crc8_pos - frame_start);
            if (computed_crc8 != expected_crc8) { return err(ERR_DECODE); }

            # Channel count and decorrelation mode
            var ch_count = 0;
            var decor = FLAC_DECOR_INDEPENDENT;
            if (ch_assign < FLAC_CH_LEFT_SIDE) {
                ch_count = ch_assign + 1;
            } else {
                ch_count = 2;
                if (ch_assign == FLAC_CH_LEFT_SIDE) { decor = FLAC_DECOR_LEFT_SIDE; }
                if (ch_assign == FLAC_CH_RIGHT_SIDE) { decor = FLAC_DECOR_RIGHT_SIDE; }
                if (ch_assign == FLAC_CH_MID_SIDE) { decor = FLAC_DECOR_MID_SIDE; }
                if (ch_assign > FLAC_CH_MID_SIDE) { return err(ERR_DECODE); }
            }

            # Decode subframes — store pointers in a small buffer
            var ch_bufs = alloc(ch_count * 8);
            var ch = 0;
            while (ch < ch_count) {
                var eff_bps = frame_bps;
                if (decor == FLAC_DECOR_LEFT_SIDE) { if (ch == 1) { eff_bps = frame_bps + 1; } }
                if (decor == FLAC_DECOR_RIGHT_SIDE) { if (ch == 0) { eff_bps = frame_bps + 1; } }
                if (decor == FLAC_DECOR_MID_SIDE) { if (ch == 1) { eff_bps = frame_bps + 1; } }

                var sf_buf = flac_decode_subframe(br, block_size, eff_bps);
                if (is_err(sf_buf) == 1) { return sf_buf; }
                store64(ch_bufs + ch * 8, sf_buf);
                ch = ch + 1;
            }

            # Apply decorrelation
            if (ch_count == 2) {
                flac_apply_decorrelation(load64(ch_bufs), load64(ch_bufs + 8), block_size, decor);
            }

            # Compute scale: 1.0 / (1 << (bps-1))
            var scale_div = f64_from(1 << (frame_bps - 1));
            var scale = f64_div(F64_ONE, scale_div);

            # Interleave and convert to f64
            var si2 = 0;
            while (si2 < block_size) {
                var c = 0;
                while (c < ch_count) {
                    var ch_buf = load64(ch_bufs + c * 8);
                    var ival = load64(ch_buf + si2 * 8);
                    var fval = f64_mul(f64_from(ival), scale);
                    vec_push(all_samples, fval);
                    c = c + 1;
                }
                si2 = si2 + 1;
            }

            # CRC-16 verification
            flac_br_align(br);
            var crc16_end = flac_br_byte_pos(br);
            if (crc16_end + 2 <= len) {
                var expected_crc16 = bitreader_read(br, 16);
                if (is_err(expected_crc16) == 1) { return expected_crc16; }
                var computed_crc16 = flac_crc16(data + frame_start, crc16_end - frame_start);
                if (computed_crc16 != expected_crc16) { return err(ERR_DECODE); }
            }
        }
    }

    # Build FormatInfo
    var total_interleaved = vec_len(all_samples);
    var total_frames = 0;
    if (si_ch > 0) { total_frames = total_interleaved / si_ch; }
    var dur = f64_div(f64_from(total_frames), f64_from(si_rate));

    var fi = fmtinfo_new(FMT_FLAC, si_rate, si_ch, si_bps, dur, total_frames);
    return decode_result_new(fi, all_samples);
}

# ================================================================
# Range decoder — decode a sample range with SEEKTABLE seeking
# ================================================================

fn flac_decode_range(data, len, start_sample, num_samples) {
    var si = flac_parse_metadata(data, len);
    if (is_err(si) == 1) { return si; }

    var si_rate = load64(si + 16);
    var si_ch   = load64(si + 24);
    var si_bps  = load64(si + 32);
    var audio_start = load64(si + 48);
    var seek_table  = load64(si + 56);

    if (si_rate == 0) { return err(ERR_INVALID_RATE); }

    var end_sample = 0;
    var has_end = 0;
    if (num_samples > 0) {
        end_sample = start_sample + num_samples;
        has_end = 1;
    }

    var start_byte = audio_start;
    if (start_sample > 0) {
        if (seek_table != 0) {
            var st_len = vec_len(seek_table);
            var i = 0;
            while (i < st_len) {
                var sp = vec_get(seek_table, i);
                var sp_sample = load64(sp);
                if (sp_sample <= start_sample) {
                    start_byte = audio_start + load64(sp + 8);
                } else {
                    i = st_len;
                }
                i = i + 1;
            }
        }
    }

    var all_samples = vec_new();
    var br = bitreader_new(data, len);
    flac_br_set_pos(br, start_byte);

    var current_sample = 0;
    var sample_pos_known = 0;
    if (start_sample == 0) { sample_pos_known = 1; }

    var done = 0;
    while (done == 0) {
        var sync_pos = flac_find_sync(br, data, len);
        if (is_err(sync_pos) == 1) { done = 1; }

        if (done == 0) {
            var frame_start = sync_pos;
            var sync_byte2 = load8(data + sync_pos + 1);
            var blocking_strategy = sync_byte2 & 1;

            var bs_code = bitreader_read(br, 4);
            if (is_err(bs_code) == 1) { return bs_code; }
            var sr_code = bitreader_read(br, 4);
            if (is_err(sr_code) == 1) { return sr_code; }
            var ch_assign = bitreader_read(br, 4);
            if (is_err(ch_assign) == 1) { return ch_assign; }
            var ss_code = bitreader_read(br, 3);
            if (is_err(ss_code) == 1) { return ss_code; }
            var _reserved = bitreader_read(br, 1);
            if (is_err(_reserved) == 1) { return _reserved; }

            var frame_or_sample = flac_br_read_utf8_u64(br);
            if (is_err(frame_or_sample) == 1) { return frame_or_sample; }

            var block_size = flac_decode_block_size(bs_code, br);
            if (is_err(block_size) == 1) { return block_size; }
            var _frame_sr = flac_decode_sample_rate(sr_code, br, si_rate);
            if (is_err(_frame_sr) == 1) { return _frame_sr; }
            var frame_bps = flac_decode_bps(ss_code, si_bps);
            if (is_err(frame_bps) == 1) { return frame_bps; }

            flac_br_align(br);
            var crc8_pos = flac_br_byte_pos(br);
            var expected_crc8 = bitreader_read(br, 8);
            if (is_err(expected_crc8) == 1) { return expected_crc8; }
            var computed_crc8 = flac_crc8(data + frame_start, crc8_pos - frame_start);
            if (computed_crc8 != expected_crc8) { return err(ERR_DECODE); }

            if (sample_pos_known == 0) {
                if (blocking_strategy == 0) {
                    current_sample = frame_or_sample * block_size;
                } else {
                    current_sample = frame_or_sample;
                }
                sample_pos_known = 1;
            }

            var frame_end_sample = current_sample + block_size;

            if (has_end == 1) {
                if (current_sample >= end_sample) { done = 1; }
            }

            if (done == 0) {
                var ch_count = 0;
                var decor = FLAC_DECOR_INDEPENDENT;
                if (ch_assign < FLAC_CH_LEFT_SIDE) {
                    ch_count = ch_assign + 1;
                } else {
                    ch_count = 2;
                    if (ch_assign == FLAC_CH_LEFT_SIDE) { decor = FLAC_DECOR_LEFT_SIDE; }
                    if (ch_assign == FLAC_CH_RIGHT_SIDE) { decor = FLAC_DECOR_RIGHT_SIDE; }
                    if (ch_assign == FLAC_CH_MID_SIDE) { decor = FLAC_DECOR_MID_SIDE; }
                    if (ch_assign > FLAC_CH_MID_SIDE) { return err(ERR_DECODE); }
                }

                var ch_bufs = alloc(ch_count * 8);
                var ch = 0;
                while (ch < ch_count) {
                    var eff_bps = frame_bps;
                    if (decor == FLAC_DECOR_LEFT_SIDE) { if (ch == 1) { eff_bps = frame_bps + 1; } }
                    if (decor == FLAC_DECOR_RIGHT_SIDE) { if (ch == 0) { eff_bps = frame_bps + 1; } }
                    if (decor == FLAC_DECOR_MID_SIDE) { if (ch == 1) { eff_bps = frame_bps + 1; } }

                    var sf_buf = flac_decode_subframe(br, block_size, eff_bps);
                    if (is_err(sf_buf) == 1) { return sf_buf; }
                    store64(ch_bufs + ch * 8, sf_buf);
                    ch = ch + 1;
                }

                if (ch_count == 2) {
                    flac_apply_decorrelation(load64(ch_bufs), load64(ch_bufs + 8), block_size, decor);
                }

                var scale_div = f64_from(1 << (frame_bps - 1));
                var scale = f64_div(F64_ONE, scale_div);

                var skip_start = 0;
                if (current_sample < start_sample) {
                    skip_start = start_sample - current_sample;
                }
                var take_end = block_size;
                if (has_end == 1) {
                    if (frame_end_sample > end_sample) {
                        take_end = end_sample - current_sample;
                    }
                }
                if (take_end > block_size) { take_end = block_size; }

                var si2 = skip_start;
                while (si2 < take_end) {
                    var c = 0;
                    while (c < ch_count) {
                        var ch_buf = load64(ch_bufs + c * 8);
                        var ival = load64(ch_buf + si2 * 8);
                        var fval = f64_mul(f64_from(ival), scale);
                        vec_push(all_samples, fval);
                        c = c + 1;
                    }
                    si2 = si2 + 1;
                }

                flac_br_align(br);
                var crc16_end = flac_br_byte_pos(br);
                if (crc16_end + 2 <= len) {
                    var expected_crc16 = bitreader_read(br, 16);
                    if (is_err(expected_crc16) == 1) { return expected_crc16; }
                    var computed_crc16 = flac_crc16(data + frame_start, crc16_end - frame_start);
                    if (computed_crc16 != expected_crc16) { return err(ERR_DECODE); }
                }

                current_sample = frame_end_sample;
            }
        }
    }

    var total_interleaved = vec_len(all_samples);
    var total_frames = 0;
    if (si_ch > 0) { total_frames = total_interleaved / si_ch; }
    var dur = f64_div(f64_from(total_frames), f64_from(si_rate));

    var fi = fmtinfo_new(FMT_FLAC, si_rate, si_ch, si_bps, dur, total_frames);
    return decode_result_new(fi, all_samples);
}

# ================================================================
# BitWriter (MSB-first) for encoder
# ================================================================
# Layout (32 bytes):
#   +0:  buf_ptr    (pointer to output byte buffer)
#   +8:  buf_cap    (capacity)
#   +16: buf_len    (current byte count, excluding partial)
#   +24: cur_byte   (current partial byte)
#   +32: bit_pos    (bits written in current byte, 0..8)

fn flac_bw_new(cap) {
    var bw = alloc(40);
    store64(bw, alloc(cap));
    store64(bw + 8, cap);
    store64(bw + 16, 0);
    store64(bw + 24, 0);
    store64(bw + 32, 0);
    return bw;
}

fn flac_bw_write_bits(bw, value, n) {
    if (n == 0) { return 0; }
    var remaining = n;
    var val = value;
    var buf = load64(bw);
    var cap = load64(bw + 8);
    var blen = load64(bw + 16);
    var cur = load64(bw + 24);
    var bpos = load64(bw + 32);

    while (remaining > 0) {
        var avail = 8 - bpos;
        var to_write = remaining;
        if (to_write > avail) { to_write = avail; }
        var bits = (val >> (remaining - to_write)) & ((1 << to_write) - 1);
        cur = cur | (bits << (avail - to_write));
        remaining = remaining - to_write;
        bpos = bpos + to_write;
        if (bpos >= 8) {
            # Grow buffer if at capacity
            if (blen >= cap) {
                var new_cap = cap * 2;
                var new_buf = alloc(new_cap);
                memcpy(new_buf, buf, cap);
                buf = new_buf;
                cap = new_cap;
                store64(bw, buf);
                store64(bw + 8, cap);
            }
            store8(buf + blen, cur);
            blen = blen + 1;
            cur = 0;
            bpos = 0;
        }
    }

    store64(bw + 16, blen);
    store64(bw + 24, cur);
    store64(bw + 32, bpos);
    return 0;
}

fn flac_bw_write_bit(bw, b) {
    return flac_bw_write_bits(bw, b, 1);
}

fn flac_bw_write_unary(bw, val) {
    var i = 0;
    while (i < val) {
        flac_bw_write_bit(bw, 0);
        i = i + 1;
    }
    flac_bw_write_bit(bw, 1);
    return 0;
}

fn flac_bw_align(bw) {
    var bpos = load64(bw + 32);
    if (bpos != 0) {
        var buf = load64(bw);
        var blen = load64(bw + 16);
        var cur = load64(bw + 24);
        store8(buf + blen, cur);
        store64(bw + 16, blen + 1);
        store64(bw + 24, 0);
        store64(bw + 32, 0);
    }
    return 0;
}

fn flac_bw_len(bw) {
    return load64(bw + 16);
}

fn flac_bw_buf(bw) {
    return load64(bw);
}

# Flush and return length (flushes partial byte)
fn flac_bw_finish(bw) {
    flac_bw_align(bw);
    return flac_bw_len(bw);
}

# Write UTF-8-like coded frame number
fn flac_bw_write_utf8_u64(bw, value) {
    if (value < 0x80) {
        flac_bw_write_bits(bw, value, 8);
    } else { if (value < 0x800) {
        flac_bw_write_bits(bw, 0xC0 | (value >> 6), 8);
        flac_bw_write_bits(bw, 0x80 | (value & 0x3F), 8);
    } else { if (value < 0x10000) {
        flac_bw_write_bits(bw, 0xE0 | (value >> 12), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 6) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | (value & 0x3F), 8);
    } else { if (value < 0x200000) {
        flac_bw_write_bits(bw, 0xF0 | (value >> 18), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 12) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 6) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | (value & 0x3F), 8);
    } else { if (value < 0x4000000) {
        flac_bw_write_bits(bw, 0xF8 | (value >> 24), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 18) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 12) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 6) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | (value & 0x3F), 8);
    } else { if (value < 0x80000000) {
        flac_bw_write_bits(bw, 0xFC | (value >> 30), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 24) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 18) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 12) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 6) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | (value & 0x3F), 8);
    } else {
        flac_bw_write_bits(bw, 0xFE, 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 30) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 24) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 18) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 12) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | ((value >> 6) & 0x3F), 8);
        flac_bw_write_bits(bw, 0x80 | (value & 0x3F), 8);
    } } } } } }
    return 0;
}

# ================================================================
# Encoder helpers
# ================================================================

# Zigzag encode: signed -> unsigned for Rice coding
fn flac_zigzag(val) {
    if (val >= 0) { return val << 1; }
    return ((0 - val) << 1) - 1;
}

# Count bits needed: floor(log2(x)) for x > 0, 0 for x == 0
fn flac_ilog2(x) {
    if (x == 0) { return 0; }
    var r = 0;
    var v = x;
    while (v > 1) { v = v >> 1; r = r + 1; }
    return r;
}

# Optimal Rice parameter for a partition
# residuals in buf[start..start+count], each an i64 at buf + i*8
fn flac_optimal_rice(buf, start, count) {
    if (count == 0) { return 0; }
    var sum = 0;
    var i = 0;
    while (i < count) {
        sum = sum + flac_zigzag(load64(buf + (start + i) * 8));
        i = i + 1;
    }
    var mean = sum / count;
    if (mean == 0) { return 0; }
    var p = flac_ilog2(mean);
    if (p > 14) { p = 14; }
    return p;
}

# Estimate bit cost of Rice-encoding residuals with given param
fn flac_rice_bit_cost(buf, start, count, param) {
    var cost = 0;
    var i = 0;
    while (i < count) {
        var u = flac_zigzag(load64(buf + (start + i) * 8));
        cost = cost + (u >> param) + 1 + param;
        i = i + 1;
    }
    return cost;
}

# Encode Rice-coded residuals into BitWriter
fn flac_encode_residual(bw, res_buf, num_res, block_size, order) {
    # Coding method 0 (RICE, 4-bit params), partition order 0
    flac_bw_write_bits(bw, 0, 2);
    flac_bw_write_bits(bw, 0, 4);

    var rice_param = flac_optimal_rice(res_buf, 0, num_res);
    flac_bw_write_bits(bw, rice_param, 4);

    var i = 0;
    while (i < num_res) {
        var uval = flac_zigzag(load64(res_buf + i * 8));
        var q = uval >> rice_param;
        var rem = uval & ((1 << rice_param) - 1);
        flac_bw_write_unary(bw, q);
        if (rice_param > 0) {
            flac_bw_write_bits(bw, rem, rice_param);
        }
        i = i + 1;
    }
    return 0;
}

# Compute fixed prediction residuals
# samples: raw buffer, order: 0-4
# Writes residuals into res_buf starting at index 0
fn flac_compute_fixed_residuals(samples, count, order, res_buf) {
    var i = order;
    var ri = 0;
    while (i < count) {
        var predicted = 0;
        if (order == 0) { predicted = 0; }
        if (order == 1) { predicted = load64(samples + (i - 1) * 8); }
        if (order == 2) { predicted = 2 * load64(samples + (i - 1) * 8) - load64(samples + (i - 2) * 8); }
        if (order == 3) { predicted = 3 * load64(samples + (i - 1) * 8) - 3 * load64(samples + (i - 2) * 8) + load64(samples + (i - 3) * 8); }
        if (order == 4) { predicted = 4 * load64(samples + (i - 1) * 8) - 6 * load64(samples + (i - 2) * 8) + 4 * load64(samples + (i - 3) * 8) - load64(samples + (i - 4) * 8); }
        store64(res_buf + ri * 8, load64(samples + i * 8) - predicted);
        ri = ri + 1;
        i = i + 1;
    }
    return ri;
}

# Find best fixed order for a sample buffer. Returns best_order.
# Writes the cost into cost_ptr (a 1-element buffer).
fn flac_best_fixed_order(samples, count, bps, cost_ptr) {
    var best_order = 0;
    var best_cost = 9999999999;
    var res_buf = alloc(count * 8);

    var order = 0;
    while (order <= 4) {
        if (order <= count) {
            var nres = flac_compute_fixed_residuals(samples, count, order, res_buf);
            var param = flac_optimal_rice(res_buf, 0, nres);
            # Cost: 8 header + order*bps warmup + 6 residual header + rice cost
            var cost = 8 + bps * order + 6 + flac_rice_bit_cost(res_buf, 0, nres, param);
            if (cost < best_cost) {
                best_cost = cost;
                best_order = order;
            }
        }
        order = order + 1;
    }

    store64(cost_ptr, best_cost);
    return best_order;
}

# Encode a single subframe into BitWriter
fn flac_encode_subframe(bw, samples, count, bps) {
    # Verbatim cost: 8 + bps * count
    var verbatim_cost = 8 + bps * count;

    var cost_ptr = alloc(8);
    var fixed_order = flac_best_fixed_order(samples, count, bps, cost_ptr);
    var fixed_cost = load64(cost_ptr);

    if (verbatim_cost <= fixed_cost) {
        # Verbatim
        flac_bw_write_bit(bw, 0);
        flac_bw_write_bits(bw, 1, 6);
        flac_bw_write_bit(bw, 0);
        var i = 0;
        while (i < count) {
            flac_bw_write_bits(bw, load64(samples + i * 8) & ((1 << bps) - 1), bps);
            i = i + 1;
        }
    } else {
        # Fixed
        flac_bw_write_bit(bw, 0);
        flac_bw_write_bits(bw, 8 + fixed_order, 6);
        flac_bw_write_bit(bw, 0);

        # Warm-up samples
        var i = 0;
        while (i < fixed_order) {
            flac_bw_write_bits(bw, load64(samples + i * 8) & ((1 << bps) - 1), bps);
            i = i + 1;
        }

        # Residuals
        var nres = count - fixed_order;
        var res_buf = alloc(nres * 8);
        flac_compute_fixed_residuals(samples, count, fixed_order, res_buf);
        flac_encode_residual(bw, res_buf, nres, count, fixed_order);
    }
    return 0;
}

# Mid-side encoding for stereo
# left, right: raw sample buffers; count: number of samples
# Writes mid into mid_buf, side into side_buf
fn flac_apply_mid_side(left, right, count, mid_buf, side_buf) {
    var i = 0;
    while (i < count) {
        var l = load64(left + i * 8);
        var r = load64(right + i * 8);
        store64(side_buf + i * 8, l - r);
        # Arithmetic right shift for (l + r) >> 1
        var sum = l + r;
        if (sum < 0) {
            store64(mid_buf + i * 8, 0 - ((0 - sum) >> 1));
        } else {
            store64(mid_buf + i * 8, sum >> 1);
        }
        i = i + 1;
    }
    return 0;
}

# Block size -> 4-bit code (returns code; tail_bits and tail_val via pointers)
fn flac_block_size_code(block_size, tail_bits_ptr, tail_val_ptr) {
    store64(tail_bits_ptr, 0);
    store64(tail_val_ptr, 0);
    if (block_size == 192) { return 1; }
    if (block_size == 576)  { return 2; }
    if (block_size == 1152) { return 3; }
    if (block_size == 2304) { return 4; }
    if (block_size == 4608) { return 5; }
    if (block_size == 256)  { return 8; }
    if (block_size == 512)  { return 9; }
    if (block_size == 1024) { return 10; }
    if (block_size == 2048) { return 11; }
    if (block_size == 4096) { return 12; }
    if (block_size == 8192) { return 13; }
    if (block_size == 16384) { return 14; }
    if (block_size == 32768) { return 15; }
    if (block_size <= 256) {
        store64(tail_bits_ptr, 8);
        store64(tail_val_ptr, block_size - 1);
        return 6;
    }
    store64(tail_bits_ptr, 16);
    store64(tail_val_ptr, block_size - 1);
    return 7;
}

# Sample rate -> 4-bit code
fn flac_sample_rate_code(rate, tail_bits_ptr, tail_val_ptr) {
    store64(tail_bits_ptr, 0);
    store64(tail_val_ptr, 0);
    if (rate == 88200)  { return 1; }
    if (rate == 176400) { return 2; }
    if (rate == 192000) { return 3; }
    if (rate == 8000)   { return 4; }
    if (rate == 16000)  { return 5; }
    if (rate == 22050)  { return 6; }
    if (rate == 24000)  { return 7; }
    if (rate == 32000)  { return 8; }
    if (rate == 44100)  { return 9; }
    if (rate == 48000)  { return 10; }
    if (rate == 96000)  { return 11; }
    if ((rate % 1000) == 0) {
        if (rate / 1000 <= 255) {
            store64(tail_bits_ptr, 8);
            store64(tail_val_ptr, rate / 1000);
            return 12;
        }
    }
    if (rate <= 65535) {
        store64(tail_bits_ptr, 16);
        store64(tail_val_ptr, rate);
        return 13;
    }
    if ((rate % 10) == 0) {
        if (rate / 10 <= 65535) {
            store64(tail_bits_ptr, 16);
            store64(tail_val_ptr, rate / 10);
            return 14;
        }
    }
    return 0;
}

# Bits per sample -> 3-bit code
fn flac_bps_code(bps) {
    if (bps == 8)  { return 1; }
    if (bps == 12) { return 2; }
    if (bps == 16) { return 4; }
    if (bps == 20) { return 5; }
    if (bps == 24) { return 6; }
    return 0;
}

# ================================================================
# MD5 computation (RFC 1321)
# ================================================================

# MD5 S table (64 entries, stored at init)
var flac_md5_s = 0;
# MD5 K table (64 entries)
var flac_md5_k = 0;

fn flac_md5_init() {
    flac_md5_s = alloc(64 * 8);
    var s_vals = alloc(64);
    # Round 1
    store8(s_vals + 0, 7); store8(s_vals + 1, 12); store8(s_vals + 2, 17); store8(s_vals + 3, 22);
    store8(s_vals + 4, 7); store8(s_vals + 5, 12); store8(s_vals + 6, 17); store8(s_vals + 7, 22);
    store8(s_vals + 8, 7); store8(s_vals + 9, 12); store8(s_vals + 10, 17); store8(s_vals + 11, 22);
    store8(s_vals + 12, 7); store8(s_vals + 13, 12); store8(s_vals + 14, 17); store8(s_vals + 15, 22);
    # Round 2
    store8(s_vals + 16, 5); store8(s_vals + 17, 9); store8(s_vals + 18, 14); store8(s_vals + 19, 20);
    store8(s_vals + 20, 5); store8(s_vals + 21, 9); store8(s_vals + 22, 14); store8(s_vals + 23, 20);
    store8(s_vals + 24, 5); store8(s_vals + 25, 9); store8(s_vals + 26, 14); store8(s_vals + 27, 20);
    store8(s_vals + 28, 5); store8(s_vals + 29, 9); store8(s_vals + 30, 14); store8(s_vals + 31, 20);
    # Round 3
    store8(s_vals + 32, 4); store8(s_vals + 33, 11); store8(s_vals + 34, 16); store8(s_vals + 35, 23);
    store8(s_vals + 36, 4); store8(s_vals + 37, 11); store8(s_vals + 38, 16); store8(s_vals + 39, 23);
    store8(s_vals + 40, 4); store8(s_vals + 41, 11); store8(s_vals + 42, 16); store8(s_vals + 43, 23);
    store8(s_vals + 44, 4); store8(s_vals + 45, 11); store8(s_vals + 46, 16); store8(s_vals + 47, 23);
    # Round 4
    store8(s_vals + 48, 6); store8(s_vals + 49, 10); store8(s_vals + 50, 15); store8(s_vals + 51, 21);
    store8(s_vals + 52, 6); store8(s_vals + 53, 10); store8(s_vals + 54, 15); store8(s_vals + 55, 21);
    store8(s_vals + 56, 6); store8(s_vals + 57, 10); store8(s_vals + 58, 15); store8(s_vals + 59, 21);
    store8(s_vals + 60, 6); store8(s_vals + 61, 10); store8(s_vals + 62, 15); store8(s_vals + 63, 21);
    var si = 0;
    while (si < 64) {
        store64(flac_md5_s + si * 8, load8(s_vals + si));
        si = si + 1;
    }

    # K table — pre-computed floor(2^32 * abs(sin(i+1)))
    flac_md5_k = alloc(64 * 8);
    store64(flac_md5_k + 0 * 8,  0xd76aa478); store64(flac_md5_k + 1 * 8,  0xe8c7b756);
    store64(flac_md5_k + 2 * 8,  0x242070db); store64(flac_md5_k + 3 * 8,  0xc1bdceee);
    store64(flac_md5_k + 4 * 8,  0xf57c0faf); store64(flac_md5_k + 5 * 8,  0x4787c62a);
    store64(flac_md5_k + 6 * 8,  0xa8304613); store64(flac_md5_k + 7 * 8,  0xfd469501);
    store64(flac_md5_k + 8 * 8,  0x698098d8); store64(flac_md5_k + 9 * 8,  0x8b44f7af);
    store64(flac_md5_k + 10 * 8, 0xffff5bb1); store64(flac_md5_k + 11 * 8, 0x895cd7be);
    store64(flac_md5_k + 12 * 8, 0x6b901122); store64(flac_md5_k + 13 * 8, 0xfd987193);
    store64(flac_md5_k + 14 * 8, 0xa679438e); store64(flac_md5_k + 15 * 8, 0x49b40821);
    store64(flac_md5_k + 16 * 8, 0xf61e2562); store64(flac_md5_k + 17 * 8, 0xc040b340);
    store64(flac_md5_k + 18 * 8, 0x265e5a51); store64(flac_md5_k + 19 * 8, 0xe9b6c7aa);
    store64(flac_md5_k + 20 * 8, 0xd62f105d); store64(flac_md5_k + 21 * 8, 0x02441453);
    store64(flac_md5_k + 22 * 8, 0xd8a1e681); store64(flac_md5_k + 23 * 8, 0xe7d3fbc8);
    store64(flac_md5_k + 24 * 8, 0x21e1cde6); store64(flac_md5_k + 25 * 8, 0xc33707d6);
    store64(flac_md5_k + 26 * 8, 0xf4d50d87); store64(flac_md5_k + 27 * 8, 0x455a14ed);
    store64(flac_md5_k + 28 * 8, 0xa9e3e905); store64(flac_md5_k + 29 * 8, 0xfcefa3f8);
    store64(flac_md5_k + 30 * 8, 0x676f02d9); store64(flac_md5_k + 31 * 8, 0x8d2a4c8a);
    store64(flac_md5_k + 32 * 8, 0xfffa3942); store64(flac_md5_k + 33 * 8, 0x8771f681);
    store64(flac_md5_k + 34 * 8, 0x6d9d6122); store64(flac_md5_k + 35 * 8, 0xfde5380c);
    store64(flac_md5_k + 36 * 8, 0xa4beea44); store64(flac_md5_k + 37 * 8, 0x4bdecfa9);
    store64(flac_md5_k + 38 * 8, 0xf6bb4b60); store64(flac_md5_k + 39 * 8, 0xbebfbc70);
    store64(flac_md5_k + 40 * 8, 0x289b7ec6); store64(flac_md5_k + 41 * 8, 0xeaa127fa);
    store64(flac_md5_k + 42 * 8, 0xd4ef3085); store64(flac_md5_k + 43 * 8, 0x04881d05);
    store64(flac_md5_k + 44 * 8, 0xd9d4d039); store64(flac_md5_k + 45 * 8, 0xe6db99e5);
    store64(flac_md5_k + 46 * 8, 0x1fa27cf8); store64(flac_md5_k + 47 * 8, 0xc4ac5665);
    store64(flac_md5_k + 48 * 8, 0xf4292244); store64(flac_md5_k + 49 * 8, 0x432aff97);
    store64(flac_md5_k + 50 * 8, 0xab9423a7); store64(flac_md5_k + 51 * 8, 0xfc93a039);
    store64(flac_md5_k + 52 * 8, 0x655b59c3); store64(flac_md5_k + 53 * 8, 0x8f0ccc92);
    store64(flac_md5_k + 54 * 8, 0xffeff47d); store64(flac_md5_k + 55 * 8, 0x85845dd1);
    store64(flac_md5_k + 56 * 8, 0x6fa87e4f); store64(flac_md5_k + 57 * 8, 0xfe2ce6e0);
    store64(flac_md5_k + 58 * 8, 0xa3014314); store64(flac_md5_k + 59 * 8, 0x4e0811a1);
    store64(flac_md5_k + 60 * 8, 0xf7537e82); store64(flac_md5_k + 61 * 8, 0xbd3af235);
    store64(flac_md5_k + 62 * 8, 0x2ad7d2bb); store64(flac_md5_k + 63 * 8, 0xeb86d391);
    return 0;
}

# 32-bit unsigned helpers for MD5 (Cyrius is i64, we mask to 32 bits)
fn u32_add(a, b) { return (a + b) & 0xFFFFFFFF; }
fn u32_not(a)    { return (a ^ 0xFFFFFFFF) & 0xFFFFFFFF; }
fn u32_rotl(val, n) {
    return ((val << n) | (val >> (32 - n))) & 0xFFFFFFFF;
}

# Compute MD5 digest. data: pointer, dlen: byte length.
# Returns pointer to 16-byte digest buffer.
fn flac_md5_compute(data, dlen) {
    var orig_bits = dlen * 8;

    # Build padded message
    var pad_len = dlen + 1;
    while ((pad_len % 64) != 56) { pad_len = pad_len + 1; }
    pad_len = pad_len + 8;
    var msg = alloc(pad_len);
    memcpy(msg, data, dlen);
    store8(msg + dlen, 0x80);
    # Zero-fill is handled by alloc
    # Append original length in bits as 64-bit little-endian
    store8(msg + pad_len - 8, orig_bits & 0xFF);
    store8(msg + pad_len - 7, (orig_bits >> 8) & 0xFF);
    store8(msg + pad_len - 6, (orig_bits >> 16) & 0xFF);
    store8(msg + pad_len - 5, (orig_bits >> 24) & 0xFF);
    store8(msg + pad_len - 4, (orig_bits >> 32) & 0xFF);
    store8(msg + pad_len - 3, (orig_bits >> 40) & 0xFF);
    store8(msg + pad_len - 2, (orig_bits >> 48) & 0xFF);
    store8(msg + pad_len - 1, (orig_bits >> 56) & 0xFF);

    var a0 = 0x67452301;
    var b0 = 0xefcdab89;
    var c0 = 0x98badcfe;
    var d0 = 0x10325476;

    var m_buf = alloc(16 * 8);
    var chunk_off = 0;
    while (chunk_off < pad_len) {
        # Parse 16 u32 words (little-endian)
        var wi = 0;
        while (wi < 16) {
            var off = chunk_off + wi * 4;
            var w = load8(msg + off) | (load8(msg + off + 1) << 8) | (load8(msg + off + 2) << 16) | (load8(msg + off + 3) << 24);
            store64(m_buf + wi * 8, w);
            wi = wi + 1;
        }

        var a = a0;
        var b = b0;
        var c = c0;
        var d = d0;

        var i = 0;
        while (i < 64) {
            var f = 0;
            var g = 0;
            if (i < 16) {
                f = (b & c) | (u32_not(b) & d);
                g = i;
            } else { if (i < 32) {
                f = (d & b) | (u32_not(d) & c);
                g = (5 * i + 1) % 16;
            } else { if (i < 48) {
                f = b ^ c ^ d;
                g = (3 * i + 5) % 16;
            } else {
                f = c ^ (b | u32_not(d));
                g = (7 * i) % 16;
            } } }
            f = f & 0xFFFFFFFF;

            var temp = d;
            d = c;
            c = b;
            var inner = u32_add(u32_add(a, f), u32_add(load64(flac_md5_k + i * 8), load64(m_buf + g * 8)));
            b = u32_add(b, u32_rotl(inner, load64(flac_md5_s + i * 8)));
            a = temp;
            i = i + 1;
        }

        a0 = u32_add(a0, a);
        b0 = u32_add(b0, b);
        c0 = u32_add(c0, c);
        d0 = u32_add(d0, d);

        chunk_off = chunk_off + 64;
    }

    # Output 16-byte digest (little-endian)
    var result = alloc(16);
    store8(result + 0, a0 & 0xFF);
    store8(result + 1, (a0 >> 8) & 0xFF);
    store8(result + 2, (a0 >> 16) & 0xFF);
    store8(result + 3, (a0 >> 24) & 0xFF);
    store8(result + 4, b0 & 0xFF);
    store8(result + 5, (b0 >> 8) & 0xFF);
    store8(result + 6, (b0 >> 16) & 0xFF);
    store8(result + 7, (b0 >> 24) & 0xFF);
    store8(result + 8, c0 & 0xFF);
    store8(result + 9, (c0 >> 8) & 0xFF);
    store8(result + 10, (c0 >> 16) & 0xFF);
    store8(result + 11, (c0 >> 24) & 0xFF);
    store8(result + 12, d0 & 0xFF);
    store8(result + 13, (d0 >> 8) & 0xFF);
    store8(result + 14, (d0 >> 16) & 0xFF);
    store8(result + 15, (d0 >> 24) & 0xFF);
    return result;
}

# ================================================================
# Encode a single FLAC frame
# ================================================================

# Encode one frame into out_buf at out_pos. Returns bytes written.
# ch_bufs: array of channel buffer pointers (alloc'd, each count samples)
# channels, bps, sample_rate, frame_number, this_block_size: integers
fn flac_encode_frame(out_buf, out_pos, ch_bufs, channels, bps, sample_rate, frame_number, this_block_size) {
    var frame_start = out_pos;

    # Build header with BitWriter
    var hdr = flac_bw_new(64);
    # Sync: 0xFFF8 = 14 bits 0x3FFE + reserved 0 + blocking_strategy 0
    flac_bw_write_bits(hdr, 0x3FFE, 14);
    flac_bw_write_bit(hdr, 0);
    flac_bw_write_bit(hdr, 0);

    var bs_tb = alloc(8);
    var bs_tv = alloc(8);
    var bs_code = flac_block_size_code(this_block_size, bs_tb, bs_tv);
    flac_bw_write_bits(hdr, bs_code, 4);

    var sr_tb = alloc(8);
    var sr_tv = alloc(8);
    var sr_code = flac_sample_rate_code(sample_rate, sr_tb, sr_tv);
    flac_bw_write_bits(hdr, sr_code, 4);

    # Channel assignment
    var use_ms = 0;
    if (channels == 2) { use_ms = 1; }
    var ch_assign = channels - 1;
    if (use_ms == 1) { ch_assign = FLAC_CH_MID_SIDE; }
    flac_bw_write_bits(hdr, ch_assign, 4);

    flac_bw_write_bits(hdr, flac_bps_code(bps), 3);
    flac_bw_write_bit(hdr, 0);

    flac_bw_write_utf8_u64(hdr, frame_number);

    # Block size tail
    var bs_tail_bits = load64(bs_tb);
    if (bs_tail_bits > 0) {
        flac_bw_write_bits(hdr, load64(bs_tv), bs_tail_bits);
    }
    # Sample rate tail
    var sr_tail_bits = load64(sr_tb);
    if (sr_tail_bits > 0) {
        flac_bw_write_bits(hdr, load64(sr_tv), sr_tail_bits);
    }

    flac_bw_align(hdr);
    var hdr_len = flac_bw_len(hdr);
    var hdr_buf = flac_bw_buf(hdr);

    # Compute CRC-8 over header bytes
    var crc8 = flac_crc8(hdr_buf, hdr_len);

    # Copy header to output
    memcpy(out_buf + out_pos, hdr_buf, hdr_len);
    out_pos = out_pos + hdr_len;
    store8(out_buf + out_pos, crc8);
    out_pos = out_pos + 1;

    # Encode subframes
    var sf_bw = flac_bw_new(this_block_size * channels * 4 + 256);

    if (use_ms == 1) {
        var left = load64(ch_bufs);
        var right = load64(ch_bufs + 8);
        var mid_buf = alloc(this_block_size * 8);
        var side_buf = alloc(this_block_size * 8);
        flac_apply_mid_side(left, right, this_block_size, mid_buf, side_buf);
        flac_encode_subframe(sf_bw, mid_buf, this_block_size, bps);
        flac_encode_subframe(sf_bw, side_buf, this_block_size, bps + 1);
    } else {
        var ch = 0;
        while (ch < channels) {
            flac_encode_subframe(sf_bw, load64(ch_bufs + ch * 8), this_block_size, bps);
            ch = ch + 1;
        }
    }

    flac_bw_align(sf_bw);
    var sf_len = flac_bw_len(sf_bw);
    var sf_buf = flac_bw_buf(sf_bw);
    memcpy(out_buf + out_pos, sf_buf, sf_len);
    out_pos = out_pos + sf_len;

    # CRC-16 over entire frame (from frame_start to current pos)
    var crc16 = flac_crc16(out_buf + frame_start, out_pos - frame_start);
    store8(out_buf + out_pos, (crc16 >> 8) & 0xFF);
    store8(out_buf + out_pos + 1, crc16 & 0xFF);
    out_pos = out_pos + 2;

    return out_pos - frame_start;
}

# ================================================================
# Main FLAC encoder
# ================================================================

fn flac_encode(samples_vec, sample_rate, channels, bits_per_sample, out_buf) {
    if (channels == 0) { return err(ERR_INVALID_CHANNELS); }
    if (sample_rate == 0) { return err(ERR_INVALID_RATE); }
    if (bits_per_sample == 0) { return err(ERR_ENCODE); }
    if (bits_per_sample > 32) { return err(ERR_ENCODE); }

    var ch = channels;
    var total_interleaved = vec_len(samples_vec);
    var total_frames = total_interleaved / ch;
    var bps = bits_per_sample;

    # Scale factor: (1 << (bps-1)) - 1
    var scale_max = (1 << (bps - 1)) - 1;
    var f64_scale = f64_from(scale_max);

    # Convert f64 samples -> i64 at target bit depth, deinterleave
    var ch_bufs = alloc(ch * 8);
    var c = 0;
    while (c < ch) {
        store64(ch_bufs + c * 8, alloc(total_frames * 8));
        c = c + 1;
    }

    var fi = 0;
    while (fi < total_frames) {
        c = 0;
        while (c < ch) {
            var fval = vec_get(samples_vec, fi * ch + c);
            var clamped = f64_clamp(fval, F64_NEG_ONE, F64_ONE);
            var ival = f64_to(f64_mul(clamped, f64_scale));
            var cb = load64(ch_bufs + c * 8);
            store64(cb + fi * 8, ival);
            c = c + 1;
        }
        fi = fi + 1;
    }

    # Compute MD5 over raw samples (little-endian bytes)
    var bytes_per_samp = bps >> 3;
    if ((bps & 7) != 0) { bytes_per_samp = bytes_per_samp + 1; }
    var md5_data_len = total_interleaved * bytes_per_samp;
    var md5_data = alloc(md5_data_len + 1);
    var md5_pos = 0;
    fi = 0;
    while (fi < total_frames) {
        c = 0;
        while (c < ch) {
            var cb = load64(ch_bufs + c * 8);
            var s = load64(cb + fi * 8);
            var b = 0;
            while (b < bytes_per_samp) {
                # Arithmetic right shift safe: just extracting bytes
                var byte_val = 0;
                if (b == 0) { byte_val = s & 0xFF; }
                if (b == 1) { byte_val = (s >> 8) & 0xFF; }
                if (b == 2) { byte_val = (s >> 16) & 0xFF; }
                if (b == 3) { byte_val = (s >> 24) & 0xFF; }
                store8(md5_data + md5_pos, byte_val);
                md5_pos = md5_pos + 1;
                b = b + 1;
            }
            c = c + 1;
        }
        fi = fi + 1;
    }
    var md5 = flac_md5_compute(md5_data, md5_data_len);

    # Write output
    var pos = 0;

    # fLaC magic
    store8(out_buf + pos, 0x66); pos = pos + 1;
    store8(out_buf + pos, 0x4C); pos = pos + 1;
    store8(out_buf + pos, 0x61); pos = pos + 1;
    store8(out_buf + pos, 0x43); pos = pos + 1;

    # STREAMINFO metadata block: is_last=1, type=0, size=34
    store8(out_buf + pos, 0x80); pos = pos + 1;
    store8(out_buf + pos, 0); pos = pos + 1;
    store8(out_buf + pos, 0); pos = pos + 1;
    store8(out_buf + pos, 34); pos = pos + 1;

    var block_size = 4096;
    var actual_bs = block_size;
    if (total_frames < actual_bs) { actual_bs = total_frames; }
    if (actual_bs < 1) { actual_bs = 1; }

    # min/max block size (16-bit BE each)
    store8(out_buf + pos, (actual_bs >> 8) & 0xFF); pos = pos + 1;
    store8(out_buf + pos, actual_bs & 0xFF); pos = pos + 1;
    store8(out_buf + pos, (actual_bs >> 8) & 0xFF); pos = pos + 1;
    store8(out_buf + pos, actual_bs & 0xFF); pos = pos + 1;

    # min/max frame size (3 bytes each, placeholder)
    var frame_size_offset = pos;
    store8(out_buf + pos, 0); pos = pos + 1;
    store8(out_buf + pos, 0); pos = pos + 1;
    store8(out_buf + pos, 0); pos = pos + 1;
    store8(out_buf + pos, 0); pos = pos + 1;
    store8(out_buf + pos, 0); pos = pos + 1;
    store8(out_buf + pos, 0); pos = pos + 1;

    # sr(20) | ch-1(3) | bps-1(5) | total_samples(36)
    var sr = sample_rate;
    var ch_m1 = channels - 1;
    var bps_m1 = bps - 1;
    store8(out_buf + pos, (sr >> 12) & 0xFF); pos = pos + 1;
    store8(out_buf + pos, (sr >> 4) & 0xFF); pos = pos + 1;
    store8(out_buf + pos, ((sr & 0x0F) << 4) | ((ch_m1 & 0x07) << 1) | ((bps_m1 >> 4) & 0x01)); pos = pos + 1;
    store8(out_buf + pos, ((bps_m1 & 0x0F) << 4) | ((total_frames >> 32) & 0x0F)); pos = pos + 1;
    store8(out_buf + pos, (total_frames >> 24) & 0xFF); pos = pos + 1;
    store8(out_buf + pos, (total_frames >> 16) & 0xFF); pos = pos + 1;
    store8(out_buf + pos, (total_frames >> 8) & 0xFF); pos = pos + 1;
    store8(out_buf + pos, total_frames & 0xFF); pos = pos + 1;

    # MD5 (16 bytes)
    var mi = 0;
    while (mi < 16) {
        store8(out_buf + pos, load8(md5 + mi));
        pos = pos + 1;
        mi = mi + 1;
    }

    # Encode frames
    var min_frame_size = 0x7FFFFFFF;
    var max_frame_size = 0;

    var num_blocks = total_frames / block_size;
    if ((total_frames % block_size) != 0) { num_blocks = num_blocks + 1; }

    var bi = 0;
    while (bi < num_blocks) {
        var start = bi * block_size;
        var end = start + block_size;
        if (end > total_frames) { end = total_frames; }
        var this_bs = end - start;

        # Build per-channel sub-buffers for this block
        var block_ch_bufs = alloc(ch * 8);
        c = 0;
        while (c < ch) {
            var src = load64(ch_bufs + c * 8);
            store64(block_ch_bufs + c * 8, src + start * 8);
            c = c + 1;
        }

        var frame_bytes = flac_encode_frame(out_buf, pos, block_ch_bufs, channels, bps, sample_rate, bi, this_bs);
        if (frame_bytes < min_frame_size) { min_frame_size = frame_bytes; }
        if (frame_bytes > max_frame_size) { max_frame_size = frame_bytes; }
        pos = pos + frame_bytes;
        bi = bi + 1;
    }

    # Backfill min/max frame sizes
    if (min_frame_size < 0x7FFFFFFF) {
        store8(out_buf + frame_size_offset, (min_frame_size >> 16) & 0xFF);
        store8(out_buf + frame_size_offset + 1, (min_frame_size >> 8) & 0xFF);
        store8(out_buf + frame_size_offset + 2, min_frame_size & 0xFF);
        store8(out_buf + frame_size_offset + 3, (max_frame_size >> 16) & 0xFF);
        store8(out_buf + frame_size_offset + 4, (max_frame_size >> 8) & 0xFF);
        store8(out_buf + frame_size_offset + 5, max_frame_size & 0xFF);
    }

    return pos;
}

# ================================================================
# FLAC module init (call before any encode/decode)
# ================================================================

fn flac_init() {
    flac_crc8_init();
    flac_crc16_init();
    flac_md5_init();
    return 0;
}

# ================================================================
# Tests
# ================================================================

fn test_flac_crc() {
    syscall(1, 1, "test: flac crc-8/16\n", 20);

    # CRC-8 of empty = 0
    var empty = alloc(1);
    assert_eq(flac_crc8(empty, 0), 0, "flac crc8 empty");

    # CRC-8 of single zero = 0
    store8(empty, 0);
    assert_eq(flac_crc8(empty, 1), 0, "flac crc8 zero");

    # CRC-8 of "123456789" = 0xF4
    var test9 = alloc(9);
    store8(test9, 0x31); store8(test9 + 1, 0x32); store8(test9 + 2, 0x33);
    store8(test9 + 3, 0x34); store8(test9 + 4, 0x35); store8(test9 + 5, 0x36);
    store8(test9 + 6, 0x37); store8(test9 + 7, 0x38); store8(test9 + 8, 0x39);
    assert_eq(flac_crc8(test9, 9), 0xF4, "flac crc8 123456789");

    # CRC-16 of empty = 0
    assert_eq(flac_crc16(empty, 0), 0, "flac crc16 empty");

    # CRC-16 of single zero = 0
    assert_eq(flac_crc16(empty, 1), 0, "flac crc16 zero");

    # CRC-16 consistency: non-trivial data should give non-zero
    var test_data = alloc(10);
    store8(test_data, 0x68); store8(test_data + 1, 0x65); store8(test_data + 2, 0x6C);
    store8(test_data + 3, 0x6C); store8(test_data + 4, 0x6F); store8(test_data + 5, 0x20);
    store8(test_data + 6, 0x46); store8(test_data + 7, 0x4C); store8(test_data + 8, 0x41);
    store8(test_data + 9, 0x43);
    var crc_val = flac_crc16(test_data, 10);
    assert(crc_val != 0, "flac crc16 non-zero for hello FLAC");

    # Corruption changes CRC
    store8(test_data, load8(test_data) ^ 1);
    var crc_val2 = flac_crc16(test_data, 10);
    assert(crc_val != crc_val2, "flac crc16 changes on corruption");

    return 0;
}

fn test_flac_bitwriter() {
    syscall(1, 1, "test: flac bitwriter\n", 21);

    # Write two full bytes
    var bw = flac_bw_new(16);
    flac_bw_write_bits(bw, 0xFF, 8);
    flac_bw_write_bits(bw, 0xAB, 8);
    var blen = flac_bw_finish(bw);
    assert_eq(blen, 2, "bw two bytes len");
    var buf = flac_bw_buf(bw);
    assert_eq(load8(buf), 0xFF, "bw byte 0");
    assert_eq(load8(buf + 1), 0xAB, "bw byte 1");

    # Write partial nibbles
    var bw2 = flac_bw_new(16);
    flac_bw_write_bits(bw2, 0x0A, 4);
    flac_bw_write_bits(bw2, 0x06, 4);
    var blen2 = flac_bw_finish(bw2);
    assert_eq(blen2, 1, "bw nibbles len");
    assert_eq(load8(flac_bw_buf(bw2)), 0xA6, "bw nibbles val");

    return 0;
}

fn test_flac_zigzag() {
    syscall(1, 1, "test: flac zigzag\n", 18);
    assert_eq(flac_zigzag(0), 0, "zz 0");
    assert_eq(flac_zigzag(1), 2, "zz 1");
    assert_eq(flac_zigzag(0 - 1), 1, "zz -1");
    assert_eq(flac_zigzag(2), 4, "zz 2");
    assert_eq(flac_zigzag(0 - 2), 3, "zz -2");
    return 0;
}

fn test_flac_md5() {
    syscall(1, 1, "test: flac md5\n", 15);

    # MD5 of empty string = d41d8cd98f00b204e9800998ecf8427e
    var md5_empty = flac_md5_compute(alloc(1), 0);
    assert_eq(load8(md5_empty), 0xd4, "md5 empty[0]");
    assert_eq(load8(md5_empty + 1), 0x1d, "md5 empty[1]");
    assert_eq(load8(md5_empty + 2), 0x8c, "md5 empty[2]");
    assert_eq(load8(md5_empty + 3), 0xd9, "md5 empty[3]");
    assert_eq(load8(md5_empty + 15), 0x7e, "md5 empty[15]");

    # MD5 of "abc" = 900150983cd24fb0d6963f7d28e17f72
    var abc = alloc(3);
    store8(abc, 0x61); store8(abc + 1, 0x62); store8(abc + 2, 0x63);
    var md5_abc = flac_md5_compute(abc, 3);
    assert_eq(load8(md5_abc), 0x90, "md5 abc[0]");
    assert_eq(load8(md5_abc + 1), 0x01, "md5 abc[1]");
    assert_eq(load8(md5_abc + 2), 0x50, "md5 abc[2]");
    assert_eq(load8(md5_abc + 15), 0x72, "md5 abc[15]");

    return 0;
}

fn test_flac_utf8_roundtrip() {
    syscall(1, 1, "test: flac utf8 roundtrip\n", 26);

    var test_vals = alloc(9 * 8);
    store64(test_vals, 0);
    store64(test_vals + 8, 1);
    store64(test_vals + 16, 127);
    store64(test_vals + 24, 128);
    store64(test_vals + 32, 255);
    store64(test_vals + 40, 256);
    store64(test_vals + 48, 1000);
    store64(test_vals + 56, 65535);
    store64(test_vals + 64, 100000);

    var ti = 0;
    while (ti < 9) {
        var val = load64(test_vals + ti * 8);
        var bw = flac_bw_new(16);
        flac_bw_write_utf8_u64(bw, val);
        var blen = flac_bw_finish(bw);
        var buf = flac_bw_buf(bw);
        var br = bitreader_new(buf, blen);
        var decoded = flac_br_read_utf8_u64(br);
        assert_eq(decoded, val, "utf8 roundtrip");
        ti = ti + 1;
    }
    return 0;
}

fn test_flac_encode_decode_silence() {
    syscall(1, 1, "test: flac encode/decode silence\n", 33);

    var num_samples = 256;
    var samples = vec_new();
    var i = 0;
    while (i < num_samples) {
        vec_push(samples, F64_ZERO);
        i = i + 1;
    }

    var out_buf = alloc(num_samples * 8 + 4096);
    var bytes_written = flac_encode(samples, 44100, 1, 16, out_buf);
    assert(res_ok(bytes_written) == 1, "flac silence encode ok");
    assert(bytes_written > 0, "flac silence bytes > 0");

    # Check magic
    assert_eq(load8(out_buf), 0x66, "flac magic f");
    assert_eq(load8(out_buf + 1), 0x4C, "flac magic L");
    assert_eq(load8(out_buf + 2), 0x61, "flac magic a");
    assert_eq(load8(out_buf + 3), 0x43, "flac magic C");

    # Decode
    var result = flac_decode(out_buf, bytes_written);
    assert(res_ok(result) == 1, "flac silence decode ok");

    var fi = decode_result_info(result);
    assert_eq(fmtinfo_format(fi), FMT_FLAC, "flac silence format");
    assert_eq(fmtinfo_sample_rate(fi), 44100, "flac silence rate");
    assert_eq(fmtinfo_channels(fi), 1, "flac silence ch");
    assert_eq(fmtinfo_bit_depth(fi), 16, "flac silence bps");

    var dec_samples = decode_result_samples(result);
    assert_eq(vec_len(dec_samples), num_samples, "flac silence sample count");

    # All samples should be ~0 (multiply by 32768, check int is 0)
    var all_zero = 1;
    i = 0;
    while (i < vec_len(dec_samples)) {
        var v = f64_to(f64_mul(vec_get(dec_samples, i), F64_32768));
        if (v > 1) { all_zero = 0; }
        if (v < (0 - 1)) { all_zero = 0; }
        i = i + 1;
    }
    assert_eq(all_zero, 1, "flac silence all zero");

    return 0;
}

fn test_flac_encode_decode_sine() {
    syscall(1, 1, "test: flac encode/decode sine\n", 30);

    # Generate a sine wave using integer approximation
    # sin(x) approx via quadratic: 4x(1-x)/1 for x in [0,1] mapped to [0, pi]
    # We generate 256 samples of a simple pattern instead
    var num_samples = 256;
    var samples = vec_new();
    var i = 0;
    while (i < num_samples) {
        # Triangular wave: goes from 0 to 1 to 0 to -1 to 0
        var phase = (i * 4) % num_samples;
        var quarter = num_samples / 4;
        var val = 0;
        if (phase < quarter) {
            val = f64_div(f64_from(phase), f64_from(quarter));
        } else { if (phase < quarter * 2) {
            val = f64_div(f64_from(quarter * 2 - phase), f64_from(quarter));
        } else { if (phase < quarter * 3) {
            val = f64_neg(f64_div(f64_from(phase - quarter * 2), f64_from(quarter)));
        } else {
            val = f64_neg(f64_div(f64_from(num_samples - phase), f64_from(quarter)));
        } } }
        # Scale to 0.9 to avoid clipping edge
        val = f64_mul(val, f64_div(f64_from(9), f64_from(10)));
        vec_push(samples, val);
        i = i + 1;
    }

    var out_buf = alloc(num_samples * 8 + 8192);
    var bytes_written = flac_encode(samples, 44100, 1, 16, out_buf);
    assert(res_ok(bytes_written) == 1, "flac sine encode ok");

    var result = flac_decode(out_buf, bytes_written);
    assert(res_ok(result) == 1, "flac sine decode ok");

    var dec = decode_result_samples(result);
    assert_eq(vec_len(dec), num_samples, "flac sine count");

    # Check roundtrip within 16-bit tolerance
    # Multiply both by 32768, compare integer parts
    var ok = 1;
    i = 0;
    while (i < num_samples) {
        var orig_scaled = f64_to(f64_mul(vec_get(samples, i), F64_32768));
        var dec_scaled = f64_to(f64_mul(vec_get(dec, i), F64_32768));
        var d = orig_scaled - dec_scaled;
        if (d < 0) { d = 0 - d; }
        if (d > 2) { ok = 0; }
        i = i + 1;
    }
    assert_eq(ok, 1, "flac sine roundtrip within tolerance");

    return 0;
}

fn test_flac_encode_decode_stereo() {
    syscall(1, 1, "test: flac encode/decode stereo\n", 32);

    var num_frames = 128;
    var samples = vec_new();
    var i = 0;
    while (i < num_frames) {
        # Left: ramp up
        var left = f64_div(f64_from(i), f64_from(num_frames));
        left = f64_sub(f64_mul(left, F64_TWO), F64_ONE);
        left = f64_mul(left, f64_div(f64_from(9), f64_from(10)));
        # Right: ramp down
        var right = f64_div(f64_from(num_frames - 1 - i), f64_from(num_frames));
        right = f64_sub(f64_mul(right, F64_TWO), F64_ONE);
        right = f64_mul(right, f64_div(f64_from(9), f64_from(10)));
        vec_push(samples, left);
        vec_push(samples, right);
        i = i + 1;
    }

    var out_buf = alloc(num_frames * 16 + 8192);
    var bytes_written = flac_encode(samples, 44100, 2, 16, out_buf);
    assert(res_ok(bytes_written) == 1, "flac stereo encode ok");

    var result = flac_decode(out_buf, bytes_written);
    assert(res_ok(result) == 1, "flac stereo decode ok");

    var fi = decode_result_info(result);
    assert_eq(fmtinfo_channels(fi), 2, "flac stereo channels");

    var dec = decode_result_samples(result);
    assert_eq(vec_len(dec), num_frames * 2, "flac stereo count");

    return 0;
}

fn test_flac_encode_decode_8bit() {
    syscall(1, 1, "test: flac encode/decode 8-bit\n", 31);

    var num_samples = 64;
    var samples = vec_new();
    var i = 0;
    while (i < num_samples) {
        var val = f64_sub(f64_div(f64_from(i), f64_from(32)), F64_ONE);
        vec_push(samples, val);
        i = i + 1;
    }

    var out_buf = alloc(num_samples * 4 + 4096);
    var bytes_written = flac_encode(samples, 44100, 1, 8, out_buf);
    assert(res_ok(bytes_written) == 1, "flac 8bit encode ok");

    var result = flac_decode(out_buf, bytes_written);
    assert(res_ok(result) == 1, "flac 8bit decode ok");

    var fi = decode_result_info(result);
    assert_eq(fmtinfo_bit_depth(fi), 8, "flac 8bit depth");

    return 0;
}

fn test_flac_encode_decode_24bit() {
    syscall(1, 1, "test: flac encode/decode 24-bit\n", 32);

    var num_samples = 64;
    var samples = vec_new();
    var i = 0;
    while (i < num_samples) {
        var val = f64_sub(f64_div(f64_from(i), f64_from(32)), F64_ONE);
        val = f64_mul(val, f64_div(f64_from(9), f64_from(10)));
        vec_push(samples, val);
        i = i + 1;
    }

    var out_buf = alloc(num_samples * 12 + 8192);
    var bytes_written = flac_encode(samples, 48000, 1, 24, out_buf);
    assert(res_ok(bytes_written) == 1, "flac 24bit encode ok");

    var result = flac_decode(out_buf, bytes_written);
    assert(res_ok(result) == 1, "flac 24bit decode ok");

    var fi = decode_result_info(result);
    assert_eq(fmtinfo_bit_depth(fi), 24, "flac 24bit depth");
    assert_eq(fmtinfo_sample_rate(fi), 48000, "flac 24bit rate");

    return 0;
}

fn test_flac_reject_invalid() {
    syscall(1, 1, "test: flac reject invalid\n", 27);

    # Not FLAC data
    var bad = alloc(12);
    store8(bad, 0x52); store8(bad + 1, 0x49); store8(bad + 2, 0x46); store8(bad + 3, 0x46);
    assert(is_err(flac_decode(bad, 12)) == 1, "flac rejects non-flac");

    # Too short
    var short = alloc(3);
    store8(short, 0x66); store8(short + 1, 0x4C); store8(short + 2, 0x61);
    assert(is_err(flac_decode(short, 3)) == 1, "flac rejects too short");

    # Encoder rejects bad params
    var empty = vec_new();
    var tmp = alloc(1024);
    assert(is_err(flac_encode(empty, 44100, 0, 16, tmp)) == 1, "flac encode 0 ch");
    assert(is_err(flac_encode(empty, 0, 1, 16, tmp)) == 1, "flac encode 0 rate");
    assert(is_err(flac_encode(empty, 44100, 1, 0, tmp)) == 1, "flac encode 0 bps");
    assert(is_err(flac_encode(empty, 44100, 1, 33, tmp)) == 1, "flac encode 33 bps");

    return 0;
}

fn test_flac_block_size_codes() {
    syscall(1, 1, "test: flac block size codes\n", 28);

    var tb = alloc(8);
    var tv = alloc(8);
    assert_eq(flac_block_size_code(192, tb, tv), 1, "bs 192");
    assert_eq(flac_block_size_code(4096, tb, tv), 12, "bs 4096");
    assert_eq(flac_block_size_code(100, tb, tv), 6, "bs 100 -> code 6");
    assert_eq(load64(tb), 8, "bs 100 tail_bits 8");
    assert_eq(load64(tv), 99, "bs 100 tail_val 99");

    return 0;
}

# --- ogg.cyr ---

# ================================================================
# ogg.cyr — Ogg container parser and muxer
# ================================================================
#
# Parses Ogg pages, extracts packets, builds pages, muxes packets.
# CRC-32 with polynomial 0x04C11DB7 (direct, no reflection).
#
# Requires: alloc, vec, string, assert helpers from main.cyr

# ================================================================
# CRC-32 table (polynomial 0x04C11DB7, init 0, no reflection)
# ================================================================

var ogg_crc32_table = 0;

fn ogg_init() {
    ogg_crc32_table = alloc(256 * 8);
    var i = 0;
    while (i < 256) {
        var crc = (i << 24) & 0xFFFFFFFF;
        var bit = 0;
        while (bit < 8) {
            if ((crc & 0x80000000) != 0) {
                crc = ((crc << 1) ^ 0x04C11DB7) & 0xFFFFFFFF;
            } else {
                crc = (crc << 1) & 0xFFFFFFFF;
            }
            bit = bit + 1;
        }
        store64(ogg_crc32_table + i * 8, crc & 0xFFFFFFFF);
        i = i + 1;
    }
    return 0;
}

# Compute CRC-32 over a raw byte buffer
fn ogg_crc32(data, len) {
    var crc = 0;
    var i = 0;
    while (i < len) {
        var idx = ((crc >> 24) ^ load8(data + i)) & 0xFF;
        crc = ((crc << 8) ^ load64(ogg_crc32_table + idx * 8)) & 0xFFFFFFFF;
        i = i + 1;
    }
    return crc;
}

# Compute CRC-32 over a page, treating bytes 22..25 (CRC field) as zero
fn ogg_crc32_page(data, len) {
    var crc = 0;
    var i = 0;
    while (i < len) {
        var byte = load8(data + i);
        if (i >= 22) {
            if (i <= 25) {
                byte = 0;
            }
        }
        var idx = ((crc >> 24) ^ byte) & 0xFF;
        crc = ((crc << 8) ^ load64(ogg_crc32_table + idx * 8)) & 0xFFFFFFFF;
        i = i + 1;
    }
    return crc;
}

# ================================================================
# Read helpers (little-endian i64 for granule position)
# ================================================================

fn ogg_read_i64_le(data, off) {
    var lo = read_u32_le(data, off);
    var hi = read_u32_le(data, off + 4);
    return lo | (hi << 32);
}

fn ogg_write_i64_le(buf, off, val) {
    write_u32_le(buf, off, val & 0xFFFFFFFF);
    write_u32_le(buf, off + 4, (val >> 32) & 0xFFFFFFFF);
    return 0;
}

# ================================================================
# OggPage — heap-allocated struct
# ================================================================
# Layout (40 bytes + segment table buffer + body buffer):
#   +0:  header_type     (i64)
#   +8:  granule_position (i64)
#   +16: serial           (i64)
#   +24: page_seq         (i64)
#   +32: num_segments     (i64)
#   +40: segments_ptr     (pointer to byte buffer)
#   +48: body_ptr         (pointer to byte buffer)
#   +56: body_size        (i64)

fn ogg_page_new() {
    var p = alloc(64);
    memset(p, 0, 64);
    return p;
}

fn ogg_page_header_type(p)  { return load64(p); }
fn ogg_page_granule(p)      { return load64(p + 8); }
fn ogg_page_serial(p)       { return load64(p + 16); }
fn ogg_page_seq(p)          { return load64(p + 24); }
fn ogg_page_num_segments(p) { return load64(p + 32); }
fn ogg_page_segments(p)     { return load64(p + 40); }
fn ogg_page_body(p)         { return load64(p + 48); }
fn ogg_page_body_size(p)    { return load64(p + 56); }

# ================================================================
# Page parsing
# ================================================================

# Parse a single Ogg page starting at data[pos].
# Returns page pointer on success, or err() on failure.
# Also stores the end offset at *out_end.
fn ogg_parse_page(data, len, pos, out_end) {
    # Minimum page header: 27 bytes
    if (pos + 27 > len) { return err(ERR_END_OF_STREAM); }

    # Check "OggS" magic
    if (load8(data + pos) != 0x4F)     { return err(ERR_INVALID_HEADER); }
    if (load8(data + pos + 1) != 0x67) { return err(ERR_INVALID_HEADER); }
    if (load8(data + pos + 2) != 0x67) { return err(ERR_INVALID_HEADER); }
    if (load8(data + pos + 3) != 0x53) { return err(ERR_INVALID_HEADER); }

    # Version must be 0
    var version = load8(data + pos + 4);
    if (version != 0) { return err(ERR_INVALID_HEADER); }

    var header_type = load8(data + pos + 5);
    var granule = ogg_read_i64_le(data, pos + 6);
    var serial = read_u32_le(data, pos + 14);
    var page_seq = read_u32_le(data, pos + 18);
    var expected_crc = read_u32_le(data, pos + 22);
    var num_segments = load8(data + pos + 26);

    var seg_table_start = pos + 27;
    if (seg_table_start + num_segments > len) { return err(ERR_END_OF_STREAM); }

    # Copy segment table
    var segments = alloc(num_segments + 1);
    var body_size = 0;
    var si = 0;
    while (si < num_segments) {
        var lv = load8(data + seg_table_start + si);
        store8(segments + si, lv);
        body_size = body_size + lv;
        si = si + 1;
    }

    var body_start = seg_table_start + num_segments;
    if (body_start + body_size > len) { return err(ERR_END_OF_STREAM); }

    # Copy body
    var body = alloc(body_size + 1);
    memcpy(body, data + body_start, body_size);

    # CRC verification
    var page_end = body_start + body_size;
    var computed_crc = ogg_crc32_page(data + pos, page_end - pos);
    if (computed_crc != (expected_crc & 0xFFFFFFFF)) {
        return err(ERR_DECODE);
    }

    # Build page struct
    var page = ogg_page_new();
    store64(page,      header_type);
    store64(page + 8,  granule);
    store64(page + 16, serial);
    store64(page + 24, page_seq);
    store64(page + 32, num_segments);
    store64(page + 40, segments);
    store64(page + 48, body);
    store64(page + 56, body_size);

    store64(out_end, page_end);
    return page;
}

# Parse all pages from data, returns vec of page pointers
fn ogg_parse_pages(data, len) {
    var pages = vec_new();
    var pos = 0;
    var end_buf = alloc(8);

    while (pos + 4 <= len) {
        # Check for OggS magic
        if (load8(data + pos) != 0x4F) { break; }
        if (load8(data + pos + 1) != 0x67) { break; }
        if (load8(data + pos + 2) != 0x67) { break; }
        if (load8(data + pos + 3) != 0x53) { break; }

        var page = ogg_parse_page(data, len, pos, end_buf);
        if (is_err(page) == 1) { return page; }
        vec_push(pages, page);
        pos = load64(end_buf);
    }

    return pages;
}

# ================================================================
# Packet extraction
# ================================================================

# Extract logical packets from Ogg pages.
# Returns a vec of vecs (each inner vec holds raw byte pointers + lengths).
# Actually: returns a vec of Str objects (data+len pairs).
fn ogg_extract_packets(data, len) {
    var pages_result = ogg_parse_pages(data, len);
    if (is_err(pages_result) == 1) { return pages_result; }
    var pages = pages_result;

    var packets = vec_new();

    # Current packet accumulator: use a builder approach
    var cur_buf = alloc(65536);
    var cur_len = 0;
    var cur_cap = 65536;

    var pi = 0;
    var num_pages = vec_len(pages);

    while (pi < num_pages) {
        var page = vec_get(pages, pi);
        var ht = ogg_page_header_type(page);

        # If NOT a continuation page and we have accumulated data, flush it
        if ((ht & 0x01) == 0) {
            if (cur_len > 0) {
                var pkt = alloc(cur_len);
                memcpy(pkt, cur_buf, cur_len);
                vec_push(packets, str_new(pkt, cur_len));
                cur_len = 0;
            }
        }

        var segments = ogg_page_segments(page);
        var nseg = ogg_page_num_segments(page);
        var body = ogg_page_body(page);
        var body_offset = 0;

        var sj = 0;
        while (sj < nseg) {
            var lacing_value = load8(segments + sj);

            if (body_offset + lacing_value > ogg_page_body_size(page)) {
                return err(ERR_DECODE);
            }

            # Ensure capacity (with overflow guard on accumulated length)
            if (cur_len + lacing_value < cur_len) { return err(ERR_DECODE); }
            if (cur_len + lacing_value > 16777216) { return err(ERR_DECODE); }
            if (cur_len + lacing_value > cur_cap) {
                var new_cap = cur_cap * 2;
                if (new_cap < cur_len + lacing_value) {
                    new_cap = cur_len + lacing_value + 65536;
                }
                var new_buf = alloc(new_cap);
                memcpy(new_buf, cur_buf, cur_len);
                cur_buf = new_buf;
                cur_cap = new_cap;
            }

            memcpy(cur_buf + cur_len, body + body_offset, lacing_value);
            cur_len = cur_len + lacing_value;
            body_offset = body_offset + lacing_value;

            if (lacing_value < 255) {
                # Packet boundary
                var pkt = alloc(cur_len + 1);
                memcpy(pkt, cur_buf, cur_len);
                vec_push(packets, str_new(pkt, cur_len));
                cur_len = 0;
            }

            sj = sj + 1;
        }

        pi = pi + 1;
    }

    # Flush remaining data
    if (cur_len > 0) {
        var pkt = alloc(cur_len);
        memcpy(pkt, cur_buf, cur_len);
        vec_push(packets, str_new(pkt, cur_len));
    }

    return packets;
}

# ================================================================
# Page building / muxing
# ================================================================

# Header type flags
var OGG_FLAG_CONTINUATION = 0x01;
var OGG_FLAG_BOS          = 0x02;
var OGG_FLAG_EOS          = 0x04;

# Build a single Ogg page from a payload buffer.
# Returns a Str (pointer + length) for the page bytes.
fn ogg_build_page(header_type, granule, serial, page_seq, payload, payload_len) {
    # Compute lacing values
    var segments = alloc(256);
    var num_segments = 0;
    var remaining = payload_len;

    while (remaining >= 255) {
        store8(segments + num_segments, 255);
        num_segments = num_segments + 1;
        remaining = remaining - 255;
        if (num_segments >= 255) { break; }
    }
    if (num_segments < 255) {
        store8(segments + num_segments, remaining);
        num_segments = num_segments + 1;
    }

    # Clamp to 255 segments max
    if (num_segments > 255) { num_segments = 255; }

    # Calculate actual payload covered
    var actual_payload = 0;
    var si = 0;
    while (si < num_segments) {
        actual_payload = actual_payload + load8(segments + si);
        si = si + 1;
    }

    var page_size = 27 + num_segments + actual_payload;
    var page = alloc(page_size);
    memset(page, 0, page_size);

    # Capture pattern: "OggS"
    store8(page, 0x4F);
    store8(page + 1, 0x67);
    store8(page + 2, 0x67);
    store8(page + 3, 0x53);

    # Version
    store8(page + 4, 0);

    # Header type
    store8(page + 5, header_type);

    # Granule position (i64 LE)
    ogg_write_i64_le(page, 6, granule);

    # Serial number (u32 LE)
    write_u32_le(page, 14, serial);

    # Page sequence number (u32 LE)
    write_u32_le(page, 18, page_seq);

    # CRC placeholder (zeroed)
    write_u32_le(page, 22, 0);

    # Number of segments
    store8(page + 26, num_segments);

    # Segment table
    var ti = 0;
    while (ti < num_segments) {
        store8(page + 27 + ti, load8(segments + ti));
        ti = ti + 1;
    }

    # Body
    memcpy(page + 27 + num_segments, payload, actual_payload);

    # Compute and fill CRC
    var crc = ogg_crc32_page(page, page_size);
    write_u32_le(page, 22, crc);

    return str_new(page, page_size);
}

# Mux packets into a complete Ogg bitstream.
# packets: vec of Str (data+len), granules: pointer to i64 array,
# serial: serial number, num_packets: count
# Returns a Str (data+len) for the whole bitstream.
fn ogg_mux_packets(packets, granules, serial, num_packets) {
    # First pass: compute total output size (upper bound)
    var total = 0;
    var mi = 0;
    while (mi < num_packets) {
        var pkt = vec_get(packets, mi);
        var plen = str_len(pkt);
        # page overhead: 27 + ceil(plen/255) + 1
        total = total + 27 + (plen / 255) + 1 + plen + 256;
        mi = mi + 1;
    }

    var out = alloc(total);
    var out_pos = 0;

    mi = 0;
    while (mi < num_packets) {
        var pkt = vec_get(packets, mi);
        var pdata = str_data(pkt);
        var plen = str_len(pkt);
        var granule = load64(granules + mi * 8);

        var flags = 0;
        if (mi == 0) {
            flags = flags | OGG_FLAG_BOS;
        }
        if (mi == num_packets - 1) {
            flags = flags | OGG_FLAG_EOS;
        }

        var page_str = ogg_build_page(flags, granule, serial, mi, pdata, plen);
        var page_data = str_data(page_str);
        var page_len = str_len(page_str);

        memcpy(out + out_pos, page_data, page_len);
        out_pos = out_pos + page_len;

        mi = mi + 1;
    }

    return str_new(out, out_pos);
}

# ================================================================
# ogg_decode — extract packets and dispatch to codec
# ================================================================

fn ogg_decode(data, len) {
    var packets = ogg_extract_packets(data, len);
    if (is_err(packets) == 1) { return packets; }
    if (vec_len(packets) == 0) { return err(ERR_END_OF_STREAM); }

    # Check first packet for OpusHead and delegate
    var pkt0 = vec_get(packets, 0);
    var pkt0_data = str_data(pkt0);
    var pkt0_len = str_len(pkt0);
    if (pkt0_len >= 8) {
        if (load8(pkt0_data) == 0x4F) {
            if (load8(pkt0_data + 1) == 0x70) {
                if (load8(pkt0_data + 2) == 0x75) {
                    if (load8(pkt0_data + 3) == 0x73) {
                        if (load8(pkt0_data + 4) == 0x48) {
                            if (load8(pkt0_data + 5) == 0x65) {
                                if (load8(pkt0_data + 6) == 0x61) {
                                    if (load8(pkt0_data + 7) == 0x64) {
                                        return opus_decode_from_packets(packets, data, len);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    return err(ERR_UNSUPPORTED_FMT);
}

# ================================================================
# Tests
# ================================================================

# Helper: build a test Ogg page with given params (raw bytes)
fn _test_build_ogg_page(header_type, granule, serial, page_seq, lacing, num_lacing, body, body_len) {
    var page_size = 27 + num_lacing + body_len;
    var page = alloc(page_size);
    memset(page, 0, page_size);

    # OggS
    store8(page, 0x4F);
    store8(page + 1, 0x67);
    store8(page + 2, 0x67);
    store8(page + 3, 0x53);
    # Version 0
    store8(page + 4, 0);
    # Header type
    store8(page + 5, header_type);
    # Granule
    ogg_write_i64_le(page, 6, granule);
    # Serial
    write_u32_le(page, 14, serial);
    # Page seq
    write_u32_le(page, 18, page_seq);
    # CRC placeholder
    write_u32_le(page, 22, 0);
    # Num segments
    store8(page + 26, num_lacing);
    # Segment table
    var li = 0;
    while (li < num_lacing) {
        store8(page + 27 + li, load8(lacing + li));
        li = li + 1;
    }
    # Body
    memcpy(page + 27 + num_lacing, body, body_len);

    # Compute and fill CRC
    var crc = ogg_crc32_page(page, page_size);
    write_u32_le(page, 22, crc);

    return str_new(page, page_size);
}

fn test_ogg_crc32_known_vectors() {
    test_group("ogg: crc32 known vectors");

    # CRC of empty data should be 0
    var empty = alloc(1);
    assert_eq(ogg_crc32(empty, 0), 0, "crc32 empty is 0");

    # CRC of "OggS" should be deterministic and non-zero
    var oggs = alloc(4);
    store8(oggs, 0x4F); store8(oggs+1, 0x67); store8(oggs+2, 0x67); store8(oggs+3, 0x53);
    var crc1 = ogg_crc32(oggs, 4);
    var crc2 = ogg_crc32(oggs, 4);
    assert_eq(crc1, crc2, "crc32 deterministic");
    assert_neq(crc1, 0, "crc32 OggS non-zero");

    # CRC of single zero byte
    var z = alloc(1);
    store8(z, 0);
    var crc3 = ogg_crc32(z, 1);
    assert_eq(crc3, ogg_crc32(z, 1), "crc32 single zero deterministic");

    return 0;
}

fn test_ogg_page_parse_roundtrip() {
    test_group("ogg: page parse roundtrip");

    # Build a page via the build function
    var payload = alloc(15);
    memcpy(payload, "hello_ogg_muxer", 15);

    var page_str = ogg_build_page(OGG_FLAG_BOS, 0, 42, 0, payload, 15);
    var page_data = str_data(page_str);
    var page_len = str_len(page_str);

    # Parse it back
    var end_buf = alloc(8);
    var page = ogg_parse_page(page_data, page_len, 0, end_buf);
    assert(res_ok(page) == 1, "parse built page ok");

    var end = load64(end_buf);
    assert_eq(end, page_len, "parse consumed all bytes");
    assert_eq(ogg_page_header_type(page), OGG_FLAG_BOS, "header type BOS");
    assert_eq(ogg_page_granule(page), 0, "granule 0");
    assert_eq(ogg_page_serial(page), 42, "serial 42");
    assert_eq(ogg_page_seq(page), 0, "page_seq 0");
    assert_eq(ogg_page_body_size(page), 15, "body size 15");

    # Verify body content
    var body = ogg_page_body(page);
    assert(memeq(body, "hello_ogg_muxer", 15) == 1, "body matches");

    return 0;
}

fn test_ogg_reject_invalid_magic() {
    test_group("ogg: reject invalid magic");
    var bad = alloc(32);
    memcpy(bad, "NotOggData1234567890123456789012", 31);
    var end_buf = alloc(8);
    var result = ogg_parse_page(bad, 32, 0, end_buf);
    assert(is_err(result) == 1, "reject bad magic");
    return 0;
}

fn test_ogg_reject_short_data() {
    test_group("ogg: reject short data");
    var short = alloc(4);
    store8(short, 0x4F); store8(short+1, 0x67); store8(short+2, 0x67); store8(short+3, 0x53);
    var end_buf = alloc(8);
    var result = ogg_parse_page(short, 4, 0, end_buf);
    assert(is_err(result) == 1, "reject short data");
    return 0;
}

fn test_ogg_extract_single_packet() {
    test_group("ogg: extract single packet");

    var body = alloc(11);
    memcpy(body, "packet_data", 11);
    var lacing = alloc(1);
    store8(lacing, 11);
    var page_str = _test_build_ogg_page(0x02, 100, 1, 0, lacing, 1, body, 11);
    var pd = str_data(page_str);
    var pl = str_len(page_str);

    var packets = ogg_extract_packets(pd, pl);
    assert(res_ok(packets) == 1, "extract ok");
    assert_eq(vec_len(packets), 1, "1 packet");

    var pkt0 = vec_get(packets, 0);
    assert_eq(str_len(pkt0), 11, "packet len 11");
    assert(memeq(str_data(pkt0), "packet_data", 11) == 1, "packet content");

    return 0;
}

fn test_ogg_extract_multi_packet() {
    test_group("ogg: extract multi packets in one page");

    # Two packets: "aaa" (3 bytes) and "bb" (2 bytes)
    var body = alloc(5);
    memcpy(body, "aaabb", 5);
    var lacing = alloc(2);
    store8(lacing, 3);
    store8(lacing + 1, 2);
    var page_str = _test_build_ogg_page(0x02, 100, 1, 0, lacing, 2, body, 5);
    var pd = str_data(page_str);
    var pl = str_len(page_str);

    var packets = ogg_extract_packets(pd, pl);
    assert(res_ok(packets) == 1, "multi extract ok");
    assert_eq(vec_len(packets), 2, "2 packets");

    var p0 = vec_get(packets, 0);
    assert_eq(str_len(p0), 3, "pkt0 len 3");
    assert(memeq(str_data(p0), "aaa", 3) == 1, "pkt0 = aaa");

    var p1 = vec_get(packets, 1);
    assert_eq(str_len(p1), 2, "pkt1 len 2");
    assert(memeq(str_data(p1), "bb", 2) == 1, "pkt1 = bb");

    return 0;
}

fn test_ogg_continuation_pages() {
    test_group("ogg: continuation across pages");

    # Page 1: 255 bytes of 0xAA, lacing [255] (continued)
    var body1 = alloc(255);
    memset(body1, 0xAA, 255);
    var lacing1 = alloc(1);
    store8(lacing1, 255);
    var p1_str = _test_build_ogg_page(0x02, 0, 1, 0, lacing1, 1, body1, 255);

    # Page 2: 10 bytes of 0xBB, continuation flag 0x01, lacing [10]
    var body2 = alloc(10);
    memset(body2, 0xBB, 10);
    var lacing2 = alloc(1);
    store8(lacing2, 10);
    var p2_str = _test_build_ogg_page(0x01, 100, 1, 1, lacing2, 1, body2, 10);

    # Concatenate pages
    var total_len = str_len(p1_str) + str_len(p2_str);
    var combined = alloc(total_len);
    memcpy(combined, str_data(p1_str), str_len(p1_str));
    memcpy(combined + str_len(p1_str), str_data(p2_str), str_len(p2_str));

    var packets = ogg_extract_packets(combined, total_len);
    assert(res_ok(packets) == 1, "continuation extract ok");
    assert_eq(vec_len(packets), 1, "1 continued packet");

    var pkt = vec_get(packets, 0);
    assert_eq(str_len(pkt), 265, "continued packet len 265");

    # Check first 255 bytes are 0xAA
    var pdata = str_data(pkt);
    var all_aa = 1;
    var ci = 0;
    while (ci < 255) {
        if (load8(pdata + ci) != 0xAA) { all_aa = 0; }
        ci = ci + 1;
    }
    assert(all_aa == 1, "first 255 bytes 0xAA");

    # Check last 10 bytes are 0xBB
    var all_bb = 1;
    ci = 255;
    while (ci < 265) {
        if (load8(pdata + ci) != 0xBB) { all_bb = 0; }
        ci = ci + 1;
    }
    assert(all_bb == 1, "last 10 bytes 0xBB");

    return 0;
}

fn test_ogg_large_packet_lacing() {
    test_group("ogg: large packet lacing roundtrip");

    # A 600-byte packet
    var big = alloc(600);
    memset(big, 0xAA, 600);

    var packets = vec_new();
    vec_push(packets, str_new(big, 600));

    var granules = alloc(8);
    store64(granules, 0);

    var stream = ogg_mux_packets(packets, granules, 1, 1);
    var extracted = ogg_extract_packets(str_data(stream), str_len(stream));
    assert(res_ok(extracted) == 1, "large packet extract ok");
    assert_eq(vec_len(extracted), 1, "1 large packet");

    var pkt = vec_get(extracted, 0);
    assert_eq(str_len(pkt), 600, "large packet len 600");
    assert(memeq(str_data(pkt), big, 600) == 1, "large packet content matches");

    return 0;
}

fn test_ogg_mux_roundtrip() {
    test_group("ogg: mux/demux roundtrip");

    var packets = vec_new();
    var p1 = alloc(12); memcpy(p1, "first_packet", 12);
    var p2 = alloc(13); memcpy(p2, "second_packet", 13);
    var p3 = alloc(12); memcpy(p3, "third_packet", 12);
    vec_push(packets, str_new(p1, 12));
    vec_push(packets, str_new(p2, 13));
    vec_push(packets, str_new(p3, 12));

    var granules = alloc(24);
    store64(granules, 0);
    store64(granules + 8, 960);
    store64(granules + 16, 1920);

    var stream = ogg_mux_packets(packets, granules, 1, 3);
    var extracted = ogg_extract_packets(str_data(stream), str_len(stream));
    assert(res_ok(extracted) == 1, "mux roundtrip extract ok");
    assert_eq(vec_len(extracted), 3, "3 packets");

    var e0 = vec_get(extracted, 0);
    assert_eq(str_len(e0), 12, "pkt0 len");
    assert(memeq(str_data(e0), "first_packet", 12) == 1, "pkt0 content");

    var e1 = vec_get(extracted, 1);
    assert_eq(str_len(e1), 13, "pkt1 len");
    assert(memeq(str_data(e1), "second_packet", 13) == 1, "pkt1 content");

    var e2 = vec_get(extracted, 2);
    assert_eq(str_len(e2), 12, "pkt2 len");
    assert(memeq(str_data(e2), "third_packet", 12) == 1, "pkt2 content");

    return 0;
}

fn test_ogg_mux_single_has_bos_eos() {
    test_group("ogg: single packet BOS+EOS");

    var packets = vec_new();
    var p1 = alloc(11); memcpy(p1, "only_packet", 11);
    vec_push(packets, str_new(p1, 11));

    var granules = alloc(8);
    store64(granules, 0);

    var stream = ogg_mux_packets(packets, granules, 1, 1);

    # Parse the single page and check flags
    var end_buf = alloc(8);
    var page = ogg_parse_page(str_data(stream), str_len(stream), 0, end_buf);
    assert(res_ok(page) == 1, "single page parse ok");

    var ht = ogg_page_header_type(page);
    assert_neq(ht & OGG_FLAG_BOS, 0, "has BOS");
    assert_neq(ht & OGG_FLAG_EOS, 0, "has EOS");

    return 0;
}

fn test_ogg_crc_mismatch() {
    test_group("ogg: CRC mismatch detection");

    var body = alloc(5);
    memcpy(body, "hello", 5);
    var lacing = alloc(1);
    store8(lacing, 5);
    var page_str = _test_build_ogg_page(0x02, 0, 1, 0, lacing, 1, body, 5);
    var pd = str_data(page_str);
    var pl = str_len(page_str);

    # Corrupt last byte
    store8(pd + pl - 1, load8(pd + pl - 1) ^ 0xFF);

    var end_buf = alloc(8);
    var result = ogg_parse_page(pd, pl, 0, end_buf);
    assert(is_err(result) == 1, "CRC mismatch detected");

    return 0;
}

fn test_ogg_multiple_pages() {
    test_group("ogg: multiple pages");

    var body1 = alloc(3); memcpy(body1, "abc", 3);
    var lacing1 = alloc(1); store8(lacing1, 3);
    var p1_str = _test_build_ogg_page(0x02, 0, 1, 0, lacing1, 1, body1, 3);

    var body2 = alloc(2); memcpy(body2, "de", 2);
    var lacing2 = alloc(1); store8(lacing2, 2);
    var p2_str = _test_build_ogg_page(0x00, 100, 1, 1, lacing2, 1, body2, 2);

    var total_len = str_len(p1_str) + str_len(p2_str);
    var combined = alloc(total_len);
    memcpy(combined, str_data(p1_str), str_len(p1_str));
    memcpy(combined + str_len(p1_str), str_data(p2_str), str_len(p2_str));

    var packets = ogg_extract_packets(combined, total_len);
    assert(res_ok(packets) == 1, "multi page extract ok");
    assert_eq(vec_len(packets), 2, "2 packets from 2 pages");

    var pk0 = vec_get(packets, 0);
    assert_eq(str_len(pk0), 3, "pkt0 len 3");
    assert(memeq(str_data(pk0), "abc", 3) == 1, "pkt0 = abc");

    var pk1 = vec_get(packets, 1);
    assert_eq(str_len(pk1), 2, "pkt1 len 2");
    assert(memeq(str_data(pk1), "de", 2) == 1, "pkt1 = de");

    return 0;
}

fn test_ogg_decode_unsupported() {
    test_group("ogg: decode returns unsupported");

    var body = alloc(8);
    memcpy(body, "NotOpus!", 8);
    var lacing = alloc(1);
    store8(lacing, 8);
    var page_str = _test_build_ogg_page(0x02, 0, 1, 0, lacing, 1, body, 8);

    var result = ogg_decode(str_data(page_str), str_len(page_str));
    assert(is_err(result) == 1, "ogg_decode unsupported codec");

    return 0;
}

# --- mp3.cyr ---

# ================================================================
# mp3.cyr — MP3 frame header parser (no audio decoding)
# ================================================================
#
# Parses MPEG audio frame headers: sync word detection, version/layer/
# bitrate/sample-rate extraction, ID3v2 tag skipping, frame scanning.
# Does NOT produce decoded audio samples.
#
# Requires: alloc, vec, string, assert helpers from main.cyr

# ================================================================
# Bitrate and sample rate tables (initialized in mp3_init)
# ================================================================

var mp3_bitrate_v1_l3 = 0;    # 16 entries
var mp3_bitrate_v2_l3 = 0;    # 16 entries (also V2/V2.5 Layer II)
var mp3_bitrate_v1_l1 = 0;    # 16 entries
var mp3_bitrate_v1_l2 = 0;    # 16 entries
var mp3_bitrate_v2_l1 = 0;    # 16 entries
var mp3_sr_v1  = 0;            # 3 entries
var mp3_sr_v2  = 0;            # 3 entries
var mp3_sr_v25 = 0;            # 3 entries

fn mp3_init() {
    # V1 Layer III bitrates (kbps): 0,32,40,48,56,64,80,96,112,128,160,192,224,256,320,0
    mp3_bitrate_v1_l3 = alloc(16 * 8);
    store64(mp3_bitrate_v1_l3 + 0 * 8, 0);
    store64(mp3_bitrate_v1_l3 + 1 * 8, 32);
    store64(mp3_bitrate_v1_l3 + 2 * 8, 40);
    store64(mp3_bitrate_v1_l3 + 3 * 8, 48);
    store64(mp3_bitrate_v1_l3 + 4 * 8, 56);
    store64(mp3_bitrate_v1_l3 + 5 * 8, 64);
    store64(mp3_bitrate_v1_l3 + 6 * 8, 80);
    store64(mp3_bitrate_v1_l3 + 7 * 8, 96);
    store64(mp3_bitrate_v1_l3 + 8 * 8, 112);
    store64(mp3_bitrate_v1_l3 + 9 * 8, 128);
    store64(mp3_bitrate_v1_l3 + 10 * 8, 160);
    store64(mp3_bitrate_v1_l3 + 11 * 8, 192);
    store64(mp3_bitrate_v1_l3 + 12 * 8, 224);
    store64(mp3_bitrate_v1_l3 + 13 * 8, 256);
    store64(mp3_bitrate_v1_l3 + 14 * 8, 320);
    store64(mp3_bitrate_v1_l3 + 15 * 8, 0);

    # V2/V2.5 Layer III bitrates (kbps): 0,8,16,24,32,40,48,56,64,80,96,112,128,144,160,0
    mp3_bitrate_v2_l3 = alloc(16 * 8);
    store64(mp3_bitrate_v2_l3 + 0 * 8, 0);
    store64(mp3_bitrate_v2_l3 + 1 * 8, 8);
    store64(mp3_bitrate_v2_l3 + 2 * 8, 16);
    store64(mp3_bitrate_v2_l3 + 3 * 8, 24);
    store64(mp3_bitrate_v2_l3 + 4 * 8, 32);
    store64(mp3_bitrate_v2_l3 + 5 * 8, 40);
    store64(mp3_bitrate_v2_l3 + 6 * 8, 48);
    store64(mp3_bitrate_v2_l3 + 7 * 8, 56);
    store64(mp3_bitrate_v2_l3 + 8 * 8, 64);
    store64(mp3_bitrate_v2_l3 + 9 * 8, 80);
    store64(mp3_bitrate_v2_l3 + 10 * 8, 96);
    store64(mp3_bitrate_v2_l3 + 11 * 8, 112);
    store64(mp3_bitrate_v2_l3 + 12 * 8, 128);
    store64(mp3_bitrate_v2_l3 + 13 * 8, 144);
    store64(mp3_bitrate_v2_l3 + 14 * 8, 160);
    store64(mp3_bitrate_v2_l3 + 15 * 8, 0);

    # MPEG1 Layer I bitrate table (kbps): {free,32,64,96,...,448,bad}
    mp3_bitrate_v1_l1 = alloc(16 * 8);
    store64(mp3_bitrate_v1_l1 + 0 * 8, 0);   store64(mp3_bitrate_v1_l1 + 1 * 8, 32);
    store64(mp3_bitrate_v1_l1 + 2 * 8, 64);  store64(mp3_bitrate_v1_l1 + 3 * 8, 96);
    store64(mp3_bitrate_v1_l1 + 4 * 8, 128); store64(mp3_bitrate_v1_l1 + 5 * 8, 160);
    store64(mp3_bitrate_v1_l1 + 6 * 8, 192); store64(mp3_bitrate_v1_l1 + 7 * 8, 224);
    store64(mp3_bitrate_v1_l1 + 8 * 8, 256); store64(mp3_bitrate_v1_l1 + 9 * 8, 288);
    store64(mp3_bitrate_v1_l1 + 10 * 8, 320); store64(mp3_bitrate_v1_l1 + 11 * 8, 352);
    store64(mp3_bitrate_v1_l1 + 12 * 8, 384); store64(mp3_bitrate_v1_l1 + 13 * 8, 416);
    store64(mp3_bitrate_v1_l1 + 14 * 8, 448); store64(mp3_bitrate_v1_l1 + 15 * 8, 0);

    # MPEG1 Layer II bitrate table (kbps)
    mp3_bitrate_v1_l2 = alloc(16 * 8);
    store64(mp3_bitrate_v1_l2 + 0 * 8, 0);   store64(mp3_bitrate_v1_l2 + 1 * 8, 32);
    store64(mp3_bitrate_v1_l2 + 2 * 8, 48);  store64(mp3_bitrate_v1_l2 + 3 * 8, 56);
    store64(mp3_bitrate_v1_l2 + 4 * 8, 64);  store64(mp3_bitrate_v1_l2 + 5 * 8, 80);
    store64(mp3_bitrate_v1_l2 + 6 * 8, 96);  store64(mp3_bitrate_v1_l2 + 7 * 8, 112);
    store64(mp3_bitrate_v1_l2 + 8 * 8, 128); store64(mp3_bitrate_v1_l2 + 9 * 8, 160);
    store64(mp3_bitrate_v1_l2 + 10 * 8, 192); store64(mp3_bitrate_v1_l2 + 11 * 8, 224);
    store64(mp3_bitrate_v1_l2 + 12 * 8, 256); store64(mp3_bitrate_v1_l2 + 13 * 8, 320);
    store64(mp3_bitrate_v1_l2 + 14 * 8, 384); store64(mp3_bitrate_v1_l2 + 15 * 8, 0);

    # MPEG2/2.5 Layer I bitrate table (kbps)
    mp3_bitrate_v2_l1 = alloc(16 * 8);
    store64(mp3_bitrate_v2_l1 + 0 * 8, 0);   store64(mp3_bitrate_v2_l1 + 1 * 8, 32);
    store64(mp3_bitrate_v2_l1 + 2 * 8, 48);  store64(mp3_bitrate_v2_l1 + 3 * 8, 56);
    store64(mp3_bitrate_v2_l1 + 4 * 8, 64);  store64(mp3_bitrate_v2_l1 + 5 * 8, 80);
    store64(mp3_bitrate_v2_l1 + 6 * 8, 96);  store64(mp3_bitrate_v2_l1 + 7 * 8, 112);
    store64(mp3_bitrate_v2_l1 + 8 * 8, 128); store64(mp3_bitrate_v2_l1 + 9 * 8, 144);
    store64(mp3_bitrate_v2_l1 + 10 * 8, 160); store64(mp3_bitrate_v2_l1 + 11 * 8, 176);
    store64(mp3_bitrate_v2_l1 + 12 * 8, 192); store64(mp3_bitrate_v2_l1 + 13 * 8, 224);
    store64(mp3_bitrate_v2_l1 + 14 * 8, 256); store64(mp3_bitrate_v2_l1 + 15 * 8, 0);

    # MPEG1 sample rates: 44100, 48000, 32000
    mp3_sr_v1 = alloc(3 * 8);
    store64(mp3_sr_v1 + 0 * 8, 44100);
    store64(mp3_sr_v1 + 1 * 8, 48000);
    store64(mp3_sr_v1 + 2 * 8, 32000);

    # MPEG2 sample rates: 22050, 24000, 16000
    mp3_sr_v2 = alloc(3 * 8);
    store64(mp3_sr_v2 + 0 * 8, 22050);
    store64(mp3_sr_v2 + 1 * 8, 24000);
    store64(mp3_sr_v2 + 2 * 8, 16000);

    # MPEG2.5 sample rates: 11025, 12000, 8000
    mp3_sr_v25 = alloc(3 * 8);
    store64(mp3_sr_v25 + 0 * 8, 11025);
    store64(mp3_sr_v25 + 1 * 8, 12000);
    store64(mp3_sr_v25 + 2 * 8, 8000);

    return 0;
}

# ================================================================
# MPEG version/layer/channel mode integer enums
# ================================================================

var MP3_VERSION_V1  = 1;
var MP3_VERSION_V2  = 2;
var MP3_VERSION_V25 = 3;

var MP3_LAYER_I   = 1;
var MP3_LAYER_II  = 2;
var MP3_LAYER_III = 3;

var MP3_CHANNEL_STEREO       = 0;
var MP3_CHANNEL_JOINT_STEREO = 1;
var MP3_CHANNEL_DUAL         = 2;
var MP3_CHANNEL_MONO         = 3;

# ================================================================
# MP3 frame info struct (heap-allocated)
# ================================================================
# Layout (72 bytes):
#   +0:  version          (i64)
#   +8:  layer            (i64)
#   +16: bitrate          (i64, kbps)
#   +24: sample_rate      (i64, Hz)
#   +32: channel_mode     (i64)
#   +40: frame_size       (i64, bytes)
#   +48: samples_per_frame (i64)
#   +56: padding          (i64, 0 or 1)

fn mp3_frame_new() {
    var f = alloc(64);
    memset(f, 0, 64);
    return f;
}

fn mp3_frame_version(f)        { return load64(f); }
fn mp3_frame_layer(f)          { return load64(f + 8); }
fn mp3_frame_bitrate(f)        { return load64(f + 16); }
fn mp3_frame_sample_rate(f)    { return load64(f + 24); }
fn mp3_frame_channel_mode(f)   { return load64(f + 32); }
fn mp3_frame_size(f)           { return load64(f + 40); }
fn mp3_frame_samples_per_frame(f) { return load64(f + 48); }
fn mp3_frame_padding(f)        { return load64(f + 56); }

# ================================================================
# Syncsafe integer (4 bytes, 7 bits each)
# ================================================================

fn mp3_syncsafe_to_u32(data, off) {
    return ((load8(data + off) & 0x7F) << 21)
         | ((load8(data + off + 1) & 0x7F) << 14)
         | ((load8(data + off + 2) & 0x7F) << 7)
         | (load8(data + off + 3) & 0x7F);
}

# ================================================================
# ID3v2 tag skip
# ================================================================

fn mp3_id3v2_skip(data, len) {
    if (len < 10) { return 0; }
    # Check for "ID3"
    if (load8(data) != 0x49)     { return 0; }
    if (load8(data + 1) != 0x44) { return 0; }
    if (load8(data + 2) != 0x33) { return 0; }
    var size = mp3_syncsafe_to_u32(data, 6);
    return 10 + size;
}

# ================================================================
# Frame header parsing
# ================================================================

# Parse a 4-byte MPEG audio frame header at data[off].
# Returns heap-allocated frame info, or err() on invalid.
fn mp3_parse_frame_header(data, off) {
    # Sync word: first 11 bits must be 1
    if (load8(data + off) != 0xFF) { return err(ERR_INVALID_HEADER); }
    var b1 = load8(data + off + 1);
    if ((b1 & 0xE0) != 0xE0) { return err(ERR_INVALID_HEADER); }

    # Version: bits 4-3 of byte 1
    var version_bits = (b1 >> 3) & 0x03;
    var version = 0;
    if (version_bits == 0) { version = MP3_VERSION_V25; }
    if (version_bits == 2) { version = MP3_VERSION_V2; }
    if (version_bits == 3) { version = MP3_VERSION_V1; }
    if (version_bits == 1) { return err(ERR_INVALID_HEADER); }  # reserved
    if (version == 0)      { return err(ERR_INVALID_HEADER); }

    # Layer: bits 2-1 of byte 1
    var layer_bits = (b1 >> 1) & 0x03;
    var layer = 0;
    if (layer_bits == 1) { layer = MP3_LAYER_III; }
    if (layer_bits == 2) { layer = MP3_LAYER_II; }
    if (layer_bits == 3) { layer = MP3_LAYER_I; }
    if (layer_bits == 0) { return err(ERR_INVALID_HEADER); }  # reserved
    if (layer == 0)      { return err(ERR_INVALID_HEADER); }

    # Bitrate: bits 7-4 of byte 2
    var b2 = load8(data + off + 2);
    var bitrate_index = (b2 >> 4) & 0x0F;

    # Each MPEG version + layer has its OWN bitrate table (Layer I and II differ from
    # Layer III — the old code used the Layer III table for all layers, giving wrong
    # frame sizes / durations / frame scanning for Layer I/II).
    var bitrate = 0;
    if (version == MP3_VERSION_V1) {
        if (layer == MP3_LAYER_I)   { bitrate = load64(mp3_bitrate_v1_l1 + bitrate_index * 8); }
        if (layer == MP3_LAYER_II)  { bitrate = load64(mp3_bitrate_v1_l2 + bitrate_index * 8); }
        if (layer == MP3_LAYER_III) { bitrate = load64(mp3_bitrate_v1_l3 + bitrate_index * 8); }
    } else {
        # MPEG2 / MPEG2.5 — Layer II and III share a table (mp3_bitrate_v2_l3).
        if (layer == MP3_LAYER_I)   { bitrate = load64(mp3_bitrate_v2_l1 + bitrate_index * 8); }
        if (layer == MP3_LAYER_II)  { bitrate = load64(mp3_bitrate_v2_l3 + bitrate_index * 8); }
        if (layer == MP3_LAYER_III) { bitrate = load64(mp3_bitrate_v2_l3 + bitrate_index * 8); }
    }
    if (bitrate == 0) { return err(ERR_INVALID_HEADER); }

    # Sample rate: bits 3-2 of byte 2
    var sr_index = (b2 >> 2) & 0x03;
    if (sr_index >= 3) { return err(ERR_INVALID_HEADER); }

    var sample_rate = 0;
    if (version == MP3_VERSION_V1) {
        sample_rate = load64(mp3_sr_v1 + sr_index * 8);
    }
    if (version == MP3_VERSION_V2) {
        sample_rate = load64(mp3_sr_v2 + sr_index * 8);
    }
    if (version == MP3_VERSION_V25) {
        sample_rate = load64(mp3_sr_v25 + sr_index * 8);
    }

    # Padding: bit 1 of byte 2
    var padding = (b2 >> 1) & 0x01;

    # Channel mode: bits 7-6 of byte 3
    var b3 = load8(data + off + 3);
    var channel_mode = (b3 >> 6) & 0x03;

    # Samples per frame
    var samples_per_frame = 0;
    if (version == MP3_VERSION_V1) {
        if (layer == MP3_LAYER_I) { samples_per_frame = 384; }
        if (layer == MP3_LAYER_II) { samples_per_frame = 1152; }
        if (layer == MP3_LAYER_III) { samples_per_frame = 1152; }
    } else {
        # V2 / V2.5
        if (layer == MP3_LAYER_I) { samples_per_frame = 384; }
        if (layer == MP3_LAYER_II) { samples_per_frame = 1152; }
        if (layer == MP3_LAYER_III) { samples_per_frame = 576; }
    }

    # Frame size calculation
    var padding_bytes = padding;
    var frame_size = 0;

    if (layer == MP3_LAYER_I) {
        frame_size = (12 * bitrate * 1000 / sample_rate + padding_bytes) * 4;
    } else {
        # Layer II / III
        var spf = 1152;
        if (layer == MP3_LAYER_III) {
            if (version == MP3_VERSION_V2) { spf = 576; }
            if (version == MP3_VERSION_V25) { spf = 576; }
        }
        frame_size = spf * bitrate * 1000 / (8 * sample_rate) + padding_bytes;
    }

    # Build frame info struct
    var f = mp3_frame_new();
    store64(f,      version);
    store64(f + 8,  layer);
    store64(f + 16, bitrate);
    store64(f + 24, sample_rate);
    store64(f + 32, channel_mode);
    store64(f + 40, frame_size);
    store64(f + 48, samples_per_frame);
    store64(f + 56, padding);

    return f;
}

# ================================================================
# Frame scanning
# ================================================================

# Scan data for all valid MP3 frame headers.
# Returns a vec of frame info pointers.
fn mp3_scan_frames(data, len) {
    var skip = mp3_id3v2_skip(data, len);
    var pos = skip;
    var frames = vec_new();

    while (pos + 4 <= len) {
        if (load8(data + pos) == 0xFF) {
            if ((load8(data + pos + 1) & 0xE0) == 0xE0) {
                var info = mp3_parse_frame_header(data, pos);
                if (res_ok(info) == 1) {
                    var fs = mp3_frame_size(info);
                    if (fs > 0) {
                        # SEC-010: guard against frame_size pointing past buffer
                        if (pos + fs > len) { break; }
                        vec_push(frames, info);
                        pos = pos + fs;
                    } else {
                        pos = pos + 1;
                    }
                } else {
                    pos = pos + 1;
                }
            } else {
                pos = pos + 1;
            }
        } else {
            pos = pos + 1;
        }
    }

    return frames;
}

# ================================================================
# mp3_decode — returns FormatInfo with empty samples
# ================================================================

fn mp3_decode(data, len) {
    if (mp3_bitrate_v1_l3 == 0) { mp3_init(); }
    # MPEG-1 Layer III: full decode to real PCM (2.5.11).
    var pcm = mp3_decode_pcm(data, len);
    if (res_ok(pcm) == 1) { return pcm; }

    # Fallback: Layer I/II, MPEG-2/2.5, or no decodable L3 frame — metadata only,
    # empty sample vector (behaviour prior to 2.5.11).
    var frames = mp3_scan_frames(data, len);
    if (vec_len(frames) == 0) { return err(ERR_INVALID_HEADER); }

    var first = vec_get(frames, 0);

    # Sum total samples across all frames
    var total_samples = 0;
    var fi = 0;
    var nframes = vec_len(frames);
    while (fi < nframes) {
        var f = vec_get(frames, fi);
        total_samples = total_samples + mp3_frame_samples_per_frame(f);
        fi = fi + 1;
    }

    var sr = mp3_frame_sample_rate(first);
    var dur = f64_div(f64_from(total_samples), f64_from(sr));

    var channels = 2;
    if (mp3_frame_channel_mode(first) == MP3_CHANNEL_MONO) {
        channels = 1;
    }

    var info = fmtinfo_new(FMT_MP3, sr, channels, 16, dur, total_samples);
    return decode_result_new(info, vec_new());
}

# ================================================================
# Tests
# ================================================================

# Helper: build a valid MPEG1 Layer III header
# 128kbps, 44100 Hz, stereo, no padding => [0xFF, 0xFB, 0x90, 0x00]
fn _mp3_make_valid_header(buf) {
    store8(buf, 0xFF);
    store8(buf + 1, 0xFB);
    store8(buf + 2, 0x90);
    store8(buf + 3, 0x00);
    return 0;
}

fn test_mp3_valid_header_parse() {
    test_group("mp3: valid header parse");

    var hdr = alloc(4);
    _mp3_make_valid_header(hdr);

    var info = mp3_parse_frame_header(hdr, 0);
    assert(res_ok(info) == 1, "parse ok");
    assert_eq(mp3_frame_version(info), MP3_VERSION_V1, "version V1");
    assert_eq(mp3_frame_layer(info), MP3_LAYER_III, "layer III");
    assert_eq(mp3_frame_bitrate(info), 128, "bitrate 128");
    assert_eq(mp3_frame_sample_rate(info), 44100, "sample rate 44100");
    assert_eq(mp3_frame_channel_mode(info), MP3_CHANNEL_STEREO, "stereo");
    assert_eq(mp3_frame_samples_per_frame(info), 1152, "1152 spf");
    assert_eq(mp3_frame_padding(info), 0, "no padding");
    # Frame size = 1152 * 128000 / (8 * 44100) = 417
    assert_eq(mp3_frame_size(info), 417, "frame size 417");

    return 0;
}

# 2.5.11: Layer I/II must use their own bitrate tables (the old code used Layer III's).
fn test_mp3_layer2_bitrate() {
    test_group("mp3: layer II uses its own bitrate table");
    var hdr = alloc(4);
    store8(hdr, 0xFF);
    store8(hdr + 1, 0xFD);   # sync + V1 + Layer II + no CRC
    store8(hdr + 2, 0xE0);   # bitrate_index=14, sr_index=0 (44100), no padding
    store8(hdr + 3, 0x00);   # stereo
    var info = mp3_parse_frame_header(hdr, 0);
    assert(res_ok(info) == 1, "parse ok");
    assert_eq(mp3_frame_layer(info), MP3_LAYER_II, "layer II");
    # V1 Layer II index 14 = 384 kbps (Layer III index 14 = 320 — the old bug value).
    assert_eq(mp3_frame_bitrate(info), 384, "L2 bitrate 384 (not L3's 320)");
    assert_eq(mp3_frame_samples_per_frame(info), 1152, "1152 spf");
    # 1152 * 384000 / (8 * 44100) = 1253 (integer division)
    assert_eq(mp3_frame_size(info), 1253, "L2 frame size 1253");
    return 0;
}

fn test_mp3_reject_bad_sync() {
    test_group("mp3: reject bad sync");

    var hdr = alloc(4);
    store8(hdr, 0x00); store8(hdr+1, 0x00); store8(hdr+2, 0x90); store8(hdr+3, 0x00);
    var result = mp3_parse_frame_header(hdr, 0);
    assert(is_err(result) == 1, "bad sync rejected");

    return 0;
}

fn test_mp3_reject_reserved_version() {
    test_group("mp3: reject reserved version");

    # version bits = 01 -> reserved
    # 0xE9 = 1110_1001 -> sync ok, version=01
    var hdr = alloc(4);
    store8(hdr, 0xFF); store8(hdr+1, 0xE9); store8(hdr+2, 0x90); store8(hdr+3, 0x00);
    var result = mp3_parse_frame_header(hdr, 0);
    assert(is_err(result) == 1, "reserved version rejected");

    return 0;
}

fn test_mp3_reject_reserved_layer() {
    test_group("mp3: reject reserved layer");

    # layer bits = 00 -> reserved
    # 0xF1 = 1111_0001 -> layer=00
    var hdr = alloc(4);
    store8(hdr, 0xFF); store8(hdr+1, 0xF1); store8(hdr+2, 0x90); store8(hdr+3, 0x00);
    var result = mp3_parse_frame_header(hdr, 0);
    assert(is_err(result) == 1, "reserved layer rejected");

    return 0;
}

fn test_mp3_reject_zero_bitrate() {
    test_group("mp3: reject zero bitrate");

    # bitrate index 0 -> free format (0 kbps, rejected)
    var hdr = alloc(4);
    store8(hdr, 0xFF); store8(hdr+1, 0xFB); store8(hdr+2, 0x00); store8(hdr+3, 0x00);
    var result = mp3_parse_frame_header(hdr, 0);
    assert(is_err(result) == 1, "zero bitrate rejected");

    return 0;
}

fn test_mp3_reject_reserved_sample_rate() {
    test_group("mp3: reject reserved sample rate");

    # sr index 3 -> reserved: byte2 bits 3-2 = 11
    # 0x9C = 1001_11_0_0
    var hdr = alloc(4);
    store8(hdr, 0xFF); store8(hdr+1, 0xFB); store8(hdr+2, 0x9C); store8(hdr+3, 0x00);
    var result = mp3_parse_frame_header(hdr, 0);
    assert(is_err(result) == 1, "reserved sample rate rejected");

    return 0;
}

fn test_mp3_id3v2_skip_no_tag() {
    test_group("mp3: id3v2 skip no tag");

    var data = alloc(4);
    store8(data, 0xFF); store8(data+1, 0xFB); store8(data+2, 0x90); store8(data+3, 0x00);
    assert_eq(mp3_id3v2_skip(data, 4), 0, "no tag skip 0");

    return 0;
}

fn test_mp3_id3v2_skip_with_tag() {
    test_group("mp3: id3v2 skip with tag");

    var data = alloc(210);
    memset(data, 0, 210);
    # "ID3"
    store8(data, 0x49);
    store8(data + 1, 0x44);
    store8(data + 2, 0x33);
    store8(data + 3, 4);     # version major
    store8(data + 4, 0);     # version minor
    store8(data + 5, 0);     # flags
    # syncsafe size = 100 -> [0, 0, 0, 100]
    store8(data + 6, 0);
    store8(data + 7, 0);
    store8(data + 8, 0);
    store8(data + 9, 100);

    assert_eq(mp3_id3v2_skip(data, 210), 110, "id3v2 skip 110");

    return 0;
}

fn test_mp3_frame_size_with_padding() {
    test_group("mp3: frame size with padding");

    # Same header but padding bit set: 0x92 = 1001_00_1_0
    var hdr = alloc(4);
    store8(hdr, 0xFF); store8(hdr+1, 0xFB); store8(hdr+2, 0x92); store8(hdr+3, 0x00);
    var info = mp3_parse_frame_header(hdr, 0);
    assert(res_ok(info) == 1, "padded parse ok");
    assert_eq(mp3_frame_padding(info), 1, "has padding");
    assert_eq(mp3_frame_size(info), 418, "frame size 418");

    return 0;
}

fn test_mp3_scan_multiple_frames() {
    test_group("mp3: scan multiple frames");

    var hdr = alloc(4);
    _mp3_make_valid_header(hdr);

    # Parse to get frame size
    var info = mp3_parse_frame_header(hdr, 0);
    var frame_size = mp3_frame_size(info);

    # Build data with 3 frames
    var total = frame_size * 3;
    var data = alloc(total);
    memset(data, 0, total);

    var fi = 0;
    while (fi < 3) {
        memcpy(data + fi * frame_size, hdr, 4);
        fi = fi + 1;
    }

    var frames = mp3_scan_frames(data, total);
    assert_eq(vec_len(frames), 3, "3 frames found");

    return 0;
}

fn test_mp3_scan_no_frames() {
    test_group("mp3: scan no frames");

    var data = alloc(100);
    memset(data, 0, 100);
    var frames = mp3_scan_frames(data, 100);
    assert_eq(vec_len(frames), 0, "no frames found");

    return 0;
}

fn test_mp3_mono_channel() {
    test_group("mp3: mono channel mode");

    # channel mode = 11 -> mono: byte3 = 0xC0
    var hdr = alloc(4);
    store8(hdr, 0xFF); store8(hdr+1, 0xFB); store8(hdr+2, 0x90); store8(hdr+3, 0xC0);
    var info = mp3_parse_frame_header(hdr, 0);
    assert(res_ok(info) == 1, "mono parse ok");
    assert_eq(mp3_frame_channel_mode(info), MP3_CHANNEL_MONO, "mono mode");

    return 0;
}

fn test_mp3_syncsafe() {
    test_group("mp3: syncsafe decode");

    var buf = alloc(4);

    # [0x00, 0x00, 0x02, 0x01] -> 257
    store8(buf, 0x00); store8(buf+1, 0x00); store8(buf+2, 0x02); store8(buf+3, 0x01);
    assert_eq(mp3_syncsafe_to_u32(buf, 0), 257, "syncsafe 257");

    # [0x00, 0x00, 0x00, 0x00] -> 0
    store8(buf, 0x00); store8(buf+1, 0x00); store8(buf+2, 0x00); store8(buf+3, 0x00);
    assert_eq(mp3_syncsafe_to_u32(buf, 0), 0, "syncsafe 0");

    # [0x7F, 0x7F, 0x7F, 0x7F] -> 0x0FFFFFFF = 268435455
    store8(buf, 0x7F); store8(buf+1, 0x7F); store8(buf+2, 0x7F); store8(buf+3, 0x7F);
    assert_eq(mp3_syncsafe_to_u32(buf, 0), 268435455, "syncsafe max");

    return 0;
}

fn test_mp3_decode_produces_info() {
    test_group("mp3: decode produces format info");

    var hdr = alloc(4);
    _mp3_make_valid_header(hdr);

    var info = mp3_parse_frame_header(hdr, 0);
    var frame_size = mp3_frame_size(info);

    # Build data with 10 frames
    var total = frame_size * 10;
    var data = alloc(total);
    memset(data, 0, total);

    var fi = 0;
    while (fi < 10) {
        memcpy(data + fi * frame_size, hdr, 4);
        fi = fi + 1;
    }

    var result = mp3_decode(data, total);
    assert(res_ok(result) == 1, "decode ok");

    var finfo = load64(result);
