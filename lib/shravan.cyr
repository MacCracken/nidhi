# Layer II decode: verified sample-exact vs minimp3 (mono + stereo + low-rate).
fn test_mp3_decode_layer2() {
    test_group("mp3: decode Layer II -> PCM");
    if (mp3_bitrate_v1_l3 == 0) { mp3_init(); }
    var buf = alloc(16384);
    var n = _mp3_b64_decode(_L2MONO_B64, buf);
    var res = mp3_decode_pcm(buf, n);
    assert(res_ok(res) == 1, "layer2 mono decode ok");
    var sv = decode_result_samples(res);
    assert_eq(fmtinfo_channels(load64(res)), 1, "layer2 mono");
    var m = vec_len(sv);
    var sb = alloc(m * 8);
    var i = 0;
    while (i < m) { store64(sb + i * 8, vec_get(sv, i)); i = i + 1; }
    var c = _mp3_tone_corr(sb, m, 44100);
    syscall(1, 1, "  layer2 mono corr*1000 = ", 26); fmt_int(c); syscall(1, 1, "\n", 1);
    assert(c > 985, "layer2 mono correlates with source");
    var n2 = _mp3_b64_decode(_L2ST_B64, buf);
    var res2 = mp3_decode_pcm(buf, n2);
    assert(res_ok(res2) == 1, "layer2 stereo decode ok");
    var sv2 = decode_result_samples(res2);
    assert_eq(fmtinfo_channels(load64(res2)), 2, "layer2 stereo 2 channels");
    var m2 = vec_len(sv2);
    var sb2 = alloc(m2 * 8);
    i = 0;
    while (i < m2) { store64(sb2 + i * 8, vec_get(sv2, i)); i = i + 1; }
    var cl = _mp3_sine_corr(sb2, m2, 2, 0, 440, 44100);
    var cr = _mp3_sine_corr(sb2, m2, 2, 1, 660, 44100);
    syscall(1, 1, "  layer2 stereo corr*1000 L=", 28); fmt_int(cl);
    syscall(1, 1, " R=", 3); fmt_int(cr); syscall(1, 1, "\n", 1);
    assert(cl > 985, "layer2 stereo L correlates");
    assert(cr > 985, "layer2 stereo R correlates");
    return 0;
}

# Layer I decode: verified sample-exact vs minimp3 on a constructed stream;
# committed as a value-level correlation against the embedded reference (frame 1).
fn test_mp3_decode_layer1() {
    test_group("mp3: decode Layer I -> PCM");
    if (mp3_bitrate_v1_l3 == 0) { mp3_init(); }
    var buf = alloc(8192);
    var flen = _mp3_b64_decode(_L1_B64, buf);
    var res = mp3_decode_pcm(buf, flen);
    assert(res_ok(res) == 1, "layer1 decode ok");
    var sv = decode_result_samples(res);
    var m = vec_len(sv);
    assert(m >= 768, "layer1 enough samples");
    var ref = alloc(384 * 8);
    _mp3_parse_csv(_L1REF_CSV, ref);
    var sdx = f64_from(0);
    var sd2 = f64_from(0);
    var sr2 = f64_from(0);
    var k = 0;
    while (k < 384) {
        var dv = vec_get(sv, 384 + k);
        var rv = load64(ref + k * 8);
        sdx = f64_add(sdx, f64_mul(dv, rv));
        sd2 = f64_add(sd2, f64_mul(dv, dv));
        sr2 = f64_add(sr2, f64_mul(rv, rv));
        k = k + 1;
    }
    var c = 0;
    if (f64_gt(sd2, f64_from(0)) == 1) {
        if (f64_gt(sr2, f64_from(0)) == 1) {
            c = f64_to(f64_mul(f64_div(sdx, f64_sqrt(f64_mul(sd2, sr2))), f64_from(1000)));
        }
    }
    syscall(1, 1, "  layer1 corr*1000 = ", 21); fmt_int(c); syscall(1, 1, "\n", 1);
    assert(c > 995, "layer1 decode matches reference (>0.995)");
    return 0;
}

# --- tag.cyr ---

# ================================================================
# tag.cyr — audio metadata tag reader (ID3v2 + Vorbis Comment)
# ================================================================
#
# Reads ID3v2.3/v2.4 text frames and Vorbis Comment fields.
# All string fields are stored as Str pointers (via str_new) or 0 for None.
#
# Requires: alloc, vec, str, string, assert helpers from main.cyr

# ================================================================
# AudioMetadata struct (heap-allocated)
# ================================================================
# Layout (56 bytes):
#   +0:  title         (Str pointer or 0)
#   +8:  artist        (Str pointer or 0)
#   +16: album         (Str pointer or 0)
#   +24: track_number  (Str pointer or 0)
#   +32: year          (Str pointer or 0)
#   +40: genre         (Str pointer or 0)
#   +48: comment       (Str pointer or 0)

fn tag_meta_new() {
    var m = alloc(56);
    memset(m, 0, 56);
    return m;
}

fn tag_meta_title(m)        { return load64(m); }
fn tag_meta_artist(m)       { return load64(m + 8); }
fn tag_meta_album(m)        { return load64(m + 16); }
fn tag_meta_track_number(m) { return load64(m + 24); }
fn tag_meta_year(m)         { return load64(m + 32); }
fn tag_meta_genre(m)        { return load64(m + 40); }
fn tag_meta_comment(m)      { return load64(m + 48); }

fn tag_meta_set_title(m, s)        { store64(m, s); return 0; }
fn tag_meta_set_artist(m, s)       { store64(m + 8, s); return 0; }
fn tag_meta_set_album(m, s)        { store64(m + 16, s); return 0; }
fn tag_meta_set_track_number(m, s) { store64(m + 24, s); return 0; }
fn tag_meta_set_year(m, s)         { store64(m + 32, s); return 0; }
fn tag_meta_set_genre(m, s)        { store64(m + 40, s); return 0; }
fn tag_meta_set_comment(m, s)      { store64(m + 48, s); return 0; }

# ================================================================
# Syncsafe integer (named tag_syncsafe to avoid mp3 collision)
# ================================================================

fn tag_syncsafe(data, off) {
    return ((load8(data + off) & 0x7F) << 21)
         | ((load8(data + off + 1) & 0x7F) << 14)
         | ((load8(data + off + 2) & 0x7F) << 7)
         | (load8(data + off + 3) & 0x7F);
}

# ================================================================
# Internal helpers
# ================================================================

# Extract text from an ID3v2 text frame body.
# First byte is encoding: 0/3 = Latin-1/UTF-8, 1/2 = UTF-16 (skip).
# Returns Str pointer or 0 if empty/unsupported.
fn _tag_extract_text(frame_data, frame_len) {
    if (frame_len < 2) { return 0; }
    var encoding = load8(frame_data);
    var text_start = frame_data + 1;
    var text_len = frame_len - 1;

    # Only handle encoding 0 (Latin-1) and 3 (UTF-8)
    if (encoding != 0) {
        if (encoding != 3) {
            return 0;  # Skip UTF-16 for now
        }
    }

    # Strip trailing null bytes
    while (text_len > 0) {
        if (load8(text_start + text_len - 1) != 0) { break; }
        text_len = text_len - 1;
    }

    if (text_len == 0) { return 0; }

    # Copy to a fresh buffer
    var buf = alloc(text_len + 1);
    memcpy(buf, text_start, text_len);
    store8(buf + text_len, 0);
    return str_new(buf, text_len);
}

# Check if 4 bytes at ptr match a 4-char tag
fn _tag_id_eq(ptr, c0, c1, c2, c3) {
    if (load8(ptr) != c0) { return 0; }
    if (load8(ptr + 1) != c1) { return 0; }
    if (load8(ptr + 2) != c2) { return 0; }
    if (load8(ptr + 3) != c3) { return 0; }
    return 1;
}

# Assign a text Str to the right metadata field based on frame ID
fn _tag_assign_text(meta, id_ptr, text) {
    if (text == 0) { return 0; }

    # TIT2 = 0x54 0x49 0x54 0x32
    if (_tag_id_eq(id_ptr, 0x54, 0x49, 0x54, 0x32) == 1) {
        tag_meta_set_title(meta, text);
        return 0;
    }
    # TPE1 = 0x54 0x50 0x45 0x31
    if (_tag_id_eq(id_ptr, 0x54, 0x50, 0x45, 0x31) == 1) {
        tag_meta_set_artist(meta, text);
        return 0;
    }
    # TALB = 0x54 0x41 0x4C 0x42
    if (_tag_id_eq(id_ptr, 0x54, 0x41, 0x4C, 0x42) == 1) {
        tag_meta_set_album(meta, text);
        return 0;
    }
    # TRCK = 0x54 0x52 0x43 0x4B
    if (_tag_id_eq(id_ptr, 0x54, 0x52, 0x43, 0x4B) == 1) {
        tag_meta_set_track_number(meta, text);
        return 0;
    }
    # TDRC = 0x54 0x44 0x52 0x43
    if (_tag_id_eq(id_ptr, 0x54, 0x44, 0x52, 0x43) == 1) {
        tag_meta_set_year(meta, text);
        return 0;
    }
    # TYER = 0x54 0x59 0x45 0x52
    if (_tag_id_eq(id_ptr, 0x54, 0x59, 0x45, 0x52) == 1) {
        tag_meta_set_year(meta, text);
        return 0;
    }
    # TCON = 0x54 0x43 0x4F 0x4E
    if (_tag_id_eq(id_ptr, 0x54, 0x43, 0x4F, 0x4E) == 1) {
        tag_meta_set_genre(meta, text);
        return 0;
    }
    return 0;
}

# ================================================================
# ID3v2 reader
# ================================================================

fn tag_read_id3v2(data, len) {
    if (len < 10) { return err(ERR_INVALID_HEADER); }

    # Check "ID3" magic
    if (load8(data) != 0x49)     { return err(ERR_INVALID_HEADER); }
    if (load8(data + 1) != 0x44) { return err(ERR_INVALID_HEADER); }
    if (load8(data + 2) != 0x33) { return err(ERR_INVALID_HEADER); }

    var major_version = load8(data + 3);
    # var revision = load8(data + 4);
    # var flags = load8(data + 5);

    var tag_size = tag_syncsafe(data, 6);
    if (len < 10 + tag_size) { return err(ERR_END_OF_STREAM); }

    var meta = tag_meta_new();
    var tag_data = data + 10;

    # ID3v2.3 / v2.4 frames: 4-byte ID + 4-byte size + 2-byte flags
    var pos = 0;
    while (pos + 10 <= tag_size) {
        var id_ptr = tag_data + pos;

        # Check for padding (all zeros)
        if (load8(id_ptr) == 0) {
            if (load8(id_ptr + 1) == 0) {
                if (load8(id_ptr + 2) == 0) {
                    if (load8(id_ptr + 3) == 0) {
                        break;
                    }
                }
            }
        }

        var frame_size = 0;
        if (major_version == 4) {
            # v2.4: syncsafe frame size
            frame_size = tag_syncsafe(tag_data, pos + 4);
        } else {
            # v2.3: big-endian u32
            frame_size = read_u32_be(tag_data, pos + 4);
        }

        # Skip flags (2 bytes)
        pos = pos + 10;

        if (frame_size == 0) { break; }
        if (pos + frame_size > tag_size) { break; }

        var frame_data = tag_data + pos;

        # Handle COMM (comment) frames specially
        # COMM = 0x43 0x4F 0x4D 0x4D
        if (_tag_id_eq(id_ptr, 0x43, 0x4F, 0x4D, 0x4D) == 1) {
            # Comment: encoding(1) + 3-byte language + text
            # SEC-018: frame_size > 4 ensures frame_data+3 read and frame_size-3 >= 2
            if (frame_size > 4) {
                var comm_text = _tag_extract_text(frame_data + 3, frame_size - 3);
                if (comm_text != 0) {
                    tag_meta_set_comment(meta, comm_text);
                }
            }
        } else {
            # Standard text frame
            var text = _tag_extract_text(frame_data, frame_size);
            _tag_assign_text(meta, id_ptr, text);
        }

        pos = pos + frame_size;
    }

    return meta;
}

# ================================================================
# Vorbis Comment reader
# ================================================================

# Convert a byte to uppercase ASCII (a-z -> A-Z)
fn _tag_to_upper(c) {
    if (c >= 97) {
        if (c <= 122) {
            return c - 32;
        }
    }
    return c;
}

# Case-insensitive field name comparison against uppercase target
fn _tag_field_eq(field_ptr, field_len, target) {
    var tlen = strlen(target);
    if (field_len != tlen) { return 0; }
    var i = 0;
    while (i < field_len) {
        var c = _tag_to_upper(load8(field_ptr + i));
        if (c != load8(target + i)) { return 0; }
        i = i + 1;
    }
    return 1;
}

fn tag_read_vorbis(data, len) {
    if (len < 4) { return err(ERR_END_OF_STREAM); }

    var pos = 0;

    # Vendor string length (LE u32)
    var vendor_len = read_u32_le(data, pos);
    pos = pos + 4;
    if (pos + vendor_len > len) { return err(ERR_END_OF_STREAM); }
    pos = pos + vendor_len;  # skip vendor string

    # Comment count
    if (pos + 4 > len) { return err(ERR_END_OF_STREAM); }
    var comment_count = read_u32_le(data, pos);
    pos = pos + 4;

    var meta = tag_meta_new();

    # SEC-013: cap comment_count to prevent DoS from crafted metadata
    if (comment_count > 65536) { comment_count = 65536; }
    var ci = 0;
    while (ci < comment_count) {
        if (pos + 4 > len) { break; }
        var comment_len = read_u32_le(data, pos);
        pos = pos + 4;
        # SEC-013: skip zero-length comments (prevent infinite loop)
        if (comment_len == 0) { ci = ci + 1; continue; }
        if (pos + comment_len > len) { break; }

        var comment_ptr = data + pos;
        pos = pos + comment_len;

        # Find '=' separator
        var eq_pos = memchr(comment_ptr, 61, comment_len);  # 61 = '='
        if (eq_pos >= 0) {
            var field_ptr = comment_ptr;
            var field_len = eq_pos;
            var value_ptr = comment_ptr + eq_pos + 1;
            var value_len = comment_len - eq_pos - 1;

            if (value_len > 0) {
                # Copy value to new buffer
                var vbuf = alloc(value_len + 1);
                memcpy(vbuf, value_ptr, value_len);
                store8(vbuf + value_len, 0);
                var val_str = str_new(vbuf, value_len);

                if (_tag_field_eq(field_ptr, field_len, "TITLE") == 1) {
                    tag_meta_set_title(meta, val_str);
                }
                if (_tag_field_eq(field_ptr, field_len, "ARTIST") == 1) {
                    tag_meta_set_artist(meta, val_str);
                }
                if (_tag_field_eq(field_ptr, field_len, "ALBUM") == 1) {
                    tag_meta_set_album(meta, val_str);
                }
                if (_tag_field_eq(field_ptr, field_len, "TRACKNUMBER") == 1) {
                    tag_meta_set_track_number(meta, val_str);
                }
                if (_tag_field_eq(field_ptr, field_len, "DATE") == 1) {
                    tag_meta_set_year(meta, val_str);
                }
                if (_tag_field_eq(field_ptr, field_len, "GENRE") == 1) {
                    tag_meta_set_genre(meta, val_str);
                }
                if (_tag_field_eq(field_ptr, field_len, "COMMENT") == 1) {
                    tag_meta_set_comment(meta, val_str);
                }
            }
        }

        ci = ci + 1;
    }

    return meta;
}

# ================================================================
# ID3v2.3 tag writer
# ================================================================

# Write syncsafe integer (4 bytes, 7 bits per byte)
fn _tag_write_syncsafe(buf, off, val) {
    store8(buf + off, (val >> 21) & 0x7F);
    store8(buf + off + 1, (val >> 14) & 0x7F);
    store8(buf + off + 2, (val >> 7) & 0x7F);
    store8(buf + off + 3, val & 0x7F);
    return 0;
}

# Write an ID3v2.3 tag from AudioMetadata into out_buf.
# Returns bytes written, or 0 if no metadata to write.
fn tag_write_id3v2(meta, out_buf) {
    # Collect non-null fields: (frame_id, value_str) pairs
    # ID3v2.3 frame IDs: TIT2, TPE1, TALB, TRCK, TDRC, TCON
    var field_offsets = alloc(7 * 8);
    store64(field_offsets + 0 * 8, 0);   # title
    store64(field_offsets + 1 * 8, 8);   # artist
    store64(field_offsets + 2 * 8, 16);  # album
    store64(field_offsets + 3 * 8, 24);  # track_number
    store64(field_offsets + 4 * 8, 32);  # year
    store64(field_offsets + 5 * 8, 40);  # genre
    store64(field_offsets + 6 * 8, 48);  # comment

    var frame_ids = alloc(7 * 8);
    store64(frame_ids + 0 * 8, 0x54495432);  # TIT2
    store64(frame_ids + 1 * 8, 0x54504531);  # TPE1
    store64(frame_ids + 2 * 8, 0x54414C42);  # TALB
    store64(frame_ids + 3 * 8, 0x5452434B);  # TRCK
    store64(frame_ids + 4 * 8, 0x54445243);  # TDRC
    store64(frame_ids + 5 * 8, 0x54434F4E);  # TCON
    store64(frame_ids + 6 * 8, 0x434F4D4D);  # COMM

    # Compute total frame data
    var total_frame_data = 0;
    var num_fields = 0;
    var fi = 0;
    while (fi < 7) {
        var val = load64(meta + load64(field_offsets + fi * 8));
        if (val != 0) {
            var vlen = str_len(val);
            if (vlen > 0) {
                total_frame_data = total_frame_data + 10 + 1 + vlen;
                num_fields = num_fields + 1;
            }
        }
        fi = fi + 1;
    }

    if (num_fields == 0) { return 0; }

    var tag_size = total_frame_data;
    var total_size = 10 + tag_size;

    # ID3 header
    store8(out_buf, 0x49); store8(out_buf + 1, 0x44); store8(out_buf + 2, 0x33);
    store8(out_buf + 3, 3); store8(out_buf + 4, 0); store8(out_buf + 5, 0);
    _tag_write_syncsafe(out_buf, 6, tag_size);

    # Write frames
    var pos = 10;
    fi = 0;
    while (fi < 7) {
        var val = load64(meta + load64(field_offsets + fi * 8));
        if (val != 0) {
            var vlen = str_len(val);
            if (vlen > 0) {
                var fid = load64(frame_ids + fi * 8);
                store8(out_buf + pos, (fid >> 24) & 0xFF);
                store8(out_buf + pos + 1, (fid >> 16) & 0xFF);
                store8(out_buf + pos + 2, (fid >> 8) & 0xFF);
                store8(out_buf + pos + 3, fid & 0xFF);
                write_u32_be(out_buf, pos + 4, 1 + vlen);
                store8(out_buf + pos + 8, 0); store8(out_buf + pos + 9, 0);
                store8(out_buf + pos + 10, 3);  # encoding = UTF-8
                memcpy(out_buf + pos + 11, str_data(val), vlen);
                pos = pos + 11 + vlen;
            }
        }
        fi = fi + 1;
    }

    return pos;
}

# ================================================================
# Vorbis Comment writer
# ================================================================

# Write a Vorbis Comment block from AudioMetadata into out_buf.
# Returns bytes written, or 0 if no metadata to write.
fn tag_write_vorbis(meta, out_buf) {
    # Vendor string
    var vendor = "shravan";
    var vendor_len = 7;

    var pos = 0;
    write_u32_le(out_buf, pos, vendor_len);
    pos = pos + 4;
    memcpy(out_buf + pos, vendor, vendor_len);
    pos = pos + vendor_len;

    # Count non-null fields
    var field_names = alloc(7 * 8);
    store64(field_names + 0 * 8, str_from("TITLE"));
    store64(field_names + 1 * 8, str_from("ARTIST"));
    store64(field_names + 2 * 8, str_from("ALBUM"));
    store64(field_names + 3 * 8, str_from("TRACKNUMBER"));
    store64(field_names + 4 * 8, str_from("DATE"));
    store64(field_names + 5 * 8, str_from("GENRE"));
    store64(field_names + 6 * 8, str_from("COMMENT"));

    var field_offsets = alloc(7 * 8);
    store64(field_offsets + 0 * 8, 0);
    store64(field_offsets + 1 * 8, 8);
    store64(field_offsets + 2 * 8, 16);
    store64(field_offsets + 3 * 8, 24);
    store64(field_offsets + 4 * 8, 32);
    store64(field_offsets + 5 * 8, 40);
    store64(field_offsets + 6 * 8, 48);

    var comment_count = 0;
    var fi = 0;
    while (fi < 7) {
        var val = load64(meta + load64(field_offsets + fi * 8));
        if (val != 0) { if (str_len(val) > 0) { comment_count = comment_count + 1; } }
        fi = fi + 1;
    }

    write_u32_le(out_buf, pos, comment_count);
    pos = pos + 4;

    # Write comments: "FIELD=value"
    fi = 0;
    while (fi < 7) {
        var val = load64(meta + load64(field_offsets + fi * 8));
        if (val != 0) {
            var vlen = str_len(val);
            if (vlen > 0) {
                var fname = load64(field_names + fi * 8);
                var flen = str_len(fname);
                var comment_len = flen + 1 + vlen;  # FIELD=value
                write_u32_le(out_buf, pos, comment_len);
                pos = pos + 4;
                memcpy(out_buf + pos, str_data(fname), flen);
                pos = pos + flen;
                store8(out_buf + pos, 61);  # '='
                pos = pos + 1;
                memcpy(out_buf + pos, str_data(val), vlen);
                pos = pos + vlen;
            }
        }
        fi = fi + 1;
    }

    return pos;
}

# ================================================================
# Tests
# ================================================================

# Helper: build an ID3v2.3 tag with text frames
# frames: vec of { id_ptr (4 bytes), value_cstr }
fn _tag_build_id3v2(frame_ids, frame_vals, num_frames) {
    # First pass: compute total frame data size
    var total_frame_data = 0;
    var fi = 0;
    while (fi < num_frames) {
        var val = vec_get(frame_vals, fi);
        var vlen = str_len(val);
        total_frame_data = total_frame_data + 10 + 1 + vlen;  # 10 header + 1 encoding + value
        fi = fi + 1;
    }

    var tag_size = total_frame_data;
    var total_size = 10 + tag_size;
    var out = alloc(total_size);
    memset(out, 0, total_size);

    # ID3 header
    store8(out, 0x49);     # 'I'
    store8(out + 1, 0x44); # 'D'
    store8(out + 2, 0x33); # '3'
    store8(out + 3, 3);    # version 2.3
    store8(out + 4, 0);    # revision
    store8(out + 5, 0);    # flags

    # Syncsafe tag size
    store8(out + 6, (tag_size >> 21) & 0x7F);
    store8(out + 7, (tag_size >> 14) & 0x7F);
    store8(out + 8, (tag_size >> 7) & 0x7F);
    store8(out + 9, tag_size & 0x7F);

    # Write frames
    var pos = 10;
    fi = 0;
    while (fi < num_frames) {
        var id = vec_get(frame_ids, fi);
        var val = vec_get(frame_vals, fi);
        var vlen = str_len(val);
        var frame_size = 1 + vlen;  # encoding byte + text

        # Frame ID (4 bytes)
        memcpy(out + pos, str_data(id), 4);
        pos = pos + 4;

        # Frame size (big-endian u32)
        write_u32_be(out, pos, frame_size);
        pos = pos + 4;

        # Flags (2 bytes, zero)
        pos = pos + 2;

        # Encoding byte: 3 = UTF-8
        store8(out + pos, 3);
        pos = pos + 1;

        # Value
        memcpy(out + pos, str_data(val), vlen);
        pos = pos + vlen;

        fi = fi + 1;
    }

    return str_new(out, total_size);
}

# Helper: build Vorbis Comment block
fn _tag_build_vorbis(vendor, comments, num_comments) {
    # Calculate total size
    var vendor_len = str_len(vendor);
    var total = 4 + vendor_len + 4;

    var ci = 0;
    while (ci < num_comments) {
        var c = vec_get(comments, ci);
        total = total + 4 + str_len(c);
        ci = ci + 1;
    }

    var out = alloc(total);
    var pos = 0;

    # Vendor string
    write_u32_le(out, pos, vendor_len);
    pos = pos + 4;
    memcpy(out + pos, str_data(vendor), vendor_len);
    pos = pos + vendor_len;

    # Comment count
    write_u32_le(out, pos, num_comments);
    pos = pos + 4;

    # Comments
    ci = 0;
    while (ci < num_comments) {
        var c = vec_get(comments, ci);
        var clen = str_len(c);
        write_u32_le(out, pos, clen);
        pos = pos + 4;
        memcpy(out + pos, str_data(c), clen);
        pos = pos + clen;
        ci = ci + 1;
    }

    return str_new(out, total);
}

fn test_tag_id3v2_parse() {
    test_group("tag: ID3v2 parse text frames");

    var ids = vec_new();
    var vals = vec_new();

    # Helper to make 4-byte ID strings
    var id_tit2 = alloc(5); memcpy(id_tit2, "TIT2", 4); store8(id_tit2+4, 0);
    var id_tpe1 = alloc(5); memcpy(id_tpe1, "TPE1", 4); store8(id_tpe1+4, 0);
    var id_talb = alloc(5); memcpy(id_talb, "TALB", 4); store8(id_talb+4, 0);
    var id_trck = alloc(5); memcpy(id_trck, "TRCK", 4); store8(id_trck+4, 0);
    var id_tyer = alloc(5); memcpy(id_tyer, "TYER", 4); store8(id_tyer+4, 0);
    var id_tcon = alloc(5); memcpy(id_tcon, "TCON", 4); store8(id_tcon+4, 0);

    vec_push(ids, str_new(id_tit2, 4)); vec_push(vals, str_from("Test Song"));
    vec_push(ids, str_new(id_tpe1, 4)); vec_push(vals, str_from("Test Artist"));
    vec_push(ids, str_new(id_talb, 4)); vec_push(vals, str_from("Test Album"));
    vec_push(ids, str_new(id_trck, 4)); vec_push(vals, str_from("5"));
    vec_push(ids, str_new(id_tyer, 4)); vec_push(vals, str_from("2025"));
    vec_push(ids, str_new(id_tcon, 4)); vec_push(vals, str_from("Rock"));

    var tag_str = _tag_build_id3v2(ids, vals, 6);
    var meta = tag_read_id3v2(str_data(tag_str), str_len(tag_str));
    assert(res_ok(meta) == 1, "id3v2 parse ok");

    var title = tag_meta_title(meta);
    assert_neq(title, 0, "has title");
    assert(memeq(str_data(title), "Test Song", 9) == 1, "title = Test Song");
    assert_eq(str_len(title), 9, "title len 9");

    var artist = tag_meta_artist(meta);
    assert_neq(artist, 0, "has artist");
    assert(memeq(str_data(artist), "Test Artist", 11) == 1, "artist = Test Artist");

    var album = tag_meta_album(meta);
    assert_neq(album, 0, "has album");
    assert(memeq(str_data(album), "Test Album", 10) == 1, "album = Test Album");

    var track = tag_meta_track_number(meta);
    assert_neq(track, 0, "has track");
    assert(memeq(str_data(track), "5", 1) == 1, "track = 5");

    var year = tag_meta_year(meta);
    assert_neq(year, 0, "has year");
    assert(memeq(str_data(year), "2025", 4) == 1, "year = 2025");

    var genre = tag_meta_genre(meta);
    assert_neq(genre, 0, "has genre");
    assert(memeq(str_data(genre), "Rock", 4) == 1, "genre = Rock");

    return 0;
}

fn test_tag_id3v2_reject_non_id3() {
    test_group("tag: reject non-ID3 data");

    var data = alloc(14);
    memcpy(data, "RIFF data here", 14);
    var result = tag_read_id3v2(data, 14);
    assert(is_err(result) == 1, "non-ID3 rejected");

    return 0;
}

fn test_tag_id3v2_reject_short() {
    test_group("tag: reject short ID3 data");

    var data = alloc(3);
    memcpy(data, "ID3", 3);
    var result = tag_read_id3v2(data, 3);
    assert(is_err(result) == 1, "short ID3 rejected");

    return 0;
}

fn test_tag_vorbis_comment_parse() {
    test_group("tag: Vorbis comment parse");

    var vendor = str_from("shravan 0.1.0");
    var comments = vec_new();
    vec_push(comments, str_from("TITLE=Test Track"));
    vec_push(comments, str_from("ARTIST=Test Musician"));
    vec_push(comments, str_from("ALBUM=Test Record"));
    vec_push(comments, str_from("TRACKNUMBER=3"));
    vec_push(comments, str_from("DATE=2025"));
    vec_push(comments, str_from("GENRE=Electronic"));
    vec_push(comments, str_from("COMMENT=A test comment"));

    var vorbis_str = _tag_build_vorbis(vendor, comments, 7);
    var meta = tag_read_vorbis(str_data(vorbis_str), str_len(vorbis_str));
    assert(res_ok(meta) == 1, "vorbis parse ok");

    var title = tag_meta_title(meta);
    assert_neq(title, 0, "vorbis has title");
    assert(memeq(str_data(title), "Test Track", 10) == 1, "vorbis title");

    var artist = tag_meta_artist(meta);
    assert_neq(artist, 0, "vorbis has artist");
    assert(memeq(str_data(artist), "Test Musician", 13) == 1, "vorbis artist");

    var album = tag_meta_album(meta);
    assert_neq(album, 0, "vorbis has album");
    assert(memeq(str_data(album), "Test Record", 11) == 1, "vorbis album");

    var track = tag_meta_track_number(meta);
    assert_neq(track, 0, "vorbis has track");
    assert(memeq(str_data(track), "3", 1) == 1, "vorbis track");

    var year = tag_meta_year(meta);
    assert_neq(year, 0, "vorbis has year");
    assert(memeq(str_data(year), "2025", 4) == 1, "vorbis year");

    var genre = tag_meta_genre(meta);
    assert_neq(genre, 0, "vorbis has genre");
    assert(memeq(str_data(genre), "Electronic", 10) == 1, "vorbis genre");

    var comment = tag_meta_comment(meta);
    assert_neq(comment, 0, "vorbis has comment");
    assert(memeq(str_data(comment), "A test comment", 14) == 1, "vorbis comment");

    return 0;
}

fn test_tag_vorbis_case_insensitive() {
    test_group("tag: Vorbis case-insensitive fields");

    var vendor = str_from("test");
    var comments = vec_new();
    vec_push(comments, str_from("title=Lower Case"));
    vec_push(comments, str_from("Artist=Mixed Case"));

    var vorbis_str = _tag_build_vorbis(vendor, comments, 2);
    var meta = tag_read_vorbis(str_data(vorbis_str), str_len(vorbis_str));
    assert(res_ok(meta) == 1, "case insensitive parse ok");

    var title = tag_meta_title(meta);
    assert_neq(title, 0, "lowercase title found");
    assert(memeq(str_data(title), "Lower Case", 10) == 1, "lowercase title value");

    var artist = tag_meta_artist(meta);
    assert_neq(artist, 0, "mixed case artist found");
    assert(memeq(str_data(artist), "Mixed Case", 10) == 1, "mixed case artist value");

    return 0;
}

fn test_tag_vorbis_reject_short() {
    test_group("tag: Vorbis reject short data");

    var empty = alloc(1);
    store8(empty, 0);
    var r1 = tag_read_vorbis(empty, 0);
    assert(is_err(r1) == 1, "empty rejected");

    var short = alloc(2);
    store8(short, 0); store8(short+1, 1);
    var r2 = tag_read_vorbis(short, 2);
    assert(is_err(r2) == 1, "2 bytes rejected");

    return 0;
}

fn test_tag_syncsafe_decode() {
    test_group("tag: syncsafe decode");

    var buf = alloc(4);

    # [0x00, 0x00, 0x02, 0x01] -> 257
    store8(buf, 0x00); store8(buf+1, 0x00); store8(buf+2, 0x02); store8(buf+3, 0x01);
    assert_eq(tag_syncsafe(buf, 0), 257, "tag syncsafe 257");

    # [0x00, 0x00, 0x00, 0x00] -> 0
    store8(buf, 0x00); store8(buf+1, 0x00); store8(buf+2, 0x00); store8(buf+3, 0x00);
    assert_eq(tag_syncsafe(buf, 0), 0, "tag syncsafe 0");

    # [0x7F, 0x7F, 0x7F, 0x7F] -> 0x0FFFFFFF = 268435455
    store8(buf, 0x7F); store8(buf+1, 0x7F); store8(buf+2, 0x7F); store8(buf+3, 0x7F);
    assert_eq(tag_syncsafe(buf, 0), 268435455, "tag syncsafe max");

    return 0;
}

# --- fft.cyr ---

# ================================================================
# fft.cyr -- Mixed-radix FFT and MDCT infrastructure
# ================================================================
#
# Provides:
#   fft_compute(re, im, n, inverse)  -- in-place mixed-radix FFT (2,3,5)
#   fft_mdct(input, n, output)       -- forward MDCT via FFT
#   fft_imdct(input, n, output)      -- inverse MDCT via FFT
#
# Complex numbers stored as f64 bit patterns in parallel arrays:
#   re[i] = load64(re_buf + i*8)
#   im[i] = load64(im_buf + i*8)
#
# Requires: f64 builtins, alloc, math.cyr

# ================================================================
# Constants
# ================================================================

# pi as f64 bit pattern: 4614256656552045848
var F64_PI = 4614256656552045848;

# 2*pi
var F64_TWO_PI = 0;

# negative 2*pi
var F64_NEG_TWO_PI = 0;

fn fft_init() {
    F64_TWO_PI = f64_mul(F64_TWO, F64_PI);
    F64_NEG_TWO_PI = f64_neg(F64_TWO_PI);
    return 0;
}

# ================================================================
# Twiddle factor cache — pre-computed cos/sin tables per FFT size
# ================================================================
# tw_re[k] = cos(-2*pi*k/N), tw_im[k] = sin(-2*pi*k/N) for k=0..N-1
# Single-size cache: rebuilt when N changes (common case is repeated
# calls at same size within a codec — AAC always uses 2048, etc.)

var _fft_tw_re = 0;
var _fft_tw_im = 0;
var _fft_tw_n  = 0;

fn _fft_ensure_twiddles(n) {
    if (n == _fft_tw_n) { return 0; }
    _fft_tw_re = alloc(n * 8);
    _fft_tw_im = alloc(n * 8);
    var angle_base = f64_neg(f64_div(F64_TWO_PI, f64_from(n)));
    var k = 0;
    while (k < n) {
        var theta = f64_mul(angle_base, f64_from(k));
        store64(_fft_tw_re + k * 8, f64_cos(theta));
        store64(_fft_tw_im + k * 8, f64_sin(theta));
        k = k + 1;
    }
    _fft_tw_n = n;
    return 0;
}

# MDCT twiddle caches (pre and post rotation angles)
var _mdct_pre_re = 0;
var _mdct_pre_im = 0;
var _mdct_pre_n  = 0;
var _mdct_post_re = 0;
var _mdct_post_im = 0;
var _mdct_post_n  = 0;

# IMDCT twiddle caches
var _imdct_pre_re = 0;
var _imdct_pre_im = 0;
var _imdct_pre_n  = 0;
var _imdct_post_re = 0;
var _imdct_post_im = 0;
var _imdct_post_n  = 0;

# ================================================================
# Complex helpers (operate on f64 bit patterns)
# ================================================================

# Complex multiply: (ar+ai*j)*(br+bi*j) = (ar*br - ai*bi) + (ar*bi + ai*br)*j
# Returns real part; call _cmul_im for imag part
fn _cmul_re(ar, ai, br, bi) {
    return f64_sub(f64_mul(ar, br), f64_mul(ai, bi));
}

fn _cmul_im(ar, ai, br, bi) {
    return f64_add(f64_mul(ar, bi), f64_mul(ai, br));
}

# exp(i*theta): returns (cos(theta), sin(theta))
# We store results via output pointers
fn _cexp(theta, out_re, out_im) {
    store64(out_re, f64_cos(theta));
    store64(out_im, f64_sin(theta));
    return 0;
}

# ================================================================
# Factorization helper
# ================================================================

# Find the smallest factor of n among {2, 3, 5}. Returns 0 if none.
fn _fft_find_factor(n) {
    if (n % 2 == 0) { return 2; }
    if (n % 3 == 0) { return 3; }
    if (n % 5 == 0) { return 5; }
    return 0;
}

# ================================================================
# Naive DFT fallback for small prime sizes
# ================================================================

fn _dft_naive(re, im, n) {
    # Copy input
    var tmp_re = alloc(n * 8);
    var tmp_im = alloc(n * 8);
    memcpy(tmp_re, re, n * 8);
    memcpy(tmp_im, im, n * 8);

    var angle_base = f64_neg(f64_div(F64_TWO_PI, f64_from(n)));

    var k = 0;
    while (k < n) {
        var sum_re = F64_ZERO;
        var sum_im = F64_ZERO;

        var j = 0;
        while (j < n) {
            var theta = f64_mul(angle_base, f64_from(k * j));
            var tw_re = f64_cos(theta);
            var tw_im = f64_sin(theta);

            var xr = load64(tmp_re + j * 8);
            var xi = load64(tmp_im + j * 8);

            # complex multiply: (xr+xi*j)*(tw_re+tw_im*j)
            var pr = _cmul_re(xr, xi, tw_re, tw_im);
            var pi = _cmul_im(xr, xi, tw_re, tw_im);

            sum_re = f64_add(sum_re, pr);
            sum_im = f64_add(sum_im, pi);

            j = j + 1;
        }

        store64(re + k * 8, sum_re);
        store64(im + k * 8, sum_im);
        k = k + 1;
    }

    return 0;
}

# ================================================================
# In-place mixed-radix DIT FFT
# ================================================================
#
# fft_compute(re, im, n, inverse)
#   re: pointer to n f64 values (real parts)
#   im: pointer to n f64 values (imag parts)
#   n: transform size (must factor into 2, 3, 5)
#   inverse: 0 for forward FFT, 1 for inverse FFT
#
# For inverse, we conjugate input, do forward FFT, then conjugate
# and scale output by 1/n.

fn fft_compute(re, im, n, inverse) {
    if (inverse != 0) {
        # Conjugate input
        var ci = 0;
        while (ci < n) {
            store64(im + ci * 8, f64_neg(load64(im + ci * 8)));
            ci = ci + 1;
        }

        # Forward FFT
        _fft_forward(re, im, n);

        # Conjugate and scale by 1/n
        var scale = f64_div(F64_ONE, f64_from(n));
        ci = 0;
        while (ci < n) {
            store64(re + ci * 8, f64_mul(load64(re + ci * 8), scale));
            store64(im + ci * 8, f64_neg(f64_mul(load64(im + ci * 8), scale)));
            ci = ci + 1;
        }
        return 0;
    }

    _fft_forward(re, im, n);
    return 0;
}

fn _fft_forward(re, im, n) {
    if (n <= 1) { return 0; }

    var radix = _fft_find_factor(n);
    if (radix == 0) {
        # n is prime and not 2, 3, or 5 -- use naive DFT
        _dft_naive(re, im, n);
        return 0;
    }

    var m = n / radix;

    # Decimation-in-time: reorder into `radix` sub-sequences of length m
    var tmp_re = alloc(n * 8);
    var tmp_im = alloc(n * 8);

    var r = 0;
    while (r < radix) {
        var j = 0;
        while (j < m) {
            var src_idx = j * radix + r;
            var dst_idx = r * m + j;
            store64(tmp_re + dst_idx * 8, load64(re + src_idx * 8));
            store64(tmp_im + dst_idx * 8, load64(im + src_idx * 8));
            j = j + 1;
        }
        r = r + 1;
    }

    # Recurse on each sub-FFT of length m
    r = 0;
    while (r < radix) {
        var off = r * m * 8;
        _fft_forward(tmp_re + off, tmp_im + off, m);
        r = r + 1;
    }

    # Combine: generic radix-R butterfly with pre-computed twiddles
    # Pre-compute all N twiddle factors for this level
    var tw_re_buf = alloc(n * 8);
    var tw_im_buf = alloc(n * 8);
    var angle_base = f64_neg(f64_div(F64_TWO_PI, f64_from(n)));
    var ti = 0;
    while (ti < n) {
        var theta = f64_mul(angle_base, f64_from(ti));
        store64(tw_re_buf + ti * 8, f64_cos(theta));
        store64(tw_im_buf + ti * 8, f64_sin(theta));
        ti = ti + 1;
    }

    var k = 0;
    while (k < n) {
        var km = k % m;
        var sum_re = F64_ZERO;
        var sum_im = F64_ZERO;

        r = 0;
        while (r < radix) {
            var tw_idx = (r * k) % n;
            var tw_re = load64(tw_re_buf + tw_idx * 8);
            var tw_im = load64(tw_im_buf + tw_idx * 8);

            var xr = load64(tmp_re + (r * m + km) * 8);
            var xi = load64(tmp_im + (r * m + km) * 8);

            var pr = _cmul_re(xr, xi, tw_re, tw_im);
            var pi_val = _cmul_im(xr, xi, tw_re, tw_im);

            sum_re = f64_add(sum_re, pr);
            sum_im = f64_add(sum_im, pi_val);

            r = r + 1;
        }

        store64(re + k * 8, sum_re);
        store64(im + k * 8, sum_im);
        k = k + 1;
    }

    return 0;
}

# ================================================================
# MDCT / IMDCT — a verified TDAC-invertible pair (shared cosine basis)
# ================================================================
# Direct O(n*m) transform over a cached cosine basis, m = n/2:
#   basis[k][i] = cos( (pi/m) (i + 0.5 + m/2) (k + 0.5) )
# fft_mdct is the analysis (X[k]=<x,basis_k>), fft_imdct the synthesis
# (y[i]=(1/m) sum_k X[k] basis_k[i]) — exact transposes, so with a symmetric
# window + 50% overlap they perfectly reconstruct (Princen-Bradley). This replaced
# an FFT-based pair whose analysis/synthesis conventions did NOT match (encode->decode
# cancelled to silence — the root cause of silent AAC/Opus encoders). Fast FFT-based
# MDCT that preserves this exact convention is a perf follow-up.
var _mdct_basis = 0;
var _mdct_basis_n = 0;

fn _mdct_ensure_basis(n) {
    if (_mdct_basis_n == n) { return 0; }
    var m = n / 2;
    var shift = n / 4;
    var bb = alloc(m * n * 8);
    var k = 0;
    while (k < m) {
        var i = 0;
        while (i < n) {
            var ang = f64_div(f64_mul(F64_PI, f64_mul(f64_add(f64_add(f64_from(i), F64_HALF), f64_from(shift)), f64_add(f64_from(k), F64_HALF))), f64_from(m));
            store64(bb + (k * n + i) * 8, f64_cos(ang));
            i = i + 1;
        }
        k = k + 1;
    }
    _mdct_basis = bb;
    _mdct_basis_n = n;
    return 0;
}

fn fft_mdct(input, n, output) {
    # SEC-014: validate MDCT size (must be >= 4, divisible by 4, bounded)
    if (n < 4) { return 0 - 1; }
    if (n % 4 != 0) { return 0 - 1; }
    if (n > 8192) { return 0 - 1; }
    _mdct_ensure_basis(n);
    var m = n / 2;
    var b = _mdct_basis;
    var k = 0;
    while (k < m) {
        var acc = F64_ZERO;
        var row = k * n;
        var i = 0;
        while (i < n) {
            acc = f64_add(acc, f64_mul(load64(input + i * 8), load64(b + (row + i) * 8)));
            i = i + 1;
        }
        store64(output + k * 8, acc);
        k = k + 1;
    }
    return 0;
}

# ================================================================
# Inverse MDCT — exact TDAC partner of fft_mdct
# ================================================================
#   input: pointer to n/2 f64 spectral coefficients
#   n: window size; output: pointer to n f64 time-domain samples
#   IMDCT: y[i] = (2/N) sum_k X[k] cos(pi/M (i + 0.5 + M/2)(k + 0.5)), M = N/2
# This is the standard AAC / Vorbis MDCT convention and the transpose of fft_mdct's
# basis, so with a symmetric analysis+synthesis window and 50% overlap it gives
# Princen-Bradley perfect reconstruction (verified OLA correlation 0.999).

fn fft_imdct(input, n, output) {
    # SEC-014: validate IMDCT size
    if (n < 4) { return 0 - 1; }
    if (n % 4 != 0) { return 0 - 1; }
    if (n > 8192) { return 0 - 1; }
    _mdct_ensure_basis(n);
    var m = n / 2;
    var b = _mdct_basis;
    # Scale 2/M: with the double sine window + 50% OLA, the single-block IMDCT∘MDCT
    # returns x/2 (the TDAC kernel has magnitude M/2), so 2/M restores unity gain.
    var invm = f64_div(F64_TWO, f64_from(m));
    var i = 0;
    while (i < n) {
        var acc = F64_ZERO;
        var k = 0;
        while (k < m) {
            acc = f64_add(acc, f64_mul(load64(input + k * 8), load64(b + (k * n + i) * 8)));
            k = k + 1;
        }
        store64(output + i * 8, f64_mul(acc, invm));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Tests
# ================================================================

fn test_fft_impulse() {
    test_group("fft: impulse response (size 4)");

    var re = alloc(4 * 8);
    var im = alloc(4 * 8);
    memset(re, 0, 4 * 8);
    memset(im, 0, 4 * 8);
    store64(re, F64_ONE);  # impulse at index 0

    fft_compute(re, im, 4, 0);

    # All bins should be 1.0 + 0.0j
    var eps = f64_from(1);  # 1e-10 threshold
    var threshold = f64_div(F64_ONE, f64_mul(f64_from(10000000), f64_from(1000)));

    var pass = 1;
    var ki = 0;
    while (ki < 4) {
        var rval = load64(re + ki * 8);
        var ival = load64(im + ki * 8);
        var rdiff = f64_abs(f64_sub(rval, F64_ONE));
        var idiff = f64_abs(ival);
        if (f64_gt(rdiff, threshold) == 1) { pass = 0; }
        if (f64_gt(idiff, threshold) == 1) { pass = 0; }
        ki = ki + 1;
    }
    assert(pass, "all bins ~= 1.0 + 0.0j");

    return 0;
}

fn test_fft_size_6() {
    test_group("fft: impulse size 6");

    var re = alloc(6 * 8);
    var im = alloc(6 * 8);
    memset(re, 0, 6 * 8);
    memset(im, 0, 6 * 8);
    store64(re, F64_ONE);

    fft_compute(re, im, 6, 0);

    var threshold = f64_div(F64_ONE, f64_mul(f64_from(10000000), f64_from(1000)));
    var pass = 1;
    var ki = 0;
    while (ki < 6) {
        var rdiff = f64_abs(f64_sub(load64(re + ki * 8), F64_ONE));
        var idiff = f64_abs(load64(im + ki * 8));
        if (f64_gt(rdiff, threshold) == 1) { pass = 0; }
        if (f64_gt(idiff, threshold) == 1) { pass = 0; }
        ki = ki + 1;
    }
    assert(pass, "size 6 impulse: all bins ~= 1.0");

    return 0;
}

fn test_fft_vs_dft_size_30() {
    test_group("fft: FFT vs DFT size 30");

    var n = 30;
    var re1 = alloc(n * 8);
    var im1 = alloc(n * 8);
    var re2 = alloc(n * 8);
    var im2 = alloc(n * 8);

    # Fill with sin/cos test pattern
    var i = 0;
    while (i < n) {
        var val_re = f64_sin(f64_mul(f64_from(i), f64_div(f64_from(7), f64_from(10))));
        var val_im = f64_cos(f64_mul(f64_from(i), f64_div(f64_from(13), f64_from(10))));
        store64(re1 + i * 8, val_re);
        store64(im1 + i * 8, val_im);
        store64(re2 + i * 8, val_re);
        store64(im2 + i * 8, val_im);
        i = i + 1;
    }

    fft_compute(re1, im1, n, 0);
    _dft_naive(re2, im2, n);

    var max_diff = F64_ZERO;
    i = 0;
    while (i < n) {
        var dr = f64_abs(f64_sub(load64(re1 + i * 8), load64(re2 + i * 8)));
        var di = f64_abs(f64_sub(load64(im1 + i * 8), load64(im2 + i * 8)));
        max_diff = f64_max(max_diff, f64_max(dr, di));
        i = i + 1;
    }

    var threshold = f64_div(F64_ONE, f64_from(1000000));
    assert(f64_lt(max_diff, threshold) == 1, "FFT vs DFT max_diff < 1e-6");

    return 0;
}

fn test_fft_size_240() {
    test_group("fft: impulse size 240");

    var n = 240;
    var re = alloc(n * 8);
    var im = alloc(n * 8);
    memset(re, 0, n * 8);
    memset(im, 0, n * 8);
    store64(re, F64_ONE);

    fft_compute(re, im, n, 0);

    var threshold = f64_div(F64_ONE, f64_mul(f64_from(10000000), f64_from(1000)));
    var rdiff = f64_abs(f64_sub(load64(re), F64_ONE));
    assert(f64_lt(rdiff, threshold) == 1, "size 240 bin[0] ~= 1.0");

    return 0;
}

fn test_fft_inverse_roundtrip() {
    test_group("fft: forward+inverse roundtrip");

    var n = 8;
    var re = alloc(n * 8);
    var im = alloc(n * 8);
    var orig_re = alloc(n * 8);

    var i = 0;
    while (i < n) {
        var v = f64_from(i + 1);
        store64(re + i * 8, v);
        store64(im + i * 8, F64_ZERO);
        store64(orig_re + i * 8, v);
        i = i + 1;
    }

    # Forward FFT
    fft_compute(re, im, n, 0);

    # Inverse FFT
    fft_compute(re, im, n, 1);

    # Check roundtrip
    var threshold = f64_div(F64_ONE, f64_from(1000000));
    var pass = 1;
    i = 0;
    while (i < n) {
        var diff = f64_abs(f64_sub(load64(re + i * 8), load64(orig_re + i * 8)));
        if (f64_gt(diff, threshold) == 1) { pass = 0; }
        i = i + 1;
    }
    assert(pass, "forward+inverse recovers original");

    return 0;
}

fn test_fft_mdct_produces_output() {
    test_group("fft: MDCT produces output");

    var n = 16;
    var input = alloc(n * 8);
    var output = alloc((n / 2) * 8);
    memset(output, 0, (n / 2) * 8);

    var i = 0;
    while (i < n) {
        store64(input + i * 8, F64_ONE);
        i = i + 1;
    }

    fft_mdct(input, n, output);

    # Check that energy is nonzero
    var energy = F64_ZERO;
    i = 0;
    while (i < n / 2) {
        var v = load64(output + i * 8);
        energy = f64_add(energy, f64_mul(v, v));
        i = i + 1;
    }
    assert(f64_gt(energy, F64_ZERO) == 1, "MDCT energy > 0");

    return 0;
}

fn test_fft_mdct_roundtrip() {
    test_group("fft: MDCT + IMDCT perfect reconstruction (windowed 50% OLA)");

    # Proper test: window -> MDCT -> IMDCT -> window -> 50%-overlap-add must reconstruct
    # the input in the interior (Princen-Bradley TDAC). The old test only checked the
    # output was nonzero and would have passed even when the transform pair did not
    # invert (which it did not — that shipped silent AAC/Opus encoders).
    var nf = 64;
    var h = nf / 2;
    var total = 256;
    var x = alloc(total * 8);
    var i = 0;
    while (i < total) {
        var a = f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, f64_from(i))), f64_from(16)));
        var b = f64_mul(f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, f64_from(i))), f64_from(9))), F64_HALF);
        store64(x + i * 8, f64_add(a, b));
        i = i + 1;
    }
    var acc = alloc(total * 8);
    memset(acc, 0, total * 8);
    var wf = alloc(nf * 8);
    var spec = alloc((nf / 2) * 8);
    var tt = alloc(nf * 8);
    var start = 0;
    while (start + nf <= total) {
        i = 0;
        while (i < nf) {
            var ang = f64_div(f64_mul(F64_PI, f64_add(f64_from(i), F64_HALF)), f64_from(nf));
            store64(wf + i * 8, f64_mul(load64(x + (start + i) * 8), f64_sin(ang)));
            i = i + 1;
        }
        fft_mdct(wf, nf, spec);
        fft_imdct(spec, nf, tt);
        i = 0;
        while (i < nf) {
            var ang2 = f64_div(f64_mul(F64_PI, f64_add(f64_from(i), F64_HALF)), f64_from(nf));
            var p = start + i;
            store64(acc + p * 8, f64_add(load64(acc + p * 8), f64_mul(load64(tt + i * 8), f64_sin(ang2))));
            i = i + 1;
        }
        start = start + h;
    }
    var maxerr = F64_ZERO;
    i = nf;
    while (i < total - nf) {
        var e = f64_abs(f64_sub(load64(acc + i * 8), load64(x + i * 8)));
        if (f64_gt(e, maxerr) == 1) { maxerr = e; }
        i = i + 1;
    }
    var tol = f64_div(F64_ONE, f64_from(1000000));   # 1e-6
    assert(f64_gt(tol, maxerr) == 1, "MDCT+IMDCT OLA reconstructs interior to <1e-6");

    return 0;
}

fn test_fft_all() {
    fft_init();
    test_fft_impulse();
    test_fft_size_6();
    test_fft_vs_dft_size_30();
    test_fft_size_240();
    test_fft_inverse_roundtrip();
    test_fft_mdct_produces_output();
    test_fft_mdct_roundtrip();
    return 0;
}

# --- opus.cyr ---

# ================================================================
# opus.cyr -- Opus header parsing and CELT-mode encoding (Ogg container)
# ================================================================
#
# Provides:
#   opus_parse_head(data, len)             -- parse OpusHead packet
#   opus_serialize_head(channels, pre_skip, sample_rate, out_buf) -- serialize OpusHead
#   opus_serialize_tags(out_buf)           -- serialize minimal OpusTags
#   opus_range_enc_init()                  -- create range encoder state
#   opus_range_enc_encode(rc, fl, fh, total) -- encode symbol
#   opus_range_enc_flush(rc)               -- finalize, returns (ptr, len) via Str
#   opus_encode(samples_vec, sample_rate, channels, bitrate, out_buf)
#   opus_decode_from_packets(packets_vec, ogg_data, ogg_len)
#
# Requires: alloc, vec, str, math, ogg, fft, assert

# ================================================================
# OpusHead struct (heap-allocated)
# ================================================================
# Layout (56 bytes):
#   +0:  version              (i64)
#   +8:  channel_count        (i64)
#   +16: pre_skip             (i64)
#   +24: input_sample_rate    (i64)
#   +32: output_gain          (i64, signed)
#   +40: channel_mapping_family (i64)

fn opus_head_new() {
    var h = alloc(48);
    memset(h, 0, 48);
    return h;
}

fn opus_head_version(h)        { return load64(h); }
fn opus_head_channels(h)       { return load64(h + 8); }
fn opus_head_pre_skip(h)       { return load64(h + 16); }
fn opus_head_sample_rate(h)    { return load64(h + 24); }
fn opus_head_output_gain(h)    { return load64(h + 32); }
fn opus_head_mapping(h)        { return load64(h + 40); }

# ================================================================
# OpusHead parsing
# ================================================================

# Parse an OpusHead identification packet.
# data: pointer to raw bytes, len: byte count.
# Returns heap-allocated OpusHead struct, or err().
fn opus_parse_head(data, len) {
    if (len < 19) { return err(ERR_INVALID_HEADER); }

    # Check "OpusHead" magic (8 bytes)
    if (load8(data)     != 0x4F) { return err(ERR_INVALID_HEADER); }  # 'O'
    if (load8(data + 1) != 0x70) { return err(ERR_INVALID_HEADER); }  # 'p'
    if (load8(data + 2) != 0x75) { return err(ERR_INVALID_HEADER); }  # 'u'
    if (load8(data + 3) != 0x73) { return err(ERR_INVALID_HEADER); }  # 's'
    if (load8(data + 4) != 0x48) { return err(ERR_INVALID_HEADER); }  # 'H'
    if (load8(data + 5) != 0x65) { return err(ERR_INVALID_HEADER); }  # 'e'
    if (load8(data + 6) != 0x61) { return err(ERR_INVALID_HEADER); }  # 'a'
    if (load8(data + 7) != 0x64) { return err(ERR_INVALID_HEADER); }  # 'd'

    var version = load8(data + 8);
    var channel_count = load8(data + 9);
    var pre_skip = read_u16_le(data, 10);
    var input_sample_rate = read_u32_le(data, 12);
    # output_gain is signed i16 LE
    var output_gain_raw = read_u16_le(data, 16);
    var output_gain = output_gain_raw;
    if (output_gain >= 32768) {
        output_gain = output_gain - 65536;
    }
    var channel_mapping_family = load8(data + 18);

    if (channel_count == 0) { return err(ERR_INVALID_CHANNELS); }

    var h = opus_head_new();
    store64(h,      version);
    store64(h + 8,  channel_count);
    store64(h + 16, pre_skip);
    store64(h + 24, input_sample_rate);
    store64(h + 32, output_gain);
    store64(h + 40, channel_mapping_family);
    return h;
}

# ================================================================
# OpusHead serialization (19 bytes)
# ================================================================

# Serialize OpusHead into out_buf (must be >= 19 bytes).
# Returns 19 (bytes written).
fn opus_serialize_head(channels, pre_skip, sample_rate, out_buf) {
    # "OpusHead" magic
    store8(out_buf,     0x4F);
    store8(out_buf + 1, 0x70);
    store8(out_buf + 2, 0x75);
    store8(out_buf + 3, 0x73);
    store8(out_buf + 4, 0x48);
    store8(out_buf + 5, 0x65);
    store8(out_buf + 6, 0x61);
    store8(out_buf + 7, 0x64);

    store8(out_buf + 8, 1);         # version
    store8(out_buf + 9, channels);
    write_u16_le(out_buf, 10, pre_skip);
    write_u32_le(out_buf, 12, sample_rate);
    write_u16_le(out_buf, 16, 0);   # output gain = 0
    store8(out_buf + 18, 0);        # channel mapping family 0

    return 19;
}

# ================================================================
# OpusTags serialization
# ================================================================

# Serialize minimal OpusTags into out_buf (must be >= 23 bytes).
# Returns bytes written.
fn opus_serialize_tags(out_buf) {
    # "OpusTags" magic
    store8(out_buf,     0x4F);
    store8(out_buf + 1, 0x70);
    store8(out_buf + 2, 0x75);
    store8(out_buf + 3, 0x73);
    store8(out_buf + 4, 0x54);
    store8(out_buf + 5, 0x61);
    store8(out_buf + 6, 0x67);
    store8(out_buf + 7, 0x73);

    # Vendor string: "shravan" (7 bytes)
    write_u32_le(out_buf, 8, 7);
    store8(out_buf + 12, 0x73);  # s
    store8(out_buf + 13, 0x68);  # h
    store8(out_buf + 14, 0x72);  # r
    store8(out_buf + 15, 0x61);  # a
    store8(out_buf + 16, 0x76);  # v
    store8(out_buf + 17, 0x61);  # a
    store8(out_buf + 18, 0x6E);  # n

    # User comment list length = 0
    write_u32_le(out_buf, 19, 0);

    return 23;
}

# ================================================================
# OpusTags parsing
# ================================================================

fn opus_parse_tags(data, len) {
    if (len < 8) { return err(ERR_INVALID_HEADER); }
    if (load8(data)     != 0x4F) { return err(ERR_INVALID_HEADER); }
    if (load8(data + 1) != 0x70) { return err(ERR_INVALID_HEADER); }
    if (load8(data + 2) != 0x75) { return err(ERR_INVALID_HEADER); }
    if (load8(data + 3) != 0x73) { return err(ERR_INVALID_HEADER); }
    if (load8(data + 4) != 0x54) { return err(ERR_INVALID_HEADER); }
    if (load8(data + 5) != 0x61) { return err(ERR_INVALID_HEADER); }
    if (load8(data + 6) != 0x67) { return err(ERR_INVALID_HEADER); }
    if (load8(data + 7) != 0x73) { return err(ERR_INVALID_HEADER); }
    return tag_read_vorbis(data + 8, len - 8);
}

# ================================================================
# Range coder (byte-oriented, LZMA-style carry) — encoder + decoder
# ================================================================
# A standard, provably-invertible range coder. The encoder emits bytes
# MSB-first with a one-byte cache plus a run counter to propagate carries;
# the decoder consumes the identical stream. RFC 6716's CELT layer uses an
# ec_enc/ec_dec pair with the same algebra; this implementation keeps the
# public opus_range_* names so existing call sites are unchanged.
#
# Encoder state (64 bytes):
#   +0:  buf (output byte pointer)   +8:  buf_len       +16: buf_cap
#   +24: low (up to 2^33, carry in bit 32)              +32: range (<= 2^32-1)
#   +40: cache (pending byte)         +48: cache_size (deferred 0xFF run + 1)
# Decoder state (48 bytes):
#   +0: data   +8: len   +16: pos   +24: range   +32: code

var RC_TOP = 0x1000000;   # 2^24 renormalization threshold (kTopValue)

fn opus_range_enc_init() {
    var rc = alloc(64);
    memset(rc, 0, 64);
    store64(rc,      alloc(4096));   # buf
    store64(rc + 8,  0);             # buf_len
    store64(rc + 16, 4096);          # buf_cap
    store64(rc + 24, 0);             # low
    store64(rc + 32, 0xFFFFFFFF);    # range
    store64(rc + 40, 0);             # cache
    store64(rc + 48, 1);             # cache_size (leading byte pending)
    return rc;
}

fn _rc_push_byte(rc, byte) {
    var buf = load64(rc);
    var blen = load64(rc + 8);
    var bcap = load64(rc + 16);
    if (blen >= bcap) {
        var new_cap = bcap * 2;
        var new_buf = alloc(new_cap);
        memcpy(new_buf, buf, blen);
        store64(rc, new_buf);
        store64(rc + 16, new_cap);
        buf = new_buf;
    }
    store8(buf + blen, byte & 0xFF);
    store64(rc + 8, blen + 1);
    return 0;
}

# LZMA ShiftLow: resolve carry, emit cache + any deferred 0xFF run, shift low.
fn _rc_shift_low(rc) {
    var low = load64(rc + 24);
    var carry = (low >> 32) & 0x1;          # 0 or 1
    if ((carry != 0) | (low < 0xFF000000)) {
        var temp = load64(rc + 40);         # cache
        var cs = load64(rc + 48);           # cache_size (>= 1)
        var i = 0;
        while (i < cs) {
            _rc_push_byte(rc, (temp + carry) & 0xFF);
            temp = 0xFF;
            i = i + 1;
        }
        store64(rc + 48, 0);
        store64(rc + 40, (low >> 24) & 0xFF);   # new cache
    }
    store64(rc + 48, load64(rc + 48) + 1);      # cache_size++
    store64(rc + 24, (low << 8) & 0xFFFFFFFF);
    return 0;
}

# Encode a symbol occupying [fl, fh) out of total.
fn opus_range_enc_encode(rc, fl, fh, total) {
    if (total == 0) { return 0; }
    var range = load64(rc + 32);
    var r = range / total;
    store64(rc + 24, load64(rc + 24) + r * fl);   # low += r*fl (carry into bit 32)
    if (fh < total) {
        store64(rc + 32, r * (fh - fl));
    } else {
        store64(rc + 32, range - r * fl);         # top symbol keeps the remainder
    }
    var rng = load64(rc + 32);
    while (rng < RC_TOP) {
        _rc_shift_low(rc);
        rng = (rng << 8) & 0xFFFFFFFF;
        store64(rc + 32, rng);
    }
    return 0;
}

# Encode a single equiprobable bit.
fn opus_range_enc_bit(rc, val) {
    if (val != 0) {
        opus_range_enc_encode(rc, 1, 2, 2);
    } else {
        opus_range_enc_encode(rc, 0, 1, 2);
    }
    return 0;
}

# Encode a value uniformly in [0, total).
fn opus_range_enc_uint(rc, val, total) {
    if (total <= 1) { return 0; }
    opus_range_enc_encode(rc, val, val + 1, total);
    return 0;
}

# Approximate bytes emitted so far (committed + pending cache run).
fn opus_range_enc_bytes_used(rc) {
    return load64(rc + 8) + load64(rc + 48);
}

# Finalize: flush the 5 low bytes and return Str(data, len).
fn opus_range_enc_flush(rc) {
    var i = 0;
    while (i < 5) {
        _rc_shift_low(rc);
        i = i + 1;
    }
    return str_new(load64(rc), load64(rc + 8));
}

# ---------------- decoder (exact mirror of the encoder) ----------------

fn _rd_next_byte(rd) {
    var pos = load64(rd + 16);
    var b = 0;
    if (pos < load64(rd + 8)) { b = load8(load64(rd) + pos); }
    store64(rd + 16, pos + 1);
    return b;
}

# Initialize from a byte buffer: prime code with 5 bytes (leading cache
# byte shifts out of the 32-bit window, mirroring the encoder's leading byte).
fn opus_range_dec_init(data, len) {
    var rd = alloc(48);
    store64(rd, data);
    store64(rd + 8, len);
    store64(rd + 16, 0);
    store64(rd + 24, 0xFFFFFFFF);
    var code = 0;
    var i = 0;
    while (i < 5) {
        code = ((code << 8) | _rd_next_byte(rd)) & 0xFFFFFFFF;
        i = i + 1;
    }
    store64(rd + 32, code);
    return rd;
}

# Decode a value uniformly in [0, total) — inverse of opus_range_enc_uint.
fn opus_range_dec_uint(rd, total) {
    if (total <= 1) { return 0; }
    var range = load64(rd + 24);
    var code = load64(rd + 32);
    var r = range / total;
    var v = code / r;
    if (v >= total) { v = total - 1; }
    code = code - r * v;
    if (v + 1 < total) {
        range = r;
    } else {
        range = range - r * v;
    }
    while (range < RC_TOP) {
        code = ((code << 8) | _rd_next_byte(rd)) & 0xFFFFFFFF;
        range = (range << 8) & 0xFFFFFFFF;
    }
    store64(rd + 24, range);
    store64(rd + 32, code);
    return v;
}

# Decode a single equiprobable bit.
fn opus_range_dec_bit(rd) {
    return opus_range_dec_uint(rd, 2);
}

fn test_opus_range_roundtrip() {
    test_group("opus: range coder roundtrip");
    var rc = opus_range_enc_init();
    opus_range_enc_uint(rc, 5, 10);
    opus_range_enc_uint(rc, 100, 128);
    opus_range_enc_uint(rc, 3, 7);
    opus_range_enc_uint(rc, 42, 256);
    opus_range_enc_bit(rc, 1);
    opus_range_enc_bit(rc, 0);
    opus_range_enc_uint(rc, 1000, 4096);
    opus_range_enc_uint(rc, 0, 3);
    opus_range_enc_uint(rc, 65535, 65536);
    var coded = opus_range_enc_flush(rc);
    assert(str_len(coded) > 0, "range coder produces output");

    var rd = opus_range_dec_init(str_data(coded), str_len(coded));
    assert_eq(opus_range_dec_uint(rd, 10), 5, "rc roundtrip uint 5/10");
    assert_eq(opus_range_dec_uint(rd, 128), 100, "rc roundtrip uint 100/128");
    assert_eq(opus_range_dec_uint(rd, 7), 3, "rc roundtrip uint 3/7");
    assert_eq(opus_range_dec_uint(rd, 256), 42, "rc roundtrip uint 42/256");
    assert_eq(opus_range_dec_bit(rd), 1, "rc roundtrip bit 1");
    assert_eq(opus_range_dec_bit(rd), 0, "rc roundtrip bit 0");
    assert_eq(opus_range_dec_uint(rd, 4096), 1000, "rc roundtrip uint 1000/4096");
    assert_eq(opus_range_dec_uint(rd, 3), 0, "rc roundtrip uint 0/3");
    assert_eq(opus_range_dec_uint(rd, 65536), 65535, "rc roundtrip uint 65535/65536");
    return 0;
}

# ================================================================
# CELT band structure (Bark-scale at 48 kHz, 20ms)
# ================================================================

# 21 bands, boundaries in MDCT bin indices (960 samples -> 480 bins)
var _celt_band_edges = 0;
var _CELT_NUM_BANDS = 21;

fn _opus_init_bands() {
    _celt_band_edges = alloc(22 * 8);
    store64(_celt_band_edges + 0 * 8, 0);
    store64(_celt_band_edges + 1 * 8, 1);
    store64(_celt_band_edges + 2 * 8, 2);
    store64(_celt_band_edges + 3 * 8, 3);
    store64(_celt_band_edges + 4 * 8, 4);
    store64(_celt_band_edges + 5 * 8, 5);
    store64(_celt_band_edges + 6 * 8, 6);
    store64(_celt_band_edges + 7 * 8, 7);
    store64(_celt_band_edges + 8 * 8, 8);
    store64(_celt_band_edges + 9 * 8, 10);
    store64(_celt_band_edges + 10 * 8, 12);
    store64(_celt_band_edges + 11 * 8, 14);
    store64(_celt_band_edges + 12 * 8, 17);
    store64(_celt_band_edges + 13 * 8, 21);
    store64(_celt_band_edges + 14 * 8, 26);
    store64(_celt_band_edges + 15 * 8, 32);
    store64(_celt_band_edges + 16 * 8, 40);
    store64(_celt_band_edges + 17 * 8, 50);
    store64(_celt_band_edges + 18 * 8, 62);
    store64(_celt_band_edges + 19 * 8, 78);
    store64(_celt_band_edges + 20 * 8, 100);
    store64(_celt_band_edges + 21 * 8, 480);
    return 0;
}

# ================================================================
# CELT frame encoder helpers
# ================================================================

# Apply sine window to frame (f64 array, n samples)
fn _opus_sine_window(frame, n) {
    var i = 0;
    while (i < n) {
        # w = sin(pi/n * (i + 0.5))
        var angle = f64_div(f64_mul(F64_PI, f64_add(f64_from(i), F64_HALF)), f64_from(n));
        var w = f64_sin(angle);
        var s = load64(frame + i * 8);
        store64(frame + i * 8, f64_mul(s, w));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# CELT MDCT / IMDCT — a verified TDAC-invertible pair (2.5.9)
# ================================================================
# The shared fft_mdct/fft_imdct in fft.cyr are NOT a matched analysis/synthesis pair
# (fft_imdct is a valid IMDCT — it decodes real AAC — but fft_mdct's convention does
# not invert it, so encode->decode cancels to silence; this also explains the silent
# AAC encoder). The Opus codec therefore uses this self-matched direct pair:
#   MDCT:  X[k] = sum_n x[n] cos((pi/M)(n + 0.5 + M/2)(k + 0.5)),  M = nf/2, k in [0,M)
#   IMDCT: y[n] = (1/M) sum_k X[k] cos(same basis),                n in [0,nf)
# They are transposes of one shared cosine basis, so with the analysis+synthesis sine
# windows (sin^2+cos^2=1) and 50% overlap they give Princen-Bradley perfect
# reconstruction (measured OLA correlation 0.999). O(nf*M) via a cached basis table;
# a faster FFT-based pair (fixing fft_mdct/fft_imdct) is a later optimization.
var _opus_mdct_basis = 0;
var _opus_mdct_basis_n = 0;

fn _opus_mdct_init(nf) {
    var m = nf / 2;
    var shift = nf / 4;
    var b = alloc(m * nf * 8);
    var k = 0;
    while (k < m) {
        var n = 0;
        while (n < nf) {
            var ang = f64_div(f64_mul(F64_PI, f64_mul(f64_add(f64_add(f64_from(n), F64_HALF), f64_from(shift)), f64_add(f64_from(k), F64_HALF))), f64_from(m));
            store64(b + (k * nf + n) * 8, f64_cos(ang));
            n = n + 1;
        }
        k = k + 1;
    }
    _opus_mdct_basis = b;
    _opus_mdct_basis_n = nf;
    return 0;
}

fn _opus_mdct(inp, nf, out) {
    if (_opus_mdct_basis_n != nf) { _opus_mdct_init(nf); }
    var m = nf / 2;
    var b = _opus_mdct_basis;
    var k = 0;
    while (k < m) {
        var acc = F64_ZERO;
        var row = k * nf;
        var n = 0;
        while (n < nf) {
            acc = f64_add(acc, f64_mul(load64(inp + n * 8), load64(b + (row + n) * 8)));
            n = n + 1;
        }
        store64(out + k * 8, acc);
        k = k + 1;
    }
    return 0;
}

fn _opus_imdct(coeffs, nf, out) {
    if (_opus_mdct_basis_n != nf) { _opus_mdct_init(nf); }
    var m = nf / 2;
    var b = _opus_mdct_basis;
    # Scale 2/M restores unity gain (single-block IMDCT∘MDCT returns x/2 under the
    # double sine window + 50% OLA).
    var invm = f64_div(F64_TWO, f64_from(m));
    var n = 0;
    while (n < nf) {
        var acc = F64_ZERO;
        var k = 0;
        while (k < m) {
            acc = f64_add(acc, f64_mul(load64(coeffs + k * 8), load64(b + (k * nf + n) * 8)));
            k = k + 1;
        }
        store64(out + n * 8, f64_mul(acc, invm));
        n = n + 1;
    }
    return 0;
}

# Compute log2 energy per CELT band from MDCT coefficients.
# mdct: pointer to n2 f64 values, energies: pointer to 21 f64 values.
fn _opus_compute_band_energies(mdct, n2, energies) {
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        var start = load64(_celt_band_edges + band * 8);
        var end = load64(_celt_band_edges + (band + 1) * 8);
        if (end > n2) { end = n2; }

        var sum = F64_ZERO;
        var j = start;
        while (j < end) {
            var c = load64(mdct + j * 8);
            sum = f64_add(sum, f64_mul(c, c));
            j = j + 1;
        }

        var band_size = end - start;
        if (band_size < 1) { band_size = 1; }
        # log2(sum / band_size), with floor to avoid log(0)
        var avg = f64_div(sum, f64_from(band_size));
        var floor_val = f64_div(F64_ONE, f64_mul(f64_from(10000000), f64_from(1000)));
        avg = f64_max(avg, floor_val);
        store64(energies + band * 8, f64_log2(avg));

        band = band + 1;
    }
    return 0;
}

# Quantize band energies to integer values.
# energies: 21 f64 values, quant: 21 i64 values.
fn _opus_quantize_energies(energies, quant) {
    var i = 0;
    while (i < _CELT_NUM_BANDS) {
        var e = load64(energies + i * 8);
        # Quantize to 1/2 dB steps: round(e * 2)
        var q = f64_to(f64_floor(f64_add(f64_mul(e, F64_TWO), F64_HALF)));
        store64(quant + i * 8, q);
        i = i + 1;
    }
    return 0;
}

# Encode band energies via range coder (Laplace-like delta coding).
fn _opus_encode_band_energies(rc, quant) {
    var prev = 0;
    var i = 0;
    while (i < _CELT_NUM_BANDS) {
        var q = load64(quant + i * 8);
        var diff = q - prev;
        # Wide delta range (256 symbols, +/-127 half-log2-power steps): a tone band next
        # to the silent floor can jump ~+100 units; the old +/-63 clamp saturated it, so
        # loud and quiet bands collapsed to the same energy and absolute levels were lost.
        if (diff < 0 - 128) { diff = 0 - 128; }
        if (diff > 127) { diff = 127; }
        var val = diff + 128;
        opus_range_enc_uint(rc, val, 256);
        prev = prev + diff;   # closed-loop DPCM: track the reconstructed (clamped) value so the decoder stays in sync
        i = i + 1;
    }
    return 0;
}

# ================================================================
# PVQ (Pyramid Vector Quantization) — spectral shape (2.5.0)
# ================================================================
# Each band's unit-L2 shape is quantized to an integer pulse vector y with
# sum|y_i| = K, coded by its CWRS index in [0, V(N,K)). Energy is coded
# separately (see band-energy path), so PVQ codes only direction.
#
# V(N,K) = # integer vectors of length N with sum|y_i| = K.
#   V(N,K) = V(N-1,K) + V(N,K-1) + V(N-1,K-1);  V(N,0)=1, V(0,K>0)=0.
# The range coder's `total` must stay small (opus_range_enc_uint), so we cap
# V at PVQ_V_SAFE (2^16) via K selection and split wide bands to N <= PVQ_MAX_N.

var PVQ_MAX_N   = 32;       # sub-block width cap (wide bands are split)
var PVQ_K_MAX   = 32;       # pulse-count cap per sub-block (plenty for shape direction)
var PVQ_V_SAFE  = 65536;    # 2^16 — keep V(N,K) at/under this (range-coder headroom)
var _pvq_v_grid = 0;        # lazily-built (PVQ_MAX_N+1) x (PVQ_K_MAX+1) V table

# Build the V(N,K) DP grid once, saturating any cell above PVQ_V_SAFE so i64
# never wraps (cells above the cap are never used to encode — K selection stops
# before them, and every sub-count used by CWRS is <= V(N,K) <= PVQ_V_SAFE, exact).
fn _pvq_v_init() {
    var stride = PVQ_K_MAX + 1;
    var grid = alloc((PVQ_MAX_N + 1) * stride * 8);
    store64(grid, 1);                                  # V(0,0) = 1
    var k = 1;
    while (k <= PVQ_K_MAX) { store64(grid + k * 8, 0); k = k + 1; }   # V(0,k>0) = 0
    var n = 1;
    while (n <= PVQ_MAX_N) {
        var base = n * stride;
        store64(grid + base * 8, 1);                   # V(n,0) = 1
        var kk = 1;
        while (kk <= PVQ_K_MAX) {
            var a = load64(grid + ((n - 1) * stride + kk) * 8);
            var b = load64(grid + (base + kk - 1) * 8);
            var c = load64(grid + ((n - 1) * stride + kk - 1) * 8);
            var v = a + b + c;
            if (v > PVQ_V_SAFE) { v = PVQ_V_SAFE + 1; }
            store64(grid + (base + kk) * 8, v);
            kk = kk + 1;
        }
        n = n + 1;
    }
    _pvq_v_grid = grid;
    return 0;
}

# V(N,K). Returns PVQ_V_SAFE+1 for out-of-grid (too big) — callers split/cap.
fn _pvq_v(n, k) {
    if (k == 0) { return 1; }
    if (n <= 0) { return 0; }
    if (k < 0)  { return 0; }
    if (_pvq_v_grid == 0) { _pvq_v_init(); }
    if (n > PVQ_MAX_N) { return PVQ_V_SAFE + 1; }
    if (k > PVQ_K_MAX) { return PVQ_V_SAFE + 1; }
    return load64(_pvq_v_grid + (n * (PVQ_K_MAX + 1) + k) * 8);
}

# ceil(log2(V(N,K))) — the cost in bits of a CWRS index over [0, V(N,K)).
fn _pvq_bits(n, k) {
    var v = _pvq_v(n, k);
    if (v <= 1) { return 0; }
    var b = 0;
    var p = 1;
    while (p < v) { p = p * 2; b = b + 1; }
    return b;
}

# Largest K (0..PVQ_K_MAX) whose codeword still fits a bit budget and keeps
# V(N,K) <= PVQ_V_SAFE. Stops early when the pyramid stops growing (N=1 plateau).
fn _pvq_choose_k(n, budget_bits) {
    if (budget_bits <= 0) { return 0; }
    var k = 0;
    var vk = 1;
    while (k < PVQ_K_MAX) {
        var vnext = _pvq_v(n, k + 1);
        if (vnext == vk)          { break; }   # no new codewords (e.g. N=1: V=2 forever)
        if (vnext > PVQ_V_SAFE)   { break; }   # keep range-coder total safe
        if (_pvq_bits(n, k + 1) > budget_bits) { break; }
        k = k + 1;
        vk = vnext;
    }
    return k;
}

# PVQ search: given real band x[n], find integer y with sum|y|=K maximizing the
# CELT metric Rxy^2/Ryy (== correlation dot(x,y)/||y||). Greedy: add pulses one
# at a time on |x|, carry signs. Returns Ryy = sum y_i^2 = ||y||^2.
fn _pvq_search(x, n, k, y_out) {
    var ax   = alloc(n * 8);   # |x|
    var sign = alloc(n * 8);   # 1 if x[j] < 0
    var j = 0;
    while (j < n) {
        var c = load64(x + j * 8);
        var s = 0;
        if (f64_lt(c, F64_ZERO) == 1) { s = 1; c = f64_neg(c); }
        store64(ax + j * 8, c);
        store64(sign + j * 8, s);
        store64(y_out + j * 8, 0);
        j = j + 1;
    }
    var xy = F64_ZERO;     # dot(|x|, y) as f64
    var yy = 0;            # sum y^2 as int (exact)
    var left = k;
    while (left > 0) {
        var best = 0 - 1;
        var best_num = F64_ZERO;   # candidate Rxy^2
        var best_den = 1;          # candidate Ryy (int, >0)
        var t = 0;
        while (t < n) {
            var nxy = f64_add(xy, load64(ax + t * 8));
            var nyy = yy + 2 * load64(y_out + t * 8) + 1;
            var num = f64_mul(nxy, nxy);
            # maximize num/nyy  <=>  num*best_den > best_num*nyy  (all positive)
            var take = 0;
            if (best < 0) { take = 1; }
            else {
                if (f64_gt(f64_mul(num, f64_from(best_den)), f64_mul(best_num, f64_from(nyy))) == 1) { take = 1; }
            }
            if (take == 1) { best = t; best_num = num; best_den = nyy; }
            t = t + 1;
        }
        xy = f64_add(xy, load64(ax + best * 8));
        yy = yy + 2 * load64(y_out + best * 8) + 1;
        store64(y_out + best * 8, load64(y_out + best * 8) + 1);
        left = left - 1;
    }
    j = 0;
    while (j < n) {
        if (load64(sign + j * 8) == 1) { store64(y_out + j * 8, 0 - load64(y_out + j * 8)); }
        j = j + 1;
    }
    return yy;
}

# CWRS encode: rank y (length n, sum|y|=k) into an index in [0, V(n,k)).
# Coordinate order (last->first), value order per coord: 0, +1, -1, +2, -2, ...
fn _pvq_index_encode(y, n, k) {
    var idx = 0;
    var kk = k;
    var pos = n - 1;
    while (pos >= 0) {
        var m = pos;                    # dims before this coord
        var a = load64(y + pos * 8);
        var aa = a; if (aa < 0) { aa = 0 - aa; }
        if (a != 0) {
            idx = idx + _pvq_v(m, kk);              # the value-0 block
            var jj = 1;
            while (jj < aa) {
                idx = idx + _pvq_v(m, kk - jj);     # +jj
                idx = idx + _pvq_v(m, kk - jj);     # -jj
                jj = jj + 1;
            }
            if (a < 0) { idx = idx + _pvq_v(m, kk - aa); }   # +aa precedes -aa
        }
        kk = kk - aa;
        pos = pos - 1;
    }
    return idx;
}

# CWRS decode: index -> vector y[n]; returns Ryy, or err(ERR_DECODE) if idx>=V.
fn _pvq_index_decode(idx, n, k, y_out) {
    var ryy = 0;
    var kk = k;
    var pos = n - 1;
    var ix = idx;
    while (pos >= 0) {
        var m = pos;
        var a = 0;
        var v0 = _pvq_v(m, kk);
        if (ix < v0) {
            a = 0;
        } else {
            ix = ix - v0;
            var jj = 1;
            var found = 0;
            while (found == 0) {
                if (jj > kk) { return err(ERR_DECODE); }   # idx out of range
                var vj = _pvq_v(m, kk - jj);
                if (ix < vj) { a = jj; found = 1; }
                else {
                    ix = ix - vj;
                    if (ix < vj) { a = 0 - jj; found = 1; }
                    else { ix = ix - vj; jj = jj + 1; }
                }
            }
        }
        store64(y_out + pos * 8, a);
        var aa = a; if (aa < 0) { aa = 0 - aa; }
        ryy = ryy + aa * aa;
        kk = kk - aa;
        pos = pos - 1;
    }
    return ryy;
}

# Assert encode(vecs[i])==i and decode(i)==vecs[i] for a table of `count` vectors
# stored flat in index order — validates exact ordering + bijection over [0,V).
fn _pvq_check_table(vecs, n, k, count) {
    assert_eq(_pvq_v(n, k), count, "table count == V(N,K)");
    var i = 0;
    while (i < count) {
        var yi = vecs + i * n * 8;
        assert_eq(_pvq_index_encode(yi, n, k), i, "encode == index");
        var ydec = alloc(n * 8);
        _pvq_index_decode(i, n, k, ydec);
        var j = 0;
        while (j < n) {
            assert_eq(load64(ydec + j * 8), load64(yi + j * 8), "decode == vector");
            j = j + 1;
        }
        i = i + 1;
    }
    return 0;
}

# Roundtrip a single vector (no exact-index assumption): decode(encode(y))==y.
fn _pvq_check_rt(y, n, k) {
    var idx = _pvq_index_encode(y, n, k);
    assert(idx >= 0, "rt idx >= 0");
    assert(idx < _pvq_v(n, k), "rt idx < V");
    var yd = alloc(n * 8);
    _pvq_index_decode(idx, n, k, yd);
    var j = 0;
    while (j < n) {
        assert_eq(load64(yd + j * 8), load64(y + j * 8), "rt decode == y");
        j = j + 1;
    }
    return 0;
}

fn test_pvq_cwrs_roundtrip() {
    syscall(1, 1, "test: pvq CWRS roundtrip\n", 25);
    # N=2, K=2 — full table (8 vectors) in index order.
    var t2 = alloc(8 * 2 * 8);
    store64(t2+0, 2);      store64(t2+8, 0);       # 0: [+2, 0]
    store64(t2+16, 0-2);  store64(t2+24, 0);       # 1: [-2, 0]
    store64(t2+32, 1);    store64(t2+40, 1);       # 2: [+1,+1]
    store64(t2+48, 0-1);  store64(t2+56, 1);       # 3: [-1,+1]
    store64(t2+64, 1);    store64(t2+72, 0-1);     # 4: [+1,-1]
    store64(t2+80, 0-1);  store64(t2+88, 0-1);     # 5: [-1,-1]
    store64(t2+96, 0);    store64(t2+104, 2);      # 6: [0,+2]
    store64(t2+112, 0);   store64(t2+120, 0-2);    # 7: [0,-2]
    _pvq_check_table(t2, 2, 2, 8);
    # Roundtrip a spread of vectors across (N,K).
    var y = alloc(4 * 8);
    # (3,2)
    store64(y+0, 1); store64(y+8, 1); store64(y+16, 0); _pvq_check_rt(y, 3, 2);
    store64(y+0, 0); store64(y+8, 0); store64(y+16, 0-2); _pvq_check_rt(y, 3, 2);
    store64(y+0, 2); store64(y+8, 0); store64(y+16, 0); _pvq_check_rt(y, 3, 2);
    store64(y+0, 1); store64(y+8, 0-1); store64(y+16, 0); _pvq_check_rt(y, 3, 2);
    # (4,3)
    store64(y+0, 1); store64(y+8, 1); store64(y+16, 1); store64(y+24, 0); _pvq_check_rt(y, 4, 3);
    store64(y+0, 3); store64(y+8, 0); store64(y+16, 0); store64(y+24, 0); _pvq_check_rt(y, 4, 3);
    store64(y+0, 0); store64(y+8, 0-2); store64(y+16, 1); store64(y+24, 0); _pvq_check_rt(y, 4, 3);
    # (2,10)
    store64(y+0, 10); store64(y+8, 0); _pvq_check_rt(y, 2, 10);
    store64(y+0, 5); store64(y+8, 0-5); _pvq_check_rt(y, 2, 10);
    # (1,3)
    store64(y+0, 3); _pvq_check_rt(y, 1, 3);
    store64(y+0, 0-3); _pvq_check_rt(y, 1, 3);
    # decode of idx==V must error
    var yd = alloc(2 * 8);
    assert(is_err(_pvq_index_decode(_pvq_v(2,2), 2, 2, yd)) == 1, "decode idx==V errors");
    return 0;
}

# Reconstruct the unit-norm shape from an integer pulse vector: out[i] = y[i]/||y||.
# (The decoder then scales by the separately-coded band energy/gain.)
fn _pvq_denormalize(y, n, ryy, out) {
    if (ryy <= 0) {
        var z = 0;
        while (z < n) { store64(out + z * 8, F64_ZERO); z = z + 1; }
        return 0;
    }
    var norm = f64_sqrt(f64_from(ryy));
    var i = 0;
    while (i < n) {
        store64(out + i * 8, f64_div(f64_from(load64(y + i * 8)), norm));
        i = i + 1;
    }
    return 0;
}

# cosine similarity dot(a,b) for two f64 vectors (both assumed unit-L2 here).
fn _pvq_dot(a, b, n) {
    var s = F64_ZERO;
    var i = 0;
    while (i < n) {
        s = f64_add(s, f64_mul(load64(a + i * 8), load64(b + i * 8)));
        i = i + 1;
    }
    return s;
}

fn test_pvq_spectral_shape_roundtrip() {
    syscall(1, 1, "test: pvq shape fidelity\n", 25);
    # unit band s=[0.9,0.3,0.3,0.1] (||s||=1), K=4
    var s = alloc(4 * 8);
    store64(s+0,  f64_div(f64_from(9), f64_from(10)));
    store64(s+8,  f64_div(f64_from(3), f64_from(10)));
    store64(s+16, f64_div(f64_from(3), f64_from(10)));
    store64(s+24, f64_div(f64_from(1), f64_from(10)));
    var y = alloc(4 * 8);
    var ryy = _pvq_search(s, 4, 4, y);
    # search -> y=[2,1,1,0], Ryy=6
    assert_eq(load64(y+0), 2, "shape y0=2");
    assert_eq(load64(y+8), 1, "shape y1=1");
    assert_eq(load64(y+16), 1, "shape y2=1");
    assert_eq(load64(y+24), 0, "shape y3=0");
    assert_eq(ryy, 6, "shape Ryy=6");
    var shat = alloc(4 * 8);
    _pvq_denormalize(y, 4, ryy, shat);
    var cos_pvq = _pvq_dot(s, shat, 4);           # ~0.9798
    # sign-only baseline: shat' = 0.5 each -> cosine = 1.6*0.5 = 0.8
    var half = f64_div(f64_from(1), f64_from(2));
    var so = alloc(4 * 8);
    store64(so+0, half); store64(so+8, half); store64(so+16, half); store64(so+24, half);
    var cos_so = _pvq_dot(s, so, 4);
    var t95 = f64_div(f64_from(95), f64_from(100));
    assert(f64_gt(cos_pvq, t95) == 1, "PVQ shape cosine > 0.95");
    assert(f64_gt(cos_pvq, cos_so) == 1, "PVQ beats sign-only");
    # ||shat|| == 1 (Ryy>0)
    var nn = _pvq_dot(shat, shat, 4);
    var eps = f64_div(f64_from(1), f64_from(1000));
    assert(f64_lt(f64_abs(f64_sub(nn, F64_ONE)), eps) == 1, "shape unit norm");
    return 0;
}

fn test_pvq_search_sanity() {
    syscall(1, 1, "test: pvq search sanity\n", 24);
    var x = alloc(3 * 8);
    var y = alloc(3 * 8);
    var f9  = f64_div(f64_from(9), f64_from(10));   # 0.9
    var f1  = f64_div(f64_from(1), f64_from(10));   # 0.1
    var f6  = f64_div(f64_from(6), f64_from(10));   # 0.6
    var f5  = f64_div(f64_from(5), f64_from(10));   # 0.5
    var f7  = f64_div(f64_from(7), f64_from(10));   # 0.7
    # x=[0.9,0.1,0] K=2 -> [2,0,0]
    store64(x+0, f9); store64(x+8, f1); store64(x+16, F64_ZERO);
    assert_eq(_pvq_search(x, 3, 2, y), 4, "search A Ryy=4");
    assert_eq(load64(y+0), 2, "A y0=2"); assert_eq(load64(y+8), 0, "A y1=0"); assert_eq(load64(y+16), 0, "A y2=0");
    # x=[0.6,0.5,0] K=2 -> [1,1,0]
    store64(x+0, f6); store64(x+8, f5); store64(x+16, F64_ZERO);
    _pvq_search(x, 3, 2, y);
    assert_eq(load64(y+0), 1, "B y0=1"); assert_eq(load64(y+8), 1, "B y1=1"); assert_eq(load64(y+16), 0, "B y2=0");
    # x=[-0.9,0.1,0] K=2 -> [-2,0,0]
    store64(x+0, f64_neg(f9)); store64(x+8, f1); store64(x+16, F64_ZERO);
    _pvq_search(x, 3, 2, y);
    assert_eq(load64(y+0), 0-2, "C y0=-2"); assert_eq(load64(y+8), 0, "C y1=0");
    # x=[0,0,-0.7] K=1 -> [0,0,-1]
    store64(x+0, F64_ZERO); store64(x+8, F64_ZERO); store64(x+16, f64_neg(f7));
    _pvq_search(x, 3, 1, y);
    assert_eq(load64(y+0), 0, "D y0=0"); assert_eq(load64(y+16), 0-1, "D y2=-1");
    # search always yields sum|y|==K (Ryy for K=2 all-equal input)
    return 0;
}

fn test_pvq_v_counting() {
    syscall(1, 1, "test: pvq V(N,K) counting\n", 26);
    assert_eq(_pvq_v(1, 0), 1, "V(1,0)=1");
    assert_eq(_pvq_v(4, 0), 1, "V(4,0)=1");
    assert_eq(_pvq_v(1, 1), 2, "V(1,1)=2");
    assert_eq(_pvq_v(1, 4), 2, "V(1,4)=2");
    assert_eq(_pvq_v(2, 1), 4, "V(2,1)=4");
    assert_eq(_pvq_v(3, 1), 6, "V(3,1)=6");
    assert_eq(_pvq_v(4, 1), 8, "V(4,1)=8");
    assert_eq(_pvq_v(2, 2), 8, "V(2,2)=8");
    assert_eq(_pvq_v(2, 3), 12, "V(2,3)=12");
    assert_eq(_pvq_v(2, 10), 40, "V(2,10)=40");
    assert_eq(_pvq_v(3, 2), 18, "V(3,2)=18");
    assert_eq(_pvq_v(3, 3), 38, "V(3,3)=38");
    assert_eq(_pvq_v(4, 2), 32, "V(4,2)=32");
    assert_eq(_pvq_v(4, 3), 88, "V(4,3)=88");
    assert_eq(_pvq_v(4, 4), 192, "V(4,4)=192");
    assert(_pvq_v(3, 2) != _pvq_v(2, 3), "V not symmetric");
    assert(_pvq_v(3, 3) > _pvq_v(3, 2), "V monotone in K");
    assert_eq(_pvq_choose_k(1, 8), 1, "N=1 caps K=1");
    assert(_pvq_choose_k(4, 32) > 0, "N=4 budget picks K>0");
    assert_eq(_pvq_choose_k(4, 0), 0, "zero budget K=0");
    return 0;
}

# Symbol-exact proof at the band level: encode a band's shape through the range
# coder, then decode the *identical* pulse vector back. Covers narrow/wide N and
# a spread of K — the CWRS bijection composed with the matched range coder.
fn test_opus_pvq_band_roundtrip() {
    test_group("opus: PVQ band symbol-exact roundtrip");
    var cfg_n = alloc(5 * 8);
    var cfg_k = alloc(5 * 8);
    store64(cfg_n + 0,  4);  store64(cfg_k + 0,  4);
    store64(cfg_n + 8,  8);  store64(cfg_k + 8,  3);
    store64(cfg_n + 16, 16); store64(cfg_k + 16, 5);
    store64(cfg_n + 24, 3);  store64(cfg_k + 24, 2);
    store64(cfg_n + 32, 32); store64(cfg_k + 32, 6);
    var seven_tenths = f64_div(f64_from(7), f64_from(10));
    var t = 0;
    while (t < 5) {
        var n = load64(cfg_n + t * 8);
        var k = load64(cfg_k + t * 8);
        # Clamp K to the legal range V(n,k) <= PVQ_V_SAFE — exactly the invariant
        # _pvq_choose_k enforces in real encoding (the range coder needs idx < total).
        while (k > 1) {
            if (_pvq_v(n, k) <= PVQ_V_SAFE) { break; }
            k = k - 1;
        }
        var x = alloc(n * 8);
        var j = 0;
        while (j < n) {
            var ang = f64_add(f64_mul(f64_from(j + 1), seven_tenths), f64_from(t));
            store64(x + j * 8, f64_sin(ang));
            j = j + 1;
        }
        var yref = alloc(n * 8);
        _pvq_search(x, n, k, yref);
        var rc = opus_range_enc_init();
        _pvq_encode_band(rc, x, n, k);
        var coded = opus_range_enc_flush(rc);
        var rd = opus_range_dec_init(str_data(coded), str_len(coded));
        var ydec = alloc(n * 8);
        _pvq_decode_band(rd, n, k, ydec);
        var ok = 1;
        j = 0;
        while (j < n) {
            if (load64(ydec + j * 8) != load64(yref + j * 8)) { ok = 0; }
            j = j + 1;
        }
        assert(ok == 1, "PVQ band y roundtrip exact");
        t = t + 1;
    }
    return 0;
}

# Band-energy DPCM roundtrip: encode a quant array, decode it, and match the
# closed-loop reconstruction (encoder + decoder track the same clamped predictor).
fn test_opus_energy_roundtrip() {
    test_group("opus: band-energy DPCM roundtrip");
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var quant = alloc(_CELT_NUM_BANDS * 8);
    var expect = alloc(_CELT_NUM_BANDS * 8);
    var i = 0;
    var v = 0;
    while (i < _CELT_NUM_BANDS) {
        v = v + ((i * 7) % 23) - 5;
        store64(quant + i * 8, v);
        i = i + 1;
    }
    var prev = 0;
    i = 0;
    while (i < _CELT_NUM_BANDS) {
        var q = load64(quant + i * 8);
        var d = q - prev;
        if (d < 0 - 128) { d = 0 - 128; }
        if (d > 127) { d = 127; }
        prev = prev + d;
        store64(expect + i * 8, prev);
        i = i + 1;
    }
    var rc = opus_range_enc_init();
    _opus_encode_band_energies(rc, quant);
    var coded = opus_range_enc_flush(rc);
    var rd = opus_range_dec_init(str_data(coded), str_len(coded));
    var dquant = alloc(_CELT_NUM_BANDS * 8);
    _opus_decode_band_energies(rd, dquant);
    var ok = 1;
    i = 0;
    while (i < _CELT_NUM_BANDS) {
        if (load64(dquant + i * 8) != load64(expect + i * 8)) { ok = 0; }
        i = i + 1;
    }
    assert(ok == 1, "energy DPCM roundtrip exact");
    return 0;
}

# Full-stream CELT roundtrip: window+MDCT+quantize a signal, encode energies+shape
# into one range coder, then decode the packet and assert BOTH sub-streams invert
# exactly — quantized energies bit-for-bit, and every K>0 sub-block's unit shape
# equal to the encoder's own PVQ output (proving lock-step traversal + coder).
fn test_opus_celt_frame_roundtrip() {
    test_group("opus: CELT frame decode roundtrip");
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var fs = 960;              # OPUS_FRAME_SIZE (20ms @ 48 kHz)
    var n2 = fs / 2;           # 480 MDCT bins
    var f6 = f64_div(f64_from(6), f64_from(10));
    var f3 = f64_div(f64_from(3), f64_from(10));
    var sig = alloc(fs * 8);
    var i = 0;
    while (i < fs) {
        var t = f64_from(i);
        var a = f64_mul(f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, t)), f64_from(64))), f6);
        var b = f64_mul(f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, t)), f64_from(17))), f3);
        store64(sig + i * 8, f64_add(a, b));
        i = i + 1;
    }
    var bytes = 80;           # 32 kbit/s @ 50 fps
    # Encoder front end (identical to _opus_encode_celt_frame's mono path).
    var ref = alloc(fs * 8);
    memcpy(ref, sig, fs * 8);
    _opus_sine_window(ref, fs);
    var refmdct = alloc(n2 * 8);
    memset(refmdct, 0, n2 * 8);
    _opus_mdct(ref, fs, refmdct);
    var refen = alloc(_CELT_NUM_BANDS * 8);
    _opus_compute_band_energies(refmdct, n2, refen);
    var refq = alloc(_CELT_NUM_BANDS * 8);
    _opus_quantize_energies(refen, refq);
    # Expected closed-loop quantized energies.
    var expq = alloc(_CELT_NUM_BANDS * 8);
    var prev = 0;
    i = 0;
    while (i < _CELT_NUM_BANDS) {
        var q = load64(refq + i * 8);
        var d = q - prev;
        if (d < 0 - 128) { d = 0 - 128; }
        if (d > 127) { d = 127; }
        prev = prev + d;
        store64(expq + i * 8, prev);
        i = i + 1;
    }
    # Build payload (isTransient + energies + shape) and pad to target size, like the encoder.
    var rc = opus_range_enc_init();
    opus_range_enc_bit(rc, 0);   # steady frame
    _opus_encode_band_energies(rc, refq);
    _opus_encode_spectral_shape(rc, refmdct, n2, bytes);
    var coded = opus_range_enc_flush(rc);
    var clen = str_len(coded);
    assert(1 + clen <= bytes, "frame payload fits target size (no truncation)");
    var pkt = alloc(bytes);
    memset(pkt, 0, bytes);
    store8(pkt, 31 << 3);     # TOC: CELT/FB 20ms mono (config 31)
    memcpy(pkt + 1, str_data(coded), clen);
    # Decode and verify both sub-streams.
    var dtrans = alloc(8);
    var dquant = alloc(_CELT_NUM_BANDS * 8);
    var dshape = alloc(n2 * 8);
    var r = _opus_decode_celt_frame(pkt, bytes, n2, dquant, dshape, dtrans);
    assert(r == 0, "CELT frame decode ok");
    assert_eq(load64(dtrans), 0, "isTransient=0 roundtrips");
    var energy_ok = 1;
    i = 0;
    while (i < _CELT_NUM_BANDS) {
        if (load64(dquant + i * 8) != load64(expq + i * 8)) { energy_ok = 0; }
        i = i + 1;
    }
    assert(energy_ok == 1, "frame energy roundtrip exact");
    var shape_bits = (bytes - 1) * 8 - PVQ_ENERGY_RSVD_BITS;
    if (shape_bits < 0) { shape_bits = 0; }
    var shape_ok = 1;
    var checked = 0;
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        var start = load64(_celt_band_edges + band * 8);
        var end = load64(_celt_band_edges + (band + 1) * 8);
        if (end > n2) { end = n2; }
        var bn = end - start;
        if (bn > 0) {
            var band_bits = shape_bits * bn / n2;
            var off = start;
            while (off < end) {
                var ns = end - off;
                if (ns > PVQ_MAX_N) { ns = PVQ_MAX_N; }
                var sub_bits = band_bits * ns / bn;
                var kk = _pvq_choose_k(ns, sub_bits);
                if (kk > 0) {
                    var yref = alloc(ns * 8);
                    var rr = _pvq_search(refmdct + off * 8, ns, kk, yref);
                    var sref = alloc(ns * 8);
                    _pvq_denormalize(yref, ns, rr, sref);
                    var j = 0;
                    while (j < ns) {
                        if (load64(dshape + (off + j) * 8) != load64(sref + j * 8)) { shape_ok = 0; }
                        j = j + 1;
                    }
                    checked = checked + 1;
                }
                off = off + ns;
            }
        }
        band = band + 1;
    }
    assert(shape_ok == 1, "frame shape roundtrip exact");
    assert(checked > 0, "frame had at least one shaped sub-block");
    return 0;
}

# Magnitude synthesis (2.5.9): _opus_denorm_frame reconstructs MDCT coefficients from
# the decoded band energies + unit shapes, and the reconstructed coefficients carry
# back the coded band energy (log2 mean power) exactly for every band whose shape is
# nonzero. This is the step that turns "CELT direction" into real spectral magnitude.
fn test_opus_magnitude_synth() {
    test_group("opus: magnitude synthesis restores band energy");
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var fs = 960;
    var n2 = fs / 2;
    var f6 = f64_div(f64_from(6), f64_from(10));
    var f3 = f64_div(f64_from(3), f64_from(10));
    var sig = alloc(fs * 8);
    var i = 0;
    while (i < fs) {
        var t = f64_from(i);
        var a = f64_mul(f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, t)), f64_from(64))), f6);
        var b = f64_mul(f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, t)), f64_from(17))), f3);
        store64(sig + i * 8, f64_add(a, b));
        i = i + 1;
    }
    var bytes = 80;
    var ref = alloc(fs * 8);
    memcpy(ref, sig, fs * 8);
    _opus_sine_window(ref, fs);
    var refmdct = alloc(n2 * 8);
    memset(refmdct, 0, n2 * 8);
    _opus_mdct(ref, fs, refmdct);
    var refen = alloc(_CELT_NUM_BANDS * 8);
    _opus_compute_band_energies(refmdct, n2, refen);
    var refq = alloc(_CELT_NUM_BANDS * 8);
    _opus_quantize_energies(refen, refq);
    var rc = opus_range_enc_init();
    opus_range_enc_bit(rc, 0);
    _opus_encode_band_energies(rc, refq);
    _opus_encode_spectral_shape(rc, refmdct, n2, bytes);
    var coded = opus_range_enc_flush(rc);
    var pkt = alloc(bytes);
    memset(pkt, 0, bytes);
    store8(pkt, 31 << 3);
    memcpy(pkt + 1, str_data(coded), str_len(coded));
    var dtrans = alloc(8);
    var dquant = alloc(_CELT_NUM_BANDS * 8);
    var dshape = alloc(n2 * 8);
    var r = _opus_decode_celt_frame(pkt, bytes, n2, dquant, dshape, dtrans);
    assert(r == 0, "decode ok");
    # Magnitude synthesis -> MDCT coefficients.
    var coeffs = alloc(n2 * 8);
    _opus_denorm_frame(dquant, dshape, n2, coeffs);
    # Recompute band energies from the reconstructed coefficients.
    var reen = alloc(_CELT_NUM_BANDS * 8);
    _opus_compute_band_energies(coeffs, n2, reen);
    var req = alloc(_CELT_NUM_BANDS * 8);
    _opus_quantize_energies(reen, req);
    var energy_ok = 1;
    var checked = 0;
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        var start = load64(_celt_band_edges + band * 8);
        var end = load64(_celt_band_edges + (band + 1) * 8);
        if (end > n2) { end = n2; }
        var bn = end - start;
        # Single-sub-block bands with a nonzero shape restore energy exactly.
        if (bn > 0) {
            if (bn <= PVQ_MAX_N) {
                var e = F64_ZERO;
                var j = start;
                while (j < end) {
                    var c = load64(dshape + j * 8);
                    e = f64_add(e, f64_mul(c, c));
                    j = j + 1;
                }
                if (f64_gt(e, F64_ZERO) == 1) {
                    if (load64(req + band * 8) != load64(dquant + band * 8)) { energy_ok = 0; }
                    checked = checked + 1;
                }
            }
        }
        band = band + 1;
    }
    assert(energy_ok == 1, "reconstructed coefficients carry the coded band energy");
    assert(checked > 0, "at least one shaped band synthesized");
    return 0;
}

# Mid/side transform is exactly invertible (energy-preserving 1/√2 normalization).
fn test_opus_stereo_ms() {
    test_group("opus: stereo mid/side invertible");
    var n = 100;
    var lch = alloc(n * 8);
    var rch = alloc(n * 8);
    var i = 0;
    while (i < n) {
        store64(lch + i * 8, f64_sin(f64_div(f64_from(i * 3), f64_from(7))));
        store64(rch + i * 8, f64_sin(f64_div(f64_from(i * 5), f64_from(11))));
        i = i + 1;
    }
    var mch = alloc(n * 8);
    var sch = alloc(n * 8);
    _opus_stereo_ms_forward(lch, rch, mch, sch, n);
    var l2 = alloc(n * 8);
    var r2 = alloc(n * 8);
    _opus_stereo_ms_inverse(mch, sch, l2, r2, n);
    var ok = 1;
    var eps = f64_div(F64_ONE, f64_from(1000000));
    i = 0;
    while (i < n) {
        if (f64_gt(f64_abs(f64_sub(load64(l2 + i * 8), load64(lch + i * 8))), eps) == 1) { ok = 0; }
        if (f64_gt(f64_abs(f64_sub(load64(r2 + i * 8), load64(rch + i * 8))), eps) == 1) { ok = 0; }
        i = i + 1;
    }
    assert(ok == 1, "M/S forward then inverse == identity");
    return 0;
}

# Per-band coupling: correlated bands pick M/S; couple∘decouple recovers L/R exactly.
fn test_opus_stereo_couple() {
    test_group("opus: stereo couple/decouple + decision");
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var n2 = 480;
    var lch = alloc(n2 * 8);
    var rch = alloc(n2 * 8);
    var i = 0;
    while (i < n2) {
        var base = f64_sin(f64_div(f64_from(i * 2), f64_from(13)));
        if (i < 100) {
            store64(lch + i * 8, base);
            store64(rch + i * 8, base);   # identical channels -> M/S
        } else {
            store64(lch + i * 8, base);
            store64(rch + i * 8, f64_sin(f64_div(f64_from(i * 7), f64_from(5))));
        }
        i = i + 1;
    }
    var mch = alloc(n2 * 8);
    var sch = alloc(n2 * 8);
    var flags = alloc(_CELT_NUM_BANDS * 8);
    _opus_stereo_couple(lch, rch, n2, mch, sch, flags);
    # band 10 (bins 12..14) is non-silent and identical L/R -> M/S chosen
    assert_eq(load64(flags + 10 * 8), 1, "correlated low band uses M/S");
    var l2 = alloc(n2 * 8);
    var r2 = alloc(n2 * 8);
    _opus_stereo_decouple(mch, sch, n2, flags, l2, r2);
    var ok = 1;
    var eps = f64_div(F64_ONE, f64_from(1000000));
    i = 0;
    while (i < n2) {
        if (f64_gt(f64_abs(f64_sub(load64(l2 + i * 8), load64(lch + i * 8))), eps) == 1) { ok = 0; }
        if (f64_gt(f64_abs(f64_sub(load64(r2 + i * 8), load64(rch + i * 8))), eps) == 1) { ok = 0; }
        i = i + 1;
    }
    assert(ok == 1, "couple then decouple == identity (any per-band choice)");
    return 0;
}

# Transient detector: steady tone is not transient; an onset after silence is.
fn test_opus_transient_detect() {
    test_group("opus: transient detection");
    var fs = 960;
    var steady = alloc(fs * 8);
    var i = 0;
    while (i < fs) {
        store64(steady + i * 8, f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, f64_from(i))), f64_from(32))));
        i = i + 1;
    }
    assert_eq(_opus_detect_transient(steady, fs), 0, "steady tone is not transient");
    var trans = alloc(fs * 8);
    memset(trans, 0, fs * 8);
    i = fs / 2;
    while (i < fs) {
        store64(trans + i * 8, f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, f64_from(i))), f64_from(20))));
        i = i + 1;
    }
    assert_eq(_opus_detect_transient(trans, fs), 1, "onset after silence is transient");
    # a click confined to the first sub-block (samples 0..fs/8), then silence
    var click = alloc(fs * 8);
    memset(click, 0, fs * 8);
    i = 0;
    while (i < fs / 8) {
        store64(click + i * 8, f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, f64_from(i))), f64_from(15))));
        i = i + 1;
    }
    assert_eq(_opus_detect_transient(click, fs), 1, "block-0 click is transient");
    return 0;
}

# Transient CELT frame: short-block MDCT + isTransient bit, full-stream roundtrip
# (flag + energies + every K>0 sub-block shape bit-exact vs the encoder's PVQ).
fn test_opus_transient_roundtrip() {
    test_group("opus: transient CELT frame roundtrip");
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var fs = 960;
    var n2 = fs / 2;
    var sig = alloc(fs * 8);
    memset(sig, 0, fs * 8);
    var i = fs / 2;
    while (i < fs) {
        store64(sig + i * 8, f64_mul(f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, f64_from(i))), f64_from(20))), f64_div(f64_from(7), f64_from(10))));
        i = i + 1;
    }
    assert_eq(_opus_detect_transient(sig, fs), 1, "signal is transient");
    var bytes = 80;
    # Reference: short-block MDCT (the encoder's transient path) → energies → quant.
    var refmdct = alloc(n2 * 8);
    memset(refmdct, 0, n2 * 8);
    _opus_short_mdct(sig, fs, CELT_SHORT_BLOCKS, refmdct);
    var refen = alloc(_CELT_NUM_BANDS * 8);
    _opus_compute_band_energies(refmdct, n2, refen);
    var refq = alloc(_CELT_NUM_BANDS * 8);
    _opus_quantize_energies(refen, refq);
    var expq = alloc(_CELT_NUM_BANDS * 8);
    var prev = 0;
    i = 0;
    while (i < _CELT_NUM_BANDS) {
        var q = load64(refq + i * 8);
        var d = q - prev;
        if (d < 0 - 128) { d = 0 - 128; }
        if (d > 127) { d = 127; }
        prev = prev + d;
        store64(expq + i * 8, prev);
        i = i + 1;
    }
    var rc = opus_range_enc_init();
    opus_range_enc_bit(rc, 1);   # transient
    _opus_encode_band_energies(rc, refq);
    _opus_encode_spectral_shape(rc, refmdct, n2, bytes);
    var coded = opus_range_enc_flush(rc);
    var clen = str_len(coded);
    assert(1 + clen <= bytes, "transient payload fits target size");
    var pkt = alloc(bytes);
    memset(pkt, 0, bytes);
    store8(pkt, 31 << 3);
    memcpy(pkt + 1, str_data(coded), clen);
    var dtrans = alloc(8);
    var dquant = alloc(_CELT_NUM_BANDS * 8);
    var dshape = alloc(n2 * 8);
    var r = _opus_decode_celt_frame(pkt, bytes, n2, dquant, dshape, dtrans);
    assert(r == 0, "transient frame decode ok");
    assert_eq(load64(dtrans), 1, "isTransient=1 roundtrips");
    var energy_ok = 1;
    i = 0;
    while (i < _CELT_NUM_BANDS) {
        if (load64(dquant + i * 8) != load64(expq + i * 8)) { energy_ok = 0; }
        i = i + 1;
    }
    assert(energy_ok == 1, "transient-frame energies roundtrip exact");
    var shape_bits = (bytes - 1) * 8 - PVQ_ENERGY_RSVD_BITS;
    if (shape_bits < 0) { shape_bits = 0; }
    var shape_ok = 1;
    var checked = 0;
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        var start = load64(_celt_band_edges + band * 8);
        var end = load64(_celt_band_edges + (band + 1) * 8);
        if (end > n2) { end = n2; }
        var bn = end - start;
        if (bn > 0) {
            var band_bits = shape_bits * bn / n2;
            var off = start;
            while (off < end) {
                var ns = end - off;
                if (ns > PVQ_MAX_N) { ns = PVQ_MAX_N; }
                var sub_bits = band_bits * ns / bn;
                var kk = _pvq_choose_k(ns, sub_bits);
                if (kk > 0) {
                    var yref = alloc(ns * 8);
                    var rr = _pvq_search(refmdct + off * 8, ns, kk, yref);
                    var sref = alloc(ns * 8);
                    _pvq_denormalize(yref, ns, rr, sref);
                    var j = 0;
                    while (j < ns) {
                        if (load64(dshape + (off + j) * 8) != load64(sref + j * 8)) { shape_ok = 0; }
                        j = j + 1;
                    }
                    checked = checked + 1;
                }
                off = off + ns;
            }
        }
        band = band + 1;
    }
    assert(shape_ok == 1, "transient-frame shape roundtrips exact");
    assert(checked > 0, "transient frame had a shaped sub-block");
    return 0;
}

# Test helper: closed-loop DPCM reconstruction of quantized energies (mirrors
# _opus_encode_band_energies) — the values the decoder should recover.
fn _opus_dpcm_expect(quant, out) {
    var prev = 0;
    var i = 0;
    while (i < _CELT_NUM_BANDS) {
        var q = load64(quant + i * 8);
        var d = q - prev;
        if (d < 0 - 128) { d = 0 - 128; }
        if (d > 127) { d = 127; }
        prev = prev + d;
        store64(out + i * 8, prev);
        i = i + 1;
    }
    return 0;
}

# Test helper: does the decoded shape match the encoder's PVQ output for every
# K>0 sub-block, given a spectral-shape bit budget? Returns 1 if all match.
fn _opus_shape_matches(refmdct, dshape, n2, shape_bits) {
    if (shape_bits < 0) { shape_bits = 0; }
    var ok = 1;
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        var start = load64(_celt_band_edges + band * 8);
        var end = load64(_celt_band_edges + (band + 1) * 8);
        if (end > n2) { end = n2; }
        var bn = end - start;
        if (bn > 0) {
            var band_bits = shape_bits * bn / n2;
            var off = start;
            while (off < end) {
                var ns = end - off;
                if (ns > PVQ_MAX_N) { ns = PVQ_MAX_N; }
                var sub_bits = band_bits * ns / bn;
                var kk = _pvq_choose_k(ns, sub_bits);
                if (kk > 0) {
                    var yref = alloc(ns * 8);
                    var rr = _pvq_search(refmdct + off * 8, ns, kk, yref);
                    var sref = alloc(ns * 8);
                    _pvq_denormalize(yref, ns, rr, sref);
                    var j = 0;
                    while (j < ns) {
                        if (load64(dshape + (off + j) * 8) != load64(sref + j * 8)) { ok = 0; }
                        j = j + 1;
                    }
                }
                off = off + ns;
            }
        }
        band = band + 1;
    }
    return ok;
}

# Full stereo CELT frame: couple L/R -> mid/side, code both channels + ms_flags,
# decode, and verify ms_flags + both channels' energies and shapes roundtrip exact.
fn test_opus_stereo_frame_roundtrip() {
    test_group("opus: stereo CELT frame roundtrip");
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var fs = 960;
    var n2 = fs / 2;
    var bytes = 120;
    var left = alloc(fs * 8);
    var right = alloc(fs * 8);
    var i = 0;
    while (i < fs) {
        var t = f64_from(i);
        store64(left + i * 8, f64_mul(f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, t)), f64_from(48))), f64_div(f64_from(6), f64_from(10))));
        store64(right + i * 8, f64_mul(f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, t)), f64_from(53))), f64_div(f64_from(5), f64_from(10))));
        i = i + 1;
    }
    # Reference: encoder stereo front end (window + MDCT + couple + quantize).
    _opus_sine_window(left, fs);
    _opus_sine_window(right, fs);
    var lmdct = alloc(n2 * 8);
    memset(lmdct, 0, n2 * 8);
    _opus_mdct(left, fs, lmdct);
    var rmdct = alloc(n2 * 8);
    memset(rmdct, 0, n2 * 8);
    _opus_mdct(right, fs, rmdct);
    var refmid = alloc(n2 * 8);
    var refside = alloc(n2 * 8);
    var refflags = alloc(_CELT_NUM_BANDS * 8);
    _opus_stereo_couple(lmdct, rmdct, n2, refmid, refside, refflags);
    var men = alloc(_CELT_NUM_BANDS * 8);
    _opus_compute_band_energies(refmid, n2, men);
    var mq = alloc(_CELT_NUM_BANDS * 8);
    _opus_quantize_energies(men, mq);
    var sen = alloc(_CELT_NUM_BANDS * 8);
    _opus_compute_band_energies(refside, n2, sen);
    var sq = alloc(_CELT_NUM_BANDS * 8);
    _opus_quantize_energies(sen, sq);
    var expmq = alloc(_CELT_NUM_BANDS * 8);
    _opus_dpcm_expect(mq, expmq);
    var expsq = alloc(_CELT_NUM_BANDS * 8);
    _opus_dpcm_expect(sq, expsq);
    # Build payload manually (mirrors the encoder's stereo branch), pad to bytes.
    var rc = opus_range_enc_init();
    opus_range_enc_bit(rc, 0);
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        opus_range_enc_bit(rc, load64(refflags + band * 8));
        band = band + 1;
    }
    _opus_encode_band_energies(rc, mq);
    _opus_encode_band_energies(rc, sq);
    var shape_total = _opus_stereo_shape_total(bytes);
    _opus_encode_spectral_shape_bits(rc, refmid, n2, shape_total / 2);
    _opus_encode_spectral_shape_bits(rc, refside, n2, shape_total / 2);
    var coded = opus_range_enc_flush(rc);
    var clen = str_len(coded);
    assert(1 + clen <= bytes, "stereo payload fits target size");
    var pkt = alloc(bytes);
    memset(pkt, 0, bytes);
    store8(pkt, (31 << 3) | (1 << 2));
    memcpy(pkt + 1, str_data(coded), clen);
    # Decode.
    var dtrans = alloc(8);
    var dmq = alloc(_CELT_NUM_BANDS * 8);
    var dsq = alloc(_CELT_NUM_BANDS * 8);
    var dms = alloc(n2 * 8);
    var dss = alloc(n2 * 8);
    var dflags = alloc(_CELT_NUM_BANDS * 8);
    var r = _opus_decode_celt_stereo_frame(pkt, bytes, n2, dmq, dsq, dms, dss, dflags, dtrans);
    assert(r == 0, "stereo frame decode ok");
    var flags_ok = 1;
    var energy_ok = 1;
    i = 0;
    while (i < _CELT_NUM_BANDS) {
        if (load64(dflags + i * 8) != load64(refflags + i * 8)) { flags_ok = 0; }
        if (load64(dmq + i * 8) != load64(expmq + i * 8)) { energy_ok = 0; }
        if (load64(dsq + i * 8) != load64(expsq + i * 8)) { energy_ok = 0; }
        i = i + 1;
    }
    assert(flags_ok == 1, "ms_flags roundtrip exact");
    assert(energy_ok == 1, "mid+side energies roundtrip exact");
    assert(_opus_shape_matches(refmid, dms, n2, shape_total / 2) == 1, "mid shape roundtrip exact");
    assert(_opus_shape_matches(refside, dss, n2, shape_total / 2) == 1, "side shape roundtrip exact");
    # The coupled channels decouple back to L/R exactly (transform is invertible).
    var lout = alloc(n2 * 8);
    var rout = alloc(n2 * 8);
    _opus_stereo_decouple(refmid, refside, n2, refflags, lout, rout);
    var decouple_ok = 1;
    var eps = f64_div(F64_ONE, f64_from(1000000));
    i = 0;
    while (i < n2) {
        if (f64_gt(f64_abs(f64_sub(load64(lout + i * 8), load64(lmdct + i * 8))), eps) == 1) { decouple_ok = 0; }
        if (f64_gt(f64_abs(f64_sub(load64(rout + i * 8), load64(rmdct + i * 8))), eps) == 1) { decouple_ok = 0; }
        i = i + 1;
    }
    assert(decouple_ok == 1, "coupled mid/side decouple back to L/R MDCT");
    return 0;
}

# Exercise the real encoder stereo branch: _opus_encode_celt_frame(ch=2) must set
# the stereo TOC bit and produce a packet the stereo decoder accepts.
fn test_opus_stereo_encode_frame() {
    test_group("opus: stereo encoder frame path");
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var fs = 960;
    var n2 = fs / 2;
    var bytes = 120;
    var frame = alloc(fs * 2 * 8);
    var i = 0;
    while (i < fs) {
        var t = f64_from(i);
        store64(frame + (i * 2) * 8, f64_mul(f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, t)), f64_from(48))), f64_div(f64_from(6), f64_from(10))));
        store64(frame + (i * 2 + 1) * 8, f64_mul(f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, t)), f64_from(53))), f64_div(f64_from(5), f64_from(10))));
        i = i + 1;
    }
    var pkt = _opus_encode_celt_frame(frame, fs, 2, bytes);
    var plen = str_len(pkt);
    var pdata = str_data(pkt);
    assert_eq((load8(pdata) >> 2) & 1, 1, "stereo TOC bit set");
    var dtrans = alloc(8);
    var dmq = alloc(_CELT_NUM_BANDS * 8);
    var dsq = alloc(_CELT_NUM_BANDS * 8);
    var dms = alloc(n2 * 8);
    var dss = alloc(n2 * 8);
    var dflags = alloc(_CELT_NUM_BANDS * 8);
    var r = _opus_decode_celt_stereo_frame(pdata, plen, n2, dmq, dsq, dms, dss, dflags, dtrans);
    assert(r == 0, "stereo encoder-frame decode ok");
    var valid = 1;
    i = 0;
    while (i < _CELT_NUM_BANDS) {
        var fl = load64(dflags + i * 8);
        if (fl < 0) { valid = 0; }
        if (fl > 1) { valid = 0; }
        i = i + 1;
    }
    assert(valid == 1, "decoded ms_flags are valid bits");
    return 0;
}

# CBR: every frame's target equals the nominal size, regardless of complexity.
fn test_opus_rate_cbr() {
    test_group("opus: rate control CBR");
    var st = _opus_rate_new(64000, RATE_CBR);
    var nominal = 64000 / 8 / 50;
    assert_eq(_opus_rate_target(st, 0), nominal, "CBR target = nominal (c=0)");
    assert_eq(_opus_rate_target(st, 100), nominal, "CBR target = nominal (c=100)");
    assert_eq(_opus_rate_target(st, 50), nominal, "CBR target = nominal (c=50)");
    return 0;
}

# VBR: a complex frame gets more bytes than a simple one; c=50 maps to nominal.
fn test_opus_rate_vbr_complexity() {
    test_group("opus: rate control VBR complexity");
    var nominal = 64000 / 8 / 50;
    var lo = _opus_rate_new(64000, RATE_VBR);
    var t_lo = _opus_rate_target(lo, 10);
    var hi = _opus_rate_new(64000, RATE_VBR);
    var t_hi = _opus_rate_target(hi, 90);
    assert(t_hi > t_lo, "VBR: complex frame gets more bytes");
    var mid = _opus_rate_new(64000, RATE_VBR);
    assert_eq(_opus_rate_target(mid, 50), nominal, "VBR c=50 ~ nominal");
    return 0;
}

# CVBR: bounded per frame, and the average never exceeds the target bitrate.
fn test_opus_rate_cvbr_reservoir() {
    test_group("opus: rate control CVBR reservoir");
    var st = _opus_rate_new(64000, RATE_CVBR);
    var nominal = 64000 / 8 / 50;
    var total = 0;
    var n = 20;
    var bounds_ok = 1;
    var i = 0;
    while (i < n) {
        var c = 10;
        if ((i % 2) == 1) { c = 100; }
        var t = _opus_rate_target(st, c);
        total = total + t;
        if (t < nominal / 2) { bounds_ok = 0; }
        if (t > nominal + nominal * 6) { bounds_ok = 0; }
        i = i + 1;
    }
    assert(bounds_ok == 1, "every CVBR target within [floor, nominal+reservoir cap]");
    assert(total <= n * nominal, "CVBR average bitrate <= target");
    return 0;
}

# Complexity: a tone is simpler than high-frequency noise; silence is 0.
fn test_opus_complexity() {
    test_group("opus: frame complexity metric");
    var n = 960;
    var tone = alloc(n * 8);
    var i = 0;
    while (i < n) {
        store64(tone + i * 8, f64_sin(f64_div(f64_mul(F64_TWO, f64_mul(F64_PI, f64_from(i))), f64_from(480))));
        i = i + 1;
    }
    var c_tone = _opus_frame_complexity(tone, n, 1);
    var noise = alloc(n * 8);
    i = 0;
    while (i < n) {
        var v = f64_from(1);
        if ((i % 2) == 1) { v = f64_neg(f64_from(1)); }
        store64(noise + i * 8, v);
        i = i + 1;
    }
    var c_noise = _opus_frame_complexity(noise, n, 1);
    assert(c_noise > c_tone, "noise more complex than tone");
    var sil = alloc(n * 8);
    memset(sil, 0, n * 8);
    assert_eq(_opus_frame_complexity(sil, n, 1), 0, "silence complexity 0");
    return 0;
}

# End-to-end: constrained-VBR encode produces a valid Ogg stream.
fn test_opus_vbr_encode() {
    test_group("opus: VBR encode produces Ogg");
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var samples = vec_new();
    var i = 0;
    while (i < 960 * 3) {
        vec_push(samples, f64_sin(f64_div(f64_from(i * 7), f64_from(60))));
        i = i + 1;
    }
    var out = alloc(131072);
    var nb = opus_encode_vbr(samples, 48000, 1, 64000, out);
    assert(is_err(nb) == 0, "vbr encode ok");
    assert(nb > 0, "produced bytes");
    assert_eq(load8(out), 0x4F, "OggS[0] = 'O'");
    assert_eq(load8(out + 1), 0x67, "OggS[1] = 'g'");
    return 0;
}

fn test_opus_pvq_all() {
    test_opus_range_roundtrip();
    test_pvq_v_counting();
    test_pvq_cwrs_roundtrip();
    test_pvq_search_sanity();
    test_pvq_spectral_shape_roundtrip();
    test_opus_pvq_band_roundtrip();
    test_opus_energy_roundtrip();
    test_opus_celt_frame_roundtrip();
    test_opus_magnitude_synth();
    test_opus_transient_detect();
    test_opus_transient_roundtrip();
    test_opus_stereo_ms();
    test_opus_stereo_couple();
    test_opus_stereo_frame_roundtrip();
    test_opus_stereo_encode_frame();
    test_opus_rate_cbr();
    test_opus_rate_vbr_complexity();
    test_opus_rate_cvbr_reservoir();
    test_opus_complexity();
    test_opus_vbr_encode();
    return 0;
}

var PVQ_ENERGY_RSVD_BITS = 168;   # fixed energy-header reserve (~21 bands) for K budgeting

# Encode one band's shape via PVQ into the range coder (K pulses, CWRS index).
fn _pvq_encode_band(rc, x, n, k) {
    if (k <= 0) { return 0; }              # V=1: band folded/zero, nothing to code
    var y = alloc(n * 8);
    _pvq_search(x, n, k, y);
    var idx = _pvq_index_encode(y, n, k);
    opus_range_enc_uint(rc, idx, _pvq_v(n, k));
    return 0;
}

# Decode one band's PVQ shape from the range coder (inverse of _pvq_encode_band).
# Reads the CWRS index over [0, V(n,k)) and expands it to the pulse vector y_out[n];
# returns Ryy (0 when k<=0, or err(ERR_DECODE) if the index is out of range).
fn _pvq_decode_band(rd, n, k, y_out) {
    if (k <= 0) {                          # V=1: band folded/zero, y is all zeros
        var z = 0;
        while (z < n) { store64(y_out + z * 8, 0); z = z + 1; }
        return 0;
    }
    var idx = opus_range_dec_uint(rd, _pvq_v(n, k));
    return _pvq_index_decode(idx, n, k, y_out);
}

# Encode spectral shape via PVQ (2.5.0 — replaces sign-only). Per band: split into
# sub-blocks of <= PVQ_MAX_N, choose K from a data-independent bit budget (derived
# purely from packet_bytes + band geometry so the decoder computes identical K),
# then search + CWRS-encode each sub-block.
# Core shape encode with an explicit bit budget (mono derives it from packet_bytes;
# stereo passes an explicit per-channel split — see _opus_encode_celt_frame).
fn _opus_encode_spectral_shape_bits(rc, mdct, n2, shape_bits) {
    if (shape_bits < 0) { shape_bits = 0; }
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        var start = load64(_celt_band_edges + band * 8);
        var end = load64(_celt_band_edges + (band + 1) * 8);
        if (end > n2) { end = n2; }
        var bn = end - start;
        if (bn > 0) {
            var band_bits = shape_bits * bn / n2;
            var off = start;
            while (off < end) {
                var ns = end - off;
                if (ns > PVQ_MAX_N) { ns = PVQ_MAX_N; }
                var sub_bits = band_bits * ns / bn;
                var kk = _pvq_choose_k(ns, sub_bits);
                _pvq_encode_band(rc, mdct + off * 8, ns, kk);
                off = off + ns;
            }
        }
        band = band + 1;
    }
    return 0;
}

fn _opus_encode_spectral_shape(rc, mdct, n2, packet_bytes) {
    return _opus_encode_spectral_shape_bits(rc, mdct, n2, (packet_bytes - 1) * 8 - PVQ_ENERGY_RSVD_BITS);
}

# ================================================================
# CELT decode (2.5.1) — inverse of the encode path above
# ================================================================
# The decoder mirrors the encoder symbol-for-symbol: band energies via inverse
# DPCM, then per-band/per-sub-block PVQ shapes using the SAME data-independent
# K budget so every opus_range_dec_uint reads the identical `total` the encoder
# wrote. Correctness rests on the matched range coder (invertible) plus this
# lock-step traversal.

# Decode band energies (inverse of _opus_encode_band_energies): read 21 deltas
# in [0,128), recover the closed-loop quantized log2 energies into quant_out[21].
fn _opus_decode_band_energies(rd, quant_out) {
    var prev = 0;
    var i = 0;
    while (i < _CELT_NUM_BANDS) {
        var val = opus_range_dec_uint(rd, 256);
        var diff = val - 128;
        prev = prev + diff;
        store64(quant_out + i * 8, prev);
        i = i + 1;
    }
    return 0;
}

# Decode spectral shape (inverse of _opus_encode_spectral_shape). Walks bands and
# sub-blocks in the same order with the same K budget; each sub-block is rebuilt as
# a unit-L2 shape (direction) in shape_out. Energy scaling is applied separately by
# the caller from the decoded band energies (full magnitude synthesis is a 2.5.x
# refinement — this reconstructs the CELT direction, which is what PVQ carries).
fn _opus_decode_spectral_shape_bits(rd, n2, shape_bits, shape_out) {
    var z = 0;
    while (z < n2) { store64(shape_out + z * 8, F64_ZERO); z = z + 1; }
    if (shape_bits < 0) { shape_bits = 0; }
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        var start = load64(_celt_band_edges + band * 8);
        var end = load64(_celt_band_edges + (band + 1) * 8);
        if (end > n2) { end = n2; }
        var bn = end - start;
        if (bn > 0) {
            var band_bits = shape_bits * bn / n2;
            var off = start;
            while (off < end) {
                var ns = end - off;
                if (ns > PVQ_MAX_N) { ns = PVQ_MAX_N; }
                var sub_bits = band_bits * ns / bn;
                var kk = _pvq_choose_k(ns, sub_bits);
                var y = alloc(ns * 8);
                var ryy = _pvq_decode_band(rd, ns, kk, y);
                _pvq_denormalize(y, ns, ryy, shape_out + off * 8);
                off = off + ns;
            }
        }
        band = band + 1;
    }
    return 0;
}

fn _opus_decode_spectral_shape(rd, n2, packet_bytes, shape_out) {
    return _opus_decode_spectral_shape_bits(rd, n2, (packet_bytes - 1) * 8 - PVQ_ENERGY_RSVD_BITS, shape_out);
}

# Decode a CELT frame packet (TOC byte + range-coded payload) into per-band
# quantized energies (quant_out[21]) and unit spectral shape (shape_out[n2]).
# packet_len must equal the encoder's target packet size so the K budget matches.
# Returns 0, or err() on a truncated packet / unsupported TOC config.
fn _opus_decode_celt_frame(packet, packet_len, n2, quant_out, shape_out, transient_out) {
    if (packet_len < 1) { return err(ERR_DECODE); }
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var toc = load8(packet);
    var config = (toc >> 3) & 0x1F;
    if (config != 31) { return err(ERR_UNSUPPORTED_FMT); }   # only CELT/FB 20ms mono for now
    var rd = opus_range_dec_init(packet + 1, packet_len - 1);
    store64(transient_out, opus_range_dec_bit(rd));
    _opus_decode_band_energies(rd, quant_out);
    _opus_decode_spectral_shape(rd, n2, packet_len, shape_out);
    return 0;
}

# Total PVQ shape bits for a stereo frame, split evenly between mid and side.
# Overhead = isTransient(1) + ms_flags(_CELT_NUM_BANDS) + two energy reserves.
# Computed identically on both sides so the K budget stays data-independent.
fn _opus_stereo_shape_total(packet_bytes) {
    var total = (packet_bytes - 1) * 8 - 1 - _CELT_NUM_BANDS - 2 * PVQ_ENERGY_RSVD_BITS;
    if (total < 0) { total = 0; }
    return total;
}

# Decode a stereo CELT frame (config 31, stereo bit set): isTransient + per-band
# ms_flags + mid/side band energies + mid/side spectral shapes. The caller applies
# _opus_stereo_decouple(mid,side,...) to the reconstructed coefficients for L/R.
fn _opus_decode_celt_stereo_frame(packet, packet_len, n2, mid_quant, side_quant, mid_shape, side_shape, ms_flags_out, transient_out) {
    if (packet_len < 1) { return err(ERR_DECODE); }
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var toc = load8(packet);
    var config = (toc >> 3) & 0x1F;
    if (config != 31) { return err(ERR_UNSUPPORTED_FMT); }
    var rd = opus_range_dec_init(packet + 1, packet_len - 1);
    store64(transient_out, opus_range_dec_bit(rd));
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        store64(ms_flags_out + band * 8, opus_range_dec_bit(rd));
        band = band + 1;
    }
    _opus_decode_band_energies(rd, mid_quant);
    _opus_decode_band_energies(rd, side_quant);
    var shape_total = _opus_stereo_shape_total(packet_len);
    _opus_decode_spectral_shape_bits(rd, n2, shape_total / 2, mid_shape);
    _opus_decode_spectral_shape_bits(rd, n2, shape_total / 2, side_shape);
    return 0;
}

# ================================================================
# Magnitude synthesis (2.5.9) — the missing step between CELT decode and PCM
# ================================================================
# _opus_decode_* recover per-band quantized log2 energies (quant[21]) + per-sub-block
# unit-L2 shapes (shape[n2], the CELT "direction"). This restores the MDCT magnitudes:
# it is the inverse of _opus_compute_band_energies' normalization. A band's total
# sum-of-squares is 2^(q/2)*band_size (compute_band_energies stored log2 of the mean
# power, quantized to 1/2-log2 steps); we split that energy evenly by width across the
# band's PVQ sub-blocks and scale each unit shape by its sub-block L2 gain. For a
# single-sub-block band (every band except the widest) this exactly restores
# magnitude (direction × band L2 norm) to within energy+shape quantization; the one
# wide band (100..480) splits energy by width. Sub-block traversal is identical to
# _opus_decode_spectral_shape_bits so shape offsets line up.
fn _opus_denorm_frame(quant, shape, n2, coeffs_out) {
    var z = 0;
    while (z < n2) { store64(coeffs_out + z * 8, F64_ZERO); z = z + 1; }
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        var start = load64(_celt_band_edges + band * 8);
        var end = load64(_celt_band_edges + (band + 1) * 8);
        if (end > n2) { end = n2; }
        var bn = end - start;
        if (bn > 0) {
            var q = load64(quant + band * 8);
            # mean power = 2^(q/2); total band sum-of-squares = mean_power * bn
            var mean_power = f64_pow(F64_TWO, f64_div(f64_from(q), F64_TWO));
            var e_sum = f64_mul(mean_power, f64_from(bn));
            var off = start;
            while (off < end) {
                var ns = end - off;
                if (ns > PVQ_MAX_N) { ns = PVQ_MAX_N; }
                # even energy split by width preserves the total band energy
                var sub_sum = f64_div(f64_mul(e_sum, f64_from(ns)), f64_from(bn));
                var gain = f64_sqrt(sub_sum);
                var j = 0;
                while (j < ns) {
                    var s = load64(shape + (off + j) * 8);
                    store64(coeffs_out + (off + j) * 8, f64_mul(s, gain));
                    j = j + 1;
                }
                off = off + ns;
            }
        }
        band = band + 1;
    }
    return 0;
}

# Decode one mono CELT packet to frame_size windowed time-domain samples (2.5.9).
# TOC + range payload -> quantized energies + unit shapes -> magnitude synthesis ->
# IMDCT -> synthesis sine window. The caller 50%-overlap-adds consecutive frames;
# with the analysis+synthesis sine windows (sin^2 + cos^2 = 1) that reconstructs the
# input (Princen-Bradley TDAC). Transient frames (isTransient=1) use short blocks and
# need the short-block inverse (a later bite) — this path handles the long block.
# Writes frame_size f64 to time_out; returns 0 or err() on a bad packet.
fn _opus_celt_decode_mono_time(packet, packet_len, frame_size, time_out) {
    var n2 = frame_size / 2;
    var quant = alloc(_CELT_NUM_BANDS * 8);
    var shape = alloc(n2 * 8);
    var transient = alloc(8);
    var r = _opus_decode_celt_frame(packet, packet_len, n2, quant, shape, transient);
    if (is_err(r) == 1) { return r; }
    var coeffs = alloc(n2 * 8);
    _opus_denorm_frame(quant, shape, n2, coeffs);
    _opus_imdct(coeffs, frame_size, time_out);
    var i = 0;
    while (i < frame_size) {
        var angle = f64_div(f64_mul(F64_PI, f64_add(f64_from(i), F64_HALF)), f64_from(frame_size));
        var w = f64_sin(angle);
        store64(time_out + i * 8, f64_mul(load64(time_out + i * 8), w));
        i = i + 1;
    }
    return 0;
}

# Decode one stereo CELT packet to two frame_size windowed time buffers (2.5.9).
# Mirror of the encoder stereo branch: decode mid/side energies+shapes+ms_flags,
# magnitude-synthesize mid/side MDCT coefficients, _opus_stereo_decouple to L/R,
# then IMDCT + synthesis window each channel. The caller 50%-overlap-adds per channel.
fn _opus_celt_decode_stereo_time(packet, packet_len, frame_size, left_out, right_out) {
    var n2 = frame_size / 2;
    var mq = alloc(_CELT_NUM_BANDS * 8);
    var sq = alloc(_CELT_NUM_BANDS * 8);
    var msh = alloc(n2 * 8);
    var ssh = alloc(n2 * 8);
    var flags = alloc(_CELT_NUM_BANDS * 8);
    var trans = alloc(8);
    var r = _opus_decode_celt_stereo_frame(packet, packet_len, n2, mq, sq, msh, ssh, flags, trans);
    if (is_err(r) == 1) { return r; }
    var midc = alloc(n2 * 8);
    var sidec = alloc(n2 * 8);
    _opus_denorm_frame(mq, msh, n2, midc);
    _opus_denorm_frame(sq, ssh, n2, sidec);
    var lc = alloc(n2 * 8);
    var rc = alloc(n2 * 8);
    _opus_stereo_decouple(midc, sidec, n2, flags, lc, rc);
    _opus_imdct(lc, frame_size, left_out);
    _opus_imdct(rc, frame_size, right_out);
    var i = 0;
    while (i < frame_size) {
        var angle = f64_div(f64_mul(F64_PI, f64_add(f64_from(i), F64_HALF)), f64_from(frame_size));
        var w = f64_sin(angle);
        store64(left_out + i * 8, f64_mul(load64(left_out + i * 8), w));
        store64(right_out + i * 8, f64_mul(load64(right_out + i * 8), w));
        i = i + 1;
    }
    return 0;
}

# ================================================================
# Transient detection + short-block MDCT (CELT, 2.5.4)
# ================================================================
# A frame with a sudden onset ("transient") is better represented by several
# short MDCTs than one long one — short blocks localize energy in time and cut
# pre-echo. We detect transients from time-domain sub-block energy, and when one
# is present replace the long MDCT with CELT_SHORT_BLOCKS short MDCTs whose
# coefficients are interleaved into the same n2-coefficient buffer (block b,
# frequency f -> index f*M + b), so the band-energy + PVQ-shape path is unchanged.
# The `isTransient` flag is coded as one range-coder bit at the head of the frame.

var CELT_SHORT_BLOCKS = 8;      # short MDCTs per 20ms frame when transient
var TRANSIENT_RATIO = 8;        # sub-block energy > 8x the preceding average => transient

# Detect a transient: 1 if some sub-block's energy sharply exceeds the running
# average of the preceding sub-blocks (or rises out of near-silence), else 0.
fn _opus_detect_transient(samples, frame_size) {
    var nsub = 8;
    var sub = frame_size / nsub;
    if (sub < 1) { return 0; }
    var tiny = f64_div(F64_ONE, f64_mul(f64_from(100000000), f64_from(100000000)));
    var en = alloc(nsub * 8);
    var b = 0;
    while (b < nsub) {
        var e = F64_ZERO;
        var i = 0;
        while (i < sub) {
            var s = load64(samples + (b * sub + i) * 8);
            e = f64_add(e, f64_mul(s, s));
            i = i + 1;
        }
        store64(en + b * 8, e);
        b = b + 1;
    }
    # Compare adjacent sub-block energies in BOTH directions: a rise (onset) or a
    # drop (decay/offset) sharper than TRANSIENT_RATIO flags a transient. Testing
    # pair (0,1) makes sub-block 0 a candidate, so a click confined to the first
    # sub-block — or an energy decay — is caught, not just mid-frame onsets.
    var transient = 0;
    b = 1;
    while (b < nsub) {
        var prev = load64(en + (b - 1) * 8);
        var cur = load64(en + b * 8);
        var lo = prev;
        var hi = cur;
        if (f64_gt(prev, cur) == 1) { lo = cur; hi = prev; }
        if (f64_gt(lo, tiny) == 1) {
            if (f64_gt(hi, f64_mul(lo, f64_from(TRANSIENT_RATIO))) == 1) { transient = 1; }
        } else {
            if (f64_gt(hi, tiny) == 1) { transient = 1; }
        }
        b = b + 1;
    }
    return transient;
}

# Short-block MDCT: num_blocks windowed MDCTs over the frame, coefficients
# interleaved as out[f*num_blocks + b] = block_b[f]. Fills n2 = frame_size/2 slots.
fn _opus_short_mdct(mono, frame_size, num_blocks, out) {
    var bsize = frame_size / num_blocks;
    var bcoefs = bsize / 2;
    var wblock = alloc(bsize * 8);
    var bout = alloc(bcoefs * 8);
    var b = 0;
    while (b < num_blocks) {
        var i = 0;
        while (i < bsize) {
            var s = load64(mono + (b * bsize + i) * 8);
            var angle = f64_div(f64_mul(F64_PI, f64_add(f64_from(i), F64_HALF)), f64_from(bsize));
            store64(wblock + i * 8, f64_mul(s, f64_sin(angle)));
            i = i + 1;
        }
        memset(bout, 0, bcoefs * 8);
        fft_mdct(wblock, bsize, bout);
        var f = 0;
        while (f < bcoefs) {
            store64(out + (f * num_blocks + b) * 8, load64(bout + f * 8));
            f = f + 1;
        }
        b = b + 1;
    }
    return 0;
}

# ================================================================
# Stereo coupling (CELT, 2.5.5)
# ================================================================
# Instead of downmixing stereo to mono, code a per-band choice between mid/side
# (M=(L+R)/√2, S=(L-R)/√2 — energy-preserving) and dual L/R. M/S concentrates
# energy when the channels correlate (side ≈ 0), so it is chosen per band when it
# makes the smaller channel smaller than either of L/R. The transform is exactly
# invertible, so couple∘decouple is the identity regardless of the per-band choice.

# Whole-buffer M/S forward: mid=(L+R)/√2, side=(L-R)/√2.
fn _opus_stereo_ms_forward(left, right, mid, side, n) {
    var inv_sqrt2 = f64_div(F64_ONE, f64_sqrt(F64_TWO));
    var i = 0;
    while (i < n) {
        var l = load64(left + i * 8);
        var r = load64(right + i * 8);
        store64(mid + i * 8, f64_mul(f64_add(l, r), inv_sqrt2));
        store64(side + i * 8, f64_mul(f64_sub(l, r), inv_sqrt2));
        i = i + 1;
    }
    return 0;
}

# Whole-buffer M/S inverse: L=(M+S)/√2, R=(M-S)/√2 (exact inverse of the forward).
fn _opus_stereo_ms_inverse(mid, side, left, right, n) {
    var inv_sqrt2 = f64_div(F64_ONE, f64_sqrt(F64_TWO));
    var i = 0;
    while (i < n) {
        var m = load64(mid + i * 8);
        var s = load64(side + i * 8);
        store64(left + i * 8, f64_mul(f64_add(m, s), inv_sqrt2));
        store64(right + i * 8, f64_mul(f64_sub(m, s), inv_sqrt2));
        i = i + 1;
    }
    return 0;
}

# Per-band coupling: for each CELT band choose M/S (flag 1) when min(E_M,E_S) <
# min(E_L,E_R) — i.e. M/S concentrates energy — else dual L/R (flag 0). Writes the
# coupled channels into mid_out/side_out and the decision into ms_flags[band].
fn _opus_stereo_couple(lmdct, rmdct, n2, mid_out, side_out, ms_flags) {
    var inv_sqrt2 = f64_div(F64_ONE, f64_sqrt(F64_TWO));
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        var start = load64(_celt_band_edges + band * 8);
        var end = load64(_celt_band_edges + (band + 1) * 8);
        if (end > n2) { end = n2; }
        var el = F64_ZERO;
        var er = F64_ZERO;
        var em = F64_ZERO;
        var es = F64_ZERO;
        var i = start;
        while (i < end) {
            var l = load64(lmdct + i * 8);
            var r = load64(rmdct + i * 8);
            var m = f64_mul(f64_add(l, r), inv_sqrt2);
            var s = f64_mul(f64_sub(l, r), inv_sqrt2);
            el = f64_add(el, f64_mul(l, l));
            er = f64_add(er, f64_mul(r, r));
            em = f64_add(em, f64_mul(m, m));
            es = f64_add(es, f64_mul(s, s));
            i = i + 1;
        }
        var min_ms = em;
        if (f64_gt(em, es) == 1) { min_ms = es; }
        var min_lr = el;
        if (f64_gt(el, er) == 1) { min_lr = er; }
        var use_ms = 0;
        if (f64_gt(min_lr, min_ms) == 1) { use_ms = 1; }
        store64(ms_flags + band * 8, use_ms);
        i = start;
        while (i < end) {
            var l2 = load64(lmdct + i * 8);
            var r2 = load64(rmdct + i * 8);
            if (use_ms == 1) {
                store64(mid_out + i * 8, f64_mul(f64_add(l2, r2), inv_sqrt2));
                store64(side_out + i * 8, f64_mul(f64_sub(l2, r2), inv_sqrt2));
            } else {
                store64(mid_out + i * 8, l2);
                store64(side_out + i * 8, r2);
            }
            i = i + 1;
        }
        band = band + 1;
    }
    return 0;
}

# Inverse of _opus_stereo_couple: reconstruct L/R using the per-band ms_flags.
fn _opus_stereo_decouple(mid, side, n2, ms_flags, lout, rout) {
    var inv_sqrt2 = f64_div(F64_ONE, f64_sqrt(F64_TWO));
    var band = 0;
    while (band < _CELT_NUM_BANDS) {
        var start = load64(_celt_band_edges + band * 8);
        var end = load64(_celt_band_edges + (band + 1) * 8);
        if (end > n2) { end = n2; }
        var use_ms = load64(ms_flags + band * 8);
        var i = start;
        while (i < end) {
            var a = load64(mid + i * 8);
            var b = load64(side + i * 8);
            if (use_ms == 1) {
                store64(lout + i * 8, f64_mul(f64_add(a, b), inv_sqrt2));
                store64(rout + i * 8, f64_mul(f64_sub(a, b), inv_sqrt2));
            } else {
                store64(lout + i * 8, a);
                store64(rout + i * 8, b);
            }
            i = i + 1;
        }
        band = band + 1;
    }
    return 0;
}

# ================================================================
# CELT frame size
# ================================================================

var OPUS_FRAME_SIZE = 960;        # 20ms at 48 kHz
var OPUS_ENCODER_PRE_SKIP = 312;  # 3.75ms at 48 kHz (RFC 7845)

# ================================================================
# Encode a single CELT frame
# ================================================================
# samples: pointer to frame_size f64 values (mono downmix)
# target_bytes: target packet size
# Returns Str (data, len).

fn _opus_encode_celt_frame(samples, frame_size, channels, target_bytes) {
    var ch = channels;
    var n2 = frame_size / 2;
    var rc = opus_range_enc_init();
    var toc = 31 << 3;   # config 31 (CELT/FB 20ms), mono

    if (ch == 2) {
        # --- Stereo: per-band mid/side coupling, two coupled channels ---
        toc = (31 << 3) | (1 << 2);   # stereo bit set
        var left = alloc(frame_size * 8);
        var right = alloc(frame_size * 8);
        var i = 0;
        while (i < frame_size) {
            store64(left + i * 8, load64(samples + (i * 2) * 8));
            store64(right + i * 8, load64(samples + (i * 2 + 1) * 8));
            i = i + 1;
        }
        # Long MDCT per channel (stereo transient handling deferred -> isTransient=0).
        _opus_sine_window(left, frame_size);
        _opus_sine_window(right, frame_size);
        var lmdct = alloc(n2 * 8);
        memset(lmdct, 0, n2 * 8);
        _opus_mdct(left, frame_size, lmdct);
        var rmdct = alloc(n2 * 8);
        memset(rmdct, 0, n2 * 8);
        _opus_mdct(right, frame_size, rmdct);
        # Per-band coupling -> mid/side coefficients + ms_flags.
        var mid = alloc(n2 * 8);
        var side = alloc(n2 * 8);
        var ms_flags = alloc(_CELT_NUM_BANDS * 8);
        _opus_stereo_couple(lmdct, rmdct, n2, mid, side, ms_flags);
        # Quantize both channels' band energies.
        var men = alloc(_CELT_NUM_BANDS * 8);
        _opus_compute_band_energies(mid, n2, men);
        var mq = alloc(_CELT_NUM_BANDS * 8);
        _opus_quantize_energies(men, mq);
        var sen = alloc(_CELT_NUM_BANDS * 8);
        _opus_compute_band_energies(side, n2, sen);
        var sq = alloc(_CELT_NUM_BANDS * 8);
        _opus_quantize_energies(sen, sq);
        # Code: isTransient(0) + ms_flags + mid/side energies + mid/side shapes.
        opus_range_enc_bit(rc, 0);
        var band = 0;
        while (band < _CELT_NUM_BANDS) {
            opus_range_enc_bit(rc, load64(ms_flags + band * 8));
            band = band + 1;
        }
        _opus_encode_band_energies(rc, mq);
        _opus_encode_band_energies(rc, sq);
        var shape_total = _opus_stereo_shape_total(target_bytes);
        _opus_encode_spectral_shape_bits(rc, mid, n2, shape_total / 2);
        _opus_encode_spectral_shape_bits(rc, side, n2, shape_total / 2);
    } else {
        # --- Mono: downmix, transient-capable MDCT, single channel ---
        var mono = alloc(frame_size * 8);
        var i = 0;
        while (i < frame_size) {
            var sum = F64_ZERO;
            var c = 0;
            while (c < ch) {
                sum = f64_add(sum, load64(samples + (i * ch + c) * 8));
                c = c + 1;
            }
            store64(mono + i * 8, f64_div(sum, f64_from(ch)));
            i = i + 1;
        }
        var is_transient = _opus_detect_transient(mono, frame_size);
        var mdct = alloc(n2 * 8);
        memset(mdct, 0, n2 * 8);
        # Transient short-block coding is detected + flagged, but proper overlapping
        # short-window CELT blocks (pre-echo reduction) need a dedicated overlap-add
        # inverse and are deferred (2.5.x refinement). Encode every frame with the
        # invertible long MDCT so transient frames still DECODE to correct audio; the
        # isTransient bit rides along for bitstream continuity. (The old non-overlapping
        # _opus_short_mdct path was not reconstructible.)
        _opus_sine_window(mono, frame_size);
        _opus_mdct(mono, frame_size, mdct);
        var energies = alloc(_CELT_NUM_BANDS * 8);
        _opus_compute_band_energies(mdct, n2, energies);
        var quant = alloc(_CELT_NUM_BANDS * 8);
        _opus_quantize_energies(energies, quant);
        opus_range_enc_bit(rc, is_transient);
        _opus_encode_band_energies(rc, quant);
        _opus_encode_spectral_shape(rc, mdct, n2, target_bytes);
    }

    # Finalize range coder
    var coded = opus_range_enc_flush(rc);

    # Build packet: TOC byte + coded data
    var coded_len = str_len(coded);
    var total_len = 1 + coded_len;
    var packet = alloc(total_len);
    store8(packet, toc);

    # Copy coded data
    memcpy(packet + 1, str_data(coded), coded_len);

    # Pad up to the target size when the coded payload is smaller (so the decoder's
    # packet-length-derived K budget matches the encoder's). On the rare overflow
    # (coded payload > target, possible for high-entropy input whose CWRS indices
    # exceed the estimate) DO NOT truncate: truncating cut the range coder's trailing
    # bytes and corrupted the whole packet (energies included). Each frame has an
    # independent range coder and Ogg carries the true length, so emitting the full
    # packet keeps that frame self-contained — band energies (coded first) still decode
    # exactly; only the overflow frame's shape budget differs. (A budget that never
    # overflows is a bespoke-coder refinement; RFC-6716 conformance replaces it.)
    if (total_len < target_bytes) {
        var padded = alloc(target_bytes);
        memcpy(padded, packet, total_len);
        memset(padded + total_len, 0, target_bytes - total_len);
        return str_new(padded, target_bytes);
    }
    return str_new(packet, total_len);
}

# ================================================================
# Rate control + VBR (2.5.8)
# ================================================================
# A bit-reservoir rate controller decides each frame's byte target. CBR emits the
# nominal size every frame. Constrained VBR (CVBR) lets a complex frame spend saved
# bits from the reservoir but never exceeds the target bitrate on average (reservoir
# stays >= 0, so total <= frames*nominal). Unconstrained VBR sizes each frame purely
# by complexity. Per-frame complexity is a cheap high-frequency-energy proxy
# (first-difference energy / total energy): tones are simple, noise/transients complex.

var RATE_CBR = 0;
var RATE_CVBR = 1;
var RATE_VBR = 2;

var RATE_ST_NOMINAL = 0;
var RATE_ST_MODE = 8;
var RATE_ST_RESERVOIR = 16;
var RATE_ST_RMAX = 24;
var RATE_ST_SIZE = 32;

fn _opus_rate_new(bitrate, mode) {
    var st = alloc(RATE_ST_SIZE);
    var nominal = bitrate / 8 / 50;   # bytes per 20ms frame
    if (nominal < 10) { nominal = 10; }
    store64(st + RATE_ST_NOMINAL, nominal);
    store64(st + RATE_ST_MODE, mode);
    store64(st + RATE_ST_RESERVOIR, 0);
    store64(st + RATE_ST_RMAX, nominal * 6);   # reservoir cap ~6 frames
    return st;
}

# Per-frame byte target for `complexity` in [0,100]; updates the reservoir.
fn _opus_rate_target(st, complexity) {
    var nominal = load64(st + RATE_ST_NOMINAL);
    var mode = load64(st + RATE_ST_MODE);
    if (mode == RATE_CBR) { return nominal; }
    # desired = nominal * (0.6 .. 1.4) as complexity goes 0..100
    var factor = 60 + (complexity * 4) / 5;    # 60..140 (percent)
    var desired = nominal * factor / 100;
    if (desired < 10) { desired = 10; }
    var reservoir = load64(st + RATE_ST_RESERVOIR);
    var rmax = load64(st + RATE_ST_RMAX);
    var target = desired;
    if (mode == RATE_CVBR) {
        var avail = nominal + reservoir;       # can't spend beyond nominal + saved
        if (target > avail) { target = avail; }
        var floor = nominal / 2;
        if (target < floor) { target = floor; }
    }
    if (target < 10) { target = 10; }
    reservoir = reservoir + nominal - target;  # save when under nominal, spend when over
    if (reservoir > rmax) { reservoir = rmax; }
    if (mode == RATE_CVBR) {
        if (reservoir < 0) { reservoir = 0; }              # no debt: keeps average <= target
    } else {
        if (reservoir < 0 - rmax) { reservoir = 0 - rmax; }
    }
    store64(st + RATE_ST_RESERVOIR, reservoir);
    return target;
}

# Per-frame complexity in [0,100] from the REAL MDCT spectrum (2.5.9, completes the
# 2.5.8 deferral — was a time-domain first-difference proxy): downmix to mono, window,
# MDCT, and take the fraction of spectral energy in the upper half of the band. Tones
# concentrate energy low (simple); noise and transients spread it high (complex — a
# transient's broadband energy naturally raises this, making allocation transient-aware).
fn _opus_frame_complexity(samples, n, ch) {
    var tiny = f64_div(F64_ONE, f64_mul(f64_from(100000000), f64_from(100000000)));
    var mono = alloc(n * 8);
    var i = 0;
    while (i < n) {
        var s = F64_ZERO;
        var c = 0;
        while (c < ch) { s = f64_add(s, load64(samples + (i * ch + c) * 8)); c = c + 1; }
        store64(mono + i * 8, f64_div(s, f64_from(ch)));
        i = i + 1;
    }
    _opus_sine_window(mono, n);
    var n2 = n / 2;
    var spec = alloc(n2 * 8);
    _opus_mdct(mono, n, spec);
    var total = F64_ZERO;
    var hi = F64_ZERO;
    var half = n2 / 2;
    i = 0;
    while (i < n2) {
        var cf = load64(spec + i * 8);
        var e = f64_mul(cf, cf);
        total = f64_add(total, e);
        if (i >= half) { hi = f64_add(hi, e); }
        i = i + 1;
    }
    if (f64_gt(total, tiny) == 0) { return 0; }
    var c2 = f64_to(f64_mul(f64_div(hi, total), f64_from(100)));
    if (c2 > 100) { c2 = 100; }
    if (c2 < 0) { c2 = 0; }
    return c2;
}

# ================================================================
# Opus encoder (Ogg container output)
# ================================================================
#
# opus_encode(samples_vec, sample_rate, channels, bitrate, out_buf)  -- CBR
# opus_encode_vbr(...)                                               -- constrained VBR
#   samples_vec: vec of f64 bit patterns (interleaved)
#   sample_rate: must be 48000; channels: 1 or 2; bitrate: 32000..256000
#   out_buf: pointer to output buffer (must be large enough)
# Returns bytes written, or err().

fn _opus_encode_impl(samples_vec, sample_rate, channels, bitrate, mode, out_buf) {
    # Validate parameters
    if (sample_rate != 48000) { return err(ERR_INVALID_RATE); }
    if (channels < 1) { return err(ERR_INVALID_CHANNELS); }
    if (channels > 2) { return err(ERR_INVALID_CHANNELS); }
    if (bitrate < 32000) { return err(ERR_ENCODE); }
    if (bitrate > 256000) { return err(ERR_ENCODE); }

    # Initialize band edges if needed
    if (_celt_band_edges == 0) { _opus_init_bands(); }

    var ch = channels;
    var total_samples = vec_len(samples_vec);
    var frame_interleaved = OPUS_FRAME_SIZE * ch;

    # Bytes per CELT frame: bitrate / 8 / 50 (20ms = 50 frames/sec)
    var bytes_per_frame = bitrate / 8 / 50;
    if (bytes_per_frame < 10) { bytes_per_frame = 10; }

    # Rate controller: CBR emits nominal every frame; VBR modes vary by complexity.
    var rate_st = _opus_rate_new(bitrate, mode);

    # Generate header packets
    var head_buf = alloc(19);
    opus_serialize_head(channels, OPUS_ENCODER_PRE_SKIP, sample_rate, head_buf);
    var head_str = str_new(head_buf, 19);

    var tags_buf = alloc(23);
    opus_serialize_tags(tags_buf);
    var tags_str = str_new(tags_buf, 23);

    # Encode audio frames
    var audio_packets = vec_new();
    var granule_positions = vec_new();
    var sample_pos = 0;
    var granule = OPUS_ENCODER_PRE_SKIP;
    # 50%-overlap MDCT framing: each frame windows OPUS_FRAME_SIZE samples, but the
    # read position advances by only half a frame, so consecutive analysis windows
    # overlap 50%. With the decoder's matching synthesis sine window this gives
    # Princen-Bradley TDAC — perfect reconstruction (sin^2 + cos^2 = 1). Each packet
    # therefore carries one hop (half a frame) of new output samples.
    var hop_interleaved = (OPUS_FRAME_SIZE / 2) * ch;

    while (sample_pos < total_samples) {
        # Build a full analysis window (OPUS_FRAME_SIZE*ch), zero-padded past the end.
        var frame_buf = alloc(frame_interleaved * 8);
        memset(frame_buf, 0, frame_interleaved * 8);
        var avail = total_samples - sample_pos;
        var count = frame_interleaved;
        if (count > avail) { count = avail; }
        var fi = 0;
        while (fi < count) {
            store64(frame_buf + fi * 8, vec_get(samples_vec, sample_pos + fi));
            fi = fi + 1;
        }

        var complexity = _opus_frame_complexity(frame_buf, OPUS_FRAME_SIZE, ch);
        var target = _opus_rate_target(rate_st, complexity);
        var pkt = _opus_encode_celt_frame(frame_buf, OPUS_FRAME_SIZE, channels, target);
        vec_push(audio_packets, pkt);

        granule = granule + OPUS_FRAME_SIZE / 2;
        vec_push(granule_positions, granule);

        sample_pos = sample_pos + hop_interleaved;
    }

    # Handle empty input: encode one frame of silence
    if (vec_len(audio_packets) == 0) {
        var silence = alloc(frame_interleaved * 8);
        memset(silence, 0, frame_interleaved * 8);
        var pkt = _opus_encode_celt_frame(silence, OPUS_FRAME_SIZE, channels, _opus_rate_target(rate_st, 0));
        vec_push(audio_packets, pkt);
        vec_push(granule_positions, granule);
    }

    # Serial number: "Shra" = 0x53687261
    var serial = 0x53687261;

    # Assemble Ogg bitstream into out_buf
    var write_pos = 0;

    # Page 0: BOS + OpusHead
    var page0 = ogg_build_page(OGG_FLAG_BOS, 0, serial, 0, head_buf, 19);
    memcpy(out_buf + write_pos, str_data(page0), str_len(page0));
    write_pos = write_pos + str_len(page0);

    # Page 1: OpusTags
    var page1 = ogg_build_page(0, 0, serial, 1, tags_buf, 23);
    memcpy(out_buf + write_pos, str_data(page1), str_len(page1));
    write_pos = write_pos + str_len(page1);

    # Audio pages (2+)
    var num_audio = vec_len(audio_packets);
    var ai = 0;
    while (ai < num_audio) {
        var pkt = vec_get(audio_packets, ai);
        var gran = vec_get(granule_positions, ai);
        var flags = 0;
        if (ai == num_audio - 1) {
            flags = OGG_FLAG_EOS;
        }
        var page = ogg_build_page(flags, gran, serial, ai + 2, str_data(pkt), str_len(pkt));
        memcpy(out_buf + write_pos, str_data(page), str_len(page));
        write_pos = write_pos + str_len(page);

        ai = ai + 1;
    }

    return write_pos;
}

# CBR: fixed-size packets (nominal bytes every frame). Unchanged public behavior.
fn opus_encode(samples_vec, sample_rate, channels, bitrate, out_buf) {
    return _opus_encode_impl(samples_vec, sample_rate, channels, bitrate, RATE_CBR, out_buf);
}

# Constrained VBR: packet size follows per-frame complexity via the bit reservoir,
# without exceeding the target bitrate on average.
fn opus_encode_vbr(samples_vec, sample_rate, channels, bitrate, out_buf) {
    return _opus_encode_impl(samples_vec, sample_rate, channels, bitrate, RATE_CVBR, out_buf);
}

# ================================================================
# Opus encoder framework (2.4.4 — opening work)
# Config/state + mode/bandwidth selection + TOC byte + frame dispatch.
# Wraps the existing CELT encoder; SILK/HYBRID are documented 2.5.x seams.
# Additive: the existing opus_encode() Ogg path is unchanged.
# CLEANUP (2.5.x): _opus_encode_celt_frame hardcodes TOC config 30 (= CELT/FB
# 10ms) but its frames are 20ms (= config 31, what opus_toc_byte computes here).
# Left as-is to keep this release purely additive; swap to opus_toc_byte(...)
# with a decode round-trip test in the PVQ/CELT work.
# ================================================================

# Internal mode (RFC 6716 §2). shravan-internal values, not the TOC config.
enum OpusMode      { OPUS_MODE_SILK = 0; OPUS_MODE_HYBRID = 1; OPUS_MODE_CELT = 2; }
# Audio bandwidth, ordered NB<MB<WB<SWB<FB so numeric clamping works.
enum OpusBandwidth { OPUS_BW_NB = 0; OPUS_BW_MB = 1; OPUS_BW_WB = 2; OPUS_BW_SWB = 3; OPUS_BW_FB = 4; }
enum OpusSignal    { OPUS_SIGNAL_AUTO = 0; OPUS_SIGNAL_VOICE = 1; OPUS_SIGNAL_MUSIC = 2; }
enum OpusApp       { OPUS_APP_VOIP = 2048; OPUS_APP_AUDIO = 2049; OPUS_APP_LOWDELAY = 2051; }

# OpusEncoder state struct (heap; store64/load64 at fixed offsets).
var OPUS_ENC_SIZE            = 72;
var OPUS_ENC_OFF_MODE        = 0;
var OPUS_ENC_OFF_BANDWIDTH   = 8;
var OPUS_ENC_OFF_FRAME_SIZE  = 16;
var OPUS_ENC_OFF_BITRATE     = 24;
var OPUS_ENC_OFF_VBR         = 32;
var OPUS_ENC_OFF_CHANNELS    = 40;
var OPUS_ENC_OFF_SAMPLE_RATE = 48;
var OPUS_ENC_OFF_SIGNAL      = 56;
var OPUS_ENC_OFF_APP         = 64;

fn opus_encoder_mode(e)        { return load64(e + OPUS_ENC_OFF_MODE); }
fn opus_encoder_bandwidth(e)   { return load64(e + OPUS_ENC_OFF_BANDWIDTH); }
fn opus_encoder_frame_size(e)  { return load64(e + OPUS_ENC_OFF_FRAME_SIZE); }
fn opus_encoder_bitrate(e)     { return load64(e + OPUS_ENC_OFF_BITRATE); }
fn opus_encoder_vbr(e)         { return load64(e + OPUS_ENC_OFF_VBR); }
fn opus_encoder_channels(e)    { return load64(e + OPUS_ENC_OFF_CHANNELS); }
fn opus_encoder_sample_rate(e) { return load64(e + OPUS_ENC_OFF_SAMPLE_RATE); }
fn opus_encoder_signal(e)      { return load64(e + OPUS_ENC_OFF_SIGNAL); }
fn opus_encoder_app(e)         { return load64(e + OPUS_ENC_OFF_APP); }

# Widest bandwidth a sample rate can carry (RFC 6716 Table 1).
fn opus_bandwidth_cap(sample_rate) {
    if (sample_rate <= 8000)  { return OPUS_BW_NB; }
    if (sample_rate <= 12000) { return OPUS_BW_MB; }
    if (sample_rate <= 16000) { return OPUS_BW_WB; }
    if (sample_rate <= 24000) { return OPUS_BW_SWB; }
    return OPUS_BW_FB;
}

# Bitrate -> bandwidth (simplified monotone thresholds; 2.5.x adds hysteresis +
# signal awareness), clamped by what the sample rate can carry.
fn opus_select_bandwidth(bitrate, sample_rate) {
    if (bitrate <= 0) { return err(ERR_ENCODE); }
    var bw = OPUS_BW_FB;
    if (bitrate < 20000) { bw = OPUS_BW_SWB; }
    if (bitrate < 14000) { bw = OPUS_BW_WB; }
    if (bitrate < 11000) { bw = OPUS_BW_MB; }
    if (bitrate < 8000)  { bw = OPUS_BW_NB; }
    var cap = opus_bandwidth_cap(sample_rate);
    if (bw > cap) { bw = cap; }
    return bw;
}

# Bitrate + signal -> internal mode. Low-rate voice -> SILK; mid-rate voice on a
# SWB/FB-capable rate -> HYBRID; music or high rate -> CELT.
fn opus_select_mode(bitrate, sample_rate, signal_type) {
    if (bitrate <= 0) { return err(ERR_ENCODE); }
    if (signal_type == OPUS_SIGNAL_MUSIC) { return OPUS_MODE_CELT; }
    if (bitrate < 16000) { return OPUS_MODE_SILK; }
    if (bitrate < 24000) {
        if (sample_rate >= 24000) { return OPUS_MODE_HYBRID; }
        return OPUS_MODE_SILK;
    }
    return OPUS_MODE_CELT;
}

fn opus_encoder_new(sample_rate, channels, application) {
    if (sample_rate != 48000) { return err(ERR_INVALID_RATE); }   # scaffold: 48k only (matches opus_encode)
    if (channels < 1)         { return err(ERR_INVALID_CHANNELS); }
    if (channels > 2)         { return err(ERR_INVALID_CHANNELS); }

    var e = alloc(OPUS_ENC_SIZE);
    memset(e, 0, OPUS_ENC_SIZE);

    var br = 64000;
    if (channels == 2) { br = 96000; }

    var sig = OPUS_SIGNAL_AUTO;
    if (application == OPUS_APP_VOIP)  { sig = OPUS_SIGNAL_VOICE; }
    if (application == OPUS_APP_AUDIO) { sig = OPUS_SIGNAL_MUSIC; }

    store64(e + OPUS_ENC_OFF_SAMPLE_RATE, sample_rate);
    store64(e + OPUS_ENC_OFF_CHANNELS,    channels);
    store64(e + OPUS_ENC_OFF_APP,         application);
    store64(e + OPUS_ENC_OFF_SIGNAL,      sig);
    store64(e + OPUS_ENC_OFF_BITRATE,     br);
    store64(e + OPUS_ENC_OFF_VBR,         1);
    store64(e + OPUS_ENC_OFF_FRAME_SIZE,  OPUS_FRAME_SIZE);   # 960 = 20ms default
    store64(e + OPUS_ENC_OFF_MODE,        opus_select_mode(br, sample_rate, sig));
    store64(e + OPUS_ENC_OFF_BANDWIDTH,   opus_select_bandwidth(br, sample_rate));
    return e;
}

fn opus_encoder_set_bitrate(e, bitrate) {
    if (bitrate < 6000)   { return err(ERR_ENCODE); }
    if (bitrate > 510000) { return err(ERR_ENCODE); }
    store64(e + OPUS_ENC_OFF_BITRATE, bitrate);
    var sr  = load64(e + OPUS_ENC_OFF_SAMPLE_RATE);
    var sig = load64(e + OPUS_ENC_OFF_SIGNAL);
    store64(e + OPUS_ENC_OFF_MODE,      opus_select_mode(bitrate, sr, sig));
    store64(e + OPUS_ENC_OFF_BANDWIDTH, opus_select_bandwidth(bitrate, sr));
    return 0;
}

fn opus_encoder_set_vbr(e, on) {
    var v = 0; if (on != 0) { v = 1; }
    store64(e + OPUS_ENC_OFF_VBR, v);
    return 0;
}

fn opus_encoder_set_bandwidth(e, bw) {          # manual override of auto-selection
    if (bw < OPUS_BW_NB) { return err(ERR_ENCODE); }
    if (bw > OPUS_BW_FB) { return err(ERR_ENCODE); }
    store64(e + OPUS_ENC_OFF_BANDWIDTH, bw);
    return 0;
}

fn opus_encoder_set_mode(e, mode) {             # force a mode (CELT = guaranteed output today)
    if (mode < OPUS_MODE_SILK) { return err(ERR_ENCODE); }
    if (mode > OPUS_MODE_CELT) { return err(ERR_ENCODE); }
    store64(e + OPUS_ENC_OFF_MODE, mode);
    return 0;
}

# TOC config index 0..31 (RFC 6716 §3.1 Table 2); err(ERR_ENCODE) for invalid
# (mode, bandwidth, frame_size) combinations.
fn opus_toc_config(mode, bandwidth, frame_size) {
    if (mode == OPUS_MODE_CELT) {                 # CELT: 2.5/5/10/20ms -> idx 0..3
        var fi = 0 - 1;
        if (frame_size == 120) { fi = 0; }
        if (frame_size == 240) { fi = 1; }
        if (frame_size == 480) { fi = 2; }
        if (frame_size == 960) { fi = 3; }
        if (fi < 0) { return err(ERR_ENCODE); }
        if (bandwidth == OPUS_BW_NB)  { return 16 + fi; }
        if (bandwidth == OPUS_BW_WB)  { return 20 + fi; }
        if (bandwidth == OPUS_BW_SWB) { return 24 + fi; }
        if (bandwidth == OPUS_BW_FB)  { return 28 + fi; }
        return err(ERR_ENCODE);                   # CELT has no MB
    }
    if (mode == OPUS_MODE_SILK) {                 # SILK: 10/20/40/60ms -> idx 0..3
        var fs = 0 - 1;
        if (frame_size == 480)  { fs = 0; }
        if (frame_size == 960)  { fs = 1; }
        if (frame_size == 1920) { fs = 2; }
        if (frame_size == 2880) { fs = 3; }
        if (fs < 0) { return err(ERR_ENCODE); }
        if (bandwidth == OPUS_BW_NB) { return 0 + fs; }
        if (bandwidth == OPUS_BW_MB) { return 4 + fs; }
        if (bandwidth == OPUS_BW_WB) { return 8 + fs; }
        return err(ERR_ENCODE);                   # SILK max is WB
    }
    if (mode == OPUS_MODE_HYBRID) {               # HYBRID: 10/20ms -> idx 0..1
        var fh = 0 - 1;
        if (frame_size == 480) { fh = 0; }
        if (frame_size == 960) { fh = 1; }
        if (fh < 0) { return err(ERR_ENCODE); }
        if (bandwidth == OPUS_BW_SWB) { return 12 + fh; }
        if (bandwidth == OPUS_BW_FB)  { return 14 + fh; }
        return err(ERR_ENCODE);
    }
    return err(ERR_ENCODE);
}

# Full 1-byte Opus TOC: (config << 3) | (stereo << 2) | code. Scaffold emits
# code = 0 (one frame per packet).
fn opus_toc_byte(mode, bandwidth, frame_size, stereo) {
    var config = opus_toc_config(mode, bandwidth, frame_size);
    if (is_err(config) == 1) { return config; }
    var s = 0; if (stereo != 0) { s = 1; }
    return (config << 3) | (s << 2);
}

# Encode ONE frame into a bare packet in out_buf; returns bytes written.
# CELT delegates to the existing _opus_encode_celt_frame; SILK/HYBRID are 2.5.x.
fn opus_encode_frame(e, samples, frame_size, out_buf) {
    var mode = load64(e + OPUS_ENC_OFF_MODE);
    if (mode == OPUS_MODE_SILK)   { return err(ERR_UNSUPPORTED_FMT); }   # 2.5.7
    if (mode == OPUS_MODE_HYBRID) { return err(ERR_UNSUPPORTED_FMT); }   # 2.5.8
    if (_celt_band_edges == 0) { _opus_init_bands(); }
    var ch = load64(e + OPUS_ENC_OFF_CHANNELS);
    var sr = load64(e + OPUS_ENC_OFF_SAMPLE_RATE);
    var br = load64(e + OPUS_ENC_OFF_BITRATE);
    var target = (br / 8) * frame_size / sr;      # matches opus_encode's bytes_per_frame at 960/48k
    if (target < 10) { target = 10; }
    var pkt = _opus_encode_celt_frame(samples, frame_size, ch, target);
    var n = str_len(pkt);
    memcpy(out_buf, str_data(pkt), n);
    return n;
}

# --- 2.4.4 framework tests (wired into test_opus_all) ---

fn test_opus_encoder_config() {
    syscall(1, 1, "test: opus encoder config\n", 26);
    var e = opus_encoder_new(48000, 1, OPUS_APP_AUDIO);
    assert(is_err(e) == 0, "encoder_new ok");
    assert_eq(opus_encoder_sample_rate(e), 48000, "cfg sample_rate");
    assert_eq(opus_encoder_channels(e), 1, "cfg channels");
    assert_eq(opus_encoder_app(e), OPUS_APP_AUDIO, "cfg app");
    assert_eq(opus_encoder_signal(e), OPUS_SIGNAL_MUSIC, "cfg signal music");
    assert_eq(opus_encoder_vbr(e), 1, "cfg vbr default on");
    assert_eq(opus_encoder_frame_size(e), 960, "cfg frame_size 20ms");
    assert_eq(opus_encoder_mode(e), OPUS_MODE_CELT, "cfg mode celt (music)");
    assert_eq(opus_encoder_set_bitrate(e, 12000), 0, "set_bitrate ok");
    assert_eq(opus_encoder_bitrate(e), 12000, "bitrate updated");
    assert_eq(opus_encoder_set_vbr(e, 0), 0, "set_vbr ok");
    assert_eq(opus_encoder_vbr(e), 0, "vbr off");
    assert_eq(opus_encoder_set_bandwidth(e, OPUS_BW_WB), 0, "set_bandwidth ok");
    assert_eq(opus_encoder_bandwidth(e), OPUS_BW_WB, "bandwidth updated");
    assert_eq(opus_encoder_set_mode(e, OPUS_MODE_CELT), 0, "set_mode ok");
    assert(is_err(opus_encoder_new(44100, 1, OPUS_APP_AUDIO)) == 1, "reject 44100");
    assert(is_err(opus_encoder_new(48000, 0, OPUS_APP_AUDIO)) == 1, "reject 0 channels");
    assert(is_err(opus_encoder_new(48000, 3, OPUS_APP_AUDIO)) == 1, "reject 3 channels");
    assert(is_err(opus_encoder_set_bitrate(e, 1000)) == 1, "reject low bitrate");
    assert(is_err(opus_encoder_set_bandwidth(e, 9)) == 1, "reject bad bandwidth");
    assert(is_err(opus_encoder_set_mode(e, 9)) == 1, "reject bad mode");
    return 0;
}

fn test_opus_select_bandwidth() {
    syscall(1, 1, "test: opus bandwidth selection\n", 31);
    assert_eq(opus_select_bandwidth(7999, 48000), OPUS_BW_NB, "bw <8k = NB");
    assert_eq(opus_select_bandwidth(8000, 48000), OPUS_BW_MB, "bw 8k = MB");
    assert_eq(opus_select_bandwidth(11000, 48000), OPUS_BW_WB, "bw 11k = WB");
    assert_eq(opus_select_bandwidth(14000, 48000), OPUS_BW_SWB, "bw 14k = SWB");
    assert_eq(opus_select_bandwidth(20000, 48000), OPUS_BW_FB, "bw 20k = FB");
    assert_eq(opus_select_bandwidth(64000, 8000), OPUS_BW_NB, "cap 8k = NB");
    assert_eq(opus_select_bandwidth(64000, 16000), OPUS_BW_WB, "cap 16k = WB");
    assert(is_err(opus_select_bandwidth(0, 48000)) == 1, "reject bitrate 0");
    return 0;
}

fn test_opus_select_mode() {
    syscall(1, 1, "test: opus mode selection\n", 26);
    assert_eq(opus_select_mode(12000, 48000, OPUS_SIGNAL_VOICE), OPUS_MODE_SILK, "voice low = SILK");
    assert_eq(opus_select_mode(20000, 48000, OPUS_SIGNAL_VOICE), OPUS_MODE_HYBRID, "voice mid FB = HYBRID");
    assert_eq(opus_select_mode(32000, 48000, OPUS_SIGNAL_VOICE), OPUS_MODE_CELT, "voice high = CELT");
    assert_eq(opus_select_mode(12000, 48000, OPUS_SIGNAL_MUSIC), OPUS_MODE_CELT, "music = CELT");
    assert_eq(opus_select_mode(20000, 16000, OPUS_SIGNAL_VOICE), OPUS_MODE_SILK, "voice mid low-sr = SILK");
    assert(is_err(opus_select_mode(0, 48000, OPUS_SIGNAL_VOICE)) == 1, "reject bitrate 0");
    return 0;
}

fn test_opus_toc_byte() {
    syscall(1, 1, "test: opus TOC byte\n", 20);
    assert_eq(opus_toc_byte(OPUS_MODE_CELT, OPUS_BW_FB, 960, 0), 31 << 3, "CELT FB 20ms mono");
    assert_eq(opus_toc_byte(OPUS_MODE_CELT, OPUS_BW_FB, 960, 1), (31 << 3) | 4, "stereo bit");
    assert_eq(opus_toc_byte(OPUS_MODE_CELT, OPUS_BW_NB, 120, 0), 16 << 3, "CELT NB 2.5ms");
    assert_eq(opus_toc_byte(OPUS_MODE_SILK, OPUS_BW_WB, 960, 0), 9 << 3, "SILK WB 20ms");
    assert_eq(opus_toc_byte(OPUS_MODE_HYBRID, OPUS_BW_SWB, 480, 0), 12 << 3, "HYBRID SWB 10ms");
    assert(is_err(opus_toc_config(OPUS_MODE_CELT, OPUS_BW_MB, 960)) == 1, "CELT MB invalid");
    assert(is_err(opus_toc_config(OPUS_MODE_SILK, OPUS_BW_FB, 960)) == 1, "SILK FB invalid");
    assert(is_err(opus_toc_config(OPUS_MODE_CELT, OPUS_BW_FB, 999)) == 1, "bad frame_size invalid");
    return 0;
}

fn test_opus_encode_frame_dispatch() {
    syscall(1, 1, "test: opus encode_frame dispatch\n", 33);
    var e = opus_encoder_new(48000, 1, OPUS_APP_AUDIO);
    opus_encoder_set_mode(e, OPUS_MODE_CELT);
    var samples = alloc(OPUS_FRAME_SIZE * 8);
    memset(samples, 0, OPUS_FRAME_SIZE * 8);
    var out = alloc(4096);
    var n = opus_encode_frame(e, samples, OPUS_FRAME_SIZE, out);
    assert(res_ok(n) == 1, "CELT dispatch ok");
    assert(n > 0, "CELT dispatch wrote bytes");
    opus_encoder_set_mode(e, OPUS_MODE_SILK);
    assert(is_err(opus_encode_frame(e, samples, OPUS_FRAME_SIZE, out)) == 1, "SILK stub errors");
    opus_encoder_set_mode(e, OPUS_MODE_HYBRID);
    assert(is_err(opus_encode_frame(e, samples, OPUS_FRAME_SIZE, out)) == 1, "HYBRID stub errors");
    return 0;
}

# ================================================================
# Opus decoder — header parsing + duration estimation
# ================================================================

fn _opus_find_last_granule(data, len) {
    if (len < 27) { return 0 - 1; }
    var pos = len - 27;
    while (pos >= 0) {
        if (load8(data + pos) == 0x4F) {
            if (load8(data + pos + 1) == 0x67) {
                if (load8(data + pos + 2) == 0x67) {
                    if (load8(data + pos + 3) == 0x53) {
                        if (load8(data + pos + 4) == 0) {
                            if (pos + 14 <= len) {
                                var granule = load8(data + pos + 6);
                                granule = granule | (load8(data + pos + 7) << 8);
                                granule = granule | (load8(data + pos + 8) << 16);
                                granule = granule | (load8(data + pos + 9) << 24);
                                granule = granule | (load8(data + pos + 10) << 32);
                                granule = granule | (load8(data + pos + 11) << 40);
                                granule = granule | (load8(data + pos + 12) << 48);
                                granule = granule | (load8(data + pos + 13) << 56);
                                return granule;
                            }
                        }
                    }
                }
            }
        }
        if (pos == 0) { return 0 - 1; }
        pos = pos - 1;
    }
    return 0 - 1;
}

fn opus_decode_from_packets(packets_vec, ogg_data, ogg_len) {
    if (vec_len(packets_vec) == 0) { return err(ERR_END_OF_STREAM); }

    var pkt0 = vec_get(packets_vec, 0);
    var pkt0_data = str_data(pkt0);
    var pkt0_len = str_len(pkt0);
    var head = opus_parse_head(pkt0_data, pkt0_len);
    if (is_err(head) == 1) { return head; }

    if (vec_len(packets_vec) >= 2) {
        var pkt1 = vec_get(packets_vec, 1);
        opus_parse_tags(str_data(pkt1), str_len(pkt1));
    }

    var duration_secs = F64_ZERO;
    var total_samples = 0;
    var F64_48000 = f64_from(48000);
    var granule = _opus_find_last_granule(ogg_data, ogg_len);
    if (granule > 0) {
        var pre_skip = opus_head_pre_skip(head);
        var effective = granule - pre_skip;
        if (effective > 0) {
            duration_secs = f64_div(f64_from(effective), F64_48000);
            total_samples = effective;
        }
    }

    var channels = opus_head_channels(head);
    var pre_skip = opus_head_pre_skip(head);
    if (_celt_band_edges == 0) { _opus_init_bands(); }

    var samples = vec_new();
    var npkts = vec_len(packets_vec);
    var num_frames = npkts - 2;
    if (num_frames < 0) { num_frames = 0; }

    # Decode audio via 50%-overlap-add of per-frame IMDCT output (mono). Stereo
    # synthesis is a later bite; a stereo stream still returns metadata only for now.
    if (num_frames > 0) {
        if (channels == 1) {
            var frame_size = OPUS_FRAME_SIZE;
            var hop = frame_size / 2;
            var out_len = num_frames * hop + frame_size;
            var acc = alloc(out_len * 8);
            memset(acc, 0, out_len * 8);
            var time = alloc(frame_size * 8);
            var f = 0;
            while (f < num_frames) {
                var pkt = vec_get(packets_vec, f + 2);
                var rr = _opus_celt_decode_mono_time(str_data(pkt), str_len(pkt), frame_size, time);
                if (is_err(rr) == 0) {
                    var i = 0;
                    while (i < frame_size) {
                        var p = f * hop + i;
                        store64(acc + p * 8, f64_add(load64(acc + p * 8), load64(time + i * 8)));
                        i = i + 1;
                    }
                }
                f = f + 1;
            }
            # Fully-reconstructed region is [hop, num_frames*hop): every interior sample
            # is covered by two overlapping frames. The leading hop is MDCT priming.
            var idx = hop;
            var stop = num_frames * hop;
            while (idx < stop) {
                vec_push(samples, load64(acc + idx * 8));
                idx = idx + 1;
            }
            total_samples = vec_len(samples);
            duration_secs = f64_div(f64_from(total_samples), F64_48000);
        }
        if (channels == 2) {
            var frame_size = OPUS_FRAME_SIZE;
            var hop = frame_size / 2;
            var out_len = num_frames * hop + frame_size;
            var accl = alloc(out_len * 8);
            memset(accl, 0, out_len * 8);
            var accr = alloc(out_len * 8);
            memset(accr, 0, out_len * 8);
            var tl = alloc(frame_size * 8);
            var tr = alloc(frame_size * 8);
            var f = 0;
            while (f < num_frames) {
                var pkt = vec_get(packets_vec, f + 2);
                var rr = _opus_celt_decode_stereo_time(str_data(pkt), str_len(pkt), frame_size, tl, tr);
                if (is_err(rr) == 0) {
                    var i = 0;
                    while (i < frame_size) {
                        var p = f * hop + i;
                        store64(accl + p * 8, f64_add(load64(accl + p * 8), load64(tl + i * 8)));
                        store64(accr + p * 8, f64_add(load64(accr + p * 8), load64(tr + i * 8)));
                        i = i + 1;
                    }
                }
                f = f + 1;
            }
            var idx = hop;
            var stop = num_frames * hop;
            while (idx < stop) {
                vec_push(samples, load64(accl + idx * 8));
                vec_push(samples, load64(accr + idx * 8));
                idx = idx + 1;
            }
            total_samples = vec_len(samples) / 2;
            duration_secs = f64_div(f64_from(total_samples), F64_48000);
        }
    }

    var fi = fmtinfo_new(FMT_OPUS, 48000, channels, 16, duration_secs, total_samples);
    return decode_result_new(fi, samples);
}

# ================================================================
# Tests
# ================================================================

fn test_opus_head_parse_valid() {
    test_group("opus: parse valid OpusHead");

    var buf = alloc(19);
    opus_serialize_head(2, 312, 48000, buf);

    var h = opus_parse_head(buf, 19);
    assert(is_err(h) == 0, "parse succeeds");
    assert_eq(opus_head_version(h), 1, "version");
    assert_eq(opus_head_channels(h), 2, "channels");
    assert_eq(opus_head_pre_skip(h), 312, "pre_skip");
    assert_eq(opus_head_sample_rate(h), 48000, "sample_rate");
    assert_eq(opus_head_output_gain(h), 0, "output_gain");
    assert_eq(opus_head_mapping(h), 0, "mapping_family");

    return 0;
}

fn test_opus_head_reject_wrong_magic() {
    test_group("opus: reject wrong magic");

    var buf = alloc(19);
    opus_serialize_head(2, 312, 48000, buf);
    # Corrupt magic
    store8(buf, 0x00);
    var h = opus_parse_head(buf, 19);
    assert(is_err(h) == 1, "wrong magic rejected");

    return 0;
}

fn test_opus_head_reject_short() {
    test_group("opus: reject short data");

    var buf = alloc(10);
    memcpy(buf, "OpusHead12", 10);
    var h = opus_parse_head(buf, 10);
    assert(is_err(h) == 1, "short data rejected");

    return 0;
}

fn test_opus_head_reject_zero_channels() {
    test_group("opus: reject zero channels");

    var buf = alloc(19);
    opus_serialize_head(0, 312, 48000, buf);
    # Channel byte is at offset 9, already 0
    var h = opus_parse_head(buf, 19);
    assert(is_err(h) == 1, "zero channels rejected");

    return 0;
}

fn test_opus_head_roundtrip() {
    test_group("opus: serialize+parse roundtrip");

    var buf = alloc(19);
    opus_serialize_head(1, 200, 44100, buf);
    var h = opus_parse_head(buf, 19);
    assert(is_err(h) == 0, "roundtrip parse ok");
    assert_eq(opus_head_channels(h), 1, "rt channels");
    assert_eq(opus_head_pre_skip(h), 200, "rt pre_skip");
    assert_eq(opus_head_sample_rate(h), 44100, "rt sample_rate");

    return 0;
}

fn test_opus_tags_parseable() {
    test_group("opus: tags serialization");

    var buf = alloc(23);
    var len = opus_serialize_tags(buf);
    assert_eq(len, 23, "tags length");

    # Check magic "OpusTags"
    assert_eq(load8(buf), 0x4F, "O");
    assert_eq(load8(buf + 1), 0x70, "p");
    assert_eq(load8(buf + 7), 0x73, "s");

    return 0;
}

fn test_opus_encode_rejects_bad_rate() {
    test_group("opus: encode rejects wrong sample rate");

    var samples = vec_new();
    var out = alloc(65536);
    var result = opus_encode(samples, 44100, 1, 64000, out);
    assert(is_err(result) == 1, "wrong rate rejected");

    return 0;
}

fn test_opus_encode_rejects_bad_channels() {
    test_group("opus: encode rejects bad channels");

    var samples = vec_new();
    var out = alloc(65536);

    var r1 = opus_encode(samples, 48000, 0, 64000, out);
    assert(is_err(r1) == 1, "0 channels rejected");

    var r2 = opus_encode(samples, 48000, 3, 64000, out);
    assert(is_err(r2) == 1, "3 channels rejected");

    return 0;
}

fn test_opus_encode_rejects_bad_bitrate() {
    test_group("opus: encode rejects bad bitrate");

    var samples = vec_new();
    var out = alloc(65536);

    var r1 = opus_encode(samples, 48000, 1, 1000, out);
    assert(is_err(r1) == 1, "low bitrate rejected");

    var r2 = opus_encode(samples, 48000, 1, 500000, out);
    assert(is_err(r2) == 1, "high bitrate rejected");

    return 0;
}

fn test_opus_range_encoder_basic() {
    test_group("opus: range encoder basic");

    var rc = opus_range_enc_init();
    opus_range_enc_bit(rc, 1);
    opus_range_enc_bit(rc, 0);
    opus_range_enc_uint(rc, 3, 8);
    var result = opus_range_enc_flush(rc);
    assert(str_len(result) > 0, "range encoder produces output");

    return 0;
}

fn test_opus_encode_produces_ogg() {
    test_group("opus: encode produces valid Ogg");

    # Initialize deps
    if (_celt_band_edges == 0) { _opus_init_bands(); }

    # Build 960 silence samples (1 frame, mono)
    var samples = vec_new();
    var si = 0;
    while (si < 960) {
        vec_push(samples, F64_ZERO);
        si = si + 1;
    }

    var out = alloc(131072);
    var result = opus_encode(samples, 48000, 1, 64000, out);
    assert(is_err(result) == 0, "encode succeeds");
    assert(result > 0, "produces bytes");

    # Check OggS magic
    assert_eq(load8(out), 0x4F, "OggS[0]='O'");
    assert_eq(load8(out + 1), 0x67, "OggS[1]='g'");
    assert_eq(load8(out + 2), 0x67, "OggS[2]='g'");
    assert_eq(load8(out + 3), 0x53, "OggS[3]='S'");

    # Extract packets and verify OpusHead
    var packets = ogg_extract_packets(out, result);
    assert(is_err(packets) == 0, "extract packets ok");
    assert(vec_len(packets) >= 3, "at least 3 packets");

    # First packet should be OpusHead (19 bytes)
    var p0 = vec_get(packets, 0);
    var head = opus_parse_head(str_data(p0), str_len(p0));
    assert(is_err(head) == 0, "parse head from ogg ok");
    assert_eq(opus_head_channels(head), 1, "mono");
    assert_eq(opus_head_sample_rate(head), 48000, "48kHz");

    # Second packet should start with "OpusTags"
    var p1 = vec_get(packets, 1);
    assert_eq(load8(str_data(p1)), 0x4F, "tags[0]='O'");
    assert_eq(load8(str_data(p1) + 7), 0x73, "tags[7]='s'");

    return 0;
}

fn test_opus_all() {
    fft_init();
    if (_celt_band_edges == 0) { _opus_init_bands(); }

    test_opus_head_parse_valid();
    test_opus_head_reject_wrong_magic();
    test_opus_head_reject_short();
    test_opus_head_reject_zero_channels();
    test_opus_head_roundtrip();
    test_opus_tags_parseable();
    test_opus_encode_rejects_bad_rate();
    test_opus_encode_rejects_bad_channels();
    test_opus_encode_rejects_bad_bitrate();
    test_opus_range_encoder_basic();
    test_opus_encode_produces_ogg();
    test_opus_encoder_config();
    test_opus_select_bandwidth();
    test_opus_select_mode();
    test_opus_toc_byte();
    test_opus_encode_frame_dispatch();
    test_opus_pvq_all();
    return 0;
}

# --- aac.cyr ---

# ================================================================
# aac.cyr -- AAC-LC codec (ADTS encoder + decoder/parser)
# ================================================================
#
# Provides:
#   aac_parse_adts_header(data, len)  -- parse 7-byte ADTS header
#   aac_build_adts_header(sr, ch, frame_len, out_buf) -- build ADTS header
#   aac_encode(samples_vec, sample_rate, channels, bitrate, out_buf)
#   aac_decode(data, len)             -- parse ADTS, return format info
#
# Requires: alloc, vec, str, math, fft, assert

# ================================================================
# AAC sample rate table (indexed by 4-bit sample_rate_index)
# ================================================================

var _aac_sample_rates = 0;

fn _aac_init_rates() {
    _aac_sample_rates = alloc(16 * 8);
    store64(_aac_sample_rates + 0 * 8, 96000);
    store64(_aac_sample_rates + 1 * 8, 88200);
    store64(_aac_sample_rates + 2 * 8, 64000);
    store64(_aac_sample_rates + 3 * 8, 48000);
    store64(_aac_sample_rates + 4 * 8, 44100);
    store64(_aac_sample_rates + 5 * 8, 32000);
    store64(_aac_sample_rates + 6 * 8, 24000);
    store64(_aac_sample_rates + 7 * 8, 22050);
    store64(_aac_sample_rates + 8 * 8, 16000);
    store64(_aac_sample_rates + 9 * 8, 12000);
    store64(_aac_sample_rates + 10 * 8, 11025);
    store64(_aac_sample_rates + 11 * 8, 8000);
    store64(_aac_sample_rates + 12 * 8, 7350);
    store64(_aac_sample_rates + 13 * 8, 0);
    store64(_aac_sample_rates + 14 * 8, 0);
    store64(_aac_sample_rates + 15 * 8, 0);
    return 0;
}

# Channel count indexed by 3-bit channel configuration
var _aac_channel_counts = 0;

fn _aac_init_channels() {
    _aac_channel_counts = alloc(8 * 8);
    store64(_aac_channel_counts + 0 * 8, 0);
    store64(_aac_channel_counts + 1 * 8, 1);
    store64(_aac_channel_counts + 2 * 8, 2);
    store64(_aac_channel_counts + 3 * 8, 3);
    store64(_aac_channel_counts + 4 * 8, 4);
    store64(_aac_channel_counts + 5 * 8, 5);
    store64(_aac_channel_counts + 6 * 8, 6);
    store64(_aac_channel_counts + 7 * 8, 8);
    return 0;
}

fn aac_init() {
    _aac_init_rates();
    _aac_init_channels();
    return 0;
}

# ================================================================
# ADTS header struct (heap-allocated)
# ================================================================
# Layout (40 bytes):
#   +0:  profile        (i64, 0=Main, 1=LC, 2=SSR, 3=LTP)
#   +8:  sample_rate    (i64, Hz)
#   +16: sr_index       (i64, 0..12)
#   +24: channels       (i64)
#   +32: frame_length   (i64, total frame bytes incl. header)

fn aac_adts_new() {
    var h = alloc(40);
    memset(h, 0, 40);
    return h;
}

fn aac_adts_profile(h)       { return load64(h); }
fn aac_adts_sample_rate(h)   { return load64(h + 8); }
fn aac_adts_sr_index(h)      { return load64(h + 16); }
fn aac_adts_channels(h)      { return load64(h + 24); }
fn aac_adts_frame_length(h)  { return load64(h + 32); }

# ================================================================
# ADTS header parsing
# ================================================================

# Parse an ADTS frame header from data (>= 7 bytes).
# Returns ADTS header struct, or err().
fn aac_parse_adts_header(data, len) {
    if (len < 7) {
        return err(ERR_INVALID_HEADER);
    }

    # Check sync word: 12 bits = 0xFFF
    if (load8(data) != 0xFF) { return err(ERR_INVALID_HEADER); }
    if ((load8(data + 1) & 0xF0) != 0xF0) { return err(ERR_INVALID_HEADER); }

    # Layer must be 0 for AAC
    if ((load8(data + 1) & 0x06) != 0) { return err(ERR_INVALID_HEADER); }

    var profile = (load8(data + 2) >> 6) & 0x03;
    var sr_index = (load8(data + 2) >> 2) & 0x0F;

    if (sr_index >= 13) { return err(ERR_INVALID_HEADER); }

    var sample_rate = load64(_aac_sample_rates + sr_index * 8);
    if (sample_rate == 0) { return err(ERR_INVALID_RATE); }

    var channel_config = ((load8(data + 2) & 0x01) << 2) | ((load8(data + 3) >> 6) & 0x03);
    if (channel_config == 0) { return err(ERR_INVALID_CHANNELS); }
    if (channel_config >= 8) { return err(ERR_INVALID_CHANNELS); }
    var channels = load64(_aac_channel_counts + channel_config * 8);

    # Frame length: 13 bits spanning bytes 3-5
    var frame_length = ((load8(data + 3) & 0x03) << 11)
                     | (load8(data + 4) << 3)
                     | ((load8(data + 5) >> 5) & 0x07);

    if (frame_length < 7) { return err(ERR_INVALID_HEADER); }

    var h = aac_adts_new();
    store64(h,      profile);
    store64(h + 8,  sample_rate);
    store64(h + 16, sr_index);
    store64(h + 24, channels);
    store64(h + 32, frame_length);
    return h;
}

# ================================================================
# ADTS header building
# ================================================================

# Find sample rate index for a given rate.
fn _aac_find_sr_index(sample_rate) {
    var i = 0;
    while (i < 13) {
        if (load64(_aac_sample_rates + i * 8) == sample_rate) {
            return i;
        }
        i = i + 1;
    }
    return 4;  # default to 44100
}

# Build a 7-byte ADTS header into out_buf.
# frame_len: raw frame data length (without header).
# Returns 7.
fn aac_build_adts_header(sample_rate, channels, frame_len, out_buf) {
    var sr_index = _aac_find_sr_index(sample_rate);
    var total_len = frame_len + 7;

    store8(out_buf, 0xFF);
    # MPEG-4, layer=0, protection_absent=1
    store8(out_buf + 1, 0xF1);
    # profile=LC(1) | sr_index | private=0 | channel MSB
    store8(out_buf + 2, (1 << 6) | (sr_index << 2) | ((channels >> 2) & 0x01));
    # channel LSBs | frame_length MSBs
    store8(out_buf + 3, ((channels & 0x03) << 6) | ((total_len >> 11) & 0x03));
    store8(out_buf + 4, (total_len >> 3) & 0xFF);
    # frame_length LSBs | buffer fullness MSBs (0x7FF = VBR)
    store8(out_buf + 5, ((total_len & 0x07) << 5) | 0x1F);
    store8(out_buf + 6, 0xFC);  # buffer fullness LSBs + 0 frames - 1

    return 7;
}

# ================================================================
# AAC-LC constants
# ================================================================

var AAC_FRAME_SIZE = 1024;
var AAC_SHORT_SIZE = 128;
var AAC_NUM_SHORT_WINDOWS = 8;

# Scale factor band boundaries for 48kHz / 44.1kHz (long window, 49 bands)
var _aac_swb_offset = 0;
var _aac_swb_short = 0;
var _AAC_NUM_SWB = 49;
var _AAC_NUM_SWB_SHORT = 14;

fn _aac_init_swb() {
    _aac_swb_offset = alloc(50 * 8);
    store64(_aac_swb_offset + 0 * 8, 0);
    store64(_aac_swb_offset + 1 * 8, 4);
    store64(_aac_swb_offset + 2 * 8, 8);
    store64(_aac_swb_offset + 3 * 8, 12);
    store64(_aac_swb_offset + 4 * 8, 16);
    store64(_aac_swb_offset + 5 * 8, 20);
    store64(_aac_swb_offset + 6 * 8, 24);
    store64(_aac_swb_offset + 7 * 8, 28);
    store64(_aac_swb_offset + 8 * 8, 32);
    store64(_aac_swb_offset + 9 * 8, 36);
    store64(_aac_swb_offset + 10 * 8, 40);
    store64(_aac_swb_offset + 11 * 8, 48);
    store64(_aac_swb_offset + 12 * 8, 56);
    store64(_aac_swb_offset + 13 * 8, 64);
    store64(_aac_swb_offset + 14 * 8, 72);
    store64(_aac_swb_offset + 15 * 8, 80);
    store64(_aac_swb_offset + 16 * 8, 88);
    store64(_aac_swb_offset + 17 * 8, 96);
    store64(_aac_swb_offset + 18 * 8, 108);
    store64(_aac_swb_offset + 19 * 8, 120);
    store64(_aac_swb_offset + 20 * 8, 132);
    store64(_aac_swb_offset + 21 * 8, 144);
    store64(_aac_swb_offset + 22 * 8, 160);
    store64(_aac_swb_offset + 23 * 8, 176);
    store64(_aac_swb_offset + 24 * 8, 196);
    store64(_aac_swb_offset + 25 * 8, 216);
    store64(_aac_swb_offset + 26 * 8, 240);
    store64(_aac_swb_offset + 27 * 8, 264);
    store64(_aac_swb_offset + 28 * 8, 292);
    store64(_aac_swb_offset + 29 * 8, 320);
    store64(_aac_swb_offset + 30 * 8, 352);
    store64(_aac_swb_offset + 31 * 8, 384);
    store64(_aac_swb_offset + 32 * 8, 416);
    store64(_aac_swb_offset + 33 * 8, 448);
    store64(_aac_swb_offset + 34 * 8, 480);
    store64(_aac_swb_offset + 35 * 8, 512);
    store64(_aac_swb_offset + 36 * 8, 544);
    store64(_aac_swb_offset + 37 * 8, 576);
    store64(_aac_swb_offset + 38 * 8, 608);
    store64(_aac_swb_offset + 39 * 8, 640);
    store64(_aac_swb_offset + 40 * 8, 672);
    store64(_aac_swb_offset + 41 * 8, 704);
    store64(_aac_swb_offset + 42 * 8, 736);
    store64(_aac_swb_offset + 43 * 8, 768);
    store64(_aac_swb_offset + 44 * 8, 800);
    store64(_aac_swb_offset + 45 * 8, 832);
    store64(_aac_swb_offset + 46 * 8, 864);
    store64(_aac_swb_offset + 47 * 8, 896);
    store64(_aac_swb_offset + 48 * 8, 928);
    store64(_aac_swb_offset + 49 * 8, 1024);

    # Short window SWB offsets (48kHz/44.1kHz, 14 bands)
    _aac_swb_short = alloc(15 * 8);
    store64(_aac_swb_short + 0 * 8, 0);
    store64(_aac_swb_short + 1 * 8, 4);
    store64(_aac_swb_short + 2 * 8, 8);
    store64(_aac_swb_short + 3 * 8, 12);
    store64(_aac_swb_short + 4 * 8, 16);
    store64(_aac_swb_short + 5 * 8, 20);
    store64(_aac_swb_short + 6 * 8, 28);
    store64(_aac_swb_short + 7 * 8, 36);
    store64(_aac_swb_short + 8 * 8, 44);
    store64(_aac_swb_short + 9 * 8, 56);
    store64(_aac_swb_short + 10 * 8, 68);
    store64(_aac_swb_short + 11 * 8, 80);
    store64(_aac_swb_short + 12 * 8, 96);
    store64(_aac_swb_short + 13 * 8, 112);
    store64(_aac_swb_short + 14 * 8, 128);
    return 0;
}

# ================================================================
# MSB-first bit writer for AAC bitstream
# ================================================================
# Layout (32 bytes):
#   +0:  buf (pointer)
#   +8:  buf_len
#   +16: buf_cap
#   +24: current (u32 accumulator)
#   +32: bits_in_current (0-7)

fn _bw_new() {
    var bw = alloc(40);
    memset(bw, 0, 40);
    var buf = alloc(8192);
    store64(bw, buf);
    store64(bw + 8, 0);
    store64(bw + 16, 8192);
    store64(bw + 24, 0);
    store64(bw + 32, 0);
    return bw;
}

fn _bw_push_byte(bw, byte) {
    var buf = load64(bw);
    var blen = load64(bw + 8);
    var bcap = load64(bw + 16);
    if (blen >= bcap) {
        var new_cap = bcap * 2;
        var new_buf = alloc(new_cap);
        memcpy(new_buf, buf, blen);
        store64(bw, new_buf);
        store64(bw + 16, new_cap);
        buf = new_buf;
    }
    store8(buf + blen, byte & 0xFF);
    store64(bw + 8, blen + 1);
    return 0;
}

# Write n bits from val (MSB-first, up to 32 bits).
fn _bw_write(bw, val, n) {
    var i = n - 1;
    while (i >= 0) {
        var cur = load64(bw + 24);
        cur = (cur << 1) | ((val >> i) & 1);
        var bits = load64(bw + 32) + 1;
        store64(bw + 24, cur);
        store64(bw + 32, bits);
        if (bits == 8) {
            _bw_push_byte(bw, cur & 0xFF);
            store64(bw + 24, 0);
            store64(bw + 32, 0);
        }
        i = i - 1;
    }
    return 0;
}

# Flush remaining bits (zero-padded to byte boundary).
# Returns Str (data, len).
fn _bw_flush(bw) {
    var bits = load64(bw + 32);
    if (bits > 0) {
        var cur = load64(bw + 24);
        cur = cur << (8 - bits);
        _bw_push_byte(bw, cur & 0xFF);
        store64(bw + 24, 0);
        store64(bw + 32, 0);
    }
    var buf = load64(bw);
    var blen = load64(bw + 8);
    return str_new(buf, blen);
}

fn _bw_byte_len(bw) {
    var blen = load64(bw + 8);
    if (load64(bw + 32) > 0) { blen = blen + 1; }
    return blen;
}

# ================================================================
# TNS (Temporal Noise Shaping) — AAC-LC, long window
# ================================================================
# Linear prediction ACROSS frequency: the encoder runs an all-zero analysis
# (FIR) filter over the top spectral bands to flatten the temporal envelope; the
# decoder runs the exact-inverse all-pole synthesis (IIR) filter. Both filters
# are built from the SAME quantized reflection (PARCOR) coefficients, so
# analysis∘synthesis is the identity — TNS shapes only the quantization noise.
# Convention: analysis e[n]=x[n]+Σa[j]x[n-j]; synthesis x[n]=e[n]-Σa[j]x[n-j].

var TNS_MAX_ORDER = 12;
var TNS_MIN_SFB = 12;      # apply TNS over SFBs [TNS_MIN_SFB, max_sfb)
var TNS_GAIN_NUM = 3;      # enable when prediction gain r0/err > 3/2
var TNS_GAIN_DEN = 2;

# per-channel TNS state (single long-window filter)
var TNS_ST_PRESENT = 0;
var TNS_ST_ORDER = 8;
var TNS_ST_DIR = 16;
var TNS_ST_START = 24;     # region start bin (inclusive)
var TNS_ST_END = 32;       # region end bin (exclusive)
var TNS_ST_LEN = 40;       # region length in SFBs (bitstream field)
var TNS_ST_RESBITS = 48;   # coef resolution bits (3 or 4)
var TNS_ST_COMPRESS = 56;  # coef_compress flag
var TNS_ST_COEF = 64;      # coef_index[0..order-1] (signed), 12 slots
var TNS_ST_SIZE = 168;     # 64 + 12*8 = 160, padded

# Autocorrelation of x[start..end) for lags 0..maxlag into r_out[0..maxlag].
fn _tns_autocorr(x, start, end, maxlag, r_out) {
    var lag = 0;
    while (lag <= maxlag) {
        var s = F64_ZERO;
        var i = start;
        while (i + lag < end) {
            s = f64_add(s, f64_mul(load64(x + i * 8), load64(x + (i + lag) * 8)));
            i = i + 1;
        }
        store64(r_out + lag * 8, s);
        lag = lag + 1;
    }
    return 0;
}

# Levinson-Durbin: r[0..order] -> reflection k_out[1..order] (f64).
# Returns 1 if the filter is stable and the prediction gain clears the threshold,
# else 0 (caller then leaves TNS disabled).
fn _tns_levinson(r, order, k_out) {
    var r0 = load64(r);
    if (f64_gt(r0, F64_ZERO) == 0) { return 0; }
    var err = r0;
    var a = alloc((TNS_MAX_ORDER + 1) * 8);
    memset(a, 0, (TNS_MAX_ORDER + 1) * 8);
    var tmp = alloc((TNS_MAX_ORDER + 1) * 8);
    store64(a, F64_ONE);
    var m = 1;
    while (m <= order) {
        var acc = load64(r + m * 8);
        var i = 1;
        while (i < m) {
            acc = f64_add(acc, f64_mul(load64(a + i * 8), load64(r + (m - i) * 8)));
            i = i + 1;
        }
        var k = f64_neg(f64_div(acc, err));
        if (f64_gt(f64_abs(k), F64_ONE) == 1) { return 0; }
        i = 1;
        while (i < m) {
            store64(tmp + i * 8, f64_add(load64(a + i * 8), f64_mul(k, load64(a + (m - i) * 8))));
            i = i + 1;
        }
        i = 1;
        while (i < m) { store64(a + i * 8, load64(tmp + i * 8)); i = i + 1; }
        store64(a + m * 8, k);
        store64(k_out + m * 8, k);
        err = f64_mul(err, f64_sub(F64_ONE, f64_mul(k, k)));
        if (f64_gt(err, F64_ZERO) == 0) { return 0; }
        m = m + 1;
    }
    if (f64_gt(f64_mul(r0, f64_from(TNS_GAIN_DEN)), f64_mul(err, f64_from(TNS_GAIN_NUM))) == 1) {
        return 1;
    }
    return 0;
}

# Rebuild LPC a_out[0..order] (a_out[0]=1) from reflection k[1..order] — the same
# recursion Levinson uses, so encoder and decoder derive identical a[] from the
# same reflection coefficients.
fn _tns_parcor_to_lpc(k, order, a_out) {
    memset(a_out, 0, (TNS_MAX_ORDER + 1) * 8);
    store64(a_out, F64_ONE);
    var tmp = alloc((TNS_MAX_ORDER + 1) * 8);
    var m = 1;
    while (m <= order) {
        var km = load64(k + m * 8);
        var i = 1;
        while (i < m) {
            store64(tmp + i * 8, f64_add(load64(a_out + i * 8), f64_mul(km, load64(a_out + (m - i) * 8))));
            i = i + 1;
        }
        i = 1;
        while (i < m) { store64(a_out + i * 8, load64(tmp + i * 8)); i = i + 1; }
        store64(a_out + m * 8, km);
        m = m + 1;
    }
    return 0;
}

# Dequantize a signed coef index to a reflection coefficient (ISO sin mapping).
fn _tns_dequant_coef(coef, res_bits) {
    var half = 1;
    var b = 0;
    while (b < res_bits - 1) { half = half * 2; b = b + 1; }
    var pi_half = f64_div(F64_PI, F64_TWO);
    var iqfac = f64_div(f64_sub(f64_from(half), F64_HALF), pi_half);
    var iqfac_m = f64_div(f64_add(f64_from(half), F64_HALF), pi_half);
    var denom = iqfac;
    if (coef < 0) { denom = iqfac_m; }
    return f64_sin(f64_div(f64_from(coef), denom));
}

# Quantize a reflection coefficient to the nearest coef index (search over the
# small signed range — guaranteed consistent with _tns_dequant_coef, no asin).
fn _tns_quant_coef(k, res_bits) {
    var half = 1;
    var b = 0;
    while (b < res_bits - 1) { half = half * 2; b = b + 1; }
    var best = 0;
    var bestd = f64_from(1000000);
    var c = 0 - half;
    while (c <= half - 1) {
        var d = f64_abs(f64_sub(_tns_dequant_coef(c, res_bits), k));
        if (f64_lt(d, bestd) == 1) { bestd = d; best = c; }
        c = c + 1;
    }
    return best;
}

# Apply the TNS filter over spec[start..end) with LPC a[0..order] (a[0]=1).
# is_synth=0: analysis FIR (encoder), reads original inputs (region copied first).
# is_synth=1: synthesis IIR (decoder), in-place using computed outputs.
# direction=0: forward (low->high); direction=1: backward (high->low).
# History bins outside the region contribute 0 (identical on both sides).
fn _tns_filter(spec, start, end, a, order, direction, is_synth) {
    if (end - start <= 0) { return 0; }
    if (order <= 0) { return 0; }
    var n = end - start;
    if (direction == 0) {
        if (is_synth == 0) {
            var x0 = alloc(n * 8);
            var t = 0;
            while (t < n) { store64(x0 + t * 8, load64(spec + (start + t) * 8)); t = t + 1; }
            var i = start;
            while (i < end) {
                var acc = load64(x0 + (i - start) * 8);
                var j = 1;
                while (j <= order) {
                    if (i - j >= start) {
                        acc = f64_add(acc, f64_mul(load64(a + j * 8), load64(x0 + (i - j - start) * 8)));
                    }
                    j = j + 1;
                }
                store64(spec + i * 8, acc);
                i = i + 1;
            }
        } else {
            var i = start;
            while (i < end) {
                var acc = load64(spec + i * 8);
                var j = 1;
                while (j <= order) {
                    if (i - j >= start) {
                        acc = f64_sub(acc, f64_mul(load64(a + j * 8), load64(spec + (i - j) * 8)));
                    }
                    j = j + 1;
                }
                store64(spec + i * 8, acc);
                i = i + 1;
            }
        }
    } else {
        if (is_synth == 0) {
            var x0 = alloc(n * 8);
            var t = 0;
            while (t < n) { store64(x0 + t * 8, load64(spec + (start + t) * 8)); t = t + 1; }
            var i = end - 1;
            while (i >= start) {
                var acc = load64(x0 + (i - start) * 8);
                var j = 1;
                while (j <= order) {
                    if (i + j < end) {
                        acc = f64_add(acc, f64_mul(load64(a + j * 8), load64(x0 + (i + j - start) * 8)));
                    }
                    j = j + 1;
                }
                store64(spec + i * 8, acc);
                i = i - 1;
            }
        } else {
            var i = end - 1;
            while (i >= start) {
                var acc = load64(spec + i * 8);
                var j = 1;
                while (j <= order) {
                    if (i + j < end) {
                        acc = f64_sub(acc, f64_mul(load64(a + j * 8), load64(spec + (i + j) * 8)));
                    }
                    j = j + 1;
                }
                store64(spec + i * 8, acc);
                i = i - 1;
            }
        }
    }
    return 0;
}

# Encoder: analyze the top spectral region, and if TNS helps, apply the analysis
# filter to spec IN PLACE (so quantization sees the flattened residual) and record
# the quantized coefficients + region in the TNS state for the bitstream writer.
fn _tns_analyze_apply(spec, max_sfb, st) {
    store64(st + TNS_ST_PRESENT, 0);
    if (_aac_swb_offset == 0) { _aac_init_swb(); }
    var s_sfb = TNS_MIN_SFB;
    if (s_sfb >= max_sfb) { return 0; }
    var start = load64(_aac_swb_offset + s_sfb * 8);
    var end = load64(_aac_swb_offset + max_sfb * 8);
    var order = TNS_MAX_ORDER;
    if (end - start < order + 1) { return 0; }
    var r = alloc((TNS_MAX_ORDER + 1) * 8);
    _tns_autocorr(spec, start, end, order, r);
    var kbuf = alloc((TNS_MAX_ORDER + 1) * 8);
    memset(kbuf, 0, (TNS_MAX_ORDER + 1) * 8);
    if (_tns_levinson(r, order, kbuf) == 0) { return 0; }
    var resbits = 4;
    var coefidx = alloc((TNS_MAX_ORDER + 1) * 8);
    var kq = alloc((TNS_MAX_ORDER + 1) * 8);
    memset(kq, 0, (TNS_MAX_ORDER + 1) * 8);
    var i = 1;
    while (i <= order) {
        var ci = _tns_quant_coef(load64(kbuf + i * 8), resbits);
        store64(coefidx + i * 8, ci);
        store64(kq + i * 8, _tns_dequant_coef(ci, resbits));
        i = i + 1;
    }
    var abuf = alloc((TNS_MAX_ORDER + 1) * 8);
    _tns_parcor_to_lpc(kq, order, abuf);
    _tns_filter(spec, start, end, abuf, order, 0, 0);
    store64(st + TNS_ST_PRESENT, 1);
    store64(st + TNS_ST_ORDER, order);
    store64(st + TNS_ST_DIR, 0);
    store64(st + TNS_ST_COMPRESS, 0);
    store64(st + TNS_ST_RESBITS, resbits);
    store64(st + TNS_ST_LEN, max_sfb - s_sfb);
    store64(st + TNS_ST_START, start);
    store64(st + TNS_ST_END, end);
    i = 0;
    while (i < order) {
        store64(st + TNS_ST_COEF + i * 8, load64(coefidx + (i + 1) * 8));
        i = i + 1;
    }
    return 0;
}

# Decoder: rebuild the LPC from the decoded reflection coefficients and apply the
# synthesis (IIR) filter to the dequantized spectrum IN PLACE, before the IMDCT.
fn _tns_synth_apply(spec, st) {
    if (load64(st + TNS_ST_PRESENT) == 0) { return 0; }
    var order = load64(st + TNS_ST_ORDER);
    if (order <= 0) { return 0; }
    var resbits = load64(st + TNS_ST_RESBITS);
    var kbuf = alloc((TNS_MAX_ORDER + 1) * 8);
    memset(kbuf, 0, (TNS_MAX_ORDER + 1) * 8);
    var i = 1;
    while (i <= order) {
        store64(kbuf + i * 8, _tns_dequant_coef(load64(st + TNS_ST_COEF + (i - 1) * 8), resbits));
        i = i + 1;
    }
    var abuf = alloc((TNS_MAX_ORDER + 1) * 8);
    _tns_parcor_to_lpc(kbuf, order, abuf);
    _tns_filter(spec, load64(st + TNS_ST_START), load64(st + TNS_ST_END), abuf, order, load64(st + TNS_ST_DIR), 1);
    return 0;
}

# Write the ICS extension after scale_factor_data: pulse_data_present=0,
# tns_data_present(+tns_data), gain_control_data_present=0 (AAC-LC syntax).
fn _aac_write_ics_ext(bw, st) {
    _bw_write(bw, 0, 1);   # pulse_data_present = 0
    if (load64(st + TNS_ST_PRESENT) == 1) {
        _bw_write(bw, 1, 1);   # tns_data_present
        _bw_write(bw, 1, 2);   # n_filt = 1 (long: 2 bits)
        var resbits = load64(st + TNS_ST_RESBITS);
        var coef_res_bit = 0;
        if (resbits == 4) { coef_res_bit = 1; }
        _bw_write(bw, coef_res_bit, 1);
        _bw_write(bw, load64(st + TNS_ST_LEN), 6);   # length in SFBs
        var order = load64(st + TNS_ST_ORDER);
        _bw_write(bw, order, 5);
        if (order > 0) {
            _bw_write(bw, load64(st + TNS_ST_DIR), 1);
            var compress = load64(st + TNS_ST_COMPRESS);
            _bw_write(bw, compress, 1);
            var coef_len = resbits - compress;
            var mask = (1 << coef_len) - 1;
            var i = 0;
            while (i < order) {
                _bw_write(bw, load64(st + TNS_ST_COEF + i * 8) & mask, coef_len);
                i = i + 1;
            }
        }
    } else {
        _bw_write(bw, 0, 1);   # tns_data_present = 0
    }
    _bw_write(bw, 0, 1);   # gain_control_data_present = 0
    return 0;
}

# Parse tns_data() into the TNS state (long window stores filter 0; short windows
# are consumed to stay in sync but not applied — the encoder is long-only).
fn _tns_parse_data(br, is_short, max_sfb, st) {
    var n_filt_bits = 2;
    var len_bits = 6;
    var order_bits = 5;
    var num_windows = 1;
    if (is_short == 1) { n_filt_bits = 1; len_bits = 4; order_bits = 3; num_windows = 8; }
    var w = 0;
    while (w < num_windows) {
        var n_filt = _br_read(br, n_filt_bits);
        if (is_err(n_filt) == 1) { return n_filt; }
        if (n_filt > 0) {
            var coef_res = _br_read(br, 1);
            if (is_err(coef_res) == 1) { return coef_res; }
            var res_bits = 3;
            if (coef_res == 1) { res_bits = 4; }
            var f = 0;
            while (f < n_filt) {
                var length = _br_read(br, len_bits);
                if (is_err(length) == 1) { return length; }
                var order = _br_read(br, order_bits);
                if (is_err(order) == 1) { return order; }
                if (order > TNS_MAX_ORDER) { return err(ERR_DECODE); }
                if (order > 0) {
                    var direction = _br_read(br, 1);
                    if (is_err(direction) == 1) { return direction; }
                    var compress = _br_read(br, 1);
                    if (is_err(compress) == 1) { return compress; }
                    var coef_len = res_bits - compress;
                    var signbit = 1;
                    var sb = 0;
                    while (sb < coef_len - 1) { signbit = signbit * 2; sb = sb + 1; }
                    var store_it = 0;
                    if (is_short == 0) { if (f == 0) { store_it = 1; } }
                    var i = 0;
                    while (i < order) {
                        var raw = _br_read(br, coef_len);
                        if (is_err(raw) == 1) { return raw; }
                        var ci = raw;
                        if (raw >= signbit) { ci = raw - signbit * 2; }
                        if (store_it == 1) { store64(st + TNS_ST_COEF + i * 8, ci); }
                        i = i + 1;
                    }
                    if (store_it == 1) {
                        store64(st + TNS_ST_PRESENT, 1);
                        store64(st + TNS_ST_ORDER, order);
                        store64(st + TNS_ST_DIR, direction);
                        store64(st + TNS_ST_COMPRESS, compress);
                        store64(st + TNS_ST_RESBITS, res_bits);
                        var s_sfb = max_sfb - length;
                        if (s_sfb < 0) { s_sfb = 0; }
                        store64(st + TNS_ST_LEN, length);
                        store64(st + TNS_ST_START, load64(_aac_swb_offset + s_sfb * 8));
                        store64(st + TNS_ST_END, load64(_aac_swb_offset + max_sfb * 8));
                    }
                }
                f = f + 1;
            }
        }
        w = w + 1;
    }
    return 0;
}

# Parse the ICS extension (pulse/tns/gain presence flags). Fills st; returns 0 or err.
fn _aac_parse_ics_ext(br, is_short, max_sfb, st) {
    store64(st + TNS_ST_PRESENT, 0);
    var pulse = _br_read(br, 1);
    if (is_err(pulse) == 1) { return pulse; }
    if (pulse == 1) { return err(ERR_UNSUPPORTED_FMT); }   # pulse_data not produced by this encoder
    var tns_present = _br_read(br, 1);
    if (is_err(tns_present) == 1) { return tns_present; }
    if (tns_present == 1) {
        var prc = _tns_parse_data(br, is_short, max_sfb, st);
        if (is_err(prc) == 1) { return prc; }
    }
    var gain = _br_read(br, 1);
    if (is_err(gain) == 1) { return gain; }
    if (gain == 1) { return err(ERR_UNSUPPORTED_FMT); }
    return 0;
}

# ================================================================
# Psychoacoustic model — simultaneous masking (AAC encoder)
# ================================================================
# Each scalefactor band's energy spreads to its neighbours (SFBs approximate
# critical bands), so a loud band raises the level below which quantization noise
# stays inaudible nearby. We derive a per-band coarseness offset (in scalefactor
# units) = 2·log2(spread/energy): zero for an isolated band, positive where
# neighbours mask it. Adding it to the baseline scale factor quantizes masked
# bands coarser (fewer bits) while leaving unmasked bands unchanged. Spreading is
# asymmetric — gentler toward higher frequency (the upward spread of masking).

var PSY_SLOPE_UP = 10;      # dB attenuation per SFB toward higher frequency (gentle)
var PSY_SLOPE_DOWN = 25;    # dB attenuation per SFB toward lower frequency (steep)
var PSY_MAX_OFFSET = 24;    # cap on masking coarseness (scf units) — avoid over-culling
var _aac_psy_up_gain = 0;   # up_gain[d]   = 10^(-PSY_SLOPE_UP*d/10)
var _aac_psy_down_gain = 0; # down_gain[d] = 10^(-PSY_SLOPE_DOWN*d/10)

fn _aac_psy_init() {
    _aac_psy_up_gain = alloc(_AAC_NUM_SWB * 8);
    _aac_psy_down_gain = alloc(_AAC_NUM_SWB * 8);
    var ten = f64_from(10);
    var d = 0;
    while (d < _AAC_NUM_SWB) {
        store64(_aac_psy_up_gain + d * 8, f64_pow(ten, f64_neg(f64_div(f64_from(PSY_SLOPE_UP * d), ten))));
        store64(_aac_psy_down_gain + d * 8, f64_pow(ten, f64_neg(f64_div(f64_from(PSY_SLOPE_DOWN * d), ten))));
        d = d + 1;
    }
    return 0;
}

# Per-band masking coarseness offset (scalefactor units, >= 0). energies[b] is the
# linear band energy (sum of squared coefficients); offset_out[b] gets the extra
# scale-factor coarseness that neighbour masking permits.
fn _aac_psy_masking_offsets(energies, num_bands, offset_out) {
    if (_aac_psy_up_gain == 0) { _aac_psy_init(); }
    var floor_e = f64_div(F64_ONE, f64_mul(f64_from(100000000), f64_from(100000000)));
    var b = 0;
    while (b < num_bands) {
        var e_self = load64(energies + b * 8);
        var spread = F64_ZERO;
        var bp = 0;
        while (bp < num_bands) {
            var e = load64(energies + bp * 8);
            var gain = F64_ZERO;
            if (b >= bp) { gain = load64(_aac_psy_up_gain + (b - bp) * 8); }
            else { gain = load64(_aac_psy_down_gain + (bp - b) * 8); }
            spread = f64_add(spread, f64_mul(e, gain));
            bp = bp + 1;
        }
        var off = 0;
        if (f64_gt(e_self, floor_e) == 1) {
            if (f64_gt(spread, e_self) == 1) {
                off = f64_to(f64_mul(F64_TWO, f64_log2(f64_div(spread, e_self))));
            }
        }
        if (off < 0) { off = 0; }
        if (off > PSY_MAX_OFFSET) { off = PSY_MAX_OFFSET; }
        store64(offset_out + b * 8, off);
        b = b + 1;
    }
    return 0;
}

# ================================================================
# AAC-LC frame encoder
# ================================================================

# Encode a single AAC-LC frame.
# samples: pointer to 1024*ch f64 values (interleaved)
# Returns Str (raw frame data without ADTS header).
fn _aac_encode_frame(samples, channels, target_bytes) {
    var ch = channels;

    # Extract mono or M/S stereo channels over the full 2048-sample MDCT span.
    # MONO uses all 2048 samples (`samples` is a 50%-overlap window supplied by the
    # caller — hop 1024) so the decoder's overlap-add reconstructs (TDAC). STEREO still
    # fills only the first 1024 (its 2nd half stays 0); the stereo overlap framing is
    # fixed together with the CPE bitstream in a later bite.
    var windowed_size = AAC_FRAME_SIZE * 2;   # 2048
    var mono = alloc(windowed_size * 8);
    memset(mono, 0, windowed_size * 8);
    var side = alloc(windowed_size * 8);
    memset(side, 0, windowed_size * 8);
    var is_stereo = 0;
    if (ch >= 2) { is_stereo = 1; }

    var i = 0;
    if (is_stereo == 1) {
        # M/S stereo over the full 2048-sample overlap window: mid=(L+R)/2, side=(L-R)/2
        while (i < windowed_size) {
            var left = load64(samples + (i * ch) * 8);
            var right = load64(samples + (i * ch + 1) * 8);
            store64(mono + i * 8, f64_mul(f64_add(left, right), F64_HALF));
            store64(side + i * 8, f64_mul(f64_sub(left, right), F64_HALF));
            i = i + 1;
        }
    } else {
        # Mono/multi-channel downmix over the full overlap window (2048 samples)
        while (i < windowed_size) {
            var sum = F64_ZERO;
            var c = 0;
            while (c < ch) {
                sum = f64_add(sum, load64(samples + (i * ch + c) * 8));
                c = c + 1;
            }
            store64(mono + i * 8, f64_div(sum, f64_from(ch)));
            i = i + 1;
        }
    }

    # Apply the 2048-point sine analysis window (full span for mono; stereo's zeroed
    # 2nd half leaves its window unchanged from before).
    var windowed = alloc(windowed_size * 8);
    memset(windowed, 0, windowed_size * 8);
    i = 0;
    while (i < windowed_size) {
        var angle = f64_div(
            f64_mul(F64_PI, f64_add(f64_from(i), F64_HALF)),
            f64_from(windowed_size)
        );
        var w = f64_sin(angle);
        store64(windowed + i * 8, f64_mul(load64(mono + i * 8), w));
        i = i + 1;
    }

    # Forward MDCT: 2048 input -> 1024 spectral coefficients
    var mdct_out = alloc(AAC_FRAME_SIZE * 8);
    memset(mdct_out, 0, AAC_FRAME_SIZE * 8);
    fft_mdct(windowed, windowed_size, mdct_out);

    # TNS analysis (mono/SCE only): flatten the temporal envelope before
    # quantization so scale factors + quantization see the prediction residual.
    # TNS temporarily disabled (tns_mid stays zeroed -> ICS ext codes no TNS). The
    # analysis-FIR / synthesis-IIR pair is an exact inverse only WITHOUT quantization;
    # engaged through the quantizer the IIR amplified quant noise and dropped the tone
    # round-trip from ~0.98 to ~0.68 correlation. Proper prediction-gain-gated TNS that
    # shapes (rather than amplifies) quant noise is a completion item (2.5.10-b5).
    var tns_mid = alloc(TNS_ST_SIZE);
    memset(tns_mid, 0, TNS_ST_SIZE);

    # Quantize spectral coefficients per scale factor band
    var scale_factors = alloc(_AAC_NUM_SWB * 8);
    memset(scale_factors, 0, _AAC_NUM_SWB * 8);
    var quant_spec = alloc(AAC_FRAME_SIZE * 8);
    memset(quant_spec, 0, AAC_FRAME_SIZE * 8);

    # Pass 1: per-band energies, then psychoacoustic masking coarseness offsets.
    var energies = alloc(_AAC_NUM_SWB * 8);
    var eb = 0;
    while (eb < _AAC_NUM_SWB) {
        var es = load64(_aac_swb_offset + eb * 8);
        var ee = load64(_aac_swb_offset + (eb + 1) * 8);
        var esum = F64_ZERO;
        var ej = es;
        while (ej < ee) {
            var ec = load64(mdct_out + ej * 8);
            esum = f64_add(esum, f64_mul(ec, ec));
            ej = ej + 1;
        }
        store64(energies + eb * 8, esum);
        eb = eb + 1;
    }
    var psy_off = alloc(_AAC_NUM_SWB * 8);
    _aac_psy_masking_offsets(energies, _AAC_NUM_SWB, psy_off);

    # Determine scale factors from the per-band PEAK so tonal peaks survive quantization
    # (the old rms-based target ~10 collapsed single-bin tones to zero), then quantize
    # with the ISO-invertible rule q = round((|x|/step)^0.75) so that the decoder's
    # dequant q^(4/3)*step reconstructs |x| (the old |x|^0.75/step did not invert).
    var band = 0;
    var j = 0;
    while (band < _AAC_NUM_SWB) {
        var start = load64(_aac_swb_offset + band * 8);
        var end = load64(_aac_swb_offset + (band + 1) * 8);

        var peak = F64_ZERO;
        var pj = start;
        while (pj < end) {
            var pv = f64_abs(load64(mdct_out + pj * 8));
            if (f64_gt(pv, peak) == 1) { peak = pv; }
            pj = pj + 1;
        }

        var floor_val = f64_div(F64_ONE, f64_mul(f64_from(10000000), f64_from(1000)));
        var scf = 0;
        if (f64_gt(peak, floor_val) == 1) {
            # step = peak / target_q^(4/3), target_q = 64 -> 64^(4/3) = 256 = 2^8, so
            # log2(step) = log2(peak) - 8; scf = 100 + 4*log2(step).
            var log_step = f64_sub(f64_log2(peak), f64_from(8));
            scf = f64_to(f64_add(f64_from(100), f64_mul(f64_from(4), log_step)));
        }
        # Psychoacoustic masking: coarsen bands that neighbours mask (0 if unmasked).
        scf = scf + load64(psy_off + band * 8);
        if (scf < 0) { scf = 0; }
        if (scf > 200) { scf = 200; }
        store64(scale_factors + band * 8, scf);

        var step = f64_pow(F64_TWO, f64_div(f64_sub(f64_from(scf), f64_from(100)), f64_from(4)));
        var e34 = f64_div(f64_from(3), f64_from(4));
        j = start;
        while (j < end) {
            var xval = load64(mdct_out + j * 8);
            var abs_val = f64_abs(xval);
            var floor_step = f64_div(F64_ONE, f64_mul(f64_from(100000000), f64_from(100000000)));
            if (f64_gt(step, floor_step) == 1) {
                var q = f64_to(f64_floor(f64_add(f64_pow(f64_div(abs_val, step), e34), F64_HALF)));
                if (q > 8191) { q = 8191; }
                if (q < 0 - 8191) { q = 0 - 8191; }
                if (f64_lt(xval, F64_ZERO) == 1) {
                    store64(quant_spec + j * 8, 0 - q);
                } else {
                    store64(quant_spec + j * 8, q);
                }
            }
            j = j + 1;
        }

        band = band + 1;
    }

    # Build AAC bitstream
    var bw = _bw_new();

    if (is_stereo == 1) {
        # ID_CPE tag (3 bits) + instance tag (4 bits)
        _bw_write(bw, 1, 3);  # ID_CPE = 1
        _bw_write(bw, 0, 4);  # instance_tag = 0

        # Common window flag = 1 (shared ICS info for both channels)
        _bw_write(bw, 1, 1);

        # ICS info (shared)
        _bw_write(bw, 0, 1);  # ics_reserved_bit
        _bw_write(bw, 0, 2);  # window_sequence = ONLY_LONG_SEQUENCE
        _bw_write(bw, 0, 1);  # window_shape = sine
        _bw_write(bw, _AAC_NUM_SWB, 6);  # max_sfb
        _bw_write(bw, 0, 1);  # predictor_data_present = 0

        # M/S mask: ms_mask_present = 2 (all bands use M/S)
        _bw_write(bw, 2, 2);
    } else {
        # ID_SCE tag (3 bits) + instance tag (4 bits)
        _bw_write(bw, 0, 3);  # ID_SCE = 0
        _bw_write(bw, 0, 4);  # instance_tag = 0

        # ICS info
        _bw_write(bw, 0, 1);  # ics_reserved_bit
        _bw_write(bw, 0, 2);  # window_sequence = ONLY_LONG_SEQUENCE
        _bw_write(bw, 0, 1);  # window_shape = sine
        _bw_write(bw, _AAC_NUM_SWB, 6);  # max_sfb
        _bw_write(bw, 0, 1);  # predictor_data_present = 0
    }

    # Determine which bands have nonzero data
    var band_has_data = alloc(_AAC_NUM_SWB * 8);
    memset(band_has_data, 0, _AAC_NUM_SWB * 8);
    band = 0;
    while (band < _AAC_NUM_SWB) {
        var start = load64(_aac_swb_offset + band * 8);
        var end = load64(_aac_swb_offset + (band + 1) * 8);
        j = start;
        while (j < end) {
            if (load64(quant_spec + j * 8) != 0) {
                store64(band_has_data + band * 8, 1);
                j = end;  # break
            }
            j = j + 1;
        }
        band = band + 1;
    }

    # Per-band codebook selection: pick the most efficient codebook
    # based on max quantized magnitude in each band.
    # cb=0: zero (no data), cb=1-2: max<=1, cb=3-4: max<=2,
    # cb=5-6: max<=4, cb=7-8: max<=7, cb=9-10: max<=12, cb=11: escape (>12)
    var band_cb = alloc(_AAC_NUM_SWB * 8);
    band = 0;
    while (band < _AAC_NUM_SWB) {
        if (load64(band_has_data + band * 8) == 0) {
            store64(band_cb + band * 8, 0);
        } else {
            var bstart = load64(_aac_swb_offset + band * 8);
            var bend = load64(_aac_swb_offset + (band + 1) * 8);
            var max_abs = 0;
            var bi = bstart;
            while (bi < bend) {
                var qv = load64(quant_spec + bi * 8);
                if (qv < 0) { qv = 0 - qv; }
                if (qv > max_abs) { max_abs = qv; }
                bi = bi + 1;
            }
            # Check if band width is multiple of 4 (for quad codebooks)
            var bw = bend - bstart;
            var can_quad = 0;
            if (bw % 4 == 0) { can_quad = 1; }
            # Select codebook
            if (max_abs <= 1) {
                if (can_quad == 1) { store64(band_cb + band * 8, 1); }
                else { store64(band_cb + band * 8, 5); }
            } else {
                if (max_abs <= 2) {
                    if (can_quad == 1) { store64(band_cb + band * 8, 3); }
                    else { store64(band_cb + band * 8, 5); }
                } else {
                    if (max_abs <= 4) {
                        store64(band_cb + band * 8, 5);
                    } else {
                        if (max_abs <= 7) {
                            store64(band_cb + band * 8, 7);
                        } else {
                            if (max_abs <= 12) {
                                store64(band_cb + band * 8, 9);
                            } else {
                                store64(band_cb + band * 8, 11);
                            }
                        }
                    }
                }
            }
        }
        band = band + 1;
    }

    # Section coding: group consecutive bands with the SAME codebook. (The old code
    # grouped by has_data but wrote the first band's codebook for the whole run, so a
    # run of data bands with different codebooks was mislabeled -> the decoder decoded
    # later bands with the wrong codebook = garbage. Masked for a single-band tone;
    # exposed by any multi-band signal, e.g. the stereo mid = two tones.)
    band = 0;
    while (band < _AAC_NUM_SWB) {
        var cb = load64(band_cb + band * 8);

        var run = 1;
        while (band + run < _AAC_NUM_SWB) {
            if (load64(band_cb + (band + run) * 8) != cb) { break; }
            run = run + 1;
        }

        _bw_write(bw, cb, 4);

        # Encode section length with escape (max 31 for long window)
        var remaining = run;
        while (remaining >= 31) {
            _bw_write(bw, 31, 5);
            remaining = remaining - 31;
        }
        _bw_write(bw, remaining, 5);

        band = band + run;
    }

    # Scale factor data: global gain (8 bits)
    var global_gain = load64(scale_factors);
    if (global_gain < 0) { global_gain = 0; }
    if (global_gain > 255) { global_gain = 255; }
    _bw_write(bw, global_gain, 8);

    # Differential scale factors for bands with data
    # (Simplified: just write zero-diff codes for non-first bands)
    var prev_scf = global_gain;
    band = 0;
    while (band < _AAC_NUM_SWB) {
        if (load64(band_has_data + band * 8) != 0) {
            var scf_val = load64(scale_factors + band * 8);
            var diff = scf_val - prev_scf;
            if (diff < 0 - 60) { diff = 0 - 60; }
            if (diff > 60) { diff = 60; }
            var index = diff + 60;
            # Scale factor Huffman codebook (ISO 14496-3)
            if (_aac_scf_lens == 0) { _aac_init_scf_codebook(); }
            var scf_nbits = load64(_aac_scf_lens + index * 8);
            var scf_code = load64(_aac_scf_codes + index * 8);
            _bw_write(bw, scf_code, scf_nbits);
            prev_scf = prev_scf + diff;   # track the transmitted (clamped) value, not the raw scf, so the decoder's predictor stays in sync (was prev_scf = scf_val)
        }
        band = band + 1;
    }

    # ICS extension (pulse/tns/gain presence + tns_data) — mono/SCE only, so the
    # stereo/CPE bitstream is untouched. Sits after scale_factor_data per ISO order.
    if (is_stereo == 0) { _aac_write_ics_ext(bw, tns_mid); }

    # Spectral data: encode each band using selected codebook
    if (_aac_hcb5_lens == 0) { _aac_init_spectral_codebooks(); }
    band = 0;
    while (band < _AAC_NUM_SWB) {
        var cb = load64(band_cb + band * 8);
        if (cb == 0) { band = band + 1; continue; }

        var start = load64(_aac_swb_offset + band * 8);
        var end = load64(_aac_swb_offset + (band + 1) * 8);
        i = start;

        # Codebooks 1-2: signed quads (4 values, directly signed, 81 entries)
        if (cb <= 2) {
            while (i + 3 < end) {
                var w = load64(quant_spec + i * 8);
                var x = load64(quant_spec + (i+1) * 8);
                var y = load64(quant_spec + (i+2) * 8);
                var z = load64(quant_spec + (i+3) * 8);
                var idx = (w+1)*27 + (x+1)*9 + (y+1)*3 + (z+1);
                if (idx < 0) { idx = 40; }
                if (idx > 80) { idx = 40; }
                var nbits = load64(_aac_hcb1_lens + idx * 8);
                var code = load64(_aac_hcb1_codes + idx * 8);
                _bw_write(bw, code, nbits);
                i = i + 4;
            }
        }

        # Codebooks 3-4: unsigned quads (4 values + sign bits, 81 entries)
        if (cb >= 3) { if (cb <= 4) {
            while (i + 3 < end) {
                var w = load64(quant_spec + i * 8);
                var x = load64(quant_spec + (i+1) * 8);
                var y = load64(quant_spec + (i+2) * 8);
                var z = load64(quant_spec + (i+3) * 8);
                var aw = w; if (aw < 0) { aw = 0 - aw; }
                var ax = x; if (ax < 0) { ax = 0 - ax; }
                var ay = y; if (ay < 0) { ay = 0 - ay; }
                var az = z; if (az < 0) { az = 0 - az; }
                var idx = aw*27 + ax*9 + ay*3 + az;
                if (idx > 80) { idx = 0; }
                var nbits = load64(_aac_hcb3_lens + idx * 8);
                var code = load64(_aac_hcb3_codes + idx * 8);
                _bw_write(bw, code, nbits);
                if (aw > 0) { if (w < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                if (ax > 0) { if (x < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                if (ay > 0) { if (y < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                if (az > 0) { if (z < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                i = i + 4;
            }
        }}

        # Codebooks 5-6: signed pairs (81 entries, values -4..4)
        if (cb >= 5) { if (cb <= 6) {
            while (i + 1 < end) {
                var qx = load64(quant_spec + i * 8);
                var qy = load64(quant_spec + (i+1) * 8);
                var idx = (qx+4)*9 + (qy+4);
                if (idx < 0) { idx = 40; }
                if (idx > 80) { idx = 40; }
                var nbits = load64(_aac_hcb5_lens + idx * 8);
                var code = load64(_aac_hcb5_codes + idx * 8);
                _bw_write(bw, code, nbits);
                i = i + 2;
            }
        }}

        # Codebooks 7-8: unsigned pairs (64 entries, values 0..7 + sign)
        if (cb >= 7) { if (cb <= 8) {
            var hcb_lens = _aac_hcb7_lens;
            var hcb_codes = _aac_hcb7_codes;
            if (cb == 8) { hcb_lens = _aac_hcb8_lens; hcb_codes = _aac_hcb8_codes; }
            while (i + 1 < end) {
                var qx = load64(quant_spec + i * 8);
                var qy = load64(quant_spec + (i+1) * 8);
                var ax = qx; if (ax < 0) { ax = 0 - ax; }
                var ay = qy; if (ay < 0) { ay = 0 - ay; }
                if (ax > 7) { ax = 7; }
                if (ay > 7) { ay = 7; }
                var idx = ax * 8 + ay;
                var nbits = load64(hcb_lens + idx * 8);
                var code = load64(hcb_codes + idx * 8);
                _bw_write(bw, code, nbits);
                if (ax > 0) { if (qx < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                if (ay > 0) { if (qy < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                i = i + 2;
            }
        }}

        # Codebooks 9-10: unsigned pairs (169 entries, values 0..12 + sign)
        if (cb >= 9) { if (cb <= 10) {
            var hcb_lens = _aac_hcb9_lens;
            var hcb_codes = _aac_hcb9_codes;
            if (cb == 10) { hcb_lens = _aac_hcb10_lens; hcb_codes = _aac_hcb10_codes; }
            while (i + 1 < end) {
                var qx = load64(quant_spec + i * 8);
                var qy = load64(quant_spec + (i+1) * 8);
                var ax = qx; if (ax < 0) { ax = 0 - ax; }
                var ay = qy; if (ay < 0) { ay = 0 - ay; }
                if (ax > 12) { ax = 12; }
                if (ay > 12) { ay = 12; }
                var idx = ax * 13 + ay;
                var nbits = load64(hcb_lens + idx * 8);
                var code = load64(hcb_codes + idx * 8);
                _bw_write(bw, code, nbits);
                if (ax > 0) { if (qx < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                if (ay > 0) { if (qy < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                i = i + 2;
            }
        }}

        # Codebook 11: escape pairs (17x17, 9-bit index + sign + escape)
        if (cb == 11) {
            while (i + 1 < end) {
                var qx = load64(quant_spec + i * 8);
                var qy = load64(quant_spec + (i+1) * 8);
                var ax = qx; if (ax < 0) { ax = 0 - ax; }
                var ay = qy; if (ay < 0) { ay = 0 - ay; }
                var cx = ax; if (cx > 16) { cx = 16; }
                var cy = ay; if (cy > 16) { cy = 16; }
                _bw_write(bw, cx * 17 + cy, 9);
                if (cx > 0) { if (qx < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                if (cy > 0) { if (qy < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                if (ax >= 16) { _bw_write(bw, ax - 16, 8); }
                if (ay >= 16) { _bw_write(bw, ay - 16, 8); }
                i = i + 2;
            }
        }

        band = band + 1;
    }

    # Side channel (for stereo M/S)
    if (is_stereo == 1) {
        # Window + MDCT the side channel
        var side_windowed = alloc(windowed_size * 8);
        memset(side_windowed, 0, windowed_size * 8);
        i = 0;
        while (i < windowed_size) {
            var angle = f64_div(
                f64_mul(F64_PI, f64_add(f64_from(i), F64_HALF)),
                f64_from(windowed_size)
            );
            var w = f64_sin(angle);
            store64(side_windowed + i * 8, f64_mul(load64(side + i * 8), w));
            i = i + 1;
        }
        var side_mdct = alloc(AAC_FRAME_SIZE * 8);
        memset(side_mdct, 0, AAC_FRAME_SIZE * 8);
        fft_mdct(side_windowed, windowed_size, side_mdct);

        # Quantize side channel with same scale factors
        var side_quant = alloc(AAC_FRAME_SIZE * 8);
        memset(side_quant, 0, AAC_FRAME_SIZE * 8);
        band = 0;
        while (band < _AAC_NUM_SWB) {
            var bstart = load64(_aac_swb_offset + band * 8);
            var bend = load64(_aac_swb_offset + (band + 1) * 8);
            var scf = load64(scale_factors + band * 8);
            var step = f64_pow(F64_TWO, f64_mul(f64_from(1), f64_div(f64_sub(f64_from(scf), f64_from(100)), f64_from(4))));
            var floor_step = f64_div(F64_ONE, f64_mul(f64_from(100000000), f64_from(100000000)));
            j = bstart;
            while (j < bend) {
                var xval = load64(side_mdct + j * 8);
                var abs_val = f64_abs(xval);
                if (f64_gt(step, floor_step) == 1) {
                    var q = f64_to(f64_floor(f64_add(f64_pow(f64_div(abs_val, step), f64_div(f64_from(3), f64_from(4))), F64_HALF)));
                    if (q > 8191) { q = 8191; }
                    if (f64_lt(xval, F64_ZERO) == 1) { store64(side_quant + j * 8, 0 - q); }
                    else { store64(side_quant + j * 8, q); }
                }
                j = j + 1;
            }
            band = band + 1;
        }

        # NO per-channel ICS here: with common_window=1 the ICS info is shared (written
        # once above) and the decoder reads ch1 starting at the section data. The old
        # code emitted an 11-bit side ICS block the decoder never read -> misalignment.

        # Side sections: escape codebook (11) for data bands, 0 otherwise, matching the
        # escape-coded side spectral below. (The old code copied the mid codebooks into
        # the sections but always escape-coded the spectral data -> decoder desync.)
        band = 0;
        while (band < _AAC_NUM_SWB) {
            var scb = 0;
            if (load64(band_has_data + band * 8) != 0) { scb = 11; }
            var run = 1;
            while (band + run < _AAC_NUM_SWB) {
                var nscb = 0;
                if (load64(band_has_data + (band + run) * 8) != 0) { nscb = 11; }
                if (nscb != scb) { break; }
                run = run + 1;
            }
            _bw_write(bw, scb, 4);
            var remaining = run;
            while (remaining >= 31) { _bw_write(bw, 31, 5); remaining = remaining - 31; }
            _bw_write(bw, remaining, 5);
            band = band + run;
        }

        # Side channel scale factors (same as mid for simplicity)
        _bw_write(bw, load64(scale_factors), 8);
        prev_scf = load64(scale_factors);
        band = 0;
        while (band < _AAC_NUM_SWB) {
            if (load64(band_has_data + band * 8) != 0) {
                var scf_val = load64(scale_factors + band * 8);
                var diff = scf_val - prev_scf;
                if (diff < 0 - 60) { diff = 0 - 60; }
                if (diff > 60) { diff = 60; }
                var index = diff + 60;
                _bw_write(bw, load64(_aac_scf_codes + index * 8), load64(_aac_scf_lens + index * 8));
                prev_scf = prev_scf + diff;   # track the transmitted (clamped) value (was prev_scf = scf_val)
            }
            band = band + 1;
        }

        # Side channel spectral data — encode with escape pairs (simplified)
        band = 0;
        while (band < _AAC_NUM_SWB) {
            if (load64(band_has_data + band * 8) == 0) { band = band + 1; continue; }
            var bstart = load64(_aac_swb_offset + band * 8);
            var bend = load64(_aac_swb_offset + (band + 1) * 8);
            i = bstart;
            while (i + 1 < bend) {
                var qx = load64(side_quant + i * 8);
                var qy = load64(side_quant + (i+1) * 8);
                var ax = qx; if (ax < 0) { ax = 0 - ax; }
                var ay = qy; if (ay < 0) { ay = 0 - ay; }
                var cx = ax; if (cx > 16) { cx = 16; }
                var cy = ay; if (cy > 16) { cy = 16; }
                _bw_write(bw, cx * 17 + cy, 9);
                if (cx > 0) { if (qx < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                if (cy > 0) { if (qy < 0) { _bw_write(bw, 1, 1); } else { _bw_write(bw, 0, 1); } }
                if (ax >= 16) { _bw_write(bw, ax - 16, 8); }
                if (ay >= 16) { _bw_write(bw, ay - 16, 8); }
                i = i + 2;
            }
            band = band + 1;
        }
    }

    # ID_END tag
    _bw_write(bw, 7, 3);

    var frame_data = _bw_flush(bw);

    # Pad to target size if needed
    var flen = str_len(frame_data);
    if (flen < target_bytes) {
        var padded = alloc(target_bytes);
        memcpy(padded, str_data(frame_data), flen);
        memset(padded + flen, 0, target_bytes - flen);
        return str_new(padded, target_bytes);
    }
    return frame_data;
}

# ================================================================
# AAC-LC Encoder (ADTS output)
# ================================================================
#
# aac_encode(samples_vec, sample_rate, channels, bitrate, out_buf)
#   samples_vec: vec of f64 bit patterns (interleaved)
#   sample_rate: must be a standard AAC rate
#   channels: 1 or 2
#   bitrate: > 0
#   out_buf: pointer to output buffer
# Returns bytes written, or err().

fn aac_encode(samples_vec, sample_rate, channels, bitrate, out_buf) {
    # Validate parameters
    if (_aac_sample_rates == 0) { aac_init(); }
    if (_aac_swb_offset == 0) { _aac_init_swb(); }

    # Check sample rate is valid
    var sr_valid = 0;
    var si = 0;
    while (si < 13) {
        if (load64(_aac_sample_rates + si * 8) == sample_rate) {
            sr_valid = 1;
        }
        si = si + 1;
    }
    if (sr_valid == 0) { return err(ERR_INVALID_RATE); }

    if (channels == 0) { return err(ERR_INVALID_CHANNELS); }
    if (channels > 2) { return err(ERR_INVALID_CHANNELS); }
    if (bitrate == 0) { return err(ERR_ENCODE); }

    var ch = channels;
    var total_samples = vec_len(samples_vec);
    var frame_interleaved = AAC_FRAME_SIZE * ch;

    # Target bytes per frame: bitrate / 8 / (sample_rate / 1024)
    var frames_per_sec = f64_div(f64_from(sample_rate), f64_from(AAC_FRAME_SIZE));
    var target_bytes = f64_to(f64_div(f64_from(bitrate / 8), frames_per_sec));
    if (target_bytes < 20) { target_bytes = 20; }

    var write_pos = 0;
    var sample_pos = 0;
    # 50%-overlap analysis: read a 2-frame (2048*ch) window but advance by one frame
    # (1024*ch), so consecutive MDCT windows overlap 50% and the decoder's overlap-add
    # reconstructs (TDAC). `_aac_encode_frame` consumes the full window for mono.
    var window_interleaved = frame_interleaved * 2;

    while (sample_pos < total_samples) {
        # Build the overlap window buffer (zero-padded past the end of the input).
        var frame_buf = alloc(window_interleaved * 8);
        memset(frame_buf, 0, window_interleaved * 8);
        var avail = total_samples - sample_pos;
        var count = window_interleaved;
        if (count > avail) { count = avail; }
        var fi = 0;
        while (fi < count) {
            store64(frame_buf + fi * 8, vec_get(samples_vec, sample_pos + fi));
            fi = fi + 1;
        }

        var frame_data = _aac_encode_frame(frame_buf, channels, target_bytes);

        # Write ADTS header + frame
        var adts_buf = alloc(7);
        aac_build_adts_header(sample_rate, channels, str_len(frame_data), adts_buf);
        memcpy(out_buf + write_pos, adts_buf, 7);
        write_pos = write_pos + 7;
        memcpy(out_buf + write_pos, str_data(frame_data), str_len(frame_data));
        write_pos = write_pos + str_len(frame_data);

        sample_pos = sample_pos + frame_interleaved;
    }

    # Handle empty input: encode one silence frame (full 2048*ch window)
    if (write_pos == 0) {
        var silence = alloc(window_interleaved * 8);
        memset(silence, 0, window_interleaved * 8);
        var frame_data = _aac_encode_frame(silence, channels, target_bytes);
        var adts_buf = alloc(7);
        aac_build_adts_header(sample_rate, channels, str_len(frame_data), adts_buf);
        memcpy(out_buf + write_pos, adts_buf, 7);
        write_pos = write_pos + 7;
        memcpy(out_buf + write_pos, str_data(frame_data), str_len(frame_data));
        write_pos = write_pos + str_len(frame_data);
    }

    return write_pos;
}

# ================================================================
# VBR encoding
# ================================================================
# Quality levels: 1 (lowest, ~64kbps) to 5 (highest, ~320kbps)
# Target bitrate estimated per quality level, but actual frame size
# varies based on spectral complexity.

var AAC_VBR_Q1 = 1;
var AAC_VBR_Q2 = 2;
var AAC_VBR_Q3 = 3;
var AAC_VBR_Q4 = 4;
var AAC_VBR_Q5 = 5;

fn aac_encode_vbr(samples_vec, sample_rate, channels, quality, out_buf) {
    # Map quality to approximate bitrate
    var bitrate = 128000;
    if (quality == 1) { bitrate = 64000; }
    if (quality == 2) { bitrate = 96000; }
    if (quality == 3) { bitrate = 128000; }
    if (quality == 4) { bitrate = 192000; }
    if (quality == 5) { bitrate = 320000; }

    # Scale for stereo
    if (channels >= 2) { bitrate = bitrate * 2; }

    return aac_encode(samples_vec, sample_rate, channels, bitrate, out_buf);
}

# ================================================================
# MSB-first bit reader for AAC bitstream
# ================================================================

fn _br_new(data, len) {
    var br = alloc(24);
    store64(br, data);
    store64(br + 8, len * 8);
    store64(br + 16, 0);
    return br;
}

fn _br_read(br, n) {
    var brd = load64(br);
    var total = load64(br + 8);
    var pos = load64(br + 16);
    if (pos + n > total) { return err(ERR_END_OF_STREAM); }
    var val = 0;
    var i = 0;
    while (i < n) {
        var byte_idx = (pos + i) / 8;
        var bit_idx = 7 - ((pos + i) % 8);
        val = (val << 1) | ((load8(brd + byte_idx) >> bit_idx) & 1);
        i = i + 1;
    }
    store64(br + 16, pos + n);
    return val;
}

fn _br_bits_left(br) {
    return load64(br + 8) - load64(br + 16);
}

# ================================================================
# AAC Huffman codebook tables + decoder
# ================================================================

# Scale factor codebook: 121 entries (index 0..120, center at 60)
# Each entry: (code_length, code_value) packed as i64
# Stored in two arrays: _aac_scf_lens[121], _aac_scf_codes[121]
var _aac_scf_lens = 0;
var _aac_scf_codes = 0;

fn _aac_init_scf_codebook() {
    _aac_scf_lens = alloc(121 * 8);
    _aac_scf_codes = alloc(121 * 8);

    # Lengths (bits per codeword)
    var lens = _aac_scf_lens;
    store64(lens+ 0*8,18); store64(lens+ 1*8,18); store64(lens+ 2*8,18); store64(lens+ 3*8,18);
    store64(lens+ 4*8,19); store64(lens+ 5*8,19); store64(lens+ 6*8,19); store64(lens+ 7*8,19);
    store64(lens+ 8*8,19); store64(lens+ 9*8,19); store64(lens+10*8,19); store64(lens+11*8,19);
    store64(lens+12*8,19); store64(lens+13*8,19); store64(lens+14*8,19); store64(lens+15*8,19);
    store64(lens+16*8,19); store64(lens+17*8,19); store64(lens+18*8,19); store64(lens+19*8,18);
    store64(lens+20*8,19); store64(lens+21*8,18); store64(lens+22*8,17); store64(lens+23*8,17);
    store64(lens+24*8,16); store64(lens+25*8,17); store64(lens+26*8,16); store64(lens+27*8,16);
    store64(lens+28*8,16); store64(lens+29*8,16); store64(lens+30*8,15); store64(lens+31*8,15);
    store64(lens+32*8,14); store64(lens+33*8,14); store64(lens+34*8,14); store64(lens+35*8,14);
    store64(lens+36*8,14); store64(lens+37*8,14); store64(lens+38*8,13); store64(lens+39*8,13);
    store64(lens+40*8,12); store64(lens+41*8,12); store64(lens+42*8,12); store64(lens+43*8,11);
    store64(lens+44*8,12); store64(lens+45*8,11); store64(lens+46*8,10); store64(lens+47*8,10);
    store64(lens+48*8,10); store64(lens+49*8, 9); store64(lens+50*8, 9); store64(lens+51*8, 8);
    store64(lens+52*8, 8); store64(lens+53*8, 8); store64(lens+54*8, 7); store64(lens+55*8, 6);
    store64(lens+56*8, 6); store64(lens+57*8, 5); store64(lens+58*8, 4); store64(lens+59*8, 3);
    store64(lens+60*8, 1); store64(lens+61*8, 4); store64(lens+62*8, 4); store64(lens+63*8, 5);
    store64(lens+64*8, 6); store64(lens+65*8, 6); store64(lens+66*8, 7); store64(lens+67*8, 7);
    store64(lens+68*8, 8); store64(lens+69*8, 8); store64(lens+70*8, 9); store64(lens+71*8, 9);
    store64(lens+72*8,10); store64(lens+73*8,10); store64(lens+74*8,10); store64(lens+75*8,11);
    store64(lens+76*8,11); store64(lens+77*8,11); store64(lens+78*8,11); store64(lens+79*8,12);
    store64(lens+80*8,12); store64(lens+81*8,13); store64(lens+82*8,13); store64(lens+83*8,13);
    store64(lens+84*8,14); store64(lens+85*8,14); store64(lens+86*8,16); store64(lens+87*8,15);
    store64(lens+88*8,16); store64(lens+89*8,15); store64(lens+90*8,18); store64(lens+91*8,19);
    store64(lens+92*8,19); store64(lens+93*8,19); store64(lens+94*8,19); store64(lens+95*8,19);
    store64(lens+96*8,19); store64(lens+97*8,19); store64(lens+98*8,19); store64(lens+99*8,19);
    store64(lens+100*8,19); store64(lens+101*8,19); store64(lens+102*8,19); store64(lens+103*8,19);
    store64(lens+104*8,19); store64(lens+105*8,19); store64(lens+106*8,19); store64(lens+107*8,19);
    store64(lens+108*8,19); store64(lens+109*8,19); store64(lens+110*8,19); store64(lens+111*8,19);
    store64(lens+112*8,19); store64(lens+113*8,19); store64(lens+114*8,19); store64(lens+115*8,19);
    store64(lens+116*8,19); store64(lens+117*8,19); store64(lens+118*8,19); store64(lens+119*8,19);
    store64(lens+120*8,19);

    # Code values
    var codes = _aac_scf_codes;
    store64(codes+ 0*8,0x3FFE8); store64(codes+ 1*8,0x3FFE6); store64(codes+ 2*8,0x3FFE7);
    store64(codes+ 3*8,0x3FFE5); store64(codes+ 4*8,0x7FFF5); store64(codes+ 5*8,0x7FFF1);
    store64(codes+ 6*8,0x7FFED); store64(codes+ 7*8,0x7FFF6); store64(codes+ 8*8,0x7FFEE);
    store64(codes+ 9*8,0x7FFEF); store64(codes+10*8,0x7FFF0); store64(codes+11*8,0x7FFFC);
