fn _aac_init_hcb7() {
    var L = alloc(64 * 8); var C = alloc(64 * 8);
    _aac_hcb7_lens = L; _aac_hcb7_codes = C;
    store64(L+ 0*8, 1); store64(L+ 1*8, 3); store64(L+ 2*8, 6); store64(L+ 3*8, 7); store64(L+ 4*8, 8); store64(L+ 5*8, 9); store64(L+ 6*8,10); store64(L+ 7*8,11);
