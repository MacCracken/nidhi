    store64(C+27*8,0x0e6); store64(C+28*8,0x02a); store64(C+29*8,0x06b); store64(C+30*8,0x02f); store64(C+31*8,0x009); store64(C+32*8,0x02b); store64(C+33*8,0x06a); store64(C+34*8,0x025); store64(C+35*8,0x0e7);
    store64(C+36*8,0x028); store64(C+37*8,0x00b); store64(C+38*8,0x026); store64(C+39*8,0x008); store64(C+40*8,0x001); store64(C+41*8,0x007); store64(C+42*8,0x024); store64(C+43*8,0x00c); store64(C+44*8,0x029);
    store64(C+45*8,0x0e5); store64(C+46*8,0x021); store64(C+47*8,0x069); store64(C+48*8,0x020); store64(C+49*8,0x00d); store64(C+50*8,0x030); store64(C+51*8,0x0ef); store64(C+52*8,0x031); store64(C+53*8,0x0f1);
    store64(C+54*8,0x1f4); store64(C+55*8,0x0e4); store64(C+56*8,0x1fb); store64(C+57*8,0x0f2); store64(C+58*8,0x032); store64(C+59*8,0x0f3); store64(C+60*8,0x1f2); store64(C+61*8,0x0f4); store64(C+62*8,0x1f5);
    store64(C+63*8,0x0e3); store64(C+64*8,0x033); store64(C+65*8,0x068); store64(C+66*8,0x034); store64(C+67*8,0x00e); store64(C+68*8,0x035); store64(C+69*8,0x0e2); store64(C+70*8,0x036); store64(C+71*8,0x0e1);
    store64(C+72*8,0x1f0); store64(C+73*8,0x0e0); store64(C+74*8,0x1fc); store64(C+75*8,0x0f5); store64(C+76*8,0x037); store64(C+77*8,0x0f6); store64(C+78*8,0x1f8); store64(C+79*8,0x0f7); store64(C+80*8,0x1ff);
