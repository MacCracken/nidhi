}

# Decode one Huffman symbol from bitstream using codebook tables.
# lens_tbl: pointer to array of code lengths (i64 each)
# codes_tbl: pointer to array of code values (i64 each)
# num_entries: number of entries in the codebook
# br: bitreader
# Returns: codebook index (0..num_entries-1), or err.
#
# Optimized: reads bits incrementally but only compares against entries
# of exactly the current bit length (early exit per length level).
fn _aac_huff_decode(br, lens_tbl, codes_tbl, num_entries) {
    var acc = 0;
    var bits_read = 0;

    while (bits_read < 20) {
        var bit = _br_read(br, 1);
        if (is_err(bit) == 1) { return bit; }
        acc = (acc << 1) | bit;
        bits_read = bits_read + 1;

        # Only check entries whose length matches current bits_read
        var i = 0;
        while (i < num_entries) {
            if (load64(lens_tbl + i * 8) == bits_read) {
                if (load64(codes_tbl + i * 8) == acc) {
                    return i;
                }
            }
            i = i + 1;
        }
    }
    return err(ERR_DECODE);
}

# ================================================================
# Fast Huffman decode via sorted codebook
# ================================================================
# Builds a sorted codebook (by length then code) for faster decode.
# _aac_huff_build_sorted: creates a sorted index table.
# _aac_huff_decode_fast: decodes using sorted table with length-group skipping.

# Build a sorted codebook for fast decode.
# Returns three parallel arrays: sorted_lens, sorted_codes, sorted_syms
# packed as a single allocation: [lens_buf | codes_buf | syms_buf]
# Sorted by length ascending so decode can skip shorter entries.
# Returns pointer to header struct: +0=lens, +8=codes, +16=syms
fn _aac_huff_build_sorted(lens_tbl, codes_tbl, num_entries) {
    var s_lens  = alloc(num_entries * 8);
    var s_codes = alloc(num_entries * 8);
    var s_syms  = alloc(num_entries * 8);

    # Copy into sortable arrays
    var i = 0;
    while (i < num_entries) {
        store64(s_lens + i * 8, load64(lens_tbl + i * 8));
        store64(s_codes + i * 8, load64(codes_tbl + i * 8));
        store64(s_syms + i * 8, i);
        i = i + 1;
    }

    # Insertion sort by (length, code) — swap all three arrays in parallel
    i = 1;
    while (i < num_entries) {
        var kl = load64(s_lens + i * 8);
        var kc = load64(s_codes + i * 8);
        var ks = load64(s_syms + i * 8);
        var j = i - 1;
        while (j >= 0) {
            var jl = load64(s_lens + j * 8);
            var should_shift = 0;
            if (jl > kl) { should_shift = 1; }
            if (jl == kl) {
                if (load64(s_codes + j * 8) > kc) { should_shift = 1; }
            }
            if (should_shift == 1) {
                store64(s_lens + (j+1)*8, load64(s_lens + j*8));
                store64(s_codes + (j+1)*8, load64(s_codes + j*8));
                store64(s_syms + (j+1)*8, load64(s_syms + j*8));
                j = j - 1;
            } else {
                # Insert here — exit loop by forcing j below 0
                # but first save correct position
                store64(s_lens + (j+1)*8, kl);
                store64(s_codes + (j+1)*8, kc);
                store64(s_syms + (j+1)*8, ks);
                j = 0 - 2;  # sentinel: already inserted
            }
        }
        # If j == -1, we shifted everything — insert at position 0
        if (j == 0 - 1) {
            store64(s_lens, kl);
            store64(s_codes, kc);
            store64(s_syms, ks);
        }
        i = i + 1;
    }

    # Return header struct
    var hdr = alloc(24);
    store64(hdr, s_lens);
    store64(hdr + 8, s_codes);
    store64(hdr + 16, s_syms);
    return hdr;
}

# Decode using sorted table — skips entries of shorter lengths.
fn _aac_huff_decode_fast(br, sorted_hdr, num_entries) {
    var s_lens  = load64(sorted_hdr);
    var s_codes = load64(sorted_hdr + 8);
    var s_syms  = load64(sorted_hdr + 16);

    var acc = 0;
    var bits_read = 0;
    var scan_from = 0;

    while (bits_read < 20) {
        var bit = _br_read(br, 1);
        if (is_err(bit) == 1) { return bit; }
        acc = (acc << 1) | bit;
        bits_read = bits_read + 1;

        # Advance scan_from past entries shorter than bits_read
        var advancing = 1;
        while (advancing == 1) {
            if (scan_from >= num_entries) { advancing = 0; }
            else {
                if (load64(s_lens + scan_from * 8) < bits_read) {
                    scan_from = scan_from + 1;
                } else { advancing = 0; }
            }
        }

        # Check entries at exactly this length
        var i = scan_from;
        var checking = 1;
        while (checking == 1) {
            if (i >= num_entries) { checking = 0; }
            else {
                var elen = load64(s_lens + i * 8);
                if (elen > bits_read) {
                    checking = 0;
                } else {
                    if (elen == bits_read) {
                        if (load64(s_codes + i * 8) == acc) {
                            return load64(s_syms + i * 8);
                        }
                    }
                    i = i + 1;
                }
            }
        }
    }
    return err(ERR_DECODE);
}

# ================================================================
# 2-level Huffman lookup table
# ================================================================
# Level 1: 256-entry table indexed by first 8 bits.
#   Entry = (symbol << 8) | length for codes <= 8 bits.
#   Entry = 0 for codes > 8 bits (fall through to sorted scan).
# Level 2: sorted scan (existing _aac_huff_decode_fast) for long codes.
#
# _aac_huff_build_lut: builds the 256-entry level-1 table.
# _aac_huff_decode_lut: tries level-1 first, falls back to sorted scan.

fn _aac_huff_build_lut(lens_tbl, codes_tbl, num_entries) {
    var lut = alloc(256 * 8);
    memset(lut, 0, 256 * 8);

    var i = 0;
    while (i < num_entries) {
        var clen = load64(lens_tbl + i * 8);
        var code = load64(codes_tbl + i * 8);
        if (clen > 0) {
            if (clen <= 8) {
                # This code fits in 8 bits — fill all entries that match
                # Left-align code to 8 bits, then fill 2^(8-clen) entries
                var prefix = code << (8 - clen);
                var fill = 1 << (8 - clen);
                var j = 0;
                while (j < fill) {
                    var idx = prefix | j;
                    if (idx < 256) {
                        # Pack: (symbol << 8) | length
                        store64(lut + idx * 8, (i << 8) | clen);
                    }
                    j = j + 1;
                }
            }
        }
        i = i + 1;
    }
    return lut;
}

fn _aac_huff_decode_lut(br, lut, sorted_hdr, num_entries) {
    # Peek 8 bits without consuming
    var saved_bpos = load64(br + 8);
    var saved_bbit = load64(br + 16);

    var peek = _br_read(br, 8);
    if (is_err(peek) == 1) {
        # Not enough bits — restore and fall back to sorted scan
        store64(br + 8, saved_bpos);
        store64(br + 16, saved_bbit);
        return _aac_huff_decode_fast(br, sorted_hdr, num_entries);
    }

    var entry = load64(lut + (peek & 0xFF) * 8);
    if (entry != 0) {
        var clen = entry & 0xFF;
        var sym = (entry >> 8) & 0xFFFF;
        # Put back unused bits: we read 8 but only used clen
        var putback = 8 - clen;
        # Rewind bitreader by putback bits
        var bpos = load64(br + 8);
        var bbit = load64(br + 16);
        bbit = bbit - putback;
        while (bbit < 0) { bbit = bbit + 8; bpos = bpos - 1; }
        store64(br + 8, bpos);
        store64(br + 16, bbit);
        return sym;
    }

    # Level-1 miss — restore bitreader and use sorted scan
    store64(br + 8, saved_bpos);
    store64(br + 16, saved_bbit);
    return _aac_huff_decode_fast(br, sorted_hdr, num_entries);
}

# Cached tables
var _aac_scf_sorted = 0;
var _aac_scf_lut = 0;
var _aac_hcb5_sorted = 0;
var _aac_hcb5_lut = 0;
var _aac_hcb7_sorted = 0;
var _aac_hcb7_lut = 0;
var _aac_hcb8_sorted = 0;
var _aac_hcb8_lut = 0;
var _aac_hcb9_sorted = 0;
var _aac_hcb9_lut = 0;
var _aac_hcb10_sorted = 0;
var _aac_hcb10_lut = 0;

# Decode a scale factor value using the Huffman codebook.
# Returns the codebook index (0..120), which maps to diff = index - 60.
fn _aac_decode_scf(br) {
    if (_aac_scf_lens == 0) { _aac_init_scf_codebook(); }
    if (_aac_scf_sorted == 0) {
        _aac_scf_sorted = _aac_huff_build_sorted(_aac_scf_lens, _aac_scf_codes, 121);
        _aac_scf_lut = _aac_huff_build_lut(_aac_scf_lens, _aac_scf_codes, 121);
    }
    return _aac_huff_decode_lut(br, _aac_scf_lut, _aac_scf_sorted, 121);
}

